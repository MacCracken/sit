# serve.cyr — sit's HTTP daemon.
#
# Read-only endpoints — exposes an opened sit repo over the
# `/sit/v1/...` wire protocol per the v0.7.x plan.
#
#   GET /sit/v1/capabilities    → server identity + advertised limits
#   GET /sit/v1/refs            → all heads + tags as JSON
#   GET /sit/v1/objects/<hash>  → raw compressed object bytes;
#                                 X-Sit-Type: <patra-ty> header
#                                 carries the type code
#
# Subsequent v0.7.x patches add: POST /want batched stream (v0.7.4),
# POST /objects + POST /refs + bearer auth (v0.7.5), TLS (v0.7.6),
# mTLS (v0.7.7).
#
# Bound to 127.0.0.1 only — listening on 0.0.0.0 / a routable
# interface needs explicit threat-model review (auth model isn't
# wired yet; non-loopback exposure of a no-auth read path leaks
# ref topology + object content). Bearer auth lands in v0.7.5.

var SIT_SERVE_DEFAULT_PORT = 8484;
var SIT_SERVE_MAX_BODY = 16777216;  # 16 MiB — advertised in capabilities
# v0.7.4: cap on the count field of a single POST /want body. The
# binding constraint is sandhi's per-process HSV_REQ_BUF_SIZE = 64 KiB
# request buffer; pinning to 512 keeps the request body ≤ 32 KiB
# even with the full 8-byte count + 512×64-byte hashes, leaving
# ample headroom for HTTP headers. See ADR 0006.
var SIT_WANT_MAX_COUNT = 512;

# v0.7.6: bearer auth. ~/.sit/serve.token is the canonical path;
# operators may pin a different file with --token. Token must be
# 16+ hex chars (64-bit minimum entropy assuming random-hex input)
# and the file must be 0600 — anything else is a config bug we
# refuse to start with rather than silently accept a weaker posture.
# `_serve_token` is the loaded value; `_serve_require_auth` is 1
# when --require-auth was set on the command line. POST handlers
# consult both before doing any DB work; GET endpoints stay
# anonymous (the per-ADR-0007 deployment surface assumes loopback
# anyway, so anonymous read is a feature, not a vulnerability).
var SIT_TOKEN_MIN_LEN = 16;
var _serve_require_auth = 0;
var _serve_token = 0;

# ── Ref-file reader ────────────────────────────────────────────────
#
# Read a ref file's content as a 64-char SHA-256 hex string. Strips
# the trailing newline conventionally written by `write_head_ref`
# and friends; rejects anything that doesn't pass `hex_prefix_valid`.
# Returns 0 on any failure (so callers can skip the entry instead of
# aborting the response).

fn serve_read_ref_file(path) {
    var pair = alloc(16);  # [data_ptr, len]
    var rc = read_file_heap(path, pair);
    if (rc < 0) { return 0; }
    var data = load64(pair);
    var len = load64(pair + 8);
    while (len > 0) {
        var lc = load8(data + len - 1) & 0xFF;
        if (lc != 10) {
            if (lc != 13) { break; }
        }
        len = len - 1;
    }
    if (len != 64) { return 0; }
    if (hex_prefix_valid(data, 64) == 0) { return 0; }
    var out = alloc(65);
    memcpy(out, data, 64);
    store8(out + 64, 0);
    return out;
}

# ── JSON builders ──────────────────────────────────────────────────
#
# Hand-rolled JSON because the response shapes are tiny and
# entirely under our control — every field name we emit is a
# constant, and every value either passes `refname_valid` (no
# JSON-escapable bytes) or `hex_prefix_valid` (digits + a-f only).
# Pulling `lib/json.cyr` here would buy nothing and add a dep
# surface inside the hot serve loop.

fn serve_build_capabilities() {
    var sb = str_builder_new();
    # The "sit" string identifies the wire-protocol release line
    # the server promises. It bumps in lockstep with VERSION at
    # each tag.
    # TODO: derive from VERSION at build time. Manually bumped each
    # release; closeout pass before tagging asserts the literal matches.
    str_builder_add_cstr(sb, "{\"sit\":\"0.8.3\",\"max_body\":");
    str_builder_add_int(sb, SIT_SERVE_MAX_BODY);
    str_builder_add_cstr(sb, ",\"auth\":[");
    if (_serve_require_auth == 1) {
        str_builder_add_cstr(sb, "\"bearer\"");
    }
    else {
        str_builder_add_cstr(sb, "\"none\"");
    }
    str_builder_add_cstr(sb, "],\"objects\":true,\"batch\":true,\"batch_max\":");
    str_builder_add_int(sb, SIT_WANT_MAX_COUNT);
    str_builder_add_cstr(sb, ",\"push\":true}");
    return str_data(str_builder_build(sb));
}

# Recursively walk one refs subtree (`.sit/refs/heads` or
# `.sit/refs/tags`) appending one JSON object per ref to `sb`.
# `prefix` is the ref namespace ("refs/heads/" / "refs/tags/");
# `dir` is the on-disk path to the corresponding directory;
# `first_ref_cell` is a heap-allocated i64 used as a shared "is
# this the first entry across BOTH subtrees?" flag — toggled to
# 0 after the first emission so subsequent entries get a leading
# comma.
#
# Errors (missing dir, malformed ref content, refnames that fail
# `refname_valid`) silently omit the entry rather than fail the
# whole response. `sit fsck` is the right tool to surface a broken
# ref file; `serve` should keep listing what it can.

fn serve_emit_refs_subtree(sb, prefix, dir, first_ref_cell) {
    if (file_exists(dir) != 1) { return 0; }
    # dir_walk expects a Str object (it does str_data internally) and pushes
    # Str objects into the results vec. Convert at the boundary.
    var files = vec_new();
    dir_walk(str_from(dir), files);
    var i = 0;
    var dlen = strlen(dir);
    var plen = strlen(prefix);
    while (i < vec_len(files)) {
        var fp_str = vec_get(files, i);
        var fp_len = str_len(fp_str);
        var fp_data = str_data(fp_str);
        # Strip the dir prefix + leading '/' to get the in-namespace name.
        var rel_offset = dlen;
        if (rel_offset < fp_len) {
            if (load8(fp_data + rel_offset) == 47) { rel_offset = rel_offset + 1; }
        }
        var rel_len = fp_len - rel_offset;
        if (rel_len > 0) {
            var name = alloc(plen + rel_len + 1);
            memcpy(name, prefix, plen);
            memcpy(name + plen, fp_data + rel_offset, rel_len);
            store8(name + plen + rel_len, 0);
            var ok_name = refname_valid(name);
            if (ok_name == 1) {
                # serve_read_ref_file is cstring-based; materialize the Str.
                var fs_cstr = alloc(fp_len + 1);
                memcpy(fs_cstr, fp_data, fp_len);
                store8(fs_cstr + fp_len, 0);
                var hex = serve_read_ref_file(fs_cstr);
                if (hex != 0) {
                    if (load64(first_ref_cell) == 0) { str_builder_add_cstr(sb, ","); }
                    str_builder_add_cstr(sb, "{\"name\":\"");
                    str_builder_add_cstr(sb, name);
                    str_builder_add_cstr(sb, "\",\"hash\":\"");
                    str_builder_add_cstr(sb, hex);
                    str_builder_add_cstr(sb, "\"}");
                    store64(first_ref_cell, 0);
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn serve_build_refs() {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"refs\":[");
    var first_cell = alloc(8);
    store64(first_cell, 1);
    serve_emit_refs_subtree(sb, "refs/heads/", ".sit/refs/heads", first_cell);
    serve_emit_refs_subtree(sb, "refs/tags/",  ".sit/refs/tags",  first_cell);
    str_builder_add_cstr(sb, "]}");
    return str_data(str_builder_build(sb));
}

# ── /sit/v1/objects/<hash> handler ────────────────────────────────
#
# Returns the raw compressed bytes of an object addressed by its
# 64-hex SHA-256. The patra type code rides on an X-Sit-Type
# response header so the client can persist it in its local
# objects.patra without re-deriving from the decompressed body.
#
# The request hash is validated as 64-hex via hex_prefix_valid
# before any DB lookup — we won't hand attacker-controlled bytes
# to a string-concatenated SQL statement, even though
# db_object_read_raw embeds it inside single quotes (the validator
# is the trust boundary; the SQL shape is a defence in depth).
#
# 400 if the path tail isn't 64 hex chars; 404 if the object isn't
# present; 200 with the compressed bytes otherwise. No retry/range
# semantics in v0.7.3 — the body is sent in one shot under the
# advertised SIT_SERVE_MAX_BODY ceiling. Decompression bombs are
# not a serve concern: the bytes are the bytes the repo already
# stores, and the server-side store has already accepted them.

var SIT_OBJECT_PATH_PREFIX = "/sit/v1/objects/";
var SIT_OBJECT_PATH_PREFIX_LEN = 16;

fn serve_handle_object(cfd, path) {
    var plen = strlen(path);
    if (plen != SIT_OBJECT_PATH_PREFIX_LEN + 64) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var hex = path + SIT_OBJECT_PATH_PREFIX_LEN;
    if (hex_prefix_valid(hex, 64) == 0) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var db = get_object_db();
    if (db == 0) {
        sandhi_server_send_status(cfd, 500, "Internal Server Error");
        return 0;
    }
    # db_object_read_raw is in wire.cyr; out layout is
    # {compressed_ptr@0, clen@8, ty@16}. Returns 0 on success,
    # negative on missing/error — we map both to 404 so we don't
    # leak whether the row missed vs the read error'd.
    var raw[24];
    if (db_object_read_raw(db, hex, &raw) != 0) {
        sandhi_server_send_status(cfd, 404, "Not Found");
        return 0;
    }
    var compressed = load64(&raw);
    var clen = load64(&raw + 8);
    var ty = load64(&raw + 16);
    if (clen <= 0) {
        sandhi_server_send_status(cfd, 404, "Not Found");
        return 0;
    }
    if (clen > SIT_SERVE_MAX_BODY) {
        # An object larger than the advertised cap means the repo
        # has accreted state newer than this server promises to
        # serve. Refuse rather than misadvertise.
        sandhi_server_send_status(cfd, 413, "Payload Too Large");
        return 0;
    }
    # Build "X-Sit-Type: <int>\r\n" — sandhi appends extra_headers
    # verbatim to the response, so the trailing CRLF is on us.
    var ty_buf[24];
    var ty_digits = write_decimal(&ty_buf, ty);
    var hdr_len = 13 + ty_digits + 2;
    var hdr = alloc(hdr_len + 1);
    memcpy(hdr, "X-Sit-Type: ", 12);
    memcpy(hdr + 12, &ty_buf, ty_digits);
    store8(hdr + 12 + ty_digits, 13);
    store8(hdr + 12 + ty_digits + 1, 10);
    store8(hdr + 12 + ty_digits + 2, 0);
    sandhi_server_send_response(cfd, 200, "OK", "application/octet-stream",
                                 compressed, clen, hdr);
    return 0;
}

# ── /sit/v1/want batched object stream (v0.7.4) ────────────────────
#
# Request body shape (per ADR 0006):
#   8 bytes  : count (i64 LE)
#   count*64 : ASCII hex hashes
#
# Response body: concatenation of per-object frames:
#   64 bytes : ASCII hex hash
#    8 bytes : ty (i64 LE) — 0=blob, 1=tree, 2=commit
#    8 bytes : clen (i64 LE) — compressed payload length
#    clen B  : zlib-compressed object content
#
# Hashes the server doesn't have are silently omitted from the
# response. The client compares response frame count to the request
# count to detect missing objects (and fall back to per-object GET
# for those, or report failure to the user).
#
# Validation: any malformed input → 400. Body length must equal
# 8 + count*64 exactly; count must fit in [0, SIT_WANT_MAX_COUNT];
# every 64-byte hash slot must pass hex_prefix_valid before any DB
# lookup. Endianness: native LE on x86_64/aarch64 — load64/store64
# do the right thing without explicit byteswaps.

fn serve_handle_want(cfd, buf, n) {
    var body_off = sandhi_server_body_offset(buf, n);
    if (body_off < 0) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var clen = sandhi_server_content_length(buf, n);
    if (clen <= 0) {
        sandhi_server_send_status(cfd, 411, "Length Required");
        return 0;
    }
    if (clen < 8) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    if (body_off + clen > n) {
        # sandhi_server_recv_request reads until full body; if we land
        # here the request was malformed at the framing layer.
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var body = buf + body_off;
    var count = load64(body);
    if (count < 0) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    if (count > SIT_WANT_MAX_COUNT) {
        sandhi_server_send_status(cfd, 413, "Payload Too Large");
        return 0;
    }
    var expected_clen = 8 + count * 64;
    if (clen != expected_clen) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }

    # Pre-validate every hash before any DB work — keeps the failure
    # mode "all 400 or full success", no half-emitted response.
    var i = 0;
    while (i < count) {
        if (hex_prefix_valid(body + 8 + i * 64, 64) == 0) {
            sandhi_server_send_status(cfd, 400, "Bad Request");
            return 0;
        }
        i = i + 1;
    }

    var db = get_object_db();
    if (db == 0) {
        sandhi_server_send_status(cfd, 500, "Internal Server Error");
        return 0;
    }

    # Build the response stream into a growing fl_alloc buffer.
    var resp_cap = 65536;
    var resp = fl_alloc(resp_cap);
    if (resp == 0) {
        sandhi_server_send_status(cfd, 500, "Internal Server Error");
        return 0;
    }
    var resp_used = 0;
    i = 0;
    while (i < count) {
        var hex = body + 8 + i * 64;
        var raw[24];
        if (db_object_read_raw(db, hex, &raw) == 0) {
            var compressed = load64(&raw);
            var obj_clen = load64(&raw + 8);
            var ty = load64(&raw + 16);
            if (obj_clen > 0) {
                var frame_len = 64 + 8 + 8 + obj_clen;
                # Grow response buffer if needed.
                var grow_done = 0;
                while (grow_done == 0) {
                    grow_done = 1;
                    if (resp_used + frame_len > resp_cap) {
                        var new_cap = resp_cap * 2;
                        if (new_cap > SIT_SERVE_MAX_BODY) {
                            new_cap = SIT_SERVE_MAX_BODY;
                        }
                        if (resp_used + frame_len > new_cap) {
                            # Already at the ceiling and it still
                            # doesn't fit — refuse rather than
                            # serve a truncated stream.
                            fl_free(resp, resp_cap);
                            sandhi_server_send_status(cfd, 413, "Payload Too Large");
                            return 0;
                        }
                        var new_resp = fl_alloc(new_cap);
                        if (new_resp == 0) {
                            fl_free(resp, resp_cap);
                            sandhi_server_send_status(cfd, 500, "Internal Server Error");
                            return 0;
                        }
                        memcpy(new_resp, resp, resp_used);
                        fl_free(resp, resp_cap);
                        resp = new_resp;
                        resp_cap = new_cap;
                        if (resp_used + frame_len > resp_cap) { grow_done = 0; }
                    }
                }
                memcpy(resp + resp_used, hex, 64);
                store64(resp + resp_used + 64, ty);
                store64(resp + resp_used + 72, obj_clen);
                memcpy(resp + resp_used + 80, compressed, obj_clen);
                resp_used = resp_used + frame_len;
            }
        }
        # else: object missing from this DB — silently omit.
        i = i + 1;
    }

    sandhi_server_send_response(cfd, 200, "OK", "application/octet-stream",
                                 resp, resp_used, 0);
    fl_free(resp, resp_cap);
    return 0;
}

# ── Bearer auth (v0.7.6) ──────────────────────────────────────────
#
# `_serve_load_token(path)` — read a token file from disk. Returns
# the heap-allocated cstring on success, 0 on any failure (missing
# file, wrong perms, too-short content, embedded NUL/control bytes).
# Caller (cmd_serve) refuses to start the server if 0 is returned
# so the auth posture is "strictly enforced or absent" — never a
# silent fall-through to no-auth.
#
# Perm check: must be 0600 exactly. fstat via newfstatat (validate.cyr's
# AT_FDCWD shape). Stricter than git's "<= 0600" — sit's token file
# has no legitimate group/world-readable use, so any wider mode is
# a configuration mistake worth refusing.
fn _serve_load_token(path) {
    if (path_is_symlink(path) == 1) {
        eprintln("sit: refusing to follow symlink for serve token");
        return 0;
    }
    var stbuf[144];
    var rc = syscall(262, VAL_AT_FDCWD, path, &stbuf, 0);
    if (rc < 0) {
        eprintln("sit: cannot stat serve token");
        return 0;
    }
    var mode = load32(&stbuf + 24);
    var perm = mode & 0xFFF;
    if (perm != 384) {        # 0600 octal = 384 decimal
        eprintln("sit: serve token file must be mode 0600");
        return 0;
    }
    var pair[16];
    if (read_file_heap(path, &pair) != 0) {
        eprintln("sit: failed to read serve token");
        return 0;
    }
    var data = load64(&pair);
    var len = load64(&pair + 8);
    # Strip trailing whitespace (trailing newline from `echo` is the
    # canonical form). Flag-driven loop because Cyrius's `break` in
    # while-with-var is unreliable per CLAUDE.md.
    var stripping = 1;
    while (stripping == 1) {
        stripping = 0;
        if (len > 0) {
            var lc = load8(data + len - 1) & 0xFF;
            if (lc == 10) { len = len - 1; stripping = 1; }
            if (lc == 13) { len = len - 1; stripping = 1; }
            if (lc == 32) { len = len - 1; stripping = 1; }
            if (lc == 9)  { len = len - 1; stripping = 1; }
        }
    }

    if (len < SIT_TOKEN_MIN_LEN) {
        eprintln("sit: serve token shorter than 16 chars — generate a stronger one");
        return 0;
    }
    # Reject control bytes / NUL inside the token; tokens travel via
    # an HTTP header so CR/LF would smuggle headers.
    var i = 0;
    while (i < len) {
        var c = load8(data + i) & 0xFF;
        if (c == 0)  { eprintln("sit: serve token contains NUL"); return 0; }
        if (c == 10) { eprintln("sit: serve token contains LF"); return 0; }
        if (c == 13) { eprintln("sit: serve token contains CR"); return 0; }
        if (c == 32) { eprintln("sit: serve token contains space"); return 0; }
        if (c == 9)  { eprintln("sit: serve token contains TAB"); return 0; }
        if (c < 32)  { eprintln("sit: serve token contains control byte"); return 0; }
        if (c == 127) { eprintln("sit: serve token contains DEL"); return 0; }
        i = i + 1;
    }
    var tok = alloc(len + 1);
    memcpy(tok, data, len);
    store8(tok + len, 0);
    return tok;
}

# Returns 1 if the request carries a valid `Authorization: Bearer <token>`
# header that constant-time-equals the loaded `_serve_token`. Returns 0
# otherwise. Consulted by POST handlers when `_serve_require_auth == 1`.
# Constant-time comparison: walk the full minimum length even on a length
# mismatch so the timing doesn't reveal the prefix the attacker got right.
fn _serve_auth_ok(buf, n) {
    if (_serve_require_auth == 0) { return 1; }
    if (_serve_token == 0) { return 0; }
    var hdr = sandhi_server_find_header(buf, n, "Authorization");
    if (hdr == 0) { return 0; }
    # Expect literal "Bearer " prefix (case-sensitive, matching git's
    # http.extraHeader convention). Eight bytes including the space.
    var hlen = strlen(hdr);
    if (hlen <= 7) { return 0; }
    if (memeq(hdr, "Bearer ", 7) == 0) { return 0; }
    var presented = hdr + 7;
    var plen = hlen - 7;
    var tlen = strlen(_serve_token);
    # Constant-time compare across max(plen, tlen) — works even when
    # lengths differ. Mismatch-flag accumulates via OR across all bytes.
    var max_len = plen;
    if (tlen > max_len) { max_len = tlen; }
    var mismatch = 0;
    if (plen != tlen) { mismatch = 1; }
    var ci = 0;
    while (ci < max_len) {
        var pc = 0;
        var tc = 0;
        if (ci < plen) { pc = load8(presented + ci) & 0xFF; }
        if (ci < tlen) { tc = load8(_serve_token + ci) & 0xFF; }
        if ((pc ^ tc) != 0) { mismatch = 1; }
        ci = ci + 1;
    }
    if (mismatch == 0) { return 1; }
    return 0;
}

# ── /sit/v1/objects/<hash> POST handler (v0.7.6) ──────────────────
#
# Accepts a single compressed sit object from a pushing client.
# Trust boundary: the server REHASHES every uploaded object. The
# claimed hex in the URL must match the SHA-256 of the decompressed
# content (in its full `<type> <len>\0<content>` framed form, the
# same shape that `write_typed_object` hashes locally). The X-Sit-
# Type request header must also agree with the type prefix on the
# decompressed body. Either mismatch → 400.
#
# The rehash is the only place sit pays SHA-256 cost on the wire
# path (CLAUDE.md "SHA-256 roundtrips belong in fsck, not the hot
# path") — but accepted-from-the-network bytes are precisely the
# point where the trust boundary lives. fetch + clone copy raw
# compressed bytes from a server we already trust; push has no such
# upstream trust and must verify what the client claims to be
# uploading.
#
# Returns: 201 Created on success (object stored); 200 OK if already
# present (idempotent); 400 on any validation failure (hex format,
# ty range, body framing, hash mismatch, type-prefix mismatch);
# 401/403 from the caller-side auth wrapper if not authenticated;
# 500 on DB / OOM. Body of any error response is empty (don't leak
# which validation step failed — the caller can compare locally).

fn _serve_rehash_and_insert(cfd, hex, claimed_ty, compressed, clen) {
    # Decompress to verify framing + recompute hash. _decompress_raw_into
    # (src/wire.cyr) handles the 4×-initial / 16 MiB-ceiling sizing
    # mirror of db_object_read_both. raw[24] = {compressed, clen, ty}.
    var raw[24];
    store64(&raw,      compressed);
    store64(&raw +  8, clen);
    store64(&raw + 16, claimed_ty);
    var deco[24];
    if (_decompress_raw_into(&raw, &deco) != 0) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var dbuf = load64(&deco);
    var dlen = load64(&deco + 8);
    var coff = load64(&deco + 16);

    # Verify the decompressed framing's type matches the claimed ty.
    # `coff - 1` is the index of the NUL; the type-string runs from
    # 0 to the first space (which must be at coff - 1 - <digits>).
    if (coff < 5) { sandhi_server_send_status(cfd, 400, "Bad Request"); return 0; }
    var sp = 0;
    var found_sp = 0;
    while (sp < coff) {
        if (load8(dbuf + sp) == 32) { found_sp = 1; sp = coff; }
        else { sp = sp + 1; }
    }
    if (found_sp == 0) { sandhi_server_send_status(cfd, 400, "Bad Request"); return 0; }
    # Recompute sp as the actual space index.
    sp = 0;
    while (sp < coff) {
        if (load8(dbuf + sp) == 32) { break; }
        sp = sp + 1;
    }
    var declared_ty = type_code_of(dbuf, sp);
    if (declared_ty < 0) { sandhi_server_send_status(cfd, 400, "Bad Request"); return 0; }
    if (declared_ty != claimed_ty) { sandhi_server_send_status(cfd, 400, "Bad Request"); return 0; }

    # Recompute the hash over the full framed bytes (type + space +
    # decimal-len + NUL + content) — what write_typed_object uses to
    # compute the canonical sit hash for any new object. hash_data
    # returns a heap-owned cstring of 64 lowercase hex chars.
    var actual_hex = hash_data(dbuf, dlen);
    if (actual_hex == 0) { sandhi_server_send_status(cfd, 500, "Internal Server Error"); return 0; }
    if (memeq(actual_hex, hex, 64) == 0) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }

    # Hash matches. Insert the original compressed bytes. db_object_insert_raw
    # returns 0 on actual insert, 1 on already-present, negative on error.
    var db = get_object_db();
    if (db == 0) { sandhi_server_send_status(cfd, 500, "Internal Server Error"); return 0; }
    var rc = db_object_insert_raw(db, hex, claimed_ty, compressed, clen);
    if (rc < 0) { sandhi_server_send_status(cfd, 500, "Internal Server Error"); return 0; }
    if (rc == 1) { sandhi_server_send_status(cfd, 200, "OK"); return 0; }
    sandhi_server_send_status(cfd, 201, "Created");
    return 0;
}

fn serve_handle_put_object(cfd, path, buf, n) {
    var plen = strlen(path);
    if (plen != SIT_OBJECT_PATH_PREFIX_LEN + 64) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var hex = path + SIT_OBJECT_PATH_PREFIX_LEN;
    if (hex_prefix_valid(hex, 64) == 0) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var ty_hdr = sandhi_server_find_header(buf, n, "X-Sit-Type");
    if (ty_hdr == 0) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    # Parse decimal int from header value. Accept exactly one of "0", "1", "2".
    var ty_len = strlen(ty_hdr);
    if (ty_len != 1) { sandhi_server_send_status(cfd, 400, "Bad Request"); return 0; }
    var ty_c = load8(ty_hdr);
    if (ty_c < 48) { sandhi_server_send_status(cfd, 400, "Bad Request"); return 0; }
    if (ty_c > 50) { sandhi_server_send_status(cfd, 400, "Bad Request"); return 0; }
    var ty = ty_c - 48;

    var body_off = sandhi_server_body_offset(buf, n);
    if (body_off < 0) { sandhi_server_send_status(cfd, 400, "Bad Request"); return 0; }
    var clen = sandhi_server_content_length(buf, n);
    if (clen <= 0) { sandhi_server_send_status(cfd, 411, "Length Required"); return 0; }
    if (clen > SIT_SERVE_MAX_BODY) { sandhi_server_send_status(cfd, 413, "Payload Too Large"); return 0; }
    if (body_off + clen > n) { sandhi_server_send_status(cfd, 400, "Bad Request"); return 0; }

    var compressed = buf + body_off;
    return _serve_rehash_and_insert(cfd, hex, ty, compressed, clen);
}

# ── /sit/v1/refs/<name> POST handler (v0.7.6) ─────────────────────
#
# Updates a single ref. Path tail is the ref name (without the
# `refs/heads/` or `refs/tags/` prefix that GET /refs returns —
# clients pass the namespace); body is the new 64-hex tip optionally
# followed by `\n`. Refs in `refs/remotes/...` are server-side
# state that clients can't directly write — refused with 400.
#
# Fast-forward gate: if the ref already exists, the new tip must be
# a descendant of the current tip. Non-FF returns 409 Conflict.
# Refs that don't exist yet are created (initial push).
#
# The new tip's commit must already be in objects.patra — push
# clients are expected to upload all reachable objects before the
# ref update. We don't transitively walk to verify completeness
# (that's the client's job per ADR 0006's protocol shape); we DO
# require the tip to exist locally, which is a cheap defense
# against accidentally pointing a ref at a hash the server has
# never seen.

var SIT_REF_PUT_PREFIX = "/sit/v1/refs/";
var SIT_REF_PUT_PREFIX_LEN = 13;

fn serve_handle_put_ref(cfd, path, buf, n) {
    var plen = strlen(path);
    if (plen <= SIT_REF_PUT_PREFIX_LEN) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var rname_start = path + SIT_REF_PUT_PREFIX_LEN;
    var rname_len = plen - SIT_REF_PUT_PREFIX_LEN;
    # Materialize as a cstring for refname_valid.
    var rname = alloc(rname_len + 1);
    memcpy(rname, rname_start, rname_len);
    store8(rname + rname_len, 0);
    if (refname_valid(rname) == 0) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    # Refuse refs/remotes/* — those are local state for tracking other
    # remotes; they have no meaning on the server side and would let a
    # malicious client smuggle a fake remote-tracking entry.
    if (rname_len >= 12) {
        if (memeq(rname, "refs/remotes/", 13) == 1) {
            sandhi_server_send_status(cfd, 400, "Bad Request");
            return 0;
        }
    }
    # Restrict v0.7.6 to refs/heads/* and refs/tags/* explicitly. Other
    # namespaces (refs/notes/*, refs/keep/*) aren't part of sit's wire
    # vocabulary today.
    var is_head = 0;
    var is_tag = 0;
    if (rname_len > 11) { if (memeq(rname, "refs/heads/", 11) == 1) { is_head = 1; } }
    if (rname_len > 10) { if (memeq(rname, "refs/tags/",  10) == 1) { is_tag  = 1; } }
    if (is_head == 0) {
        if (is_tag == 0) {
            sandhi_server_send_status(cfd, 400, "Bad Request");
            return 0;
        }
    }

    var body_off = sandhi_server_body_offset(buf, n);
    if (body_off < 0) { sandhi_server_send_status(cfd, 400, "Bad Request"); return 0; }
    var clen = sandhi_server_content_length(buf, n);
    # Body must be exactly 64 hex chars, optionally followed by '\n'.
    if (clen != 64) {
        if (clen != 65) {
            sandhi_server_send_status(cfd, 400, "Bad Request");
            return 0;
        }
    }
    if (body_off + clen > n) { sandhi_server_send_status(cfd, 400, "Bad Request"); return 0; }
    var body = buf + body_off;
    if (hex_prefix_valid(body, 64) == 0) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    if (clen == 65) {
        if (load8(body + 64) != 10) {
            sandhi_server_send_status(cfd, 400, "Bad Request");
            return 0;
        }
    }
    var new_hex = alloc(65);
    memcpy(new_hex, body, 64);
    store8(new_hex + 64, 0);

    # The new tip must already be in objects.patra (pushed by the
    # client via /sit/v1/objects before this call). No transitive
    # check.
    var db = get_object_db();
    if (db == 0) { sandhi_server_send_status(cfd, 500, "Internal Server Error"); return 0; }
    if (db_object_has(db, new_hex) == 0) {
        sandhi_server_send_status(cfd, 400, "Bad Request");
        return 0;
    }

    # Build the on-disk path: ".sit/<rname>". rname already
    # passed refname_valid so no traversal possible.
    var disk_path = alloc(rname_len + 6);
    memcpy(disk_path, ".sit/", 5);
    memcpy(disk_path + 5, rname, rname_len);
    store8(disk_path + 5 + rname_len, 0);

    # Existing tip? FF check via is_ancestor_in_db.
    if (file_exists(disk_path) == 1) {
        # Refuse to follow a symlink on the ref file itself (S-04).
        if (path_is_symlink(disk_path) == 1) {
            sandhi_server_send_status(cfd, 500, "Internal Server Error");
            return 0;
        }
        var rbuf = alloc(128);
        var nr = file_read_all(disk_path, rbuf, 128);
        if (nr < 64) { sandhi_server_send_status(cfd, 500, "Internal Server Error"); return 0; }
        if (hex_prefix_valid(rbuf, 64) == 0) { sandhi_server_send_status(cfd, 500, "Internal Server Error"); return 0; }
        var cur = alloc(65);
        memcpy(cur, rbuf, 64);
        store8(cur + 64, 0);
        if (memeq(cur, new_hex, 64) == 1) {
            # No-op update — tip already at the new hex.
            sandhi_server_send_status(cfd, 200, "OK");
            return 0;
        }
        # Heads must be FF; tags are immutable (any update — including
        # the same value — is a no-op above; a different value is
        # refused).
        if (is_tag == 1) {
            sandhi_server_send_status(cfd, 409, "Conflict");
            return 0;
        }
        if (is_ancestor_in_db(db, cur, new_hex) == 0) {
            sandhi_server_send_status(cfd, 409, "Conflict");
            return 0;
        }
    }

    # Write atomically (write to .tmp then rename). file_write_all
    # already does a single write call — for sit's ref file size
    # (65 bytes) that's atomic on every Linux fs the workflow targets.
    var wbuf = alloc(66);
    memcpy(wbuf, new_hex, 64);
    store8(wbuf + 64, 10);
    ensure_parent_dirs(disk_path);
    if (file_write_all(disk_path, wbuf, 65) < 0) {
        sandhi_server_send_status(cfd, 500, "Internal Server Error");
        return 0;
    }
    sandhi_server_send_status(cfd, 200, "OK");
    return 0;
}

# ── Request dispatcher ─────────────────────────────────────────────
#
# Signature dictated by sandhi: (ctx, cfd, req_buf, req_len) → 0.
# `ctx` is unused in v0.7.3; v0.7.5+ will pass the bearer-token
# config + auth state through it.

fn serve_handle_request(ctx, cfd, buf, n) {
    var method = sandhi_server_get_method(buf, n);
    var path_with_query = sandhi_server_get_path(buf, n);
    var path = sandhi_server_path_only(path_with_query);

    if (streq(method, "GET") == 1) {
        if (streq(path, "/sit/v1/capabilities") == 1) {
            var b1 = serve_build_capabilities();
            sandhi_server_send_response(cfd, 200, "OK", "application/json",
                                         b1, strlen(b1), 0);
            return 0;
        }
        if (streq(path, "/sit/v1/refs") == 1) {
            var b2 = serve_build_refs();
            sandhi_server_send_response(cfd, 200, "OK", "application/json",
                                         b2, strlen(b2), 0);
            return 0;
        }
        # /sit/v1/objects/<64-hex>: prefix-match (path is the path-only
        # form, query string already stripped by sandhi_server_path_only).
        var plen = strlen(path);
        if (plen >= SIT_OBJECT_PATH_PREFIX_LEN) {
            if (memeq(path, SIT_OBJECT_PATH_PREFIX,
                      SIT_OBJECT_PATH_PREFIX_LEN) == 1) {
                return serve_handle_object(cfd, path);
            }
        }
    }
    if (streq(method, "POST") == 1) {
        # /want is read-shaped (bulk fetch) so it stays anonymous in
        # both auth modes. /objects + /refs (push) are auth-gated when
        # --require-auth is set.
        if (streq(path, "/sit/v1/want") == 1) {
            return serve_handle_want(cfd, buf, n);
        }
        var plen3 = strlen(path);
        var is_put_object = 0;
        var is_put_ref = 0;
        if (plen3 >= SIT_OBJECT_PATH_PREFIX_LEN) {
            if (memeq(path, SIT_OBJECT_PATH_PREFIX,
                      SIT_OBJECT_PATH_PREFIX_LEN) == 1) { is_put_object = 1; }
        }
        if (plen3 >= SIT_REF_PUT_PREFIX_LEN) {
            if (memeq(path, SIT_REF_PUT_PREFIX,
                      SIT_REF_PUT_PREFIX_LEN) == 1) { is_put_ref = 1; }
        }
        if (is_put_object == 1) {
            if (_serve_auth_ok(buf, n) == 0) {
                sandhi_server_send_status(cfd, 401, "Unauthorized");
                return 0;
            }
            return serve_handle_put_object(cfd, path, buf, n);
        }
        if (is_put_ref == 1) {
            if (_serve_auth_ok(buf, n) == 0) {
                sandhi_server_send_status(cfd, 401, "Unauthorized");
                return 0;
            }
            return serve_handle_put_ref(cfd, path, buf, n);
        }
    }
    sandhi_server_send_status(cfd, 404, "Not Found");
    return 0;
}

# ── --listen parser ────────────────────────────────────────────────
#
# Parses "<addr>:<port>". Only "127.0.0.1:<n>" is accepted today —
# any other address is rejected at parse time so users don't
# accidentally expose the no-auth daemon. Non-loopback exposure
# unlocks alongside bearer auth in v0.7.5. Writes the parsed port
# to *out_port and returns 1 on success, 0 on any malformation.

fn serve_parse_listen(arg, out_port) {
    var alen = strlen(arg);
    var colon = 0 - 1;
    var i = 0;
    var seen = 0;
    while (i < alen) {
        if (seen == 0) {
            if (load8(arg + i) == 58) {
                colon = i;
                seen = 1;
            }
        }
        i = i + 1;
    }
    if (colon < 0) { return 0; }
    if (colon != 9) { return 0; }
    if (memeq(arg, "127.0.0.1", 9) != 1) { return 0; }
    var port = 0;
    var j = colon + 1;
    var saw_digit = 0;
    while (j < alen) {
        var c = load8(arg + j) & 0xFF;
        if (c < 48) { return 0; }
        if (c > 57) { return 0; }
        port = port * 10 + (c - 48);
        if (port > 65535) { return 0; }
        saw_digit = 1;
        j = j + 1;
    }
    if (saw_digit == 0) { return 0; }
    if (port < 1) { return 0; }
    store64(out_port, port);
    return 1;
}

# ── --stdio dispatch loop (v0.8.2) ─────────────────────────────────
#
# When invoked as `sit serve <repo> --stdio`, sit reads HTTP/1.1
# requests from STDIN and writes responses to STDOUT — no socket. The
# canonical use case is being exec'd as the remote side of an SSH
# connection: `ssh user@host -- sit serve <repo> --stdio` pipes the
# wire over SSH's stdin/stdout channel. SSH owns encryption + auth;
# sit's wire (the same HTTP/1.1 we already speak over TCP) just rides
# the bytes through. Process boundary, not FFI — sit consumes the
# ssh binary, no crypto in sit's address space.
#
# Framing: each request carries Content-Length, so the server reads
# until headers + body are complete, dispatches one request, writes
# one response (with Content-Length), and loops. Client closes STDIN
# to signal end-of-session; recv returns 0, loop exits.
#
# Reuses sandhi's send/recv functions because `sock_send` / `sock_recv`
# are just `sys_write` / `sys_read` (see lib/net.cyr) — they work
# unchanged on pipe fds. The fd we pass to dispatch is STDOUT_FILENO=1.
var STDIN_FILENO = 0;
var STDOUT_FILENO = 1;

# Pipelining-safe stdin recv. Reads until one HTTP request is complete
# (headers + Content-Length body), preserving any trailing bytes that
# belong to a subsequent request. `start_have` is the carryover count
# from the previous iteration; if non-zero, those bytes are already at
# the head of `buf` and we try to parse the header against them before
# blocking on another sys_read.
#
# Returns the total bytes in buf belonging to the first request (the
# caller computes the request boundary via body_offset + content_length
# and moves the trailing bytes to offset 0 for the next call). 0 on
# clean EOF, -1 on read error.
fn _stdio_recv_request(buf, max, start_have) {
    var have = start_have;
    var need_body = 0 - 1;

    if (have > 0) {
        store8(buf + have, 0);
        var bo0 = sandhi_server_body_offset(buf, have);
        if (bo0 >= 0) {
            var clen0 = sandhi_server_content_length(buf, have);
            need_body = bo0 + clen0;
            if (have >= need_body) { return have; }
        }
    }

    while (have < max) {
        var r = sock_recv(STDIN_FILENO, buf + have, max - have);
        if (is_err_result(r) == 1) { return 0 - 1; }
        var n = payload(r);
        if (n <= 0) {
            store8(buf + have, 0);
            return have;
        }
        have = have + n;

        if (need_body == 0 - 1) {
            store8(buf + have, 0);
            var bo = sandhi_server_body_offset(buf, have);
            if (bo >= 0) {
                var clen = sandhi_server_content_length(buf, have);
                need_body = bo + clen;
            }
        }
        if (need_body != 0 - 1) {
            if (have >= need_body) {
                store8(buf + have, 0);
                return have;
            }
        }
    }
    store8(buf + have, 0);
    return have;
}

fn _serve_run_stdio() {
    # Lazily allocate the same 64 KiB request buffer sandhi's
    # accept-loop uses, sized to HSV_REQ_BUF_SIZE so the existing
    # body-cap math in serve_handle_request / serve_handle_want
    # carries over unchanged.
    var buf = alloc(HSV_REQ_BUF_SIZE);
    var carry = 0;

    while (1 == 1) {
        var n = _stdio_recv_request(buf, HSV_REQ_BUF_SIZE - 1, carry);
        if (n <= 0) {
            stdout_flush();
            if (n < 0) { return 1; }
            return 0;
        }

        # Compute the request-1 boundary so any pipelined request-2
        # bytes can carry over to the next iteration. Malformed
        # headers (no body offset) abort the session.
        var bo = sandhi_server_body_offset(buf, n);
        if (bo < 0) {
            sandhi_server_send_status(STDOUT_FILENO, 400, "Bad Request");
            stdout_flush();
            return 1;
        }
        var clen = sandhi_server_content_length(buf, n);
        var req_end = bo + clen;
        var leftover = n - req_end;
        if (leftover < 0) { leftover = 0; }

        # Dispatch just request-1's bytes. The sandhi parsers take
        # `(buf, n)` and bound their reads by `n`, so any pipelined
        # request-2 bytes sitting in `buf[req_end:]` are ignored — we
        # MUST NOT NUL-terminate at req_end, that would overwrite the
        # first byte of request 2 before the carryover memcpy.
        serve_handle_request(0, STDOUT_FILENO, buf, req_end);
        stdout_flush();

        # Shift carryover to the front of buf for the next iteration.
        # memcpy is safe here because dst (buf) < src (buf + req_end);
        # forward-copy semantics never overwrite a yet-to-be-read source byte.
        if (leftover > 0) {
            memcpy(buf, buf + req_end, leftover);
        }
        carry = leftover;
    }
    return 0;
}

# ── Top-level command ──────────────────────────────────────────────

fn cmd_serve() {
    if (argc() < 3) {
        eprintln("usage: sit serve <repo-path> [--stdio | --listen 127.0.0.1:<port>] [--require-auth] [--token <path>]");
        return 1;
    }
    var repo_path = argv_heap(2);
    var port = SIT_SERVE_DEFAULT_PORT;
    var stdio_mode = 0;
    var token_path = "~/.sit/serve.token";   # default; overridable via --token
    var custom_token_path = 0;
    var ai = 3;
    while (ai < argc()) {
        var a = argv(ai);
        if (streq(a, "--stdio") == 1) {
            stdio_mode = 1;
            ai = ai + 1;
            continue;
        }
        if (streq(a, "--listen") == 1) {
            if (ai + 1 >= argc()) {
                eprintln("sit: --listen requires an argument");
                return 1;
            }
            var port_cell = alloc(8);
            store64(port_cell, 0);
            if (serve_parse_listen(argv(ai + 1), port_cell) != 1) {
                eprintln("sit: --listen requires 127.0.0.1:<port> (non-loopback waits on first-party TLS, ADR 0007)");
                return 1;
            }
            port = load64(port_cell);
            ai = ai + 2;
        }
        else {
            if (streq(a, "--require-auth") == 1) {
                _serve_require_auth = 1;
                ai = ai + 1;
            }
            else {
                if (streq(a, "--token") == 1) {
                    if (ai + 1 >= argc()) {
                        eprintln("sit: --token requires a path argument");
                        return 1;
                    }
                    token_path = argv_heap(ai + 1);
                    custom_token_path = 1;
                    ai = ai + 2;
                }
                else {
                    eprintln("sit: unknown serve option");
                    return 1;
                }
            }
        }
    }

    # --stdio + --listen are mutually exclusive transport modes.
    if (stdio_mode == 1) {
        if (port != SIT_SERVE_DEFAULT_PORT) {
            eprintln("sit: --stdio and --listen are mutually exclusive");
            return 1;
        }
    }

    # If --require-auth: load the token before chdir'ing into the repo
    # (default token path is ~/.sit/serve.token, which is HOME-relative,
    # not repo-relative). Refuse to start if the token doesn't load —
    # the auth posture is "strictly enforced or absent" per ADR 0007.
    if (_serve_require_auth == 1) {
        var resolved = token_path;
        if (custom_token_path == 0) {
            var home = getenv("HOME");
            if (home == 0) {
                eprintln("sit: $HOME not set; pass --token <path> explicitly");
                return 1;
            }
            var hl = strlen(home);
            resolved = alloc(hl + 18);
            memcpy(resolved, home, hl);
            memcpy(resolved + hl, "/.sit/serve.token", 17);
            store8(resolved + hl + 17, 0);
        }
        _serve_token = _serve_load_token(resolved);
        if (_serve_token == 0) {
            eprintln("sit: --require-auth set but token failed to load — refusing to start");
            return 1;
        }
    }

    # chdir into the repo so .sit/refs/* and .sit/objects.patra
    # resolve as relative paths in every dependent helper.
    if (syscall(SYS_CHDIR, repo_path) != 0) {
        eprintln("sit: cannot chdir to repo path");
        return 1;
    }
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository at given path");
        return 1;
    }

    # In --stdio mode any chatter on stdout would land between HTTP
    # responses and corrupt the wire — log the listening posture to
    # stderr instead. Bearer auth still applies; it just runs over
    # the SSH-encrypted pipe rather than a TCP socket.
    if (stdio_mode == 1) {
        if (_serve_require_auth == 1) {
            eprintln("sit serve --stdio (auth: bearer)");
        }
        else {
            eprintln("sit serve --stdio (auth: none)");
        }
        return _serve_run_stdio();
    }

    if (_serve_require_auth == 1) {
        println("sit serve listening on 127.0.0.1 (auth: bearer)");
    }
    else {
        println("sit serve listening on 127.0.0.1 (auth: none)");
    }
    stdout_flush();
    return sandhi_server_run(INADDR_LOOPBACK(), port, &serve_handle_request, 0);
}
