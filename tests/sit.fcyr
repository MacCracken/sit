# sit — fuzz harness
# Pokes random/adversarial bytes at the primitives that parse untrusted data
# (zlib frames in object files, tree/commit bodies from disk). Confirms no
# crash on malformed input.

fn fill_pseudo_random(buf, len, seed) {
    var s = seed;
    var i = 0;
    while (i < len) {
        s = s * 2654435769 + 1;
        store8(buf + i, s & 0xFF);
        i = i + 1;
    }
    return 0;
}

# Feed random bytes to zlib_decompress; it must return safely (likely error).
fn fuzz_zlib_decompress(rounds) {
    var buf_cap = 8192;
    var out_cap = 65536;
    var input = alloc(buf_cap);
    var output = alloc(out_cap);
    var seed = 1;
    var i = 0;
    while (i < rounds) {
        var size = (seed & 0xFFF) + 1;  # 1..4096
        if (size > buf_cap) { size = buf_cap; }
        fill_pseudo_random(input, size, seed);
        zlib_decompress(input, size, output, out_cap);
        seed = seed * 1103515245 + 12345;
        i = i + 1;
    }
    return 0;
}

# Feed random bytes to hash_data at varied sizes; verify return is non-null.
fn fuzz_hash_data(rounds) {
    var buf_cap = 16384;
    var input = alloc(buf_cap);
    var seed = 0x13379001;
    var i = 0;
    while (i < rounds) {
        var size = (seed & 0x3FFF);  # 0..16383
        if (size > buf_cap) { size = buf_cap; }
        fill_pseudo_random(input, size, seed);
        var hex = hash_data(input, size);
        if (hex == 0) {
            println("fuzz: hash_data returned 0 — unexpected");
            return 1;
        }
        seed = seed * 2862933555 + 3037000493;
        i = i + 1;
    }
    return 0;
}

# Feed random bytes to hex_decode — malformed hex should return 0, not crash.
fn fuzz_hex_decode(rounds) {
    var buf_cap = 128;
    var input = alloc(buf_cap);
    var seed = 0x5a5a5a5a;
    var i = 0;
    while (i < rounds) {
        var size = seed & 0x7F;  # 0..127
        if (size > buf_cap) { size = buf_cap; }
        fill_pseudo_random(input, size, seed);
        hex_decode(input, size);
        seed = seed * 1664525 + 1013904223;
        i = i + 1;
    }
    return 0;
}

fn main() {
    alloc_init();
    println("fuzz: zlib_decompress (10000 rounds)");
    if (fuzz_zlib_decompress(10000) != 0) { return 1; }
    println("fuzz: hash_data (5000 rounds)");
    if (fuzz_hash_data(5000) != 0) { return 1; }
    println("fuzz: hex_decode (10000 rounds)");
    if (fuzz_hex_decode(10000) != 0) { return 1; }
    println("fuzz: no crashes");
    return 0;
}

var r = main();
syscall(60, r);
