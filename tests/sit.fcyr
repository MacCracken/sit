# sit — fuzz harness
# Pokes random/adversarial bytes at the primitives that parse untrusted data
# (zlib frames in object files, tree/commit bodies from disk, /sit/v1/want
# response frames). Confirms no crash on malformed input.
#
# v0.7.1: add validate.cyr include for url_scheme + remote_url_valid fuzzing.
# v0.7.5: include src/lib.cyr to reach `_wire_http_decode_frames` for the
#   `/sit/v1/want` frame-decoder fuzz target. Pulls in the whole sit surface
#   (cmd_*, serve, etc.) but DCE strips everything not reachable from the
#   fuzz `main()`.
# Stdlib + deps are auto-included via cyrius.cyml.
include "src/lib.cyr"

fn fill_pseudo_random(buf, len, seed) {
    var s = seed;
    var i = 0;
    while (i < len) {
        s = s * 2654435769 + 1;
        store8(buf + i, s & 0xFF);
        i = i + 1;
    }
    return 0;
}

# Feed random bytes to zlib_decompress; it must return safely (likely error).
fn fuzz_zlib_decompress(rounds) {
    var buf_cap = 8192;
    var out_cap = 65536;
    var input = alloc(buf_cap);
    var output = alloc(out_cap);
    var seed = 1;
    var i = 0;
    while (i < rounds) {
        var size = (seed & 0xFFF) + 1;  # 1..4096
        if (size > buf_cap) { size = buf_cap; }
        fill_pseudo_random(input, size, seed);
        zlib_decompress(input, size, output, out_cap);
        seed = seed * 1103515245 + 12345;
        i = i + 1;
    }
    return 0;
}

# Feed random bytes to hash_data at varied sizes; verify return is non-null.
fn fuzz_hash_data(rounds) {
    var buf_cap = 16384;
    var input = alloc(buf_cap);
    var seed = 0x13379001;
    var i = 0;
    while (i < rounds) {
        var size = (seed & 0x3FFF);  # 0..16383
        if (size > buf_cap) { size = buf_cap; }
        fill_pseudo_random(input, size, seed);
        var hex = hash_data(input, size);
        if (hex == 0) {
            println("fuzz: hash_data returned 0 — unexpected");
            return 1;
        }
        seed = seed * 2862933555 + 3037000493;
        i = i + 1;
    }
    return 0;
}

# Feed random bytes to hex_decode — malformed hex should return 0, not crash.
fn fuzz_hex_decode(rounds) {
    var buf_cap = 128;
    var input = alloc(buf_cap);
    var seed = 0x5a5a5a5a;
    var i = 0;
    while (i < rounds) {
        var size = seed & 0x7F;  # 0..127
        if (size > buf_cap) { size = buf_cap; }
        fill_pseudo_random(input, size, seed);
        hex_decode(input, size);
        seed = seed * 1664525 + 1013904223;
        i = i + 1;
    }
    return 0;
}

# v0.7.1: feed random bytes to url_scheme + remote_url_valid. Both must return
# cleanly (0 / -1 / 1) for any input. NUL-terminator is forced at the end of
# the random region so strlen() never reads past the buffer; embedded NULs
# inside the body are deliberately preserved so strlen-truncation behavior
# also gets exercised. Catches: scheme-prefix off-by-one, body-validator
# bounds slip, sign-extension on `load8 & 0xFF`-missing branches.
fn fuzz_url_validators(rounds) {
    var buf_cap = 256;
    var input = alloc(buf_cap);
    var seed = 0xdeadbeef;
    var i = 0;
    while (i < rounds) {
        var size = seed & 0xFF;  # 0..255
        if (size >= buf_cap) { size = buf_cap - 1; }
        fill_pseudo_random(input, size, seed);
        store8(input + size, 0);  # NUL terminate
        url_scheme(input);
        remote_url_valid(input);
        seed = seed * 1664525 + 1013904223;
        i = i + 1;
    }
    return 0;
}

# v0.7.5 — fuzz the `/sit/v1/want` response-frame decoder.
# Adversarial pseudo-random bytes go through `_wire_http_decode_frames`;
# the parser must terminate cleanly (returns 0 or -1) on every input
# without OOB reads, infinite loops, or oversized allocs. The decoder
# is the single trust boundary for compressed-bytes-from-the-wire and
# every byte of its input is attacker-controlled when an http remote
# is in use, so 10M+ iterations are warranted (per ADR 0006 success
# gate). Each round draws a fresh size in [0, 4096] — exercises both
# "frame fits" (rare, mostly empty cache) and "frame doesn't fit"
# (common, parser must reject without alloc'ing the bogus payload
# size). Buffer sizes >= 80 occasionally produce a syntactically
# complete header followed by a clen large enough to extend past
# the buffer; the parser must reject those instead of reading OOB.
fn fuzz_want_frame_decoder(rounds) {
    var buf_cap = 4096;
    var input = alloc(buf_cap);
    var seed = 0xfa57b047;
    var i = 0;
    while (i < rounds) {
        var size = seed & 0xFFF;  # 0..4095
        if (size > buf_cap) { size = buf_cap; }
        fill_pseudo_random(input, size, seed);
        # Use a fresh map per round to keep the parser path pristine —
        # collisions in the cache key space don't crash but they
        # waste memory across millions of iterations.
        var cache = map_new();
        _wire_http_decode_frames(input, size, cache);
        seed = seed * 1664525 + 1013904223;
        i = i + 1;
    }
    return 0;
}

# Drive pseudo-random bytes through _ssh_parse_url. The parser is the
# load-bearing CVE-2017-1000117 defense (rejects user / host / path
# components starting with `-`). Verifies the parser survives malformed
# input without OOB-reads or infinite loops — every byte sequence
# either returns a parsed handle or 0. Particularly exercises the
# leading-dash rejection, the user@host @-separator, and host:port
# colon detection.
fn fuzz_ssh_url_parser(rounds) {
    var buf_cap = 256;
    var input = alloc(buf_cap + 1);
    memcpy(input, "ssh://", 6);
    var u_cell = alloc(8);
    var h_cell = alloc(8);
    var p_cell = alloc(8);
    var path_cell = alloc(8);
    var seed = 0x55534831;
    var i = 0;
    while (i < rounds) {
        var size = (seed & 0xFF) + 6;
        if (size > buf_cap) { size = buf_cap; }
        fill_pseudo_random(input + 6, size - 6, seed);
        store8(input + size, 0);
        store64(u_cell, 0); store64(h_cell, 0);
        store64(p_cell, 0); store64(path_cell, 0);
        _ssh_parse_url(input, u_cell, h_cell, p_cell, path_cell);
        seed = seed * 1664525 + 1013904223;
        i = i + 1;
    }
    return 0;
}

# Feed random bytes to the reflog index/parse core as if it were a log
# buffer. count/nth/msg must never read past `len` or crash on garbage.
fn fuzz_reflog_index(rounds) {
    var buf_cap = 4096;
    var input = alloc(buf_cap);
    var out = alloc(80);
    var pair[16];
    var seed = 7;
    var i = 0;
    while (i < rounds) {
        var size = (seed & 0xFFF) + 1;  # 1..4096
        if (size > buf_cap) { size = buf_cap; }
        fill_pseudo_random(input, size, seed);
        _reflog_count_in_buf(input, size);
        var n = (seed >> 8) & 0x3F;
        _reflog_nth_in_buf(input, size, n, out);
        _reflog_nth_in_buf(input, size, 0, out);
        _reflog_nth_in_buf(input, size, 0 - 1, out);
        _reflog_line_msg(input, size, &pair);
        seed = seed * 1103515245 + 12345;
        i = i + 1;
    }
    return 0;
}

fn main() {
    alloc_init();
    println("fuzz: zlib_decompress (10000 rounds)");
    if (fuzz_zlib_decompress(10000) != 0) { return 1; }
    println("fuzz: hash_data (5000 rounds)");
    if (fuzz_hash_data(5000) != 0) { return 1; }
    println("fuzz: hex_decode (10000 rounds)");
    if (fuzz_hex_decode(10000) != 0) { return 1; }
    println("fuzz: url_validators (10000 rounds)");
    if (fuzz_url_validators(10000) != 0) { return 1; }
    println("fuzz: ssh_url_parser (100000 rounds)");
    if (fuzz_ssh_url_parser(100000) != 0) { return 1; }
    println("fuzz: want_frame_decoder (10000000 rounds)");
    if (fuzz_want_frame_decoder(10000000) != 0) { return 1; }
    println("fuzz: reflog_index (200000 rounds)");
    if (fuzz_reflog_index(200000) != 0) { return 1; }
    println("fuzz: no crashes");
    return 0;
}

var r = main();
syscall(60, r);
