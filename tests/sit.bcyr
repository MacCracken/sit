# sit — benchmark harness
# Measures throughput of the primitives sit's hot paths depend on. Results go
# to stdout in ns/op, ops/s, and MB/s where meaningful.
#
# Phase 1 (pre-0.6.0): sigil SHA-256 + sankoch zlib micro-benchmarks.
# Phase 2 (0.6.0, added alongside the P(-1) audit): patra open/close,
# copy_objects per-row cost, commit-body parse, ed25519 sign/verify,
# validator throughput.

include "src/lib.cyr"

fn fill_pseudo_random(buf, len) {
    var i = 0;
    while (i < len) {
        store8(buf + i, (i * 2654435769 + i / 7) & 0xFF);
        i = i + 1;
    }
    return 0;
}

# ── Phase 1: sigil + sankoch primitive throughput ──────────────────

fn bench_sigil_sha256(size, iters) {
    var name_prefix = "sha256-";
    var nb = alloc(32);
    memcpy(nb, name_prefix, 7);
    var digits = write_decimal(nb + 7, size);
    memcpy(nb + 7 + digits, "B", 1);
    store8(nb + 7 + digits + 1, 0);

    var buf = alloc(size);
    fill_pseudo_random(buf, size);

    var b = bench_new(nb);
    bench_batch_start(b);
    var i = 0;
    while (i < iters) {
        hash_data(buf, size);
        i = i + 1;
    }
    bench_batch_stop(b, iters);
    bench_report(b);
    return 0;
}

fn bench_sankoch_compress(size, iters) {
    var nb = alloc(32);
    memcpy(nb, "zlib-compress-", 14);
    var digits = write_decimal(nb + 14, size);
    memcpy(nb + 14 + digits, "B", 1);
    store8(nb + 14 + digits + 1, 0);

    var src = alloc(size);
    fill_pseudo_random(src, size);
    var out_cap = size + 128;
    var dst = alloc(out_cap);

    var b = bench_new(nb);
    bench_batch_start(b);
    var i = 0;
    while (i < iters) {
        zlib_compress(src, size, dst, out_cap);
        i = i + 1;
    }
    bench_batch_stop(b, iters);
    bench_report(b);
    return 0;
}

fn bench_sankoch_decompress(size, iters) {
    var nb = alloc(32);
    memcpy(nb, "zlib-decompress-", 16);
    var digits = write_decimal(nb + 16, size);
    memcpy(nb + 16 + digits, "B", 1);
    store8(nb + 16 + digits + 1, 0);

    var src = alloc(size);
    fill_pseudo_random(src, size);
    var out_cap = size + 128;
    var compressed = alloc(out_cap);
    var clen = zlib_compress(src, size, compressed, out_cap);

    var decompressed = alloc(size + 128);
    var b = bench_new(nb);
    bench_batch_start(b);
    var i = 0;
    while (i < iters) {
        zlib_decompress(compressed, clen, decompressed, size + 128);
        i = i + 1;
    }
    bench_batch_stop(b, iters);
    bench_report(b);
    return 0;
}

# ── Phase 2 ────────────────────────────────────────────────────────
#
# These benches directly drive the v0.6.x performance roadmap. The
# patra-open-close number is the baseline that the P-01 DB-handle-caching
# refactor targets — every read_object pays this cost once per call today.
# Copy-objects per-row measures the 3-SQL-op-per-object cost P-03 wants
# to collapse into a single transaction. Commit-parse and iso8601 scale
# directly with sit log history length (P-05).

fn bench_patra_open_close(iters) {
    var path = "/tmp/sit-bench-openclose.patra";
    sys_unlink(path);
    patra_init();

    var b = bench_new("patra-open-close");
    bench_batch_start(b);
    var i = 0;
    while (i < iters) {
        var db = patra_open(path);
        patra_exec(db, "CREATE TABLE objects (hash STR, ty INT, content BYTES)");
        patra_close(db);
        i = i + 1;
    }
    bench_batch_stop(b, iters);
    bench_report(b);
    sys_unlink(path);
    return 0;
}

# Insert `count` pseudo-random rows into an objects table so copy_objects has
# something to walk. Uses a single open handle — this is the setup cost, not
# part of the measured span.
fn bench_populate_db(db, count, content_size) {
    var content = alloc(content_size);
    fill_pseudo_random(content, content_size);

    var types[24];
    store64(&types +  0, 1);
    store64(&types +  8, 0);
    store64(&types + 16, 2);

    var i = 0;
    while (i < count) {
        # Generate a deterministic 64-char hex key from i.
        var hex = alloc(65);
        var j = 0;
        while (j < 64) {
            var nibble = (i + j * 17) & 0xF;
            if (nibble < 10) { store8(hex + j, 48 + nibble); }
            else { store8(hex + j, 87 + nibble); }
            j = j + 1;
        }
        store8(hex + 64, 0);

        var ivals[24];
        store64(&ivals + 8, 0);
        var sptrs[24];
        store64(&sptrs + 0, hex);
        var slens[24];
        store64(&slens + 0, 64);
        var bptrs[24];
        store64(&bptrs + 16, content);
        var blens[24];
        store64(&blens + 16, content_size);
        patra_insert_row(db, "objects", 7, 3,
            &types, &ivals, &sptrs, &slens, &bptrs, &blens);
        i = i + 1;
    }
    return 0;
}

# Measure the per-object copy cost of the fetch/push/clone inner loop. Matches
# the current 3-SQL-op shape: has(dst, hex) + read_raw(src, hex) + insert_raw.
# Setup is out of band; only the loop body is timed.
fn bench_copy_objects_per_row(count) {
    var src_path = "/tmp/sit-bench-copy-src.patra";
    var dst_path = "/tmp/sit-bench-copy-dst.patra";
    sys_unlink(src_path);
    sys_unlink(dst_path);
    patra_init();

    var src_db = patra_open(src_path);
    patra_exec(src_db, "CREATE TABLE objects (hash STR, ty INT, content BYTES)");
    bench_populate_db(src_db, count, 256);

    var dst_db = patra_open(dst_path);
    patra_exec(dst_db, "CREATE TABLE objects (hash STR, ty INT, content BYTES)");

    # Build the hashes vec the way walk_reachable_from_commit would.
    var hashes = vec_new();
    var i = 0;
    while (i < count) {
        var hex = alloc(65);
        var j = 0;
        while (j < 64) {
            var nibble = (i + j * 17) & 0xF;
            if (nibble < 10) { store8(hex + j, 48 + nibble); }
            else { store8(hex + j, 87 + nibble); }
            j = j + 1;
        }
        store8(hex + 64, 0);
        vec_push(hashes, hex);
        i = i + 1;
    }

    # v0.7.3 changed copy_objects to (obj_src, dst_db, hashes, raw_cache).
    # The pre-v0.7.3 3-arg call here was stale — it passed a raw patra db
    # where an obj_src tagged handle was expected, so the number was noise.
    var src = obj_src_for_db(src_db);
    var raw_cache = map_new();
    var b = bench_new("copy-objects-100");
    bench_batch_start(b);
    copy_objects(src, dst_db, hashes, raw_cache);
    bench_batch_stop(b, count);
    bench_report(b);

    patra_close(src_db);
    patra_close(dst_db);
    sys_unlink(src_path);
    sys_unlink(dst_path);
    return 0;
}

# commit-body parse + iso8601 — the per-commit cost during `sit log`.
fn bench_commit_parse(iters) {
    var body = "tree 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef\nparent fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210\nauthor Test Author <test@example.com> 1776999445 +0000\ncommitter Test Author <test@example.com> 1776999445 +0000\n\nTypical commit message body on one line.\n";
    var body_len = strlen(body);

    var b = bench_new("commit-parse+iso8601");
    bench_batch_start(b);
    var i = 0;
    while (i < iters) {
        var info[56];
        parse_commit_body(body, body_len, &info);
        iso8601(1776999445);
        i = i + 1;
    }
    bench_batch_stop(b, iters);
    bench_report(b);
    return 0;
}

# ed25519 sign / verify throughput — governs `sit commit -S` and
# `sit verify-commit`. Worth an explicit measurement so sigil regressions
# show up in sit's bench output, not just sigil's.
fn bench_ed25519_sign_verify(iters) {
    var seed[32];
    var s = 0;
    while (s < 32) { store8(&seed + s, s); s = s + 1; }
    var sk[64];
    var pk[32];
    ed25519_keypair(&seed, &sk, &pk);

    var msg = "tree 0123456789abcdef\nparent fedcba98\nauthor t <t@t> 1 +0000\ncommitter t <t@t> 1 +0000\n\nbench";
    var msg_len = strlen(msg);
    var sig[64];

    var bs = bench_new("ed25519-sign");
    bench_batch_start(bs);
    var i = 0;
    while (i < iters) {
        ed25519_sign(&sk, msg, msg_len, &sig);
        i = i + 1;
    }
    bench_batch_stop(bs, iters);
    bench_report(bs);

    # Pre-sign once so the verify loop has a valid signature to check each time.
    ed25519_sign(&sk, msg, msg_len, &sig);
    var bv = bench_new("ed25519-verify");
    bench_batch_start(bv);
    i = 0;
    while (i < iters) {
        ed25519_verify(&pk, msg, msg_len, &sig);
        i = i + 1;
    }
    bench_batch_stop(bv, iters);
    bench_report(bv);
    return 0;
}

# Validator throughput — called on every ref write, every tree parse, every
# clone. Cheap, but "cheap × 10000 entries" adds up; track so regressions
# don't silently creep in.
fn bench_validators(iters) {
    var b1 = bench_new("refname_valid-good");
    bench_batch_start(b1);
    var i = 0;
    while (i < iters) {
        refname_valid("feature/nested/branch-name");
        i = i + 1;
    }
    bench_batch_stop(b1, iters);
    bench_report(b1);

    var b2 = bench_new("tree_entry_name_valid-good");
    bench_batch_start(b2);
    i = 0;
    while (i < iters) {
        tree_entry_name_valid("main.cyr");
        i = i + 1;
    }
    bench_batch_stop(b2, iters);
    bench_report(b2);

    var b3 = bench_new("tree_flat_path_valid-good");
    bench_batch_start(b3);
    i = 0;
    while (i < iters) {
        tree_flat_path_valid("src/deep/nested/path/to/file.cyr");
        i = i + 1;
    }
    bench_batch_stop(b3, iters);
    bench_report(b3);

    var b4 = bench_new("hex_prefix_valid-64char");
    bench_batch_start(b4);
    i = 0;
    var sample = "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef";
    while (i < iters) {
        hex_prefix_valid(sample, 64);
        i = i + 1;
    }
    bench_batch_stop(b4, iters);
    bench_report(b4);
    return 0;
}

# ── Phase 3 (v0.8.12): diff LCS, gitignore matcher, blob hashing ───
#
# Three targets scoped during the 0.6.0 audit but never landed. They map
# directly to sit's hot paths: `compute_file_diff` drives `sit diff/show`,
# `is_ignored` runs on every `sit add`/`status` walk entry, and
# `hash_blob_of_content` is the per-file cost of `sit add`. Landing them
# makes `cyrius bench` a meaningful per-release gate again.

# Build a heap text buffer of `n` lines ("line <i>\n"); writes total byte
# length to the 8-byte cell `out_len`. Returns the buffer pointer.
fn bench_make_lines(n, out_len) {
    var cap = n * 16 + 16;
    var buf = alloc(cap);
    var off = 0;
    var i = 0;
    while (i < n) {
        memcpy(buf + off, "line ", 5);
        off = off + 5;
        off = off + write_decimal(buf + off, i);
        store8(buf + off, 10);
        off = off + 1;
        i = i + 1;
    }
    store64(out_len, off);
    return buf;
}

# LCS diff at n×n lines (every 10th line edited → realistic small-change
# shape). Drives `sit diff`/`show`'s compute_file_diff (split + lcs + annotate).
fn bench_lcs_diff(n, iters) {
    var nb = alloc(32);
    memcpy(nb, "lcs-diff-", 9);
    var d = write_decimal(nb + 9, n);
    memcpy(nb + 9 + d, "x", 1);
    var d2 = write_decimal(nb + 9 + d + 1, n);
    store8(nb + 9 + d + 1 + d2, 0);

    var olen[8];
    var old_buf = bench_make_lines(n, &olen);
    var old_len = load64(&olen);
    var nlen[8];
    var new_buf = bench_make_lines(n, &nlen);
    var new_len = load64(&nlen);

    # Mutate the first char of every 10th line so the LCS has real edits.
    var cnt = 0;
    var p = 0;
    while (p < new_len) {
        if (cnt == 0) { store8(new_buf + p, 88); }
        cnt = cnt + 1;
        if (cnt >= 10) { cnt = 0; }
        var go = 1;
        while (go == 1) {
            if (p >= new_len) { go = 0; }
            else {
                if (load8(new_buf + p) == 10) { go = 0; }
                else { p = p + 1; }
            }
        }
        p = p + 1;
    }

    var b = bench_new(nb);
    bench_batch_start(b);
    var i = 0;
    while (i < iters) {
        compute_file_diff(old_buf, old_len, new_buf, new_len);
        i = i + 1;
    }
    bench_batch_stop(b, iters);
    bench_report(b);
    return 0;
}

# Build a vec of `n` non-anchored `*.tmp` pattern structs (matching
# load_sitignore's 32-byte [text, len, negated, anchored] layout).
fn bench_make_patterns(n) {
    var patterns = vec_new();
    var i = 0;
    while (i < n) {
        var text = alloc(8);
        memcpy(text, "*.tmp", 5);
        store8(text + 5, 0);
        var p = alloc(32);
        store64(p, text);
        store64(p + 8, 5);
        store64(p + 16, 0);
        store64(p + 24, 0);
        vec_push(patterns, p);
        i = i + 1;
    }
    return patterns;
}

# `.sitignore` matcher cost: is_ignored against an n-pattern set. Drives
# every `sit add`/`status` working-tree walk entry (last-match-wins scans
# all n patterns).
fn bench_wildmatch(n, iters) {
    var nb = alloc(32);
    memcpy(nb, "is_ignored-", 11);
    var d = write_decimal(nb + 11, n);
    memcpy(nb + 11 + d, "pat", 3);
    store8(nb + 11 + d + 3, 0);

    var patterns = bench_make_patterns(n);
    var path = "src/deep/nested/path/to/file.cyr";

    var b = bench_new(nb);
    bench_batch_start(b);
    var i = 0;
    while (i < iters) {
        is_ignored(path, patterns);
        i = i + 1;
    }
    bench_batch_stop(b, iters);
    bench_report(b);
    return 0;
}

# Blob framing + SHA-256 of `size`-byte content — the per-file cost of
# `sit add` (hash_file_as_blob's compute core, minus the file read).
fn bench_blob_hash(size, iters) {
    var nb = alloc(32);
    memcpy(nb, "blob-hash-", 10);
    var d = write_decimal(nb + 10, size);
    memcpy(nb + 10 + d, "B", 1);
    store8(nb + 10 + d + 1, 0);

    var content = alloc(size);
    fill_pseudo_random(content, size);

    var b = bench_new(nb);
    bench_batch_start(b);
    var i = 0;
    while (i < iters) {
        hash_blob_of_content(content, size);
        i = i + 1;
    }
    bench_batch_stop(b, iters);
    bench_report(b);
    return 0;
}

fn main() {
    alloc_init();

    # ── Phase 1: primitive throughput ─────────────────────────────
    bench_sigil_sha256(64, 10000);
    bench_sigil_sha256(1024, 5000);
    bench_sigil_sha256(65536, 500);

    bench_sankoch_compress(1024, 2000);
    bench_sankoch_compress(65536, 200);
    bench_sankoch_decompress(1024, 5000);
    bench_sankoch_decompress(65536, 500);

    # ── Phase 2: sit-level hot paths (0.6.0 additions) ────────────
    bench_patra_open_close(500);
    bench_copy_objects_per_row(100);
    bench_commit_parse(10000);
    bench_ed25519_sign_verify(1000);
    bench_validators(100000);

    # ── Phase 3: diff LCS, gitignore matcher, blob hashing (0.8.12) ─
    bench_lcs_diff(100, 100);
    bench_lcs_diff(1000, 10);
    bench_lcs_diff(4000, 2);

    bench_wildmatch(10, 100000);
    bench_wildmatch(50, 20000);
    bench_wildmatch(200, 5000);

    bench_blob_hash(1024, 5000);
    bench_blob_hash(65536, 500);
    bench_blob_hash(1048576, 50);

    return 0;
}

var r = main();
syscall(60, r);
