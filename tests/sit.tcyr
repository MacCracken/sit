# sit — test suite
# Exercises the dep primitives sit's correctness rests on: sigil SHA-256,
# sankoch zlib roundtrip, hex encode/decode, and git-SHA-256-framed blob
# hashing. Stdlib + deps are auto-included via cyrius.cyml.
#
# As of v0.6.0: validate.cyr is included directly so its pure validators
# can be tested without the full sit include chain (they only depend on
# stdlib primitives).

include "src/validate.cyr"

fn test_sigil_hash_known_answer() {
    test_group("sigil SHA-256 known answers");

    # sha256("") = e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
    var empty_hex = hash_data("", 0);
    assert_streq(empty_hex,
        "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
        "sha256 of empty string");

    # sha256("abc") = ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad
    var abc_hex = hash_data("abc", 3);
    assert_streq(abc_hex,
        "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad",
        "sha256 of 'abc'");
    return 0;
}

fn test_blob_framing_git_compatible() {
    test_group("git-SHA-256 blob framing");

    # sit's blob format: "blob <len>\0<content>". Same as git-SHA-256.
    # Expected: sha256(b"blob 12\0hello, sit!\n")
    #         = 37f70a18b0d27d5dd912f6080063bf6fe10820814bccc4bcd13c67ce97c2a96c
    var framed = alloc(32);
    memcpy(framed, "blob 12", 7);
    store8(framed + 7, 0);
    memcpy(framed + 8, "hello, sit!\n", 12);
    var hex = hash_data(framed, 20);
    assert_streq(hex,
        "37f70a18b0d27d5dd912f6080063bf6fe10820814bccc4bcd13c67ce97c2a96c",
        "blob('hello, sit!\\n') matches git SHA-256");
    return 0;
}

fn test_hex_roundtrip() {
    test_group("hex encode / decode");

    var src[4];
    store8(&src, 0xDE);
    store8(&src + 1, 0xAD);
    store8(&src + 2, 0xBE);
    store8(&src + 3, 0xEF);
    var hex = hex_encode(&src, 4);
    assert_streq(hex, "deadbeef", "encode 0xDEADBEEF");

    var bytes = hex_decode("deadbeef", 8);
    assert(bytes != 0, "decode returned non-null");
    assert_eq(load8(bytes) & 0xFF, 0xDE, "byte 0");
    assert_eq(load8(bytes + 1) & 0xFF, 0xAD, "byte 1");
    assert_eq(load8(bytes + 2) & 0xFF, 0xBE, "byte 2");
    assert_eq(load8(bytes + 3) & 0xFF, 0xEF, "byte 3");
    return 0;
}

fn test_sankoch_zlib_roundtrip() {
    test_group("sankoch zlib roundtrip");

    var src = "The quick brown fox jumps over the lazy dog. The quick brown fox jumps over the lazy dog.";
    var src_len = strlen(src);

    var compressed = alloc(256);
    var clen = zlib_compress(src, src_len, compressed, 256);
    assert_gt(clen, 0, "compress returned positive length");
    assert_lt(clen, src_len, "compressed is smaller than source");

    var decompressed = alloc(256);
    var dlen = zlib_decompress(compressed, clen, decompressed, 256);
    assert_eq(dlen, src_len, "decompressed length matches source");
    assert_eq(memeq(decompressed, src, src_len), 1, "decompressed bytes match source");
    return 0;
}

fn test_patra_col_bytes_small() {
    test_group("patra COL_BYTES small roundtrip");

    sys_unlink("/tmp/sit-patra-bytes-small.db");
    patra_init();
    var db = patra_open("/tmp/sit-patra-bytes-small.db");
    assert(db != 0, "open db");

    var r = patra_exec(db, "CREATE TABLE objs (hash STR, ty INT, content BYTES)");
    assert_eq(r, 0, "create table with BYTES column");

    # 3 cols: 0=STR, 1=INT, 2=BYTES
    var types[24];
    store64(&types +  0, 1);  # COL_STR
    store64(&types +  8, 0);  # COL_INT
    store64(&types + 16, 2);  # COL_BYTES

    var ivals[24];
    store64(&ivals +  8, 42);

    var sptrs[24];
    store64(&sptrs +  0, "deadbeef");
    var slens[24];
    store64(&slens +  0, 8);

    var content = "hello, sit via patra BYTES!";
    var clen = 27;
    var bptrs[24];
    store64(&bptrs + 16, content);
    var blens[24];
    store64(&blens + 16, clen);

    r = patra_insert_row(db, "objs", 4, 3, &types, &ivals, &sptrs, &slens, &bptrs, &blens);
    assert_eq(r, 0, "insert_row returned PATRA_OK");

    var rs = patra_query(db, "SELECT hash, ty, content FROM objs");
    assert(rs != 0, "select returned result set");
    assert_eq(patra_result_count(rs), 1, "one row");

    var blen = patra_result_get_bytes_len(rs, 0, 2);
    assert_eq(blen, clen, "reported BYTES length matches");

    var out = alloc(clen + 1);
    r = patra_result_read_bytes(db, rs, 0, 2, out);
    assert_eq(r, 0, "read_bytes returned PATRA_OK");
    assert_eq(memeq(out, content, clen), 1, "byte content roundtrips");

    patra_result_free(rs);
    patra_close(db);
    sys_unlink("/tmp/sit-patra-bytes-small.db");
    return 0;
}

fn test_patra_col_bytes_overflow() {
    test_group("patra COL_BYTES overflow-page roundtrip");

    # Write 16 KB (> one 4072-byte page) to exercise the overflow chain.
    var content = alloc(16384);
    var i = 0;
    while (i < 16384) {
        store8(content + i, (i * 2654435769 + i / 7) & 0xFF);
        i = i + 1;
    }
    var clen = 16384;

    sys_unlink("/tmp/sit-patra-bytes-big.db");
    patra_init();
    var db = patra_open("/tmp/sit-patra-bytes-big.db");
    assert(db != 0, "open db");

    var r = patra_exec(db, "CREATE TABLE blobs (hash STR, content BYTES)");
    assert_eq(r, 0, "create blobs table");

    var types[16];
    store64(&types + 0, 1);  # COL_STR
    store64(&types + 8, 2);  # COL_BYTES

    var ivals[16];
    var sptrs[16];
    store64(&sptrs + 0, "k1");
    var slens[16];
    store64(&slens + 0, 2);
    var bptrs[16];
    store64(&bptrs + 8, content);
    var blens[16];
    store64(&blens + 8, clen);

    r = patra_insert_row(db, "blobs", 5, 2, &types, &ivals, &sptrs, &slens, &bptrs, &blens);
    assert_eq(r, 0, "insert 16 KB row");

    var rs = patra_query(db, "SELECT hash, content FROM blobs");
    assert_eq(patra_result_count(rs), 1, "one row back");

    var blen = patra_result_get_bytes_len(rs, 0, 1);
    assert_eq(blen, clen, "16 KB length preserved");

    var out = alloc(clen + 16);
    r = patra_result_read_bytes(db, rs, 0, 1, out);
    assert_eq(r, 0, "read 16 KB ok");
    assert_eq(memeq(out, content, clen), 1, "16 KB bytes match (overflow chain correct)");

    patra_result_free(rs);
    patra_close(db);
    sys_unlink("/tmp/sit-patra-bytes-big.db");
    return 0;
}

fn test_ed25519_sign_verify_roundtrip() {
    test_group("sigil ed25519 sign/verify roundtrip");

    # Generate a keypair from a fixed seed — deterministic.
    var seed[32];
    var i = 0;
    while (i < 32) { store8(&seed + i, i); i = i + 1; }

    var sk[64];
    var pk[32];
    ed25519_keypair(&seed, &sk, &pk);

    var msg = "sit commit body — author, committer, tree, parent";
    var msg_len = strlen(msg);

    var sig[64];
    ed25519_sign(&sk, msg, msg_len, &sig);

    var ok = ed25519_verify(&pk, msg, msg_len, &sig);
    assert_eq(ok, 1, "verify accepts untampered message");

    # Flip one bit of the message — verify must reject.
    var tampered = alloc(msg_len + 1);
    memcpy(tampered, msg, msg_len);
    store8(tampered + 10, load8(tampered + 10) ^ 1);
    store8(tampered + msg_len, 0);
    var bad = ed25519_verify(&pk, tampered, msg_len, &sig);
    assert_eq(bad, 0, "verify rejects tampered message");

    # Flip one bit of the signature — verify must reject.
    var sig2[64];
    memcpy(&sig2, &sig, 64);
    store8(&sig2 + 5, load8(&sig2 + 5) ^ 1);
    var bad2 = ed25519_verify(&pk, msg, msg_len, &sig2);
    assert_eq(bad2, 0, "verify rejects tampered signature");

    return 0;
}

fn test_validate_refname() {
    test_group("validate.cyr — refname_valid");

    # git check-ref-format rules
    assert_eq(refname_valid("main"),          1, "main");
    assert_eq(refname_valid("feature/foo"),   1, "feature/foo");
    assert_eq(refname_valid("release-1.0"),   1, "release-1.0");

    assert_eq(refname_valid(""),              0, "empty");
    assert_eq(refname_valid("@"),             0, "single @");
    assert_eq(refname_valid("../evil"),       0, "path traversal");
    assert_eq(refname_valid(".hidden"),       0, "leading dot");
    assert_eq(refname_valid("foo.lock"),      0, "trailing .lock");
    assert_eq(refname_valid("has space"),     0, "embedded space");
    assert_eq(refname_valid("has:colon"),     0, "colon");
    assert_eq(refname_valid("has~tilde"),     0, "tilde");
    assert_eq(refname_valid("has..dots"),     0, "consecutive dots");
    assert_eq(refname_valid("trailing."),     0, "trailing dot");
    assert_eq(refname_valid("/abs"),          0, "leading slash");
    assert_eq(refname_valid("trail/"),        0, "trailing slash");
    assert_eq(refname_valid("two//slash"),    0, "consecutive slashes");
    assert_eq(refname_valid("has@{"),         0, "at-brace");
    assert_eq(refname_valid("foo\\bar"),      0, "backslash");
    return 0;
}

fn test_validate_tree_entry_name() {
    test_group("validate.cyr — tree_entry_name_valid");

    assert_eq(tree_entry_name_valid("main.cyr"),   1, "normal file");
    assert_eq(tree_entry_name_valid("README.md"),  1, "dotted file");

    assert_eq(tree_entry_name_valid(""),           0, "empty");
    assert_eq(tree_entry_name_valid("."),          0, "dot");
    assert_eq(tree_entry_name_valid(".."),         0, "double dot");
    assert_eq(tree_entry_name_valid("has/slash"),  0, "slash");
    assert_eq(tree_entry_name_valid("has\\slash"), 0, "backslash");
    assert_eq(tree_entry_name_valid("has:colon"),  0, "colon (NTFS ADS / drive letter)");
    assert_eq(tree_entry_name_valid("trailing "),  0, "trailing space");
    assert_eq(tree_entry_name_valid("trailing."),  0, "trailing dot");
    assert_eq(tree_entry_name_valid(".sit"),       0, ".sit rejected");
    assert_eq(tree_entry_name_valid(".SIT"),       0, ".SIT rejected (case-fold)");
    assert_eq(tree_entry_name_valid(".git"),       0, ".git rejected");
    assert_eq(tree_entry_name_valid(".ssh"),       0, ".ssh rejected");
    assert_eq(tree_entry_name_valid("CON"),        0, "NTFS reserved CON");
    assert_eq(tree_entry_name_valid("com1"),       0, "NTFS reserved com1");
    assert_eq(tree_entry_name_valid("LPT9.txt"),   0, "NTFS reserved LPT9 with ext");

    return 0;
}

fn test_validate_tree_flat_path() {
    test_group("validate.cyr — tree_flat_path_valid");

    assert_eq(tree_flat_path_valid("a"),              1, "single segment");
    assert_eq(tree_flat_path_valid("src/main.cyr"),   1, "nested");
    assert_eq(tree_flat_path_valid("a/b/c/d.txt"),    1, "deep");

    assert_eq(tree_flat_path_valid(""),               0, "empty");
    assert_eq(tree_flat_path_valid("/abs"),           0, "absolute");
    assert_eq(tree_flat_path_valid("../evil"),        0, "traversal");
    assert_eq(tree_flat_path_valid("src/../evil"),    0, "mid-path traversal");
    assert_eq(tree_flat_path_valid("a//b"),           0, "empty segment");
    assert_eq(tree_flat_path_valid("a/.sit/HEAD"),    0, ".sit segment case-fold");
    return 0;
}

fn test_validate_hex_prefix() {
    test_group("validate.cyr — hex_prefix_valid");

    assert_eq(hex_prefix_valid("abcd", 4),                                1, "4 hex chars");
    assert_eq(hex_prefix_valid("0123456789abcdef", 16),                    1, "all hex digits");
    assert_eq(hex_prefix_valid("0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef", 64), 1, "full length");

    assert_eq(hex_prefix_valid("", 0),                                    0, "empty");
    assert_eq(hex_prefix_valid("abcd' OR 1=1 --", 15),                    0, "SQL injection attempt");
    assert_eq(hex_prefix_valid("ABCD", 4),                                0, "uppercase rejected");
    assert_eq(hex_prefix_valid("abcg", 4),                                0, "g not hex");
    return 0;
}

fn test_validate_config_value() {
    test_group("validate.cyr — config_value_valid / config_key_valid");

    assert_eq(config_value_valid("Some Name"),             1, "normal value");
    assert_eq(config_value_valid("you@example.com"),       1, "email");
    assert_eq(config_value_valid(""),                      1, "empty (allowed)");

    # Newlines and NULs rejected (CVE-2023-29007 / CVE-2025-48384 shape)
    assert_eq(config_value_valid("name\ninjected=evil"),   0, "newline injection");
    assert_eq(config_value_valid("has\rcr"),               0, "carriage return");

    assert_eq(config_key_valid("user.name"),               1, "dotted key");
    assert_eq(config_key_valid("remote.origin.url"),       1, "three segments");
    assert_eq(config_key_valid(""),                        0, "empty key");
    assert_eq(config_key_valid("has space"),               0, "space in key");
    assert_eq(config_key_valid("has=equals"),              0, "equals in key");
    return 0;
}

fn test_validate_remote_url() {
    test_group("validate.cyr — remote_url_valid");

    # Local-path schemes — unchanged from v0.6.x.
    assert_eq(remote_url_valid("file:///srv/repo"),         1, "file:// scheme");
    assert_eq(remote_url_valid("/abs/path"),                1, "absolute path");
    assert_eq(remote_url_valid("./relative"),               1, "relative ./");
    assert_eq(remote_url_valid("../parent"),                1, "relative ../");

    # v0.7.1: network schemes accepted (transport ships in later 0.7.x patches).
    assert_eq(remote_url_valid("http://example.com/repo"),  1, "http accepted");
    assert_eq(remote_url_valid("https://example.com/repo"), 1, "https accepted");
    assert_eq(remote_url_valid("https://host:8080/p"),      1, "https with port");
    assert_eq(remote_url_valid("ssh://user@host/path"),     1, "ssh with userinfo");
    assert_eq(remote_url_valid("ssh://host/p"),             1, "ssh no userinfo");

    # Universal rejects.
    assert_eq(remote_url_valid(""),                         0, "empty");
    assert_eq(remote_url_valid("-oProxyCommand=x"),         0, "leading dash (CVE-2017-1000117)");
    assert_eq(remote_url_valid("file://good\nbad"),         0, "embedded newline");
    assert_eq(remote_url_valid("ftp://ok"),                 0, "unknown scheme");
    assert_eq(remote_url_valid("http://"),                  0, "empty authority http");
    assert_eq(remote_url_valid("https://"),                 0, "empty authority https");
    assert_eq(remote_url_valid("ssh://"),                   0, "empty authority ssh");

    # Authority-body whitelist gates: shell metachars + spaces rejected.
    assert_eq(remote_url_valid("http://host;rm -rf"),       0, "semicolon in authority");
    assert_eq(remote_url_valid("http://host /p"),           0, "space in authority");
    assert_eq(remote_url_valid("http://host`whoami`"),      0, "backtick");
    assert_eq(remote_url_valid("http://host$(x)"),          0, "dollar paren");
    assert_eq(remote_url_valid("http://host'q"),            0, "single quote");
    assert_eq(remote_url_valid("ssh://-oProxyCommand=x/r"), 0, "ssh leading-dash authority");
    return 0;
}

fn test_validate_url_scheme() {
    test_group("validate.cyr — url_scheme");

    assert_eq(url_scheme("file:///srv/repo"),      URL_SCHEME_FILE,    "file://");
    assert_eq(url_scheme("/abs/path"),             URL_SCHEME_FILE,    "absolute path");
    assert_eq(url_scheme("./relative"),            URL_SCHEME_FILE,    "relative ./");
    assert_eq(url_scheme("../parent"),             URL_SCHEME_FILE,    "relative ../");
    assert_eq(url_scheme("http://host/p"),         URL_SCHEME_HTTP,    "http://");
    assert_eq(url_scheme("https://host/p"),        URL_SCHEME_HTTPS,   "https://");
    assert_eq(url_scheme("ssh://host/p"),          URL_SCHEME_SSH,     "ssh://");
    assert_eq(url_scheme(""),                      URL_SCHEME_INVALID, "empty");
    assert_eq(url_scheme("ftp://x"),               URL_SCHEME_INVALID, "ftp unknown");
    assert_eq(url_scheme("git://x"),               URL_SCHEME_INVALID, "git unknown");
    assert_eq(url_scheme("nonsense"),              URL_SCHEME_INVALID, "bare bad");
    # Prefix-collision smoke: "http" without :// is not http.
    assert_eq(url_scheme("http"),                  URL_SCHEME_INVALID, "scheme without ://");
    assert_eq(url_scheme("https"),                 URL_SCHEME_INVALID, "scheme without ://");
    return 0;
}

fn main() {
    alloc_init();
    test_sigil_hash_known_answer();
    test_blob_framing_git_compatible();
    test_hex_roundtrip();
    test_sankoch_zlib_roundtrip();
    test_patra_col_bytes_small();
    test_patra_col_bytes_overflow();
    test_ed25519_sign_verify_roundtrip();
    test_validate_refname();
    test_validate_tree_entry_name();
    test_validate_tree_flat_path();
    test_validate_hex_prefix();
    test_validate_config_value();
    test_validate_remote_url();
    test_validate_url_scheme();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
