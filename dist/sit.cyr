# --- util.cyr ---

# util.cyr — universal helpers.
#
# Everything here is consumed by two or more domain modules. Keep this file
# free of sit-specific domain knowledge — no refs, no objects, no patra.

var SEEK_SET = 0;
var SEEK_END = 2;

fn eprintln(s) {
    var len = strlen(s);
    syscall(SYS_WRITE, STDERR, s, len);
    syscall(SYS_WRITE, STDERR, "\n", 1);
    return 0;
}

# P-17: buffered stdout. Without this, sit's command output is dozens to
# thousands of separate syscall(SYS_WRITE, STDOUT, ...) calls — `cmd_diff`
# on a 500-line edit emits 3000+ writes. With a single 64KB heap buffer +
# explicit flush at command end, the same workload lands in a handful of
# syscalls. STDERR (eprintln) stays direct so error output is immediate
# even when the process is being killed mid-command.
var STDOUT_BUF_SIZE = 65536;
var _stdout_buf = 0;
var _stdout_pos = 0;

fn stdout_write(data, len) {
    if (len <= 0) { return 0; }
    if (_stdout_buf == 0) {
        _stdout_buf = alloc_or_die(STDOUT_BUF_SIZE);
    }
    # Writes larger than the buffer go straight to the kernel after a flush
    # of any pending bytes — no point copying into a buffer we'd just empty.
    if (len >= STDOUT_BUF_SIZE) {
        stdout_flush();
        syscall(SYS_WRITE, STDOUT, data, len);
        return 0;
    }
    if (_stdout_pos + len > STDOUT_BUF_SIZE) {
        stdout_flush();
    }
    memcpy(_stdout_buf + _stdout_pos, data, len);
    _stdout_pos = _stdout_pos + len;
    return 0;
}

fn stdout_flush() {
    if (_stdout_pos == 0) { return 0; }
    syscall(SYS_WRITE, STDOUT, _stdout_buf, _stdout_pos);
    _stdout_pos = 0;
    return 0;
}

# S-17: alloc-or-die wrapper for the common case where OOM is unrecoverable
# (no transactional rollback in sit; a half-filled buffer will be memcpy'd
# from address 0 if alloc returns null and we don't notice). Use this at
# every fixed-shape `alloc(N)` site in object_db / tree / commit / merge
# instead of bare alloc; reserve bare alloc for the few callers that
# genuinely have a propagation path (read_file_heap, read_object).
fn alloc_or_die(size) {
    var p = alloc(size);
    if (p == 0) {
        eprintln("sit: out of memory");
        syscall(SYS_EXIT, 1);
    }
    return p;
}

# mkdir(path, 0o755), tolerating EEXIST (-17).
fn ensure_dir(path) {
    var r = sys_mkdir(path, 0x1ED);
    if (r == 0) { return 0; }
    if (r == 0 - 17) { return 0; }
    return r;
}

# Walk `path`, mkdir every '/'-delimited directory prefix. Used by ref writers
# so `.sit/refs/heads/feature/foo` creates `.sit/refs/heads/feature/` on demand.
fn ensure_parent_dirs(path) {
    var len = strlen(path);
    var i = 0;
    while (i < len) {
        if (load8(path + i) == 47) {
            if (i > 0) {
                var segment = alloc(i + 1);
                memcpy(segment, path, i);
                store8(segment + i, 0);
                ensure_dir(segment);
            }
        }
        i = i + 1;
    }
    return 0;
}

# Write decimal representation of n into buf. Returns digit count.
fn write_decimal(buf, n) {
    if (n == 0) { store8(buf, 48); return 1; }
    var digits = 0;
    var m = n;
    while (m > 0) { digits = digits + 1; m = m / 10; }
    m = n;
    var i = digits - 1;
    while (m > 0) {
        store8(buf + i, 48 + m % 10);
        i = i - 1;
        m = m / 10;
    }
    return digits;
}

# Copy argv(n) into a heap-owned, null-terminated string. See
# docs/architecture/001 — argv pointers alias post-return stack memory,
# so we must copy before doing anything stack-heavy.
fn argv_heap(n) {
    var raw = argv(n);
    var len = strlen(raw);
    var s = alloc(len + 1);
    memcpy(s, raw, len);
    store8(s + len, 0);
    return s;
}

# Advance past any run of spaces or tabs in [pos, stop).
fn skip_ws(data, pos, stop) {
    var i = pos;
    var scanning = 1;
    while (scanning == 1) {
        if (i >= stop) { scanning = 0; }
        else {
            var c = load8(data + i);
            if (c == 32) { i = i + 1; }
            else {
                if (c == 9) { i = i + 1; }
                else { scanning = 0; }
            }
        }
    }
    return i;
}

fn strcmp_cstr(a, b) {
    var i = 0;
    var done = 0;
    var result = 0;
    while (done == 0) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        if (ca != cb) {
            if (ca < cb) { result = 0 - 1; }
            else { result = 1; }
            done = 1;
        }
        else {
            if (ca == 0) { done = 1; }
            else { i = i + 1; }
        }
    }
    return result;
}

# Insertion-sort a vec of cstrings in place (ascending).
fn sort_cstrings(vec) {
    var n = vec_len(vec);
    var i = 1;
    while (i < n) {
        var cur = vec_get(vec, i);
        var j = i - 1;
        var placed = 0;
        while (placed == 0) {
            if (j < 0) { placed = 1; }
            else {
                var prev = vec_get(vec, j);
                if (strcmp_cstr(cur, prev) >= 0) { placed = 1; }
                else {
                    vec_set(vec, j + 1, prev);
                    j = j - 1;
                }
            }
        }
        vec_set(vec, j + 1, cur);
        i = i + 1;
    }
    return 0;
}

# Write a sanitized copy of `bytes[len]` to `fd`, replacing ASCII control
# chars (< 0x20 except \t, plus \x7f) with '?'. Used (S-21) for attacker-
# controlled commit body fragments like Author identity so a malicious commit
# can't emit ANSI escape sequences that forge log output or manipulate the
# terminal. Builds the sanitized output into a heap buffer in one pass and
# emits via a single write — both for perf (no per-char syscall) and so the
# STDOUT path stays in order with the surrounding stdout_write calls (P-17).
fn write_sanitized(fd, bytes, len) {
    if (len <= 0) { return 0; }
    var out = alloc_or_die(len);
    var i = 0;
    while (i < len) {
        var c = load8(bytes + i) & 0xFF;
        var emit = c;
        if (c < 32) {
            if (c == 9) { }              # allow tab
            else { emit = 63; }           # '?'
        }
        if (c == 127) { emit = 63; }
        store8(out + i, emit);
        i = i + 1;
    }
    if (fd == STDOUT) { stdout_write(out, len); }
    else { syscall(SYS_WRITE, fd, out, len); }
    return 0;
}

# Read an entire file into a heap buffer. Writes (ptr, len) to out_pair.
# Returns 0 on success, negative on failure.
fn read_file_heap(path, out_pair) {
    var fd = file_open(path, 0, 0);
    if (fd < 0) { return 0 - 1; }
    var size = syscall(SYS_LSEEK, fd, 0, SEEK_END);
    syscall(SYS_LSEEK, fd, 0, SEEK_SET);
    if (size < 0) { file_close(fd); return 0 - 2; }
    # S-06: read_file_heap is used for config files and ref files, which should
    # never exceed a few KB. Cap at 64 MiB to keep a hostile / accidentally-huge
    # file from triggering a multi-GB allocation here.
    if (size > 67108864) { file_close(fd); return 0 - 4; }
    var buf = alloc(size + 1);
    if (buf == 0) { file_close(fd); return 0 - 3; }
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var n = file_read(fd, buf + total, size - total);
        if (n <= 0) { rgo = 0; }
        else { total = total + n; if (total >= size) { rgo = 0; } }
    }
    file_close(fd);
    store64(out_pair, buf);
    store64(out_pair + 8, total);
    return 0;
}

# --- validate.cyr ---

# validate.cyr — input validators for the P(-1) audit fixes.
#
# Every validator is PURE: returns 1 if the input is acceptable, 0 otherwise.
# No stdout, no side effects. Callers decide the error message and disposition.
#
# See docs/audit/2026-04-24-audit.md for the finding-by-finding rationale.

# Length caps picked to match git conventions where they exist and to avoid
# pathological allocations where they don't.
var VAL_REFNAME_MAX = 255;         # S-02 / S-26
var VAL_TREE_NAME_MAX = 255;       # S-03
var VAL_CONFIG_VALUE_MAX = 1024;   # S-05
var VAL_CONFIG_KEY_MAX = 128;      # S-05
var VAL_REMOTE_URL_MAX = 4096;     # S-04

# ── Hex prefix (S-01) ───────────────────────────────────────────────
#
# Accept only [0-9a-f], length 4..64. Used by resolve_hash before interpolating
# the prefix into `LIKE '<prefix>%'`. Preserves sit's existing "too short" (-2)
# behavior by letting the caller check length separately first; this validator
# only checks the CHARACTER set so callers can distinguish "too short" from
# "has bogus characters".

fn hex_prefix_valid(s, len) {
    if (len == 0) { return 0; }
    if (len > 64) { return 0; }
    var i = 0;
    while (i < len) {
        var c = load8(s + i) & 0xFF;
        var ok = 0;
        if (c >= 48) { if (c <= 57) { ok = 1; } }  # 0-9
        if (c >= 97) { if (c <= 102) { ok = 1; } } # a-f
        if (ok == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# ── Ref name (S-02, S-26) ───────────────────────────────────────────
#
# Enforces git check-ref-format rules:
#   - non-empty, <= VAL_REFNAME_MAX
#   - no component begins with '.'
#   - no component ends with '.lock'
#   - no '..' anywhere
#   - no ASCII control chars (< 0x20 or == 0x7F)
#   - no space, '~', '^', ':', '?', '*', '['
#   - cannot begin or end with '/', no '//'
#   - cannot end with '.'
#   - no '@{'
#   - cannot be the single '@'
#   - no '\'

fn _ref_is_bad_char(c) {
    if (c < 32) { return 1; }
    if (c == 127) { return 1; }
    if (c == 32) { return 1; }       # space
    if (c == 126) { return 1; }      # ~
    if (c == 94) { return 1; }       # ^
    if (c == 58) { return 1; }       # :
    if (c == 63) { return 1; }       # ?
    if (c == 42) { return 1; }       # *
    if (c == 91) { return 1; }       # [
    if (c == 92) { return 1; }       # backslash
    return 0;
}

fn refname_valid(name) {
    if (name == 0) { return 0; }
    var len = strlen(name);
    if (len == 0) { return 0; }
    if (len > VAL_REFNAME_MAX) { return 0; }

    # Single-char '@' rejected
    if (len == 1) {
        if (load8(name) == 64) { return 0; }
    }

    # First or last char cannot be '/'
    if (load8(name) == 47) { return 0; }
    if (load8(name + len - 1) == 47) { return 0; }
    # Last char cannot be '.'
    if (load8(name + len - 1) == 46) { return 0; }

    var i = 0;
    var comp_start = 0;  # Start offset of current '/'-separated component
    while (i < len) {
        var c = load8(name + i) & 0xFF;
        if (_ref_is_bad_char(c) == 1) { return 0; }

        # Check for '@{' sequence
        if (c == 64) {
            if (i + 1 < len) {
                if (load8(name + i + 1) == 123) { return 0; }
            }
        }

        # Check for '..' sequence
        if (c == 46) {
            if (i + 1 < len) {
                if (load8(name + i + 1) == 46) { return 0; }
            }
        }

        if (c == 47) {
            # End of a component: validate it was nonempty (i.e. no '//'),
            # didn't end with .lock, didn't start with '.', etc.
            if (i == comp_start) { return 0; }  # '//'
            # Component-start checks already handled at the boundary transition below.
            # Component-end .lock check: does component end with ".lock"?
            var comp_len = i - comp_start;
            if (comp_len >= 5) {
                if (memeq(name + i - 5, ".lock", 5) == 1) { return 0; }
            }
            # Next component starts right after the '/'
            comp_start = i + 1;
            # Must not start with '.'
            if (comp_start < len) {
                if (load8(name + comp_start) == 46) { return 0; }
            }
        }
        i = i + 1;
    }

    # First component: name cannot begin with '.'
    if (load8(name) == 46) { return 0; }

    # Final component .lock check
    var final_len = len - comp_start;
    if (final_len >= 5) {
        if (memeq(name + len - 5, ".lock", 5) == 1) { return 0; }
    }

    return 1;
}

# ── Tree entry name (S-03) ──────────────────────────────────────────
#
# Called by parse_tree on each entry, AND by materialize_target before the
# write, so attackers have to clear two hurdles. Belt-and-suspenders.
#
# Rejects:
#   - empty
#   - ".", ".."
#   - any '/' or '\' or NUL
#   - any ':' (NTFS ADS + Windows drive letter)
#   - any ASCII control char (< 0x20 or == 0x7F)
#   - trailing space or dot (Windows)
#   - case-fold-equal to ".sit", ".git", ".ssh"
#   - NTFS reserved names (CON, PRN, NUL, AUX, COM1-9, LPT1-9)
#   - length > VAL_TREE_NAME_MAX
#
# HFS-ignorable Unicode codepoints are not handled byte-level here — they
# belong in a higher-level check that operates on decoded Unicode. Flagged
# as a v0.7 follow-up.

fn _ascii_tolower(c) {
    if (c >= 65) { if (c <= 90) { return c + 32; } }
    return c;
}

# Case-insensitive match: is `name` equal to `lower_ref` ignoring ASCII case?
# `lower_ref` must already be lowercase (saves an op per char).
fn _name_iequal_ascii(name, name_len, lower_ref, ref_len) {
    if (name_len != ref_len) { return 0; }
    var i = 0;
    while (i < name_len) {
        var nc = _ascii_tolower(load8(name + i) & 0xFF);
        var rc = load8(lower_ref + i) & 0xFF;
        if (nc != rc) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn _is_ntfs_reserved(name, name_len) {
    # Strip trailing extension for comparison: CON, CON.txt both reserved.
    var stem_len = name_len;
    var i = 0;
    while (i < name_len) {
        if (load8(name + i) == 46) { stem_len = i; i = name_len; }
        else { i = i + 1; }
    }
    if (stem_len == 3) {
        if (_name_iequal_ascii(name, 3, "con", 3) == 1) { return 1; }
        if (_name_iequal_ascii(name, 3, "prn", 3) == 1) { return 1; }
        if (_name_iequal_ascii(name, 3, "nul", 3) == 1) { return 1; }
        if (_name_iequal_ascii(name, 3, "aux", 3) == 1) { return 1; }
    }
    if (stem_len == 4) {
        # COM1..COM9, LPT1..LPT9
        var c0 = _ascii_tolower(load8(name) & 0xFF);
        var c1 = _ascii_tolower(load8(name + 1) & 0xFF);
        var c2 = _ascii_tolower(load8(name + 2) & 0xFF);
        var c3 = load8(name + 3) & 0xFF;
        if (c3 >= 49) {
            if (c3 <= 57) {
                if (c0 == 99) {
                    if (c1 == 111) {
                        if (c2 == 109) { return 1; }  # com1..com9
                    }
                }
                if (c0 == 108) {
                    if (c1 == 112) {
                        if (c2 == 116) { return 1; }  # lpt1..lpt9
                    }
                }
            }
        }
    }
    return 0;
}

fn tree_entry_name_valid(name) {
    if (name == 0) { return 0; }
    var len = strlen(name);
    if (len == 0) { return 0; }
    if (len > VAL_TREE_NAME_MAX) { return 0; }

    # Reject "." and ".."
    if (len == 1) {
        if (load8(name) == 46) { return 0; }
    }
    if (len == 2) {
        if (load8(name) == 46) {
            if (load8(name + 1) == 46) { return 0; }
        }
    }

    # Character-by-character sweep
    var i = 0;
    while (i < len) {
        var c = load8(name + i) & 0xFF;
        if (c == 0) { return 0; }       # embedded NUL
        if (c < 32) { return 0; }       # control char
        if (c == 127) { return 0; }     # DEL
        if (c == 47) { return 0; }      # /
        if (c == 92) { return 0; }      # \
        if (c == 58) { return 0; }      # :
        i = i + 1;
    }

    # Trailing space or dot (Windows)
    var last = load8(name + len - 1) & 0xFF;
    if (last == 32) { return 0; }
    if (last == 46) { return 0; }

    # Case-fold comparison to dot-directories we guard
    if (_name_iequal_ascii(name, len, ".sit", 4) == 1) { return 0; }
    if (_name_iequal_ascii(name, len, ".git", 4) == 1) { return 0; }
    if (_name_iequal_ascii(name, len, ".ssh", 4) == 1) { return 0; }

    # NTFS reserved names
    if (_is_ntfs_reserved(name, len) == 1) { return 0; }

    return 1;
}

# Flattened tree path (S-03 second gate).
#
# `flatten_tree` concatenates prefix + entry-name producing paths like
# "src/main.cyr". Each segment between '/'s must individually pass
# tree_entry_name_valid; the full path must also be relative and capped.

var VAL_TREE_PATH_MAX = 4096;

fn tree_flat_path_valid(path) {
    if (path == 0) { return 0; }
    var len = strlen(path);
    if (len == 0) { return 0; }
    if (len > VAL_TREE_PATH_MAX) { return 0; }

    # Cannot be absolute — no leading '/'
    if (load8(path) == 47) { return 0; }

    # Walk '/'-separated segments; each must pass tree_entry_name_valid.
    var seg_start = 0;
    var i = 0;
    while (i <= len) {
        var at_end = 0;
        if (i == len) { at_end = 1; }
        else {
            if (load8(path + i) == 47) { at_end = 1; }
        }
        if (at_end == 1) {
            var seg_len = i - seg_start;
            if (seg_len == 0) { return 0; }  # leading/trailing/consecutive '/'
            # Copy segment to a nul-terminated scratch buffer for the validator.
            var seg = alloc(seg_len + 1);
            memcpy(seg, path + seg_start, seg_len);
            store8(seg + seg_len, 0);
            if (tree_entry_name_valid(seg) == 0) { return 0; }
            seg_start = i + 1;
        }
        i = i + 1;
    }
    return 1;
}

# Tree entry mode allowlist (S-03). Only "100644" (regular file) and "40000"
# (directory) are accepted. Reject symlinks (120000), submodules (160000),
# executable (100755) — sit doesn't emit those today; accepting them from a
# remote tree gives an attacker surface we don't need.

fn tree_entry_mode_valid(mode) {
    if (mode == 0) { return 0; }
    if (streq(mode, "100644") == 1) { return 1; }
    if (streq(mode, "40000") == 1) { return 1; }
    return 0;
}

# ── Config key / value (S-05) ───────────────────────────────────────
#
# Reject control chars (includes \n, \r, \0), cap lengths, and for the key
# require dot-separated tokens that look reasonable.

fn config_value_valid(v) {
    if (v == 0) { return 0; }
    var len = strlen(v);
    if (len > VAL_CONFIG_VALUE_MAX) { return 0; }
    var i = 0;
    while (i < len) {
        var c = load8(v + i) & 0xFF;
        if (c == 0) { return 0; }
        if (c == 10) { return 0; }
        if (c == 13) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn config_key_valid(k) {
    if (k == 0) { return 0; }
    var len = strlen(k);
    if (len == 0) { return 0; }
    if (len > VAL_CONFIG_KEY_MAX) { return 0; }
    var i = 0;
    while (i < len) {
        var c = load8(k + i) & 0xFF;
        # Keys may contain ASCII letters, digits, '.', '_', '-'
        var ok = 0;
        if (c >= 97) { if (c <= 122) { ok = 1; } }  # a-z
        if (c >= 65) { if (c <= 90) { ok = 1; } }   # A-Z
        if (c >= 48) { if (c <= 57) { ok = 1; } }   # 0-9
        if (c == 46) { ok = 1; }  # .
        if (c == 95) { ok = 1; }  # _
        if (c == 45) { ok = 1; }  # -
        if (ok == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# ── Remote URL (S-04) ───────────────────────────────────────────────
#
# Scheme-aware validator. v0.6.x accepted only local-path schemes; v0.7.1
# extends acceptance to http://, https://, ssh:// (transport itself lands in
# v0.7.2+, but URLs validate at remote-add time so users can wire config in
# advance without seeing parse errors when transport ships).
#
# Per-scheme strictness is deliberately conservative: control-char / NUL /
# leading-dash gates apply uniformly; the network-scheme path then runs the
# authority+path body through a whitelist character set. v0.7.3 (HTTP fetch)
# and v0.7.8 (SSH transport) tighten further as those code paths land —
# e.g. RFC3986 host-label rules, port range enforcement, no-`..`-segments.
#
# CVE-2017-1000117 prophylactic: any URL with a leading '-' is rejected so
# the day a transport forks a subprocess, an attacker-controlled URL cannot
# masquerade as a flag.

var URL_SCHEME_INVALID = 0 - 1;
var URL_SCHEME_FILE = 0;
var URL_SCHEME_HTTP = 1;
var URL_SCHEME_HTTPS = 2;
var URL_SCHEME_SSH = 3;

# Classify a URL by its scheme prefix. Path-shaped inputs ('/abs', './rel',
# '../rel') classify as FILE so callers can dispatch with a single switch.
# Returns INVALID for empty / NULL / unrecognized-scheme inputs. Does NOT
# perform body validation — pair with remote_url_valid for the full check.
fn url_scheme(url) {
    if (url == 0) { return URL_SCHEME_INVALID; }
    var len = strlen(url);
    if (len == 0) { return URL_SCHEME_INVALID; }
    if (len >= 8) {
        if (memeq(url, "https://", 8) == 1) { return URL_SCHEME_HTTPS; }
    }
    if (len >= 7) {
        if (memeq(url, "file://", 7) == 1) { return URL_SCHEME_FILE; }
        if (memeq(url, "http://",  7) == 1) { return URL_SCHEME_HTTP;  }
    }
    if (len >= 6) {
        if (memeq(url, "ssh://",   6) == 1) { return URL_SCHEME_SSH;   }
    }
    # Bare paths: absolute (/…) or relative (./…, ../…).
    if (load8(url) == 47) { return URL_SCHEME_FILE; }
    if (load8(url) == 46) { return URL_SCHEME_FILE; }
    return URL_SCHEME_INVALID;
}

# Whitelist body validator for the authority+path of a network URL. Accepts
# alphanumeric plus . - _ / : @ % ~ — sufficient to express
# user@host:port/path-with-encoded-segments without admitting shell or SQL
# metachars. Empty body and leading '-' are rejected (the latter as a second
# layer of CVE-2017-1000117 defense if the scheme prefix was 7+ bytes long).
fn url_authority_path_valid(s, len) {
    if (len == 0) { return 0; }
    if (load8(s) == 45) { return 0; }
    var i = 0;
    while (i < len) {
        var c = load8(s + i) & 0xFF;
        var ok = 0;
        if (c >= 48) { if (c <=  57) { ok = 1; } }  # 0-9
        if (c >= 65) { if (c <=  90) { ok = 1; } }  # A-Z
        if (c >= 97) { if (c <= 122) { ok = 1; } }  # a-z
        if (c == 46) { ok = 1; }  # .
        if (c == 45) { ok = 1; }  # -
        if (c == 95) { ok = 1; }  # _
        if (c == 47) { ok = 1; }  # /
        if (c == 58) { ok = 1; }  # :
        if (c == 64) { ok = 1; }  # @
        if (c == 37) { ok = 1; }  # %
        if (c == 126) { ok = 1; } # ~
        if (ok == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn remote_url_valid(url) {
    if (url == 0) { return 0; }
    var len = strlen(url);
    if (len == 0) { return 0; }
    if (len > VAL_REMOTE_URL_MAX) { return 0; }

    # CVE-2017-1000117 prophylactic
    if (load8(url) == 45) { return 0; }

    # Control chars / NUL
    var i = 0;
    while (i < len) {
        var c = load8(url + i) & 0xFF;
        if (c == 0) { return 0; }
        if (c == 10) { return 0; }
        if (c == 13) { return 0; }
        i = i + 1;
    }

    var s = url_scheme(url);
    if (s == URL_SCHEME_FILE) {
        # Already passed control-char + leading-dash gates above; file://
        # plus bare absolute/relative paths are accepted as-is.
        return 1;
    }
    if (s == URL_SCHEME_HTTP) {
        return url_authority_path_valid(url + 7, len - 7);
    }
    if (s == URL_SCHEME_HTTPS) {
        return url_authority_path_valid(url + 8, len - 8);
    }
    if (s == URL_SCHEME_SSH) {
        return url_authority_path_valid(url + 6, len - 6);
    }
    return 0;
}

# ── Filesystem symlink guard (S-04, S-12) ──────────────────────────
#
# Calls newfstatat(AT_FDCWD, path, &stat, AT_SYMLINK_NOFOLLOW) and returns:
#   1 if path exists and is a SYMLINK
#   0 if path exists and is NOT a symlink (regular file, dir, etc.)
#  -1 if path does not exist or stat failed
#
# struct stat layout on Linux x86_64: st_mode is u32 at offset 24.
# S_IFMT = 0xF000, S_IFLNK = 0xA000.

var VAL_AT_FDCWD = 0 - 100;
var VAL_AT_SYMLINK_NOFOLLOW = 256;

fn path_is_symlink(path) {
    var stbuf[144];
    var rc = syscall(262, VAL_AT_FDCWD, path, &stbuf, VAL_AT_SYMLINK_NOFOLLOW);
    if (rc < 0) { return 0 - 1; }
    var mode = load32(&stbuf + 24);
    var fmt = mode & 0xF000;
    if (fmt == 0xA000) { return 1; }
    return 0;
}

# Return the file-type bits (S_IFMT-masked mode) for a path via lstat, or -1
# if stat failed. Caller compares against 0xA000 (symlink), 0x4000 (dir),
# 0x8000 (regular), etc. Useful for S-04's "is this a directory" and for
# S-25's "does target already exist as something other than a dir".

fn path_lstat_kind(path) {
    var stbuf[144];
    var rc = syscall(262, VAL_AT_FDCWD, path, &stbuf, VAL_AT_SYMLINK_NOFOLLOW);
    if (rc < 0) { return 0 - 1; }
    var mode = load32(&stbuf + 24);
    return mode & 0xF000;
}

# --- config.cyr ---

# config.cyr — sit config file parsing + cmd_config.
#
# Flat `key = value` format. Local at .sit/config; global at ~/.sitconfig.
# Resolution priority: env (at call sites) → local → global → fallback.

# Advance past any run of spaces or tabs in [pos, stop).
# Parse a `key = value` line in [start, stop). Returns heap cstring value
# if the key matches, else 0. Tolerates arbitrary whitespace and skips
# `#`-comment / blank lines.
fn config_parse_value(data, start, stop, key, key_len) {
    var i = skip_ws(data, start, stop);
    if (i >= stop) { return 0; }
    if (load8(data + i) == 35) { return 0; }

    if (stop - i < key_len) { return 0; }
    if (memeq(data + i, key, key_len) == 0) { return 0; }
    i = i + key_len;

    i = skip_ws(data, i, stop);
    if (i >= stop) { return 0; }
    if (load8(data + i) != 61) { return 0; }
    i = i + 1;

    i = skip_ws(data, i, stop);

    var end = stop;
    var trimming = 1;
    while (trimming == 1) {
        if (end <= i) { trimming = 0; }
        else {
            var c = load8(data + end - 1);
            if (c == 32) { end = end - 1; }
            else {
                if (c == 9) { end = end - 1; }
                else { trimming = 0; }
            }
        }
    }

    var value_len = end - i;
    var val = alloc(value_len + 1);
    memcpy(val, data + i, value_len);
    store8(val + value_len, 0);
    return val;
}

# Look up `key` in a single config file. Returns heap cstring value or 0.
fn config_file_get(path, key) {
    if (file_exists(path) != 1) { return 0; }
    var pair[16];
    if (read_file_heap(path, &pair) != 0) { return 0; }
    var data = load64(&pair);
    var len = load64(&pair + 8);
    var key_len = strlen(key);

    var pos = 0;
    while (pos < len) {
        var le = pos;
        var finding = 1;
        while (finding == 1) {
            if (le >= len) { finding = 0; }
            else {
                if (load8(data + le) == 10) { finding = 0; }
                else { le = le + 1; }
            }
        }
        var stop = le;
        if (stop > pos) {
            if (load8(data + stop - 1) == 13) { stop = stop - 1; }
        }
        var v = config_parse_value(data, pos, stop, key, key_len);
        if (v != 0) { return v; }
        pos = le + 1;
    }
    return 0;
}

# Look up `key` in .sit/config (local, higher precedence) then ~/.sitconfig.
fn config_get(key) {
    var v = config_file_get(".sit/config", key);
    if (v != 0) { return v; }
    var home = getenv("HOME");
    if (home == 0) { return 0; }
    var hlen = strlen(home);
    var path = alloc(hlen + 12);
    memcpy(path, home, hlen);
    memcpy(path + hlen, "/.sitconfig", 11);
    store8(path + hlen + 11, 0);
    return config_file_get(path, key);
}

# Upsert `key = value` in a config file. Replaces the first matching line
# or appends a new one. Returns 0 on success, negative on write failure.
#
# S-05: reject newlines/NUL/control chars in both key and value. Prevents
# `sit remote add origin $'foo\nother = attacker'`-shape injection
# (CVE-2023-29007 / CVE-2025-48384).
fn config_file_set(path, key, value) {
    if (config_key_valid(key) == 0) { return 0 - 2; }
    if (config_value_valid(value) == 0) { return 0 - 2; }
    var key_len = strlen(key);
    var val_len = strlen(value);

    var data = 0;
    var len = 0;
    if (file_exists(path) == 1) {
        var pair[16];
        if (read_file_heap(path, &pair) == 0) {
            data = load64(&pair);
            len = load64(&pair + 8);
        }
    }

    var out = alloc(len + key_len + val_len + 8);
    var out_pos = 0;
    var replaced = 0;

    var pos = 0;
    while (pos < len) {
        var le = pos;
        var finding = 1;
        while (finding == 1) {
            if (le >= len) { finding = 0; }
            else {
                if (load8(data + le) == 10) { finding = 0; }
                else { le = le + 1; }
            }
        }
        var stop = le;
        if (stop > pos) {
            if (load8(data + stop - 1) == 13) { stop = stop - 1; }
        }

        var v = config_parse_value(data, pos, stop, key, key_len);
        if (v != 0) {
            memcpy(out + out_pos, key, key_len);
            out_pos = out_pos + key_len;
            memcpy(out + out_pos, " = ", 3);
            out_pos = out_pos + 3;
            memcpy(out + out_pos, value, val_len);
            out_pos = out_pos + val_len;
            store8(out + out_pos, 10);
            out_pos = out_pos + 1;
            replaced = 1;
        }
        else {
            var copy_len = le - pos;
            if (le < len) { copy_len = copy_len + 1; }
            memcpy(out + out_pos, data + pos, copy_len);
            out_pos = out_pos + copy_len;
        }
        pos = le + 1;
    }

    if (replaced == 0) {
        if (out_pos > 0) {
            if (load8(out + out_pos - 1) != 10) {
                store8(out + out_pos, 10);
                out_pos = out_pos + 1;
            }
        }
        memcpy(out + out_pos, key, key_len);
        out_pos = out_pos + key_len;
        memcpy(out + out_pos, " = ", 3);
        out_pos = out_pos + 3;
        memcpy(out + out_pos, value, val_len);
        out_pos = out_pos + val_len;
        store8(out + out_pos, 10);
        out_pos = out_pos + 1;
    }

    if (file_write_all(path, out, out_pos) < 0) { return 0 - 1; }
    return 0;
}

# Print every non-blank, non-comment line of a config file to stdout.
fn config_file_list(path) {
    if (file_exists(path) != 1) { return 0; }
    var pair[16];
    if (read_file_heap(path, &pair) != 0) { return 0; }
    var data = load64(&pair);
    var len = load64(&pair + 8);
    var pos = 0;
    while (pos < len) {
        var le = pos;
        var finding = 1;
        while (finding == 1) {
            if (le >= len) { finding = 0; }
            else {
                if (load8(data + le) == 10) { finding = 0; }
                else { le = le + 1; }
            }
        }
        var stop = le;
        if (stop > pos) {
            if (load8(data + stop - 1) == 13) { stop = stop - 1; }
        }
        var start = skip_ws(data, pos, stop);
        if (start < stop) {
            if (load8(data + start) != 35) {
                stdout_write(data + pos, le - pos);
                if (le < len) { stdout_write("\n", 1); }
            }
        }
        pos = le + 1;
    }
    return 0;
}

# Remove the first line matching `key = value` from a config file.
# Returns 0 on success, -1 on I/O failure, -2 if the key wasn't present.
fn config_file_unset(path, key) {
    var key_len = strlen(key);
    if (file_exists(path) != 1) { return 0 - 2; }
    var pair[16];
    if (read_file_heap(path, &pair) != 0) { return 0 - 1; }
    var data = load64(&pair);
    var len = load64(&pair + 8);

    var out = alloc(len + 1);
    var out_pos = 0;
    var removed = 0;
    var pos = 0;
    while (pos < len) {
        var le = pos;
        var finding = 1;
        while (finding == 1) {
            if (le >= len) { finding = 0; }
            else {
                if (load8(data + le) == 10) { finding = 0; }
                else { le = le + 1; }
            }
        }
        var stop = le;
        if (stop > pos) {
            if (load8(data + stop - 1) == 13) { stop = stop - 1; }
        }
        var v = config_parse_value(data, pos, stop, key, key_len);
        if (v != 0) {
            removed = 1;
        }
        else {
            var copy_len = le - pos;
            if (le < len) { copy_len = copy_len + 1; }
            memcpy(out + out_pos, data + pos, copy_len);
            out_pos = out_pos + copy_len;
        }
        pos = le + 1;
    }
    if (removed == 0) { return 0 - 2; }
    if (file_write_all(path, out, out_pos) < 0) { return 0 - 1; }
    return 0;
}

fn cmd_config() {
    var global = 0;
    var arg_base = 2;
    if (argc() >= 3) {
        if (streq(argv(2), "--global") == 1) {
            global = 1;
            arg_base = 3;
        }
    }

    var path = 0;
    if (global == 1) {
        var home = getenv("HOME");
        if (home == 0) {
            eprintln("sit: HOME not set");
            return 1;
        }
        var hlen = strlen(home);
        path = alloc(hlen + 12);
        memcpy(path, home, hlen);
        memcpy(path + hlen, "/.sitconfig", 11);
        store8(path + hlen + 11, 0);
    }
    else {
        if (file_exists(".sit/HEAD") != 1) {
            eprintln("sit: not a sit repository (run 'sit init')");
            return 1;
        }
        path = ".sit/config";
    }

    if (argc() < arg_base + 1) {
        eprintln("usage: sit config [--global] [--list | --unset <key> | <key> [<value>]]");
        return 1;
    }

    # --list: dump all entries (or nothing if file missing)
    if (streq(argv(arg_base), "--list") == 1) {
        config_file_list(path);
        return 0;
    }

    # --unset <key>: remove key
    if (streq(argv(arg_base), "--unset") == 1) {
        if (argc() < arg_base + 2) {
            eprintln("sit: --unset requires a key");
            return 1;
        }
        var ukey = argv_heap(arg_base + 1);
        var r = config_file_unset(path, ukey);
        if (r == 0 - 2) {
            syscall(SYS_WRITE, STDERR, "sit: '", 6);
            syscall(SYS_WRITE, STDERR, ukey, strlen(ukey));
            syscall(SYS_WRITE, STDERR, "' not set in ", 13);
            syscall(SYS_WRITE, STDERR, path, strlen(path));
            syscall(SYS_WRITE, STDERR, "\n", 1);
            return 1;
        }
        if (r == 0 - 2) {
            eprintln("sit: invalid key or value (no newlines, control chars, or NULs)");
            return 1;
        }
        if (r < 0) {
            eprintln("sit: failed to write config");
            return 1;
        }
        return 0;
    }

    var key = argv_heap(arg_base);
    if (argc() < arg_base + 2) {
        var val = 0;
        if (global == 1) { val = config_file_get(path, key); }
        else             { val = config_get(key); }
        if (val == 0) { return 1; }
        stdout_write(val, strlen(val));
        stdout_write("\n", 1);
        return 0;
    }

    var value = argv_heap(arg_base + 1);
    var set_r = config_file_set(path, key, value);
    if (set_r == 0 - 2) {
        eprintln("sit: invalid key or value (no newlines, control chars, or NULs)");
        return 1;
    }
    if (set_r < 0) {
        eprintln("sit: failed to write config");
        return 1;
    }
    return 0;
}

# --- object_db.cyr ---

# object_db.cyr — patra object store, compression / framing, read commands.
#
# Content-addressed via sigil SHA-256 over the git-SHA-256-compatible framing
# "<type> <len>\0<content>". Zlib compression via sankoch. Objects live in
# .sit/objects.patra (`objects(hash STR, ty INT, content BYTES)`). Legacy
# loose-file layout auto-migrates on first access. Read verbs: cat-file,
# owl-file, fsck. Also the blob-hash primitives used by add + status.

fn object_path(buf, hex) {
    memcpy(buf, ".sit/objects/", 13);
    store8(buf + 13, load8(hex));
    store8(buf + 14, load8(hex + 1));
    store8(buf + 15, 47);
    memcpy(buf + 16, hex + 2, 62);
    store8(buf + 78, 0);
    return 78;
}

# Try to resolve `name` as a ref: HEAD, refs/tags/<name>, or refs/heads/<name>
# in that order. On success, writes the 64-char hash into out_buf and returns 1.
# Returns 0 if no ref matches.
fn resolve_hash(prefix, out_buf) {
    var plen = strlen(prefix);
    if (plen == 64) {
        # S-01: a full-length hash must still be hex — otherwise the
        # short-circuit here would pass garbage bytes straight through.
        if (hex_prefix_valid(prefix, 64) == 0) { return 0; }
        memcpy(out_buf, prefix, 64);
        store8(out_buf + 64, 0);
        return 1;
    }

    # Try as a ref name first (HEAD, tags, branches)
    if (resolve_ref_name(prefix, out_buf) == 1) { return 1; }

    if (plen < 4) { return 0 - 2; }

    # S-01: reject any non-hex character before interpolating into LIKE.
    # Without this, a prefix containing `'` would break / inject the SQL.
    if (hex_prefix_valid(prefix, plen) == 0) { return 0; }

    var db = get_object_db();
    if (db == 0) { return 0; }

    # S-24: SQL strings on the freelist instead of bump heap so they don't
    # accumulate per-call.
    var sql = fl_alloc(64 + plen);
    memcpy(sql, "SELECT hash FROM objects WHERE hash LIKE '", 42);
    memcpy(sql + 42, prefix, plen);
    memcpy(sql + 42 + plen, "%'", 2);
    store8(sql + 42 + plen + 2, 0);

    var rs = patra_query(db, sql);
    fl_free(sql);
    if (rs == 0) { return 0; }
    var count = patra_result_count(rs);
    var ret = 0;
    if (count == 1) {
        var hash_str = patra_result_get_str(rs, 0, 0);
        memcpy(out_buf, hash_str, 64);
        store8(out_buf + 64, 0);
        ret = 1;
    }
    else {
        if (count > 1) { ret = 0 - 1; }
    }
    patra_result_free(rs);
    return ret;
}

# Read and decompress an object by full 64-char hex hash.
# On success, writes to out (24 bytes):
#   out[0..8)    decompressed buffer ptr
#   out[8..16)   decompressed length (framing + content)
#   out[16..24)  content offset (first byte past framing \0)
# Returns 0 on success, negative on error.
fn read_object(hex, out) {
    var db = get_object_db();
    if (db == 0) { return 0 - 1; }

    # S-24: SQL string via fl_alloc + fl_free; freed before any non-trivial
    # work below so we don't hold both the buffer and the result-set.
    var sql = fl_alloc(128);
    memcpy(sql, "SELECT content FROM objects WHERE hash = '", 42);
    memcpy(sql + 42, hex, 64);
    memcpy(sql + 42 + 64, "'", 1);
    store8(sql + 42 + 64 + 1, 0);

    var rs = patra_query(db, sql);
    fl_free(sql);
    if (rs == 0) { return 0 - 2; }
    if (patra_result_count(rs) == 0) {
        patra_result_free(rs);
        return 0 - 3;
    }

    var blen = patra_result_get_bytes_len(rs, 0, 0);
    if (blen <= 0) {
        patra_result_free(rs);
        return 0 - 4;
    }

    var compressed = alloc_or_die(blen);
    if (patra_result_read_bytes(db, rs, 0, 0, compressed) != 0) {
        patra_result_free(rs);
        return 0 - 5;
    }
    patra_result_free(rs);

    # S-08 + P-06: multiplier history is 256× (pre-audit) → 16× (S-08, v0.6.0)
    # → 4× (P-06, v0.6.9). 4× covers the typical sit object (commits, trees,
    # source code blobs all sit at ratio ~2-3); legitimately high-ratio
    # outliers retry at the 16 MiB ceiling. Critically, retry only on a
    # confirmed -ERR_BUFFER_TOO_SMALL (-2) — other negative codes mean the
    # stream is actually corrupt and more memory won't help. Fail fast.
    var dec_cap = blen * 4;
    if (dec_cap < 4096) { dec_cap = 4096; }
    if (dec_cap > 16 * 1024 * 1024) { dec_cap = 16 * 1024 * 1024; }
    var decompressed = alloc_or_die(dec_cap);
    if (decompressed == 0) { return 0 - 6; }
    var dlen = zlib_decompress(compressed, blen, decompressed, dec_cap);
    if (dlen == 0 - ERR_BUFFER_TOO_SMALL) {
        if (dec_cap < 16 * 1024 * 1024) {
            dec_cap = 16 * 1024 * 1024;
            decompressed = alloc_or_die(dec_cap);
            if (decompressed == 0) { return 0 - 6; }
            dlen = zlib_decompress(compressed, blen, decompressed, dec_cap);
        }
    }
    if (dlen <= 0) { return 0 - 7; }

    var nul = 0;
    while (nul < dlen) {
        if (load8(decompressed + nul) == 0) { break; }
        nul = nul + 1;
    }
    if (nul >= dlen) { return 0 - 8; }

    store64(out, decompressed);
    store64(out + 8, dlen);
    store64(out + 16, nul + 1);
    return 0;
}

fn write_typed_object(type_str, type_len, content, content_len) {
    var hdr_max = 32;
    var full_cap = hdr_max + content_len;
    var full = alloc_or_die(full_cap);
    memcpy(full, type_str, type_len);
    store8(full + type_len, 32);
    var digits = write_decimal(full + type_len + 1, content_len);
    store8(full + type_len + 1 + digits, 0);
    var hdr_len = type_len + 1 + digits + 1;
    memcpy(full + hdr_len, content, content_len);
    var full_len = hdr_len + content_len;

    var hex = hash_data(full, full_len);

    var out_cap = full_len + 64 + full_len / 10;
    if (out_cap < 128) { out_cap = 128; }
    var compressed = alloc_or_die(out_cap);
    var clen = zlib_compress(full, full_len, compressed, out_cap);
    if (clen <= 0) { return 0; }

    var db = get_object_db();
    if (db == 0) { return 0; }

    # Content-addressed — skip if hash already present.
    # S-24: SQL on the freelist; freed before the insert path runs.
    var check_sql = fl_alloc(128);
    memcpy(check_sql, "SELECT hash FROM objects WHERE hash = '", 39);
    memcpy(check_sql + 39, hex, 64);
    memcpy(check_sql + 39 + 64, "'", 1);
    store8(check_sql + 39 + 64 + 1, 0);
    var rs = patra_query(db, check_sql);
    fl_free(check_sql);
    var exists = 0;
    if (rs != 0) {
        if (patra_result_count(rs) > 0) { exists = 1; }
        patra_result_free(rs);
    }

    if (exists == 0) {
        var type_code = type_code_of(type_str, type_len);
        var types[24];
        store64(&types + 0, 1);
        store64(&types + 8, 0);
        store64(&types + 16, 2);
        var ivals[24];
        store64(&ivals + 8, type_code);
        var sptrs[24];
        store64(&sptrs + 0, hex);
        var slens[24];
        store64(&slens + 0, 64);
        var bptrs[24];
        store64(&bptrs + 16, compressed);
        var blens[24];
        store64(&blens + 16, clen);
        patra_insert_row(db, "objects", 7, 3,
            &types, &ivals, &sptrs, &slens, &bptrs, &blens);
    }
    return hex;
}

fn write_blob_object(content, content_len) {
    return write_typed_object("blob", 4, content, content_len);
}

fn resolve_and_read(obj_out, hex_out) {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    var prefix = argv_heap(2);
    var rr = resolve_hash(prefix, hex_out);
    if (rr == 0 - 2) { eprintln("sit: hash prefix too short (min 4 chars)"); return 1; }
    if (rr == 0 - 1) { eprintln("sit: ambiguous hash prefix"); return 1; }
    if (rr == 0)     { eprintln("sit: no object matches"); return 1; }

    var er = read_object(hex_out, obj_out);
    if (er != 0) {
        eprintln("sit: cannot read object (corrupt or missing)");
        return 1;
    }
    return 0;
}

fn cmd_cat_file() {
    if (argc() < 3) {
        eprintln("usage: sit cat-file <hash>");
        return 1;
    }

    var hex[72];
    var obj[24];
    var r = resolve_and_read(&obj, &hex);
    if (r != 0) { return r; }

    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    stdout_write(buf + coff, blen - coff);
    return 0;
}

# Locate the owl binary. Priority: SIT_OWL env var (explicit override) →
# /usr/local/bin/owl → /usr/bin/owl → /opt/owl/bin/owl. Returns a C-string
# path or 0 if not found. S-09: each candidate is lstat-checked; symlinks
# are accepted (owl is usually installed this way via package managers)
# but anything in a world-writable directory is logged and rejected.
#
# Writable-dir detection is coarse today — we only check the candidate path
# lstat mode, not the directory's perms up the chain. That's a best-effort
# defense-in-depth; a properly locked-down system has /usr/bin etc. already
# root-owned 0755.
fn find_owl() {
    var env_owl = getenv("SIT_OWL");
    if (env_owl != 0) {
        if (file_exists(env_owl) == 1) { return env_owl; }
        eprintln("sit: SIT_OWL points at a nonexistent file — falling back to system paths");
    }
    if (file_exists("/usr/local/bin/owl") == 1) { return "/usr/local/bin/owl"; }
    if (file_exists("/usr/bin/owl") == 1)       { return "/usr/bin/owl"; }
    if (file_exists("/opt/owl/bin/owl") == 1)   { return "/opt/owl/bin/owl"; }
    return 0;
}

fn cmd_owl_file() {
    if (argc() < 3) {
        eprintln("usage: sit owl-file <hash>");
        return 1;
    }

    var hex[72];
    var obj[24];
    var r = resolve_and_read(&obj, &hex);
    if (r != 0) { return r; }

    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var content = buf + coff;
    var content_len = blen - coff;

    # S-10: write content to $XDG_RUNTIME_DIR (or $HOME/.cache/sit as fallback)
    # with O_CREAT | O_EXCL | O_WRONLY and mode 0600, so we can't be tricked
    # into writing through an attacker-planted symlink at /tmp and other local
    # users can't read the blob.
    var xdg = getenv("XDG_RUNTIME_DIR");
    var home = getenv("HOME");
    var dir_base = 0;
    if (xdg != 0) { dir_base = xdg; }
    else {
        if (home != 0) {
            var hlen = strlen(home);
            var cache = alloc_or_die(hlen + 12);
            memcpy(cache, home, hlen);
            memcpy(cache + hlen, "/.cache/sit", 11);
            store8(cache + hlen + 11, 0);
            var parent = alloc_or_die(hlen + 8);
            memcpy(parent, home, hlen);
            memcpy(parent + hlen, "/.cache", 7);
            store8(parent + hlen + 7, 0);
            ensure_dir(parent);
            ensure_dir(cache);
            dir_base = cache;
        }
        else {
            dir_base = "/tmp";
        }
    }
    var db_len = strlen(dir_base);
    var tmppath = alloc_or_die(db_len + 32);
    memcpy(tmppath, dir_base, db_len);
    memcpy(tmppath + db_len, "/sit-owl-", 9);
    memcpy(tmppath + db_len + 9, &hex, 12);
    store8(tmppath + db_len + 9 + 12, 0);

    # O_WRONLY | O_CREAT | O_EXCL = 1 | 64 | 128 = 193. Mode 0o600 = 0x180.
    # O_EXCL refuses to follow a pre-existing symlink and refuses EEXIST,
    # closing the TOCTOU window.
    var tfd = sys_open(tmppath, 193, 0x180);
    if (tfd < 0) {
        eprintln("sit: cannot create tempfile");
        return 1;
    }
    if (syscall(SYS_WRITE, tfd, content, content_len) < 0) {
        sys_close(tfd);
        # S-16: best-effort tempfile cleanup. Tempfiles live in
        # $XDG_RUNTIME_DIR/sit/ so a leak gets reaped eventually; a stderr
        # warning makes it loud rather than silent.
        if (sys_unlink(tmppath) != 0) {
            eprintln("sit: warning: failed to remove owl tempfile after write error");
        }
        eprintln("sit: cannot write tempfile");
        return 1;
    }
    sys_close(tfd);

    var owl = find_owl();
    if (owl == 0) {
        eprintln("sit: owl not installed — emitting raw content");
        eprintln("sit:   (owl is pre-1.0; https://github.com/MacCracken/owl)");
        stdout_write(content, content_len);
        if (sys_unlink(tmppath) != 0) {
            eprintln("sit: warning: failed to remove owl tempfile");
        }
        return 0;
    }

    var args = vec_new();
    vec_push(args, owl);
    vec_push(args, tmppath);
    var rc = exec_vec(args);
    if (sys_unlink(tmppath) != 0) {
        eprintln("sit: warning: failed to remove owl tempfile after exec");
    }
    return rc;
}

# Type codes stored in the objects.type INT column.
fn type_code_of(type_str, type_len) {
    if (type_len == 4) {
        if (memeq(type_str, "blob", 4) == 1) { return 0; }
        if (memeq(type_str, "tree", 4) == 1) { return 1; }
    }
    if (type_len == 6) {
        if (memeq(type_str, "commit", 6) == 1) { return 2; }
    }
    return 0 - 1;
}

# Open (or create) the patra-backed object store. Returns db handle, or 0.
# Used by the wire protocol when it needs an explicit handle (push/fetch
# open both ends with named locals); hot read paths should go through
# get_object_db() instead.
fn object_db_open() {
    patra_init();
    var db = patra_open(".sit/objects.patra");
    if (db == 0) { return 0; }
    patra_exec(db, "CREATE TABLE objects (hash STR, ty INT, content BYTES)");
    return db;
}

# v0.6.4: process-wide cached handle for .sit/objects.patra. Collapses
# P-01/02/05/08/12/25 — every read_object / write_typed_object /
# resolve_hash previously did patra_init + patra_open + CREATE TABLE +
# loose-migration check + patra_close on every call. With the cache:
# first call opens + migrates once; subsequent calls reuse the handle;
# fd dies with the process (patra_close just frees in-process buffers
# and closes the fd — no WAL flush — so skipping it at exit is safe).
var _object_db_cached = 0;

fn get_object_db() {
    if (_object_db_cached != 0) { return _object_db_cached; }
    _object_db_cached = object_db_open();
    if (_object_db_cached == 0) { return 0; }
    # v0.6.10 — investigated patra 1.8's BATCH sync mode here and reverted:
    # the cache never closes the handle (fd dies with the process, no
    # patra_close call), so BATCH-pending writes between the every-64-writes
    # auto-flush would be lost on power loss within the kernel writeback
    # window. `copy_objects` already wraps its hot loop in patra_begin /
    # patra_commit (v0.6.5 P-03), which gets the same fsync amortization on
    # the only batch-shaped write path. Stay on FULL (default) for now;
    # revisit if/when sit grows explicit patra_flush() calls at command exit.
    object_db_migrate_from_loose(_object_db_cached);
    return _object_db_cached;
}

# Migrate legacy loose-file objects (under .sit/objects/<xx>/<yy...>) into
# the patra table. No-op if no legacy files present. Deletes loose files
# + empty 2-char directories as they're migrated.
fn object_db_migrate_from_loose(db) {
    if (file_exists(".sit/objects") != 1) { return 0; }

    var dirs = dir_list(str_from(".sit/objects"));
    var dn = vec_len(dirs);
    var di = 0;
    while (di < dn) {
        var s = vec_get(dirs, di);
        var sdata = str_data(s);
        var slen = str_len(s);

        if (slen == 2) {
            var sub_path = alloc_or_die(16);
            memcpy(sub_path, ".sit/objects/", 13);
            memcpy(sub_path + 13, sdata, 2);
            store8(sub_path + 15, 0);

            var files = dir_list(str_from(sub_path));
            var fn_ct = vec_len(files);
            var fi = 0;
            while (fi < fn_ct) {
                var f = vec_get(files, fi);
                var fdata = str_data(f);
                var flen = str_len(f);

                if (flen == 62) {
                    var hex = alloc_or_die(65);
                    memcpy(hex, sdata, 2);
                    memcpy(hex + 2, fdata, 62);
                    store8(hex + 64, 0);

                    var loose_path = alloc_or_die(96);
                    object_path(loose_path, hex);
                    var pair[16];
                    if (read_file_heap(loose_path, &pair) == 0) {
                        var compressed = load64(&pair);
                        var clen = load64(&pair + 8);

                        # Sniff type from decompressed header for the INT column.
                        # S-08 + P-06 (v0.6.9): 4× initial; retry at 16 MiB ceiling
                        # only on confirmed -ERR_BUFFER_TOO_SMALL. Matches read_object.
                        var dec_cap = clen * 4;
                        if (dec_cap < 4096) { dec_cap = 4096; }
                        if (dec_cap > 16 * 1024 * 1024) { dec_cap = 16 * 1024 * 1024; }
                        var decompressed = alloc_or_die(dec_cap);
                        var dlen = zlib_decompress(compressed, clen, decompressed, dec_cap);
                        if (dlen == 0 - ERR_BUFFER_TOO_SMALL) {
                            if (dec_cap < 16 * 1024 * 1024) {
                                dec_cap = 16 * 1024 * 1024;
                                decompressed = alloc_or_die(dec_cap);
                                dlen = zlib_decompress(compressed, clen, decompressed, dec_cap);
                            }
                        }
                        var type_code = 0;
                        if (dlen > 5) {
                            if (memeq(decompressed, "blob ", 5) == 1) { type_code = 0; }
                            else {
                                if (memeq(decompressed, "tree ", 5) == 1) { type_code = 1; }
                                else {
                                    if (dlen > 7) {
                                        if (memeq(decompressed, "commit ", 7) == 1) { type_code = 2; }
                                    }
                                }
                            }
                        }

                        var types[24];
                        store64(&types + 0, 1);
                        store64(&types + 8, 0);
                        store64(&types + 16, 2);
                        var ivals[24];
                        store64(&ivals + 8, type_code);
                        var sptrs[24];
                        store64(&sptrs + 0, hex);
                        var slens[24];
                        store64(&slens + 0, 64);
                        var bptrs[24];
                        store64(&bptrs + 16, compressed);
                        var blens[24];
                        store64(&blens + 16, clen);
                        patra_insert_row(db, "objects", 7, 3,
                            &types, &ivals, &sptrs, &slens, &bptrs, &blens);

                        sys_unlink(loose_path);
                    }
                }
                fi = fi + 1;
            }
            sys_rmdir(sub_path);
        }
        di = di + 1;
    }
    return 0;
}

# Read a ref tip file (heads/tags/remotes leaf) — trim trailing CR/LF,
# validate 64-hex, return a heap-allocated 65-byte cstring or 0 on
# malformed content. Caller does not free (bump-allocated for the life
# of the fsck pass).
fn fsck_read_ref_tip(path) {
    var pair[16];
    if (read_file_heap(path, &pair) != 0) { return 0; }
    var data = load64(&pair);
    var len = load64(&pair + 8);
    # Trim trailing CR/LF (cyrius `break` in while-with-var is unreliable,
    # so use a flag).
    var trimming = 1;
    while (trimming == 1) {
        if (len == 0) { trimming = 0; }
        else {
            var lc = load8(data + len - 1) & 0xFF;
            if (lc == 10) { len = len - 1; }
            else {
                if (lc == 13) { len = len - 1; }
                else { trimming = 0; }
            }
        }
    }
    if (len != 64) { return 0; }
    if (hex_prefix_valid(data, 64) == 0) { return 0; }
    var out = alloc(65);
    memcpy(out, data, 64);
    store8(out + 64, 0);
    return out;
}

# Walk one refs subtree (`.sit/refs/heads` etc.) and push every valid
# tip hex into `roots`. Missing dir is a no-op. Malformed ref files are
# silently skipped — the integrity pass surfaces unreachable objects,
# and a broken ref shows up there as a dangling chain.
fn fsck_walk_refs_dir(dir, roots) {
    if (file_exists(dir) != 1) { return 0; }
    var files = vec_new();
    dir_walk(str_from(dir), files);
    var i = 0;
    while (i < vec_len(files)) {
        var fp_str = vec_get(files, i);
        var fp_len = str_len(fp_str);
        var fp_data = str_data(fp_str);
        var fs_cstr = alloc(fp_len + 1);
        memcpy(fs_cstr, fp_data, fp_len);
        store8(fs_cstr + fp_len, 0);
        var hex = fsck_read_ref_tip(fs_cstr);
        if (hex != 0) { vec_push(roots, hex); }
        i = i + 1;
    }
    return 0;
}

# Collect every reachability root from the on-disk refs:
#   .sit/refs/heads/<*>, .sit/refs/tags/<*>, .sit/refs/remotes/<*>/<*>
# plus .sit/HEAD when it's a raw hex (detached) rather than symbolic.
# Symbolic HEAD targets are already covered by the matching ref file.
fn fsck_collect_roots() {
    var roots = vec_new();
    fsck_walk_refs_dir(".sit/refs/heads",   roots);
    fsck_walk_refs_dir(".sit/refs/tags",    roots);
    fsck_walk_refs_dir(".sit/refs/remotes", roots);

    if (file_exists(".sit/HEAD") == 1) {
        var pair[16];
        if (read_file_heap(".sit/HEAD", &pair) == 0) {
            var data = load64(&pair);
            var len = load64(&pair + 8);
            var trimming = 1;
            while (trimming == 1) {
                if (len == 0) { trimming = 0; }
                else {
                    var lc = load8(data + len - 1) & 0xFF;
                    if (lc == 10) { len = len - 1; }
                    else {
                        if (lc == 13) { len = len - 1; }
                        else { trimming = 0; }
                    }
                }
            }
            if (len == 64) {
                if (hex_prefix_valid(data, 64) == 1) {
                    var hex = alloc(65);
                    memcpy(hex, data, 64);
                    store8(hex + 64, 0);
                    vec_push(roots, hex);
                }
            }
        }
    }
    return roots;
}

# Extract every `parent <hex>\n` from a commit body and push each as a
# fresh 65-byte cstring into `parents`. Distinct from parse_commit_body,
# which captures only the LAST parent line (merge commits have two);
# reachability MUST follow both legs or merged-only objects appear
# dangling. Stops at the first blank line (end of headers).
fn fsck_collect_commit_parents(body, body_len, parents) {
    var pos = 0;
    var done = 0;
    while (done == 0) {
        if (pos >= body_len) { done = 1; }
        else {
            # Find end of current line (cyrius `break` in while-with-var
            # is unreliable, so use a flag).
            var le = pos;
            var scanning = 1;
            while (scanning == 1) {
                if (le >= body_len) { scanning = 0; }
                else {
                    if (load8(body + le) == 10) { scanning = 0; }
                    else { le = le + 1; }
                }
            }
            var line_len = le - pos;
            if (line_len == 0) { done = 1; }
            else {
                if (line_len >= 71) {
                    if (memeq(body + pos, "parent ", 7) == 1) {
                        if (hex_prefix_valid(body + pos + 7, 64) == 1) {
                            var p = alloc(65);
                            memcpy(p, body + pos + 7, 64);
                            store8(p + 64, 0);
                            vec_push(parents, p);
                        }
                    }
                }
                pos = le + 1;
            }
        }
    }
    return 0;
}

# Extract `tree <hex>\n` from a commit body. Returns a heap-allocated
# 65-byte hex cstring, or 0 if absent / malformed. Looks at the first
# line only — git always emits `tree` as the very first header.
fn fsck_extract_commit_tree(body, body_len) {
    if (body_len < 70) { return 0; }
    if (memeq(body, "tree ", 5) == 0) { return 0; }
    if (hex_prefix_valid(body + 5, 64) == 0) { return 0; }
    var t = alloc(65);
    memcpy(t, body + 5, 64);
    store8(t + 64, 0);
    return t;
}

# Reachability walker for fsck. BFS from `root` over the object graph,
# marking each visited hex in `seen` (map_new, cstr-keyed). Commits
# enqueue their tree + every parent hex; trees enqueue every entry
# (sub-trees and blobs); blobs are leaves. Missing / unreadable objects
# get marked in `seen` so we don't loop, but no children are enqueued.
# Type detection is by framing prefix ("blob "/"tree "/"commit ").
#
# Distinct from `walk_reachable_phased` in src/wire.cyr: that walker
# only follows the first parse_commit_body-captured parent (which is
# actually the LAST parent line in the body — a pre-existing limitation
# that doesn't show up in CI because the fixtures are linear).
# Reachability must traverse every parent edge or merge-only objects
# look dangling.
fn fsck_walk_reachable(root, seen) {
    var queue = vec_new();
    vec_push(queue, root);
    while (vec_len(queue) > 0) {
        var hex = vec_get(queue, vec_len(queue) - 1);
        vec_pop(queue);
        if (map_has(seen, hex) == 0) {
            map_set(seen, hex, 1);
            var obj[24];
            if (read_object(hex, &obj) == 0) {
                var buf = load64(&obj);
                var blen = load64(&obj + 8);
                var coff = load64(&obj + 16);
                var body = buf + coff;
                var body_len = blen - coff;
                # Classify by framing prefix.
                if (blen >= 7) {
                    if (memeq(buf, "commit ", 7) == 1) {
                        var t = fsck_extract_commit_tree(body, body_len);
                        if (t != 0) {
                            if (map_has(seen, t) == 0) { vec_push(queue, t); }
                        }
                        var parents = vec_new();
                        fsck_collect_commit_parents(body, body_len, parents);
                        var pi = 0;
                        while (pi < vec_len(parents)) {
                            var p = vec_get(parents, pi);
                            if (map_has(seen, p) == 0) { vec_push(queue, p); }
                            pi = pi + 1;
                        }
                    }
                }
                if (blen >= 5) {
                    if (memeq(buf, "tree ", 5) == 1) {
                        var entries = parse_tree(body, body_len);
                        var en = vec_len(entries);
                        var ei = 0;
                        while (ei < en) {
                            var e = vec_get(entries, ei);
                            var ehash = tree_entry_hash(e);
                            if (map_has(seen, ehash) == 0) {
                                var ec = alloc(65);
                                memcpy(ec, ehash, 64);
                                store8(ec + 64, 0);
                                vec_push(queue, ec);
                            }
                            ei = ei + 1;
                        }
                    }
                }
                # blob: leaf — no further enqueue.
            }
        }
    }
    return 0;
}

# Map the patra `ty` INT back to the canonical word for dangling
# output. Returns 0 if unknown — caller falls back to "object".
fn fsck_ty_word(ty) {
    if (ty == 0) { return "blob"; }
    if (ty == 1) { return "tree"; }
    if (ty == 2) { return "commit"; }
    return 0;
}

# fsck — integrity + reachability.
#
# Integrity pass: SELECT every (hash, ty) from .sit/objects.patra; for
# each, read+decompress and sigil-rehash the framed body against the
# stored hex. Mismatch / unreadable rows are emitted on stderr and
# count toward `bad`.
#
# Reachability pass (v0.8.5): collect roots from refs/heads/tags/remotes
# + detached HEAD + every staged index entry; BFS the object graph
# from each root marking `seen`; any object in the integrity inventory
# that isn't in `seen` is dangling. Dangling objects are reported on
# stdout one per line in `dangling <type> <hex>` format (git-shaped);
# they don't fail the command — only integrity errors set non-zero
# exit, mirroring git's policy that dangling objects are expected
# after resets / rewinds.
# Delete a single object row by hex (v0.8.14, fsck --prune). The hex is
# validated 64-char hex before interpolation — even though it comes from the
# inventory SELECT, never build SQL from unchecked bytes. Returns patra_exec's
# code (0 = ok), or -1 if the hex fails validation.
fn db_object_delete(db, hex) {
    if (hex_prefix_valid(hex, 64) == 0) { return 0 - 1; }
    var sql = alloc(128);
    memcpy(sql, "DELETE FROM objects WHERE hash = '", 34);
    memcpy(sql + 34, hex, 64);
    memcpy(sql + 34 + 64, "'", 1);
    store8(sql + 34 + 64 + 1, 0);
    return patra_exec(db, sql);
}

fn cmd_fsck() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    # v0.8.14: `--prune` removes the dangling (unreachable) objects this walk
    # identifies. Immediate + unrecoverable (sit has no reflog yet — matches
    # `git gc --prune=now`, not git's default 2-week grace). Refused while a
    # merge is in progress so a half-finished op's objects can't be dropped.
    var prune = 0;
    var ai = 2;
    while (ai < argc()) {
        if (streq(argv(ai), "--prune") == 1) { prune = 1; }
        ai = ai + 1;
    }
    if (prune == 1) {
        if (file_exists(".sit/MERGE_HEAD") == 1) {
            eprintln("sit: refusing --prune during an in-progress merge (.sit/MERGE_HEAD present)");
            return 1;
        }
    }

    var db = get_object_db();
    if (db == 0) {
        stdout_write("checked 0 objects, 0 bad, 0 dangling\n", 37);
        return 0;
    }

    # Integrity pass. v0.8.5: pull `ty` alongside `hash` so the
    # reachability report can emit `dangling <type> <hex>` without a
    # second read per dangling object.
    var rs = patra_query(db, "SELECT hash, ty FROM objects");
    var total = 0;
    var bad = 0;
    var hashes = vec_new();
    var ty_map = map_new();
    if (rs != 0) {
        var count = patra_result_count(rs);
        var i = 0;
        while (i < count) {
            var s = patra_result_get_str(rs, i, 0);
            var ty = patra_result_get_int(rs, i, 1);
            var copy = alloc_or_die(65);
            memcpy(copy, s, 64);
            store8(copy + 64, 0);
            vec_push(hashes, copy);
            map_set(ty_map, copy, ty + 1);
            i = i + 1;
        }
        patra_result_free(rs);
    }

    var hn = vec_len(hashes);
    var hi = 0;
    while (hi < hn) {
        var hex = vec_get(hashes, hi);
        var obj[24];
        if (read_object(hex, &obj) == 0) {
            var buf = load64(&obj);
            var blen = load64(&obj + 8);
            var actual = hash_data(buf, blen);
            if (streq(hex, actual) == 0) {
                syscall(SYS_WRITE, STDERR, "bad object ", 11);
                syscall(SYS_WRITE, STDERR, hex, 64);
                syscall(SYS_WRITE, STDERR, "\n", 1);
                bad = bad + 1;
            }
            total = total + 1;
        }
        else {
            syscall(SYS_WRITE, STDERR, "unreadable ", 11);
            syscall(SYS_WRITE, STDERR, hex, 64);
            syscall(SYS_WRITE, STDERR, "\n", 1);
            bad = bad + 1;
        }
        hi = hi + 1;
    }

    # Reachability pass (v0.8.5).
    var seen = map_new();
    var roots = fsck_collect_roots();
    var ri = 0;
    while (ri < vec_len(roots)) {
        fsck_walk_reachable(vec_get(roots, ri), seen);
        ri = ri + 1;
    }

    # Staged blobs count as roots — without this, every `sit add` that
    # hasn't been committed yet would look dangling. (Mirrors git's
    # implicit-keep of `git ls-files` blobs during fsck.)
    var idx_entries = parse_index();
    if (idx_entries != 0) {
        var ii = 0;
        while (ii < vec_len(idx_entries)) {
            var e = vec_get(idx_entries, ii);
            var bin = entry_hash(e);
            var ihex = hex_encode(bin, 32);
            if (map_has(seen, ihex) == 0) { map_set(seen, ihex, 1); }
            ii = ii + 1;
        }
    }

    # Diff: objects in the inventory but not reachable.
    var dangling = 0;
    var dangling_hexes = vec_new();
    var di = 0;
    while (di < hn) {
        var hex2 = vec_get(hashes, di);
        if (map_has(seen, hex2) == 0) {
            var stored = map_get(ty_map, hex2);
            var ty_word = 0;
            if (stored > 0) { ty_word = fsck_ty_word(stored - 1); }
            if (ty_word == 0) { ty_word = "object"; }
            stdout_write("dangling ", 9);
            stdout_write(ty_word, strlen(ty_word));
            stdout_write(" ", 1);
            stdout_write(hex2, 64);
            stdout_write("\n", 1);
            dangling = dangling + 1;
            vec_push(dangling_hexes, hex2);
        }
        di = di + 1;
    }

    stdout_write("checked ", 8);
    write_unsigned(total);
    stdout_write(" objects, ", 10);
    write_unsigned(bad);
    stdout_write(" bad, ", 6);
    write_unsigned(dangling);
    stdout_write(" dangling\n", 10);

    # v0.8.14: prune the dangling set. Deletes each unreachable object, then
    # flushes (the main trailer only flushes stdout, not patra) so the removal
    # is durable across the process exit. Reachable history is untouched —
    # only objects absent from the reachability walk are removed.
    if (prune == 1) {
        # Data-loss guard: the reachability walk SKIPS unreadable objects
        # (read_object failure → its children are never enqueued), so a single
        # corrupt interior commit/tree would orphan its whole subgraph into the
        # dangling set. Pruning then deletes genuinely-reachable objects with no
        # reflog to recover them. Refuse while any object is bad/unreadable.
        if (bad > 0) {
            eprintln("sit: refusing --prune with bad/unreadable objects — resolve integrity first");
            return 1;
        }
        # If EVERY object is unreachable, the roots are almost certainly broken
        # (corrupt / missing HEAD or refs), not the objects. Pruning would wipe
        # the whole store. Refuse.
        if (total > 0) {
            if (dangling == total) {
                eprintln("sit: refusing --prune — every object is unreachable (corrupt or missing HEAD/refs?)");
                return 1;
            }
        }
        var pruned = 0;
        var pi = 0;
        while (pi < vec_len(dangling_hexes)) {
            if (db_object_delete(db, vec_get(dangling_hexes, pi)) == 0) {
                pruned = pruned + 1;
            }
            pi = pi + 1;
        }
        patra_flush(db);
        stdout_write("pruned ", 7);
        write_unsigned(pruned);
        stdout_write(" objects\n", 9);
    }

    if (bad > 0) { return 1; }
    return 0;
}

fn hash_blob_of_content(content, content_len) {
    var full_cap = 32 + content_len;
    var full = alloc_or_die(full_cap);
    memcpy(full, "blob ", 5);
    var digits = write_decimal(full + 5, content_len);
    store8(full + 5 + digits, 0);
    var hdr_len = 5 + digits + 1;
    memcpy(full + hdr_len, content, content_len);
    return hash_data(full, hdr_len + content_len);
}

# Read a regular file into a heap buffer. Stores (buf_ptr, len) to out_pair.
# Returns 0 on success, negative on error.
fn hash_file_as_blob(path) {
    var pair[16];
    if (read_file_heap(path, &pair) != 0) { return 0; }
    return hash_blob_of_content(load64(&pair), load64(&pair + 8));
}

# Tree entry layout (24 bytes):
#   0..8:   mode ptr (heap cstring, e.g. "100644")
#   8..16:  name ptr (heap cstring)
#   16..24: hash_hex ptr (heap cstring, 64 chars + null)

# --- index.cyr ---

# index.cyr — staging index + .sitignore + cmd_add / cmd_rm / cmd_reset.
#
# Patra-backed index at .sit/index.patra. Git-parity `.sitignore` (v0.8.10):
# `*` / `?` / `[...]` char classes, `**` multi-segment wildcard, `!` negation
# (last match wins), and leading/middle `/` anchoring. See _wildmatch /
# is_ignored / load_sitignore below.

fn cmd_add() {
    if (argc() < 3) {
        eprintln("usage: sit add [-f] <path>");
        return 1;
    }

    var forced = 0;
    var arg_idx = 2;
    if (streq(argv(2), "-f") == 1) {
        forced = 1;
        arg_idx = 3;
        if (argc() < 4) {
            eprintln("usage: sit add -f <path>");
            return 1;
        }
    }
    var path = argv_heap(arg_idx);
    var path_len = strlen(path);

    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    if (forced == 0) {
        var patterns = load_sitignore();
        if (is_ignored(path, patterns) == 1) {
            syscall(SYS_WRITE, STDERR, "sit: '", 6);
            syscall(SYS_WRITE, STDERR, path, path_len);
            syscall(SYS_WRITE, STDERR, "' matches a .sitignore pattern (use -f to override)\n", 52);
            return 1;
        }
    }

    var fd = file_open(path, 0, 0);
    if (fd < 0) {
        syscall(SYS_WRITE, STDERR, "sit: cannot open '", 18);
        syscall(SYS_WRITE, STDERR, path, path_len);
        syscall(SYS_WRITE, STDERR, "'\n", 2);
        return 1;
    }
    var size = syscall(SYS_LSEEK, fd, 0, SEEK_END);
    syscall(SYS_LSEEK, fd, 0, SEEK_SET);
    if (size < 0) {
        file_close(fd);
        eprintln("sit: cannot stat file");
        return 1;
    }
    # S-06: cap single-blob add at 1 GiB to prevent OOM from `sit add /dev/zero`
    # or symlinked-to-huge-file. Real-world source files don't approach this.
    if (size > 1073741824) {
        file_close(fd);
        eprintln("sit: file too large (> 1 GiB)");
        return 1;
    }

    var content = alloc(size);
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var r = file_read(fd, content + total, size - total);
        if (r <= 0) { rgo = 0; }
        else { total = total + r; if (total >= size) { rgo = 0; } }
    }
    file_close(fd);

    var hex = write_blob_object(content, total);
    if (hex == 0) {
        eprintln("sit: failed to write object");
        return 1;
    }

    if (index_upsert(hex, path) != 0) {
        eprintln("sit: failed to update index");
        return 1;
    }

    stdout_write("added ", 6);
    stdout_write(hex, 12);
    stdout_write(" ", 1);
    stdout_write(path, path_len);
    stdout_write("\n", 1);
    return 0;
}

# Common setup for read-side commands: parse prefix, resolve to full hash,
# read+decompress. On success: writes 24-byte struct to obj_out, returns 0.
# On error: emits message to stderr and returns non-zero for main to return.
fn index_db_open() {
    patra_init();
    var db = patra_open(".sit/index.patra");
    if (db == 0) { return 0; }
    # Idempotent — second call returns "already exists", which we ignore.
    patra_exec(db, "CREATE TABLE entries (path STR, hash_hex STR)");
    return db;
}

# v0.6.4: process-wide cache for .sit/index.patra. Same pattern as
# get_object_db (object_db.cyr). Lazy-open + lazy-migrate-from-plaintext.
var _index_db_cached = 0;

fn get_index_db() {
    if (_index_db_cached != 0) { return _index_db_cached; }
    _index_db_cached = index_db_open();
    if (_index_db_cached == 0) { return 0; }
    # v0.6.10 — see get_object_db (object_db.cyr) for the BATCH-mode revert
    # rationale. Same shape: cache never closes, so BATCH-pending writes
    # would be lost on power loss before the every-64-writes auto-flush.
    index_migrate_from_plaintext(_index_db_cached);
    return _index_db_cached;
}

# Migrate legacy plaintext .sit/index (v0.1 format) into the patra table.
# No-op if the plaintext file is absent. Deletes it on successful migration.
fn index_migrate_from_plaintext(db) {
    if (file_exists(".sit/index") != 1) { return 0; }
    var pair[16];
    if (read_file_heap(".sit/index", &pair) != 0) { return 0; }
    var data = load64(&pair);
    var len = load64(&pair + 8);

    var pos = 0;
    while (pos < len) {
        if (pos + 65 > len) { pos = len; }
        else {
            if (load8(data + pos + 64) != 9) { pos = len; }
            else {
                var nl = pos + 65;
                while (nl < len) {
                    if (load8(data + nl) == 10) { break; }
                    nl = nl + 1;
                }
                var plen = nl - pos - 65;
                # S-22: refuse multi-megabyte path lines (a malformed legacy
                # index could otherwise force a single huge alloc on migrate).
                # Real paths fit in a few hundred bytes; 4096 leaves headroom
                # for deep nested cases without paying for a malicious blob.
                if (plen > 4096) { pos = len; }
                else {

                var hash_copy = alloc(65);
                memcpy(hash_copy, data + pos, 64);
                store8(hash_copy + 64, 0);
                var path_copy = alloc(plen + 1);
                memcpy(path_copy, data + pos + 65, plen);
                store8(path_copy + plen, 0);

                var types[16];
                store64(&types + 0, 1);
                store64(&types + 8, 1);
                var ivals[16];
                var sptrs[16];
                store64(&sptrs + 0, path_copy);
                store64(&sptrs + 8, hash_copy);
                var slens[16];
                store64(&slens + 0, plen);
                store64(&slens + 8, 64);
                var bptrs[16];
                var blens[16];
                patra_insert_row(db, "entries", 7, 2,
                    &types, &ivals, &sptrs, &slens, &bptrs, &blens);

                pos = nl + 1;
                }
            }
        }
    }
    sys_unlink(".sit/index");
    return 0;
}

# Rewrite the staging index to exactly the given entries. DELETE + insert all.
fn rewrite_index(entries) {
    var db = get_index_db();
    if (db == 0) { return 0 - 1; }
    patra_exec(db, "DELETE FROM entries");

    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        var path = entry_path(e);
        var hash_hex = hex_encode(entry_hash(e), 32);

        var types[16];
        store64(&types + 0, 1);
        store64(&types + 8, 1);
        var ivals[16];
        var sptrs[16];
        store64(&sptrs + 0, path);
        store64(&sptrs + 8, hash_hex);
        var slens[16];
        store64(&slens + 0, strlen(path));
        store64(&slens + 8, 64);
        var bptrs[16];
        var blens[16];
        patra_insert_row(db, "entries", 7, 2,
            &types, &ivals, &sptrs, &slens, &bptrs, &blens);
        i = i + 1;
    }
    return 0;
}

# Upsert a single (hash, path) entry — replaces any existing row for that path.
# Used by `sit add` to stage a file.
fn index_upsert(hash_hex, path) {
    var existing = parse_index();
    var filtered = vec_new();
    if (existing != 0) {
        var n = vec_len(existing);
        var i = 0;
        while (i < n) {
            var e = vec_get(existing, i);
            if (streq(entry_path(e), path) == 0) { vec_push(filtered, e); }
            i = i + 1;
        }
    }

    var bytes = hex_decode(hash_hex, 64);
    if (bytes == 0) { return 0 - 1; }
    var new_e = alloc(40);
    memcpy(new_e, bytes, 32);
    var plen = strlen(path);
    var path_copy = alloc(plen + 1);
    memcpy(path_copy, path, plen);
    store8(path_copy + plen, 0);
    store64(new_e + 32, path_copy);
    vec_push(filtered, new_e);

    return rewrite_index(filtered);
}

# Staging entry layout (40 bytes):
#   0..32:  raw hash bytes (SHA-256, decoded from the hex in .sit/index)
#   32..40: path ptr (heap, null-terminated)
fn entry_hash(e) { return e; }
fn entry_path(e) { return load64(e + 32); }

# Load staging index from .sit/index.patra. Returns vec of entries or 0.
# Auto-migrates plaintext .sit/index from v0.1 layout if present.
fn parse_index() {
    # Nothing to load if neither file exists
    if (file_exists(".sit/index.patra") != 1) {
        if (file_exists(".sit/index") != 1) { return 0; }
    }

    var db = get_index_db();
    if (db == 0) { return 0; }

    # P-20 (v0.6.11): pre-sort at the patra layer so sort_entries can fall
    # through O(N) on the already-ordered vec. Patra supports ORDER BY since
    # at least 1.6.0; passing it here lets every parse_index consumer skip
    # the O(N²) insertion sort below.
    var rs = patra_query(db, "SELECT path, hash_hex FROM entries ORDER BY path");
    if (rs == 0) { return 0; }

    var count = patra_result_count(rs);
    if (count == 0) {
        patra_result_free(rs);
        return 0;
    }

    var entries = vec_new();
    var i = 0;
    while (i < count) {
        var path_str = patra_result_get_str(rs, i, 0);
        var hash_str = patra_result_get_str(rs, i, 1);

        var bytes = hex_decode(hash_str, 64);
        if (bytes != 0) {
            var entry = alloc(40);
            memcpy(entry, bytes, 32);
            # S-31 RESOLVED in v0.6.10: patra 1.6.1 shipped a sized accessor
            # `patra_result_get_str_len` that bound-walks within the
            # COL_STR_SZ slot. Replaces the v0.6.3 strnlen(path_str, 256)
            # workaround — same safety property at the read site, but now
            # asked of patra's API directly instead of guarded in sit.
            var plen = patra_result_get_str_len(rs, i, 0);
            var p = alloc(plen + 1);
            memcpy(p, path_str, plen);
            store8(p + plen, 0);
            store64(entry + 32, p);
            vec_push(entries, entry);
        }
        i = i + 1;
    }

    patra_result_free(rs);
    if (vec_len(entries) == 0) { return 0; }
    return entries;
}

# Byte-wise compare two null-terminated C strings. Returns -1/0/+1.
# Insertion-sort entries vec by path name (ascending). In place.
fn sort_entries(entries) {
    var n = vec_len(entries);
    var i = 1;
    while (i < n) {
        var cur = vec_get(entries, i);
        var cur_path = entry_path(cur);
        var j = i - 1;
        var placed = 0;
        while (placed == 0) {
            if (j < 0) { placed = 1; }
            else {
                var prev = vec_get(entries, j);
                if (strcmp_cstr(cur_path, entry_path(prev)) >= 0) { placed = 1; }
                else {
                    vec_set(entries, j + 1, prev);
                    j = j - 1;
                }
            }
        }
        vec_set(entries, j + 1, cur);
        i = i + 1;
    }
    return entries;
}

# After sorting, keep only the last entry for each path (staged-twice wins).
fn dedupe_entries(entries) {
    var n = vec_len(entries);
    var out = vec_new();
    var i = 0;
    while (i < n) {
        var cur = vec_get(entries, i);
        var is_last = 1;
        if (i + 1 < n) {
            var nxt = vec_get(entries, i + 1);
            if (strcmp_cstr(entry_path(cur), entry_path(nxt)) == 0) { is_last = 0; }
        }
        if (is_last == 1) { vec_push(out, cur); }
        i = i + 1;
    }
    return out;
}

# Internal tree-level entry (24 bytes):
#   0..8:   mode ptr ("100644" for files, "40000" for dirs)
#   8..16:  name ptr (heap, null-term; leaf name only)
#   16..24: hash bytes ptr (heap, 32 raw bytes)
fn cmd_reset() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }
    if (argc() < 3) {
        eprintln("usage: sit reset <path> | sit reset --hard <ref>");
        return 1;
    }

    # --hard <ref>: move current branch ref to <ref>, overwrite working + index.
    if (streq(argv(2), "--hard") == 1) {
        if (argc() < 4) {
            eprintln("usage: sit reset --hard <ref>");
            return 1;
        }
        var target = argv_heap(3);
        var hex[72];
        var rr = resolve_hash(target, &hex);
        if (rr != 1) {
            syscall(SYS_WRITE, STDERR, "sit: cannot resolve '", 21);
            syscall(SYS_WRITE, STDERR, target, strlen(target));
            syscall(SYS_WRITE, STDERR, "'\n", 2);
            return 1;
        }
        if (write_head_ref(&hex) != 0) {
            eprintln("sit: failed to update branch ref");
            return 1;
        }
        materialize_target(&hex);
        stdout_write("HEAD reset --hard to ", 21);
        stdout_write(&hex, 12);
        stdout_write("\n", 1);
        return 0;
    }

    # sit reset <path>: unstage the path — set its index entry to HEAD's hash,
    # or remove it from the index if HEAD doesn't have it.
    var path = argv_heap(2);
    var path_len = strlen(path);

    var head_entries = read_head_tree_entries();
    var head_ent = tree_find(head_entries, path);

    var index_entries = parse_index();
    if (index_entries != 0) {
        sort_entries(index_entries);
        index_entries = dedupe_entries(index_entries);
    }

    var filtered = vec_new();
    if (index_entries != 0) {
        var n = vec_len(index_entries);
        var i = 0;
        while (i < n) {
            var e = vec_get(index_entries, i);
            if (streq(entry_path(e), path) == 0) { vec_push(filtered, e); }
            i = i + 1;
        }
    }

    if (head_ent != 0) {
        var head_hash_hex = tree_entry_hash(head_ent);
        var bytes = hex_decode(head_hash_hex, 64);
        if (bytes != 0) {
            var new_e = alloc(40);
            memcpy(new_e, bytes, 32);
            var pcopy = alloc(path_len + 1);
            memcpy(pcopy, path, path_len);
            store8(pcopy + path_len, 0);
            store64(new_e + 32, pcopy);
            vec_push(filtered, new_e);
        }
    }

    if (rewrite_index(filtered) != 0) {
        eprintln("sit: failed to update index");
        return 1;
    }
    stdout_write("unstaged '", 10);
    stdout_write(path, path_len);
    stdout_write("'\n", 2);
    return 0;
}

fn cmd_rm() {
    if (argc() < 3) {
        eprintln("usage: sit rm [--cached] <path>");
        return 1;
    }
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    var cached = 0;
    var arg_idx = 2;
    if (streq(argv(2), "--cached") == 1) {
        cached = 1;
        arg_idx = 3;
        if (argc() < 4) {
            eprintln("usage: sit rm --cached <path>");
            return 1;
        }
    }
    var path = argv_heap(arg_idx);
    var path_len = strlen(path);

    var index_entries = parse_index();
    if (index_entries != 0) {
        sort_entries(index_entries);
        index_entries = dedupe_entries(index_entries);
    }

    var head_entries = read_head_tree_entries();

    var in_index = 0;
    if (index_entries != 0) {
        if (index_find(index_entries, path) != 0) { in_index = 1; }
    }
    var in_head = 0;
    if (tree_find(head_entries, path) != 0) { in_head = 1; }

    if (in_index == 0) {
        if (in_head == 0) {
            syscall(SYS_WRITE, STDERR, "sit: '", 6);
            syscall(SYS_WRITE, STDERR, path, path_len);
            syscall(SYS_WRITE, STDERR, "' is not tracked\n", 17);
            return 1;
        }
    }

    if (index_entries != 0) {
        var filtered = vec_new();
        var n = vec_len(index_entries);
        var i = 0;
        while (i < n) {
            var e = vec_get(index_entries, i);
            if (streq(entry_path(e), path) == 0) { vec_push(filtered, e); }
            i = i + 1;
        }
        if (rewrite_index(filtered) != 0) {
            eprintln("sit: failed to rewrite index");
            return 1;
        }
    }

    if (cached == 0) {
        if (file_exists(path) == 1) {
            if (sys_unlink(path) != 0) {
                syscall(SYS_WRITE, STDERR, "sit: failed to remove '", 23);
                syscall(SYS_WRITE, STDERR, path, path_len);
                syscall(SYS_WRITE, STDERR, "'\n", 2);
                return 1;
            }
        }
    }

    stdout_write("rm '", 4);
    stdout_write(path, path_len);
    stdout_write("'\n", 2);
    return 0;
}

fn index_find(entries, path) {
    if (entries == 0) { return 0; }
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        if (streq(entry_path(e), path) == 1) { return e; }
        i = i + 1;
    }
    return 0;
}

# gitignore-style wildmatch (v0.8.10 — WM_PATHNAME semantics):
#   '*'     a run of non-'/' chars
#   '?'     one non-'/' char
#   '[...]' a char class for one non-'/' char ('!' negates; 'a-z' ranges;
#           a leading ']' is a literal member)
#   '**'    (two+ stars) a run that MAY cross '/'; a following '/' allows zero
#           dirs, so '**/foo' matches 'foo' at any depth and '/**/' collapses
#   '/'     a literal separator
# Trailing match also succeeds at a '/' boundary in str — directory exclusion:
# 'foo/bar' matches 'foo/bar/baz'. Pattern length capped (S-15) against crafted
# '*'-heavy patterns forcing exponential backtracking.
#
# Simplification vs git: any '**' crosses '/', even when not a whole path
# segment (git only crosses for a segment-bounded '**'). 'a**b' is vanishingly
# rare in real ignore files; the segment cases ('**/x', 'x/**', 'a/**/b') are
# exact.
var _GLOB_PAT_MAX = 256;

fn _wildmatch(pat, plen, str, slen) {
    if (plen > _GLOB_PAT_MAX) { return 0; }
    if (plen == 0) {
        if (slen == 0) { return 1; }
        if ((load8(str) & 0xFF) == 47) { return 1; }   # dir-exclusion
        return 0;
    }
    var pc = load8(pat) & 0xFF;

    if (pc == 42) {   # '*'
        var nstar = 0;
        var counting = 1;
        while (counting == 1) {
            if (nstar < plen) {
                if ((load8(pat + nstar) & 0xFF) == 42) { nstar = nstar + 1; }
                else { counting = 0; }
            }
            else { counting = 0; }
        }
        var rest = pat + nstar;
        var restlen = plen - nstar;
        if (nstar >= 2) {                       # '**' — may cross '/'
            if (restlen == 0) { return 1; }
            if ((load8(rest) & 0xFF) == 47) {   # '**/...' may match zero dirs
                if (_wildmatch(rest + 1, restlen - 1, str, slen) == 1) { return 1; }
            }
            var m = 0;
            var res = 0;
            var done = 0;
            while (done == 0) {
                if (_wildmatch(rest, restlen, str + m, slen - m) == 1) { res = 1; done = 1; }
                else {
                    if (m >= slen) { done = 1; }
                    else { m = m + 1; }
                }
            }
            return res;
        }
        # single '*' — run of non-'/'
        if (_wildmatch(rest, restlen, str, slen) == 1) { return 1; }
        if (slen == 0) { return 0; }
        if ((load8(str) & 0xFF) == 47) { return 0; }
        return _wildmatch(pat, plen, str + 1, slen - 1);
    }

    if (pc == 47) {   # '/'
        if (slen == 0) { return 0; }
        if ((load8(str) & 0xFF) != 47) { return 0; }
        return _wildmatch(pat + 1, plen - 1, str + 1, slen - 1);
    }

    if (slen == 0) { return 0; }
    var sc = load8(str) & 0xFF;

    if (pc == 63) {   # '?'
        if (sc == 47) { return 0; }
        return _wildmatch(pat + 1, plen - 1, str + 1, slen - 1);
    }

    if (pc == 91) {   # '[' char class
        if (sc == 47) { return 0; }
        var ci = 1;
        var negate = 0;
        if (ci < plen) {
            if ((load8(pat + ci) & 0xFF) == 33) { negate = 1; ci = ci + 1; }
        }
        var matched = 0;
        var first = 1;
        var closed = 0;
        var bad = 0;
        while (closed == 0) {
            if (ci >= plen) { bad = 1; closed = 1; }   # unterminated class
            else {
                var cc = load8(pat + ci) & 0xFF;
                if (cc == 93) {                        # ']'
                    if (first == 1) {                  # literal ']' as first member
                        if (sc == 93) { matched = 1; }
                        ci = ci + 1;
                        first = 0;
                    }
                    else { closed = 1; ci = ci + 1; }
                }
                else {
                    first = 0;
                    var is_range = 0;
                    if (ci + 2 < plen) {
                        if ((load8(pat + ci + 1) & 0xFF) == 45) {
                            if ((load8(pat + ci + 2) & 0xFF) != 93) { is_range = 1; }
                        }
                    }
                    if (is_range == 1) {
                        var lo = cc;
                        var hi = load8(pat + ci + 2) & 0xFF;
                        if (sc >= lo) { if (sc <= hi) { matched = 1; } }
                        ci = ci + 3;
                    }
                    else {
                        if (sc == cc) { matched = 1; }
                        ci = ci + 1;
                    }
                }
            }
        }
        if (bad == 1) { return 0; }
        var ok = matched;
        if (negate == 1) {
            if (matched == 1) { ok = 0; }
            else { ok = 1; }
        }
        if (ok == 0) { return 0; }
        return _wildmatch(pat + ci, plen - ci, str + 1, slen - 1);
    }

    if (pc != sc) { return 0; }
    return _wildmatch(pat + 1, plen - 1, str + 1, slen - 1);
}

# True if `path` (repo-relative, e.g. "src/build/foo.o") is ignored. Patterns are
# evaluated IN ORDER and the LAST matching pattern wins — so a later `!pattern`
# re-includes a file an earlier pattern excluded (git semantics). Each pattern is
# a struct: [text, text_len, negated, anchored] (see load_sitignore).
#
#   anchored (pattern had a leading or middle '/'): matched against the full path
#     from the repo root via _wildmatch (its '**' handles any-depth cases).
#   non-anchored (no '/'): matches at ANY level — tried against the full path and
#     against every suffix beginning just after a '/'.
fn is_ignored(path, patterns) {
    if (patterns == 0) { return 0; }
    var path_len = strlen(path);
    var n = vec_len(patterns);
    var i = 0;
    var result = 0;   # 0 = not ignored; the last matching pattern overwrites this
    while (i < n) {
        var p = vec_get(patterns, i);
        var text = load64(p);
        var tlen = load64(p + 8);
        var negated = load64(p + 16);
        var anchored = load64(p + 24);

        var m = 0;
        if (anchored == 1) {
            m = _wildmatch(text, tlen, path, path_len);
        }
        else {
            if (_wildmatch(text, tlen, path, path_len) == 1) { m = 1; }
            else {
                var k = 0;
                while (k < path_len) {
                    if (load8(path + k) == 47) {
                        if (_wildmatch(text, tlen, path + k + 1, path_len - k - 1) == 1) {
                            m = 1;
                            k = path_len;
                        }
                    }
                    if (k < path_len) { k = k + 1; }
                }
            }
        }

        if (m == 1) {
            if (negated == 1) { result = 0; }
            else { result = 1; }
        }
        i = i + 1;
    }
    return result;
}

# Read `.sitignore` into a vec of pattern structs (32 bytes each):
#   [0]  text ptr (NUL-terminated, with leading `!` / leading `/` / trailing `/`
#        stripped), [8] text_len, [16] negated (leading `!`), [24] anchored
#        (leading or middle `/` → matched from the repo root).
# Blank lines and `#` comments are skipped; `\!` / `\#` escape a literal first
# char; a trailing `/` (directory hint) is stripped (dir-only is not enforced —
# the same simplification as before).
fn load_sitignore() {
    if (file_exists(".sitignore") != 1) { return 0; }
    var pair[16];
    if (read_file_heap(".sitignore", &pair) != 0) { return 0; }
    var data = load64(&pair);
    var len = load64(&pair + 8);

    var patterns = vec_new();
    var pos = 0;
    while (pos < len) {
        var line_end = pos;
        while (line_end < len) {
            if (load8(data + line_end) == 10) { break; }
            line_end = line_end + 1;
        }

        var ls = pos;
        var le = line_end;
        if (le > ls) {
            if (load8(data + le - 1) == 13) { le = le - 1; }   # strip CR
        }

        var keep = 1;
        if (le == ls) { keep = 0; }                            # blank line
        else {
            if (load8(data + ls) == 35) { keep = 0; }          # '#' comment
        }

        if (keep == 1) {
            var s = ls;
            var negated = 0;
            var c0 = load8(data + s) & 0xFF;
            if (c0 == 33) { negated = 1; s = s + 1; }           # leading '!'
            else {
                if (c0 == 92) {                                 # '\' escape
                    if (s + 1 < le) {
                        var nx = load8(data + s + 1) & 0xFF;
                        if (nx == 33) { s = s + 1; }             # '\!' -> literal '!'
                        else {
                            if (nx == 35) { s = s + 1; }         # '\#' -> literal '#'
                        }
                    }
                }
            }

            var anchored = 0;
            if (s < le) {
                if (load8(data + s) == 47) { anchored = 1; s = s + 1; }   # leading '/'
            }
            var e = le;
            if (e > s) {
                if (load8(data + e - 1) == 47) { e = e - 1; }   # strip trailing '/'
            }
            if (anchored == 0) {
                var k = s;
                while (k < e) {
                    if (load8(data + k) == 47) { anchored = 1; k = e; }   # middle '/'
                    else { k = k + 1; }
                }
            }

            var tlen = e - s;
            if (tlen > 0) {
                var text = alloc(tlen + 1);
                memcpy(text, data + s, tlen);
                store8(text + tlen, 0);
                var p = alloc(32);
                store64(p, text);
                store64(p + 8, tlen);
                store64(p + 16, negated);
                store64(p + 24, anchored);
                vec_push(patterns, p);
            }
        }
        pos = line_end + 1;
    }
    return patterns;
}

# Recursive working-dir walker. Entries are pushed as full repo-relative
# paths ("src/main.cyr"). Hardcoded skip: `.sit/`. Everything else is
# included unless it matches a `.sitignore` pattern.

# --- refs.cyr ---

# refs.cyr — HEAD / branch / tag / resolution.
#
# Refs live at .sit/HEAD (symbolic), .sit/refs/heads/<name>, .sit/refs/tags/<name>,
# and .sit/refs/remotes/<remote>/<name>. ensure_parent_dirs (util.cyr) is called
# by every write path so nested names like feature/foo work.

fn resolve_ref_name(name, out_buf) {
    if (streq(name, "HEAD") == 1) {
        var h = read_head_ref();
        if (h == 0) { return 0; }
        memcpy(out_buf, h, 64);
        store8(out_buf + 64, 0);
        return 1;
    }

    var name_len = strlen(name);

    var tag_path = alloc(15 + name_len + 1);
    memcpy(tag_path, ".sit/refs/tags/", 15);
    memcpy(tag_path + 15, name, name_len);
    store8(tag_path + 15 + name_len, 0);
    # S-11: all three ref-file readers below validate that the first 64 bytes
    # are actual hex before accepting. A garbage or attacker-crafted ref is
    # treated as "no such ref" rather than flowed through as a "hash".
    if (file_exists(tag_path) == 1) {
        var tfd = file_open(tag_path, 0, 0);
        if (tfd >= 0) {
            var tbuf = alloc(80);
            var tn = file_read(tfd, tbuf, 80);
            file_close(tfd);
            if (tn >= 64) {
                if (hex_prefix_valid(tbuf, 64) == 1) {
                    memcpy(out_buf, tbuf, 64);
                    store8(out_buf + 64, 0);
                    return 1;
                }
            }
        }
    }

    var head_path = alloc(16 + name_len + 1);
    memcpy(head_path, ".sit/refs/heads/", 16);
    memcpy(head_path + 16, name, name_len);
    store8(head_path + 16 + name_len, 0);
    if (file_exists(head_path) == 1) {
        var hfd = file_open(head_path, 0, 0);
        if (hfd >= 0) {
            var hbuf = alloc(80);
            var hn = file_read(hfd, hbuf, 80);
            file_close(hfd);
            if (hn >= 64) {
                if (hex_prefix_valid(hbuf, 64) == 1) {
                    memcpy(out_buf, hbuf, 64);
                    store8(out_buf + 64, 0);
                    return 1;
                }
            }
        }
    }

    # Remote-tracking ref (e.g. "origin/main" → .sit/refs/remotes/origin/main)
    var rem_path = alloc(18 + name_len + 1);
    memcpy(rem_path, ".sit/refs/remotes/", 18);
    memcpy(rem_path + 18, name, name_len);
    store8(rem_path + 18 + name_len, 0);
    if (file_exists(rem_path) == 1) {
        var rfd = file_open(rem_path, 0, 0);
        if (rfd >= 0) {
            var rbuf = alloc(80);
            var rn = file_read(rfd, rbuf, 80);
            file_close(rfd);
            if (rn >= 64) {
                if (hex_prefix_valid(rbuf, 64) == 1) {
                    memcpy(out_buf, rbuf, 64);
                    store8(out_buf + 64, 0);
                    return 1;
                }
            }
        }
    }

    return 0;
}

# Resolve a reference: either a symbolic name (HEAD, tag, branch) or a hex hash
# (full 64 chars or a prefix of 4+). Writes null-terminated hash into out_buf
# (65 bytes) and returns:
#    1  exact match
#    0  no match
#   -1  ambiguous
#   -2  prefix too short
fn read_head_ref_path() {
    var pair[16];
    if (read_file_heap(".sit/HEAD", &pair) != 0) { return 0; }
    var buf = load64(&pair);
    var len = load64(&pair + 8);

    if (len < 5) { return 0; }
    if (memeq(buf, "ref: ", 5) == 0) { return 0; }

    var stop = 5;
    var scanning = 1;
    while (scanning == 1) {
        if (stop >= len) { scanning = 0; }
        else {
            var c = load8(buf + stop);
            if (c == 10) { scanning = 0; }
            else {
                if (c == 13) { scanning = 0; }
                else { stop = stop + 1; }
            }
        }
    }

    var ref_len = stop - 5;
    if (ref_len == 0) { return 0; }

    var ref = alloc(ref_len + 1);
    memcpy(ref, buf + 5, ref_len);
    store8(ref + ref_len, 0);
    return ref;
}

# Read the ref file pointed at by HEAD. Returns 64-char hex or 0.
fn read_head_ref() {
    var ref_path = read_head_ref_path();
    if (ref_path == 0) { return 0; }
    var ref_len = strlen(ref_path);
    var full = alloc(5 + ref_len + 1);
    memcpy(full, ".sit/", 5);
    memcpy(full + 5, ref_path, ref_len);
    store8(full + 5 + ref_len, 0);

    if (file_exists(full) != 1) { return 0; }
    var fd = file_open(full, 0, 0);
    if (fd < 0) { return 0; }
    var buf = alloc(80);
    var n = file_read(fd, buf, 80);
    file_close(fd);
    if (n < 64) { return 0; }
    # S-11: validate the first 64 bytes are actual hex before returning —
    # otherwise a corrupt or hostile ref file flows garbage through the
    # whole stack (and into resolve_hash's LIKE after S-01 rejects it).
    if (hex_prefix_valid(buf, 64) == 0) { return 0; }
    store8(buf + 64, 0);
    return buf;
}

# Write the given 64-char hex to the ref file HEAD points at.
fn write_head_ref(hex) {
    var ref_path = read_head_ref_path();
    if (ref_path == 0) { return 0 - 1; }
    var ref_len = strlen(ref_path);
    var full = alloc(5 + ref_len + 1);
    memcpy(full, ".sit/", 5);
    memcpy(full + 5, ref_path, ref_len);
    store8(full + 5 + ref_len, 0);
    ensure_parent_dirs(full);

    var out = alloc(66);
    memcpy(out, hex, 64);
    store8(out + 64, 10);
    store8(out + 65, 0);
    if (file_write_all(full, out, 65) < 0) { return 0 - 1; }
    return 0;
}

# Extract the branch name from HEAD (e.g. "main" from "refs/heads/main").
# Returns heap cstring or 0 if HEAD isn't a branch ref.
fn current_branch_name() {
    var ref_path = read_head_ref_path();
    if (ref_path == 0) { return 0; }
    var ref_len = strlen(ref_path);
    if (ref_len <= 11) { return ref_path; }
    if (memeq(ref_path, "refs/heads/", 11) == 0) { return ref_path; }
    var name_len = ref_len - 11;
    var name = alloc(name_len + 1);
    memcpy(name, ref_path + 11, name_len);
    store8(name + name_len, 0);
    return name;
}

# Build and write a commit object. Returns hex hash or 0.
fn set_head_ref(ref_path) {
    var rlen = strlen(ref_path);
    var total = 5 + rlen + 1;
    var buf = alloc(total + 1);
    memcpy(buf, "ref: ", 5);
    memcpy(buf + 5, ref_path, rlen);
    store8(buf + 5 + rlen, 10);
    store8(buf + total, 0);
    if (file_write_all(".sit/HEAD", buf, total) < 0) { return 0 - 1; }
    return 0;
}

# Extract hunks from an LCS op-script. A hunk groups consecutive
# non-keep ops (deletes and/or inserts) and records the base line range
# it covers along with the replacement lines from the other side.
#
# Hunk layout (24 bytes):
#   [0..8)   base_start (inclusive base line index)
#   [8..16)  base_end   (exclusive base line index)
#   [16..24) replacement lines vec (each element is a line-tuple pointer)
fn cmd_tag() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    if (argc() < 3) {
        if (file_exists(".sit/refs/tags") != 1) { return 0; }
        var raw = dir_list(str_from(".sit/refs/tags"));
        var names = vec_new();
        var n = vec_len(raw);
        var i = 0;
        while (i < n) {
            var s = vec_get(raw, i);
            var slen = str_len(s);
            var nm = alloc(slen + 1);
            memcpy(nm, str_data(s), slen);
            store8(nm + slen, 0);
            vec_push(names, nm);
            i = i + 1;
        }
        sort_cstrings(names);
        var m = vec_len(names);
        i = 0;
        while (i < m) {
            var nm = vec_get(names, i);
            stdout_write(nm, strlen(nm));
            stdout_write("\n", 1);
            i = i + 1;
        }
        return 0;
    }

    # Deletion: sit tag -d <name>
    if (streq(argv(2), "-d") == 1) {
        if (argc() < 4) {
            eprintln("usage: sit tag -d <name>");
            return 1;
        }
        var dname = argv_heap(3);
        var dnlen = strlen(dname);
        var dpath = alloc(15 + dnlen + 1);
        memcpy(dpath, ".sit/refs/tags/", 15);
        memcpy(dpath + 15, dname, dnlen);
        store8(dpath + 15 + dnlen, 0);
        if (file_exists(dpath) != 1) {
            syscall(SYS_WRITE, STDERR, "sit: tag '", 10);
            syscall(SYS_WRITE, STDERR, dname, dnlen);
            syscall(SYS_WRITE, STDERR, "' not found\n", 12);
            return 1;
        }
        if (sys_unlink(dpath) != 0) {
            eprintln("sit: failed to remove tag ref");
            return 1;
        }
        stdout_write("deleted tag '", 13);
        stdout_write(dname, dnlen);
        stdout_write("'\n", 2);
        return 0;
    }

    var name = argv_heap(2);
    var nlen = strlen(name);
    # S-02: tag names follow the same ref-format grammar as branches.
    if (refname_valid(name) == 0) {
        eprintln("sit: invalid tag name (see git check-ref-format rules)");
        return 1;
    }
    var path = alloc(15 + nlen + 1);
    memcpy(path, ".sit/refs/tags/", 15);
    memcpy(path + 15, name, nlen);
    store8(path + 15 + nlen, 0);

    if (file_exists(path) == 1) {
        syscall(SYS_WRITE, STDERR, "sit: tag '", 10);
        syscall(SYS_WRITE, STDERR, name, nlen);
        syscall(SYS_WRITE, STDERR, "' already exists\n", 17);
        return 1;
    }

    var target_hex = 0;
    if (argc() >= 4) {
        var prefix = argv_heap(3);
        var hex[72];
        var rr = resolve_hash(prefix, &hex);
        if (rr != 1) {
            eprintln("sit: cannot resolve target commit");
            return 1;
        }
        target_hex = alloc(65);
        memcpy(target_hex, &hex, 64);
        store8(target_hex + 64, 0);
    }
    else {
        target_hex = read_head_ref();
        if (target_hex == 0) {
            eprintln("sit: cannot tag with no commits");
            return 1;
        }
    }

    ensure_dir(".sit/refs/tags");
    ensure_parent_dirs(path);

    var buf = alloc(66);
    memcpy(buf, target_hex, 64);
    store8(buf + 64, 10);
    store8(buf + 65, 0);
    if (file_write_all(path, buf, 65) < 0) {
        eprintln("sit: failed to write tag ref");
        return 1;
    }

    stdout_write("created tag '", 13);
    stdout_write(name, nlen);
    stdout_write("'\n", 2);
    return 0;
}

fn cmd_branch() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    if (argc() < 3) {
        if (file_exists(".sit/refs/heads") != 1) { return 0; }
        var raw = dir_list(str_from(".sit/refs/heads"));
        var names = vec_new();
        var n = vec_len(raw);
        var i = 0;
        while (i < n) {
            var s = vec_get(raw, i);
            var slen = str_len(s);
            var nm = alloc(slen + 1);
            memcpy(nm, str_data(s), slen);
            store8(nm + slen, 0);
            vec_push(names, nm);
            i = i + 1;
        }
        sort_cstrings(names);
        var curr = current_branch_name();
        i = 0;
        var m = vec_len(names);
        while (i < m) {
            var nm = vec_get(names, i);
            var is_current = 0;
            if (curr != 0) {
                if (streq(nm, curr) == 1) { is_current = 1; }
            }
            if (is_current == 1) { stdout_write("* ", 2); }
            else                 { stdout_write("  ", 2); }
            stdout_write(nm, strlen(nm));
            stdout_write("\n", 1);
            i = i + 1;
        }
        return 0;
    }

    # Deletion: sit branch -d <name>
    if (streq(argv(2), "-d") == 1) {
        if (argc() < 4) {
            eprintln("usage: sit branch -d <name>");
            return 1;
        }
        var dname = argv_heap(3);
        var dnlen = strlen(dname);
        var dpath = alloc(16 + dnlen + 1);
        memcpy(dpath, ".sit/refs/heads/", 16);
        memcpy(dpath + 16, dname, dnlen);
        store8(dpath + 16 + dnlen, 0);
        if (file_exists(dpath) != 1) {
            syscall(SYS_WRITE, STDERR, "sit: branch '", 13);
            syscall(SYS_WRITE, STDERR, dname, dnlen);
            syscall(SYS_WRITE, STDERR, "' not found\n", 12);
            return 1;
        }
        var curr_br = current_branch_name();
        if (curr_br != 0) {
            if (streq(curr_br, dname) == 1) {
                eprintln("sit: cannot delete the currently checked-out branch");
                return 1;
            }
        }
        if (sys_unlink(dpath) != 0) {
            eprintln("sit: failed to remove branch ref");
            return 1;
        }
        stdout_write("deleted branch '", 16);
        stdout_write(dname, dnlen);
        stdout_write("'\n", 2);
        return 0;
    }

    var name = argv_heap(2);
    var nlen = strlen(name);
    # S-02: reject names that don't satisfy git check-ref-format rules.
    if (refname_valid(name) == 0) {
        eprintln("sit: invalid branch name (see git check-ref-format rules)");
        return 1;
    }
    var path = alloc(16 + nlen + 1);
    memcpy(path, ".sit/refs/heads/", 16);
    memcpy(path + 16, name, nlen);
    store8(path + 16 + nlen, 0);

    if (file_exists(path) == 1) {
        syscall(SYS_WRITE, STDERR, "sit: branch '", 13);
        syscall(SYS_WRITE, STDERR, name, nlen);
        syscall(SYS_WRITE, STDERR, "' already exists\n", 17);
        return 1;
    }

    var head_hex = read_head_ref();
    if (head_hex == 0) {
        eprintln("sit: cannot create a branch with no commits");
        return 1;
    }

    ensure_parent_dirs(path);
    var buf = alloc(66);
    memcpy(buf, head_hex, 64);
    store8(buf + 64, 10);
    store8(buf + 65, 0);
    if (file_write_all(path, buf, 65) < 0) {
        eprintln("sit: failed to write branch ref");
        return 1;
    }

    stdout_write("created branch '", 16);
    stdout_write(name, nlen);
    stdout_write("'\n", 2);
    return 0;
}

# True if there are any staged or unstaged changes vs HEAD. Untracked files
# are not considered dirty (they don't block checkout unless they collide).
fn cmd_checkout() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }
    if (argc() < 3) {
        eprintln("usage: sit checkout [-b] <branch>");
        return 1;
    }

    var create = 0;
    var arg_idx = 2;
    if (streq(argv(2), "-b") == 1) {
        create = 1;
        arg_idx = 3;
        if (argc() < 4) {
            eprintln("usage: sit checkout -b <branch>");
            return 1;
        }
    }
    var target = argv_heap(arg_idx);
    var tlen = strlen(target);

    if (create == 1) {
        # S-02: validate branch name before touching the filesystem.
        if (refname_valid(target) == 0) {
            eprintln("sit: invalid branch name (see git check-ref-format rules)");
            return 1;
        }
        var new_branch = alloc(16 + tlen + 1);
        memcpy(new_branch, ".sit/refs/heads/", 16);
        memcpy(new_branch + 16, target, tlen);
        store8(new_branch + 16 + tlen, 0);
        if (file_exists(new_branch) == 1) {
            syscall(SYS_WRITE, STDERR, "sit: branch '", 13);
            syscall(SYS_WRITE, STDERR, target, tlen);
            syscall(SYS_WRITE, STDERR, "' already exists\n", 17);
            return 1;
        }
        var head_hex = read_head_ref();
        if (head_hex == 0) {
            eprintln("sit: cannot create a branch with no commits");
            return 1;
        }
        ensure_parent_dirs(new_branch);
        var buf = alloc(66);
        memcpy(buf, head_hex, 64);
        store8(buf + 64, 10);
        store8(buf + 65, 0);
        if (file_write_all(new_branch, buf, 65) < 0) {
            eprintln("sit: failed to write branch ref");
            return 1;
        }
    }

    var target_ref_len = 11 + tlen;
    var target_ref = alloc(target_ref_len + 1);
    memcpy(target_ref, "refs/heads/", 11);
    memcpy(target_ref + 11, target, tlen);
    store8(target_ref + target_ref_len, 0);

    var target_path = alloc(5 + target_ref_len + 1);
    memcpy(target_path, ".sit/", 5);
    memcpy(target_path + 5, target_ref, target_ref_len);
    store8(target_path + 5 + target_ref_len, 0);

    if (file_exists(target_path) != 1) {
        syscall(SYS_WRITE, STDERR, "sit: branch '", 13);
        syscall(SYS_WRITE, STDERR, target, tlen);
        syscall(SYS_WRITE, STDERR, "' not found\n", 12);
        return 1;
    }

    var curr = current_branch_name();
    if (curr != 0) {
        if (streq(curr, target) == 1) {
            stdout_write("already on '", 12);
            stdout_write(target, tlen);
            stdout_write("'\n", 2);
            return 0;
        }
    }

    if (is_dirty() == 1) {
        eprintln("sit: working tree has uncommitted changes");
        eprintln("sit:   commit or revert before switching branches");
        return 1;
    }

    var target_fd = file_open(target_path, 0, 0);
    if (target_fd < 0) {
        eprintln("sit: cannot read target branch ref");
        return 1;
    }
    var target_hex = alloc(80);
    var n = file_read(target_fd, target_hex, 80);
    file_close(target_fd);
    if (n < 64) {
        eprintln("sit: target ref is invalid");
        return 1;
    }
    store8(target_hex + 64, 0);

    var target_entries = commit_tree_entries(target_hex);
    if (target_entries == 0) { target_entries = vec_new(); }
    var curr_entries = read_head_tree_entries();
    if (curr_entries == 0) { curr_entries = vec_new(); }

    # Collision check: untracked files on disk that would be overwritten
    var working = list_working_files();
    var wn = vec_len(working);
    var wi = 0;
    while (wi < wn) {
        var wpath = vec_get(working, wi);
        if (tree_find(curr_entries, wpath) == 0) {
            if (tree_find(target_entries, wpath) != 0) {
                syscall(SYS_WRITE, STDERR, "sit: untracked file '", 21);
                syscall(SYS_WRITE, STDERR, wpath, strlen(wpath));
                syscall(SYS_WRITE, STDERR, "' would be overwritten\n", 23);
                return 1;
            }
        }
        wi = wi + 1;
    }

    materialize_target(target_hex);

    if (set_head_ref(target_ref) != 0) {
        eprintln("sit: failed to update HEAD");
        return 1;
    }

    stdout_write("switched to branch '", 20);
    stdout_write(target, tlen);
    stdout_write("'\n", 2);
    return 0;
}

# --- tree.cyr ---

# tree.cyr — sit tree objects.
#
# Top-level tree layout for subdirectory grouping (`tlvl_*`), git-SHA-256-compatible
# tree entry parse / build / flatten, and tree_find lookups. Trees encode
# directories as `40000 <name>\0<32B hash>` entries and files as `100644 ...`.

fn tlvl_mode(e) { return load64(e); }
fn tlvl_name(e) { return load64(e + 8); }
fn tlvl_bytes(e) { return load64(e + 16); }

# Recursive tree writer.
# `entries` is a slice of the sorted+deduped staging index; all entries passed
# at a given call share the same prefix of length `prefix_len` (empty at root).
# Lexical sort of full paths produces correct per-tree git order when walked
# depth-first — no separate sort step needed at the level.
# Returns tree hex hash, or 0 on failure.
fn build_tree(entries, prefix_len) {
    var level = vec_new();
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        var full_path = entry_path(e);
        var rest = full_path + prefix_len;
        var rest_len = strlen(full_path) - prefix_len;

        var slash = 0;
        var found = 0;
        while (slash < rest_len) {
            if (load8(rest + slash) == 47) { found = 1; break; }
            slash = slash + 1;
        }

        if (found == 0) {
            var name = alloc_or_die(rest_len + 1);
            memcpy(name, rest, rest_len);
            store8(name + rest_len, 0);

            var le = alloc_or_die(24);
            store64(le, "100644");
            store64(le + 8, name);
            store64(le + 16, entry_hash(e));
            vec_push(level, le);
            i = i + 1;
        }
        else {
            var subdir_name = alloc_or_die(slash + 1);
            memcpy(subdir_name, rest, slash);
            store8(subdir_name + slash, 0);

            var sub_prefix_len = prefix_len + slash + 1;
            var sub_entries = vec_new();

            var collecting = 1;
            while (collecting == 1) {
                if (i >= n) { collecting = 0; }
                else {
                    var ee = vec_get(entries, i);
                    var ee_path = entry_path(ee);
                    var ee_len = strlen(ee_path);
                    var ok = 1;
                    if (ee_len <= prefix_len + slash) { ok = 0; }
                    else {
                        var m = 0;
                        while (m < slash) {
                            if (load8(ee_path + prefix_len + m) != load8(rest + m)) { ok = 0; }
                            m = m + 1;
                        }
                        if (ok == 1) {
                            if (load8(ee_path + prefix_len + slash) != 47) { ok = 0; }
                        }
                    }
                    if (ok == 0) { collecting = 0; }
                    else {
                        vec_push(sub_entries, ee);
                        i = i + 1;
                    }
                }
            }

            var sub_hex = build_tree(sub_entries, sub_prefix_len);
            if (sub_hex == 0) { return 0; }
            var sub_bytes = hex_decode(sub_hex, 64);
            if (sub_bytes == 0) { return 0; }

            var le = alloc_or_die(24);
            store64(le, "40000");
            store64(le + 8, subdir_name);
            store64(le + 16, sub_bytes);
            vec_push(level, le);
        }
    }

    var body_size = 0;
    var k = 0;
    var nl = vec_len(level);
    while (k < nl) {
        var le = vec_get(level, k);
        body_size = body_size + strlen(tlvl_mode(le)) + 1 + strlen(tlvl_name(le)) + 1 + 32;
        k = k + 1;
    }

    var body = alloc_or_die(body_size);
    var pos = 0;
    k = 0;
    while (k < nl) {
        var le = vec_get(level, k);
        var mode = tlvl_mode(le);
        var name = tlvl_name(le);
        var mlen = strlen(mode);
        var nlen = strlen(name);
        memcpy(body + pos, mode, mlen); pos = pos + mlen;
        store8(body + pos, 32); pos = pos + 1;
        memcpy(body + pos, name, nlen); pos = pos + nlen;
        store8(body + pos, 0); pos = pos + 1;
        memcpy(body + pos, tlvl_bytes(le), 32); pos = pos + 32;
        k = k + 1;
    }

    return write_typed_object("tree", 4, body, body_size);
}

# Parse .sit/HEAD. If symbolic (`ref: refs/heads/<branch>\n`), returns the
# ref path (heap cstring, e.g. "refs/heads/main"). Returns 0 on missing HEAD,
# detached (raw hex), or malformed content.
fn tree_entry_mode(e) { return load64(e); }
fn tree_entry_name(e) { return load64(e + 8); }
fn tree_entry_hash(e) { return load64(e + 16); }

# Parse tree object body. Returns vec of entries.
fn parse_tree(body, body_len) {
    var entries = vec_new();
    var pos = 0;
    while (pos < body_len) {
        var sp = pos;
        while (sp < body_len) {
            if (load8(body + sp) == 32) { break; }
            sp = sp + 1;
        }
        if (sp >= body_len) { pos = body_len; }
        else {
            var mode_len = sp - pos;
            var mode = alloc_or_die(mode_len + 1);
            memcpy(mode, body + pos, mode_len);
            store8(mode + mode_len, 0);

            var nu = sp + 1;
            while (nu < body_len) {
                if (load8(body + nu) == 0) { break; }
                nu = nu + 1;
            }
            if (nu >= body_len) { pos = body_len; }
            else {
                var name_len = nu - sp - 1;
                var name = alloc_or_die(name_len + 1);
                memcpy(name, body + sp + 1, name_len);
                store8(name + name_len, 0);

                if (nu + 1 + 32 > body_len) { pos = body_len; }
                else {
                    # S-03: reject tree entries whose mode isn't allowlisted or
                    # whose name would let an attacker escape the working tree.
                    # Silent drop here means a malicious subtree is treated as
                    # empty — materialize_target won't act on it, and fsck will
                    # flag the mismatch on the outer tree's hash-of-bytes.
                    if (tree_entry_mode_valid(mode) == 1) {
                        if (tree_entry_name_valid(name) == 1) {
                            var hash_hex = hex_encode(body + nu + 1, 32);
                            var e = alloc_or_die(24);
                            store64(e, mode);
                            store64(e + 8, name);
                            store64(e + 16, hash_hex);
                            vec_push(entries, e);
                        }
                    }
                    pos = nu + 1 + 32;
                }
            }
        }
    }
    return entries;
}

# Recursively walk a tree, pushing one entry per file to `out` with the full
# path (e.g., "src/main.cyr") stored in the `name` slot. Subtree entries are
# traversed, not emitted. Returned entries can be searched by `tree_find`
# against full paths because it only uses the name/hash slots.
#
# S-14: bounds recursion depth via a module-level counter. 256 levels matches
# git's limit and covers every realistic project hierarchy.

var _TREE_MAX_DEPTH = 256;
var _tree_walk_depth = 0;

fn flatten_tree(tree_hex, prefix, out) {
    if (_tree_walk_depth >= _TREE_MAX_DEPTH) {
        eprintln("sit: tree depth exceeds 256 — refusing to walk further");
        return 0 - 2;
    }
    _tree_walk_depth = _tree_walk_depth + 1;
    var obj[24];
    if (read_object(tree_hex, &obj) != 0) {
        _tree_walk_depth = _tree_walk_depth - 1;
        return 0 - 1;
    }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);

    var entries = parse_tree(buf + coff, blen - coff);
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        var mode = tree_entry_mode(e);
        var name = tree_entry_name(e);
        var hash_hex = tree_entry_hash(e);

        var prefix_len = strlen(prefix);
        var name_len = strlen(name);

        if (streq(mode, "40000") == 1) {
            var sub_prefix = alloc_or_die(prefix_len + name_len + 2);
            memcpy(sub_prefix, prefix, prefix_len);
            memcpy(sub_prefix + prefix_len, name, name_len);
            store8(sub_prefix + prefix_len + name_len, 47);
            store8(sub_prefix + prefix_len + name_len + 1, 0);
            flatten_tree(hash_hex, sub_prefix, out);
        }
        else {
            var full_path = alloc_or_die(prefix_len + name_len + 1);
            memcpy(full_path, prefix, prefix_len);
            memcpy(full_path + prefix_len, name, name_len);
            store8(full_path + prefix_len + name_len, 0);

            var flat = alloc_or_die(24);
            store64(flat, mode);
            store64(flat + 8, full_path);
            store64(flat + 16, hash_hex);
            vec_push(out, flat);
        }
        i = i + 1;
    }
    _tree_walk_depth = _tree_walk_depth - 1;
    return 0;
}

# Read HEAD → commit → tree, recursively flatten into full-path entries.
# Returns vec or 0 if there's no HEAD commit yet.
fn read_head_tree_entries() {
    var head_commit = read_head_ref();
    if (head_commit == 0) { return 0; }

    var obj[24];
    if (read_object(head_commit, &obj) != 0) { return 0; }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var body = buf + coff;
    var body_len = blen - coff;

    if (body_len < 70) { return 0; }
    if (memeq(body, "tree ", 5) == 0) { return 0; }
    var tree_hex = alloc_or_die(65);
    memcpy(tree_hex, body + 5, 64);
    store8(tree_hex + 64, 0);

    var out = vec_new();
    flatten_tree(tree_hex, "", out);
    return out;
}

# P-10: tree_find cache. The previous O(N) linear scan was called in O(N)
# loops (cmd_status iterating index entries against head_entries; cmd_diff;
# materialize_target; the merge three-way loops). For any entries vec that's
# searched more than once, build a name → entry hashmap on first call and
# reuse it for every subsequent tree_find on the same vec. Cache keyed by
# vec pointer; lifetime = process (sit is short-lived per invocation).
#
# Worst case (one tree_find per vec): one map build + one lookup = O(N) + O(1).
# Same complexity as the old linear scan. Strictly an improvement when called
# more than once on the same vec, which every hot caller does.
var _tree_find_keys = 0;
var _tree_find_maps = 0;

fn _tree_find_map(entries) {
    if (_tree_find_keys == 0) {
        _tree_find_keys = vec_new();
        _tree_find_maps = vec_new();
    }
    var k = vec_len(_tree_find_keys);
    var ki = 0;
    while (ki < k) {
        if (vec_get(_tree_find_keys, ki) == entries) {
            return vec_get(_tree_find_maps, ki);
        }
        ki = ki + 1;
    }
    var m = map_new();
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        map_set(m, tree_entry_name(e), e);
        i = i + 1;
    }
    vec_push(_tree_find_keys, entries);
    vec_push(_tree_find_maps, m);
    return m;
}

fn tree_find(entries, name) {
    if (entries == 0) { return 0; }
    var m = _tree_find_map(entries);
    return map_get(m, name);
}

fn tree_find_hash(entries, path) {
    if (entries == 0) { return 0; }
    var e = tree_find(entries, path);
    if (e == 0) { return 0; }
    return tree_entry_hash(e);
}

# Union of paths across three flattened tree entry vecs. Returns a vec of
# heap-copied path cstrings, each unique.
#
# P-18: dedup via hashmap rather than the O(N²) nested-streq scan over the
# growing `paths` vec. For three trees of N entries each, the old loop did
# ~3N × (3N/2) = ~4.5N² streqs; with the map it's 3N inserts + 3N membership
# checks, all O(1) amortized.
fn three_way_path_set(base, ours, theirs) {
    var paths = vec_new();
    var seen = map_new();
    var sources_cnt = 3;
    var sources[24];
    store64(&sources + 0, base);
    store64(&sources + 8, ours);
    store64(&sources + 16, theirs);

    var si = 0;
    while (si < sources_cnt) {
        var entries = load64(&sources + si * 8);
        if (entries != 0) {
            var n = vec_len(entries);
            var i = 0;
            while (i < n) {
                var e = vec_get(entries, i);
                var p = tree_entry_name(e);
                if (map_has(seen, p) == 0) {
                    var plen = strlen(p);
                    var copy = alloc_or_die(plen + 1);
                    memcpy(copy, p, plen);
                    store8(copy + plen, 0);
                    map_set(seen, copy, 1);
                    vec_push(paths, copy);
                }
                i = i + 1;
            }
        }
        si = si + 1;
    }
    return paths;
}

# Walk descendant's parent chain; return 1 if ancestor_hex is descendant
# or any of its ancestors. Linear — sit has no merge commits yet.

# --- diff.cyr ---

# diff.cyr — unified diff, LCS, hunk grouping, status, show.
#
# Classical LCS on split_lines tables (capped at 16M cells), git-style hunk
# grouping with 3-line context, unified-diff emitter, diffstat variant, and
# cmd_diff / cmd_show / cmd_status which all consume the same primitives.
# Also home to is_dirty and the working-tree walker used by status + add.

fn is_dirty() {
    var index_entries = parse_index();
    if (index_entries != 0) {
        sort_entries(index_entries);
        index_entries = dedupe_entries(index_entries);
    }
    var head_entries = read_head_tree_entries();

    if (index_entries != 0) {
        var n = vec_len(index_entries);
        var i = 0;
        while (i < n) {
            var e = vec_get(index_entries, i);
            var path = entry_path(e);
            var idx_hex = hex_encode(entry_hash(e), 32);
            var head_ent = tree_find(head_entries, path);
            if (head_ent == 0) { return 1; }
            if (streq(tree_entry_hash(head_ent), idx_hex) == 0) { return 1; }
            if (file_exists(path) == 1) {
                var wh = hash_file_as_blob(path);
                if (wh != 0) {
                    if (streq(wh, idx_hex) == 0) { return 1; }
                }
            }
            else { return 1; }
            i = i + 1;
        }
    }

    if (head_entries != 0) {
        var hn = vec_len(head_entries);
        var hi = 0;
        while (hi < hn) {
            var he = vec_get(head_entries, hi);
            if (index_find(index_entries, tree_entry_name(he)) == 0) { return 1; }
            hi = hi + 1;
        }
    }
    return 0;
}

# Ensure all parent directories of `path` exist. For "src/lib/foo.cyr",
# creates "src" and "src/lib".
# Write "ref: <ref_path>\n" to .sit/HEAD. Returns 0 on success.
fn list_working_walk(prefix, fs_path, out, patterns) {
    var raw = dir_list(str_from(fs_path));
    var n = vec_len(raw);
    var fs_path_len = strlen(fs_path);
    var prefix_len = strlen(prefix);
    var i = 0;
    while (i < n) {
        var s = vec_get(raw, i);
        var sdata = str_data(s);
        var slen = str_len(s);

        var skip = 0;
        if (slen == 4) {
            if (memeq(sdata, ".sit", 4) == 1) { skip = 1; }
        }

        if (skip == 0) {
            var rel_path_len = prefix_len + slen;
            var rel_path = alloc(rel_path_len + 1);
            memcpy(rel_path, prefix, prefix_len);
            memcpy(rel_path + prefix_len, sdata, slen);
            store8(rel_path + rel_path_len, 0);
            if (is_ignored(rel_path, patterns) == 1) { skip = 1; }
        }

        if (skip == 0) {
            var child_fs = alloc(fs_path_len + 1 + slen + 1);
            memcpy(child_fs, fs_path, fs_path_len);
            store8(child_fs + fs_path_len, 47);
            memcpy(child_fs + fs_path_len + 1, sdata, slen);
            store8(child_fs + fs_path_len + 1 + slen, 0);

            if (is_dir(str_from(child_fs)) == 1) {
                var new_prefix = alloc(prefix_len + slen + 2);
                memcpy(new_prefix, prefix, prefix_len);
                memcpy(new_prefix + prefix_len, sdata, slen);
                store8(new_prefix + prefix_len + slen, 47);
                store8(new_prefix + prefix_len + slen + 1, 0);
                list_working_walk(new_prefix, child_fs, out, patterns);
            }
            else {
                var full_len = prefix_len + slen;
                var full = alloc(full_len + 1);
                memcpy(full, prefix, prefix_len);
                memcpy(full + prefix_len, sdata, slen);
                store8(full + full_len, 0);
                vec_push(out, full);
            }
        }
        i = i + 1;
    }
    return 0;
}

fn list_working_files() {
    var files = vec_new();
    var patterns = load_sitignore();
    list_working_walk("", ".", files, patterns);
    return files;
}

# A "status item" is a 16-byte (label_ptr, path_ptr) pair.
fn push_status_item(vec, label, path) {
    var item = alloc(16);
    store64(item, label);
    store64(item + 8, path);
    vec_push(vec, item);
    return 0;
}

fn print_labeled_section(title, title_len, items) {
    if (vec_len(items) == 0) { return 0; }
    stdout_write("\n", 1);
    stdout_write(title, title_len);
    stdout_write("\n", 1);
    var si = 0;
    while (si < vec_len(items)) {
        var it = vec_get(items, si);
        var lab = load64(it);
        var pth = load64(it + 8);
        stdout_write("  ", 2);
        stdout_write(lab, strlen(lab));
        stdout_write(pth, strlen(pth));
        stdout_write("\n", 1);
        si = si + 1;
    }
    return 1;
}

fn print_name_section(title, title_len, names) {
    if (vec_len(names) == 0) { return 0; }
    stdout_write("\n", 1);
    stdout_write(title, title_len);
    stdout_write("\n", 1);
    var si = 0;
    while (si < vec_len(names)) {
        var nm = vec_get(names, si);
        stdout_write("  ", 2);
        stdout_write(nm, strlen(nm));
        stdout_write("\n", 1);
        si = si + 1;
    }
    return 1;
}

fn cmd_status() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    var head_entries = read_head_tree_entries();
    var index_entries = parse_index();
    if (index_entries != 0) {
        sort_entries(index_entries);
        index_entries = dedupe_entries(index_entries);
    }
    var working = list_working_files();

    var staged = vec_new();
    var unstaged = vec_new();
    var untracked = vec_new();

    if (index_entries != 0) {
        var ni = vec_len(index_entries);
        var ii = 0;
        while (ii < ni) {
            var e = vec_get(index_entries, ii);
            var path = entry_path(e);
            var idx_hash_hex = hex_encode(entry_hash(e), 32);

            var head_ent = tree_find(head_entries, path);
            var label = 0;
            if (head_ent == 0) { label = "new file:  "; }
            else {
                if (streq(tree_entry_hash(head_ent), idx_hash_hex) == 0) {
                    label = "modified:  ";
                }
            }
            if (label != 0) { push_status_item(staged, label, path); }

            if (file_exists(path) == 1) {
                var working_hex = hash_file_as_blob(path);
                if (working_hex != 0) {
                    if (streq(working_hex, idx_hash_hex) == 0) {
                        push_status_item(unstaged, "modified:  ", path);
                    }
                }
            }
            else {
                push_status_item(unstaged, "deleted:   ", path);
            }
            ii = ii + 1;
        }
    }

    var nw = vec_len(working);
    var wi = 0;
    while (wi < nw) {
        var name = vec_get(working, wi);
        if (index_find(index_entries, name) == 0) {
            if (tree_find(head_entries, name) == 0) {
                vec_push(untracked, name);
            }
        }
        wi = wi + 1;
    }

    if (head_entries != 0) {
        var hn = vec_len(head_entries);
        var hi = 0;
        while (hi < hn) {
            var he = vec_get(head_entries, hi);
            var hpath = tree_entry_name(he);
            if (index_find(index_entries, hpath) == 0) {
                push_status_item(staged, "deleted:   ", hpath);
            }
            hi = hi + 1;
        }
    }

    var branch = current_branch_name();
    stdout_write("On branch ", 10);
    if (branch != 0) { stdout_write(branch, strlen(branch)); }
    else             { stdout_write("(detached)", 10); }
    stdout_write("\n", 1);
    if (read_head_ref() == 0) {
        stdout_write("No commits yet\n", 15);
    }
    if (read_merge_head() != 0) {
        var msg = "Merge in progress. Resolve conflicts and commit, or run 'sit merge --abort'.\n";
        stdout_write(msg, strlen(msg));
    }

    var any = 0;
    if (print_labeled_section("Staged for commit:", 18, staged) == 1)   { any = 1; }
    if (print_labeled_section("Unstaged changes:", 17, unstaged) == 1)   { any = 1; }
    if (print_name_section("Untracked files:", 16, untracked) == 1)      { any = 1; }

    if (any == 0) {
        stdout_write("\nnothing to commit, working tree clean\n", 39);
    }
    return 0;
}

# ---- diff ------------------------------------------------------------------
# Line layout (16 bytes): { ptr_into_data, len } — \n excluded.
fn line_ptr(l) { return load64(l); }
fn line_len(l) { return load64(l + 8); }

fn split_lines(data, len) {
    var lines = vec_new();
    var pos = 0;
    while (pos < len) {
        var start = pos;
        while (pos < len) {
            if (load8(data + pos) == 10) { break; }
            pos = pos + 1;
        }
        var line = alloc(16);
        store64(line, data + start);
        store64(line + 8, pos - start);
        vec_push(lines, line);
        if (pos < len) { pos = pos + 1; }
    }
    return lines;
}

fn lines_equal(a, b) {
    var alen = line_len(a);
    var blen = line_len(b);
    if (alen != blen) { return 0; }
    return memeq(line_ptr(a), line_ptr(b), alen);
}

# Read trace slice for depth `d` at diagonal `kp` (P-14). The slice holds the
# parity-(d-1) V entries in [-(d-1), d-1] that depth d read/produced; `kp` must
# be that parity (the caller only ever asks for valid k±1 / prev_k diagonals).
fn _myers_sget(slice, d, kp) {
    return load64(slice + ((kp + d - 1) / 2) * 8);
}

# Myers O((N+M)D) diff fallback (P-14). Produces the SAME op-tuple format as
# `lcs_diff` (16-byte {kind, line_ptr}, forward order) so callers don't care
# which path ran. Used when the LCS DP table would be too large — Myers needs
# only O(N+M) working space plus an O(D²) backtrack trace, where D is the edit
# distance, so a large-but-similar file (small D) diffs cheaply where the DP
# would allocate 100+ MB. Bounded: if D exceeds `dcap` (a fully-rewritten huge
# file — the rare pathological case) it returns 0, preserving the old "too
# large" refusal. Greedy forward search + trace backtrack, per Myers 1986.
fn myers_diff(a, b) {
    var n = vec_len(a);
    var m = vec_len(b);

    # D is bounded by `dcap`, so k = x - y stays in [-dcap, dcap]: V is sized to
    # that, not to N+M. Trace = Σ(d) i64 ≈ dcap²/2; dcap=4096 → ~67 MB ceiling.
    var dcap = 4096;
    var voff = dcap;
    var vsize = 2 * dcap + 1;
    var V = fl_alloc(vsize * 8);
    if (V == 0) { return 0; }
    store64(V + (1 + voff) * 8, 0);
    var trace = vec_new();

    var searching = 1;
    var found_d = 0 - 1;
    var d = 0;
    while (searching == 1) {
        if (d > dcap) { searching = 0; }
        else {
            # Snapshot V (depth d's inputs) for the backtrack — only d >= 1 is
            # ever read back. Compact: parity-(d-1) entries in [-(d-1), d-1].
            if (d >= 1) {
                var slice = fl_alloc(d * 8);
                var kp = 0 - (d - 1);
                while (kp <= d - 1) {
                    store64(slice + ((kp + d - 1) / 2) * 8, load64(V + (kp + voff) * 8));
                    kp = kp + 2;
                }
                vec_push(trace, slice);
            }
            var k = 0 - d;
            while (k <= d) {
                if (searching == 1) {
                    # x = (k==-d || (k!=d && V[k-1]<V[k+1])) ? V[k+1] : V[k-1]+1
                    var down = 0;
                    if (k == 0 - d) { down = 1; }
                    else {
                        if (k != d) {
                            if (load64(V + (k - 1 + voff) * 8) < load64(V + (k + 1 + voff) * 8)) { down = 1; }
                        }
                    }
                    var x = 0;
                    if (down == 1) { x = load64(V + (k + 1 + voff) * 8); }
                    else { x = load64(V + (k - 1 + voff) * 8) + 1; }
                    var y = x - k;
                    var snaking = 1;
                    while (snaking == 1) {
                        if (x < n) {
                            if (y < m) {
                                if (lines_equal(vec_get(a, x), vec_get(b, y)) == 1) {
                                    x = x + 1;
                                    y = y + 1;
                                }
                                else { snaking = 0; }
                            }
                            else { snaking = 0; }
                        }
                        else { snaking = 0; }
                    }
                    store64(V + (k + voff) * 8, x);
                    if (x >= n) {
                        if (y >= m) { found_d = d; searching = 0; }
                    }
                }
                k = k + 2;
            }
            if (searching == 1) { d = d + 1; }
        }
    }

    if (found_d < 0) { fl_free(V); return 0; }

    # Backtrack: from (n,m) to the origin, emitting ops in reverse.
    var script = vec_new();
    var x = n;
    var y = m;
    var dd = found_d;
    while (dd >= 1) {
        var slice = vec_get(trace, dd - 1);
        var k = x - y;
        var down = 0;
        if (k == 0 - dd) { down = 1; }
        else {
            if (k != dd) {
                if (_myers_sget(slice, dd, k - 1) < _myers_sget(slice, dd, k + 1)) { down = 1; }
            }
        }
        var prev_k = 0;
        if (down == 1) { prev_k = k + 1; }
        else { prev_k = k - 1; }
        var prev_x = _myers_sget(slice, dd, prev_k);
        var prev_y = prev_x - prev_k;
        var diaging = 1;
        while (diaging == 1) {
            if (x > prev_x) {
                if (y > prev_y) {
                    var op = alloc(16);
                    store64(op, 0);
                    store64(op + 8, vec_get(a, x - 1));
                    vec_push(script, op);
                    x = x - 1;
                    y = y - 1;
                }
                else { diaging = 0; }
            }
            else { diaging = 0; }
        }
        if (down == 1) {
            var op = alloc(16);
            store64(op, 2);
            store64(op + 8, vec_get(b, y - 1));
            vec_push(script, op);
        }
        else {
            var op = alloc(16);
            store64(op, 1);
            store64(op + 8, vec_get(a, x - 1));
            vec_push(script, op);
        }
        x = prev_x;
        y = prev_y;
        dd = dd - 1;
    }
    while (x > 0) {
        var op = alloc(16);
        store64(op, 0);
        store64(op + 8, vec_get(a, x - 1));
        vec_push(script, op);
        x = x - 1;
        y = y - 1;
    }

    # script is reversed; flip into forward order (matches lcs_diff).
    var out = vec_new();
    var si = vec_len(script) - 1;
    while (si >= 0) {
        vec_push(out, vec_get(script, si));
        si = si - 1;
    }
    fl_free(V);
    var ti = 0;
    while (ti < vec_len(trace)) {
        fl_free(vec_get(trace, ti));
        ti = ti + 1;
    }
    return out;
}

# LCS-based diff. Returns a vec of op-tuples (16 bytes):
#   op kind: 0 = keep, 1 = delete, 2 = insert
#   line ptr: points at one of the input line tuples
# For small inputs this is the exact O(N·M) DP; when the DP table would be too
# large it hands off to `myers_diff` (P-14), which only refuses (returns 0) on
# a pathologically large edit distance.
fn lcs_diff(a, b) {
    var n1 = vec_len(a);
    var n2 = vec_len(b);
    # S-07: per-dimension cap BEFORE the multiply to prevent integer-overflow
    # that would let `cells` wrap into a small positive and bypass the cap.
    # sqrt(16M) ~ 4096; keep a little headroom. Past the cap → Myers fallback.
    if (n1 > 8192) { return myers_diff(a, b); }
    if (n2 > 8192) { return myers_diff(a, b); }
    var stride = n2 + 1;
    var cells = (n1 + 1) * stride;
    if (cells > 16 * 1024 * 1024) { return myers_diff(a, b); }
    # P-15 (v0.6.9): the DP table can be up to 128 MB. fl_alloc routes large
    # allocations through mmap directly and we fl_free below before the
    # function returns — diff-heavy commands no longer permanently reserve
    # the table on the bump heap for the life of the process.
    var T = fl_alloc(cells * 8);
    if (T == 0) { return myers_diff(a, b); }

    # Zero the LCS base case — row 0 (`T[0][0..n2]`) and column 0
    # (`T[0..n1][0]`). The DP reads `T[i-1][*]` / `T[*][j-1]`, so the base must
    # be 0. `fl_alloc` only zero-fills fresh mmap pages (large tables); a small
    # table served from the recycled freelist carries stale non-zero values, so
    # without this the DP computed a too-short LCS (non-minimal diff) on the
    # 2nd+ diff in a process. Surfaced by the P-14 Myers differential test.
    var z = 0;
    while (z <= n2) { store64(T + z * 8, 0); z = z + 1; }
    z = 0;
    while (z <= n1) { store64(T + z * stride * 8, 0); z = z + 1; }

    var i = 1;
    while (i <= n1) {
        var j = 1;
        while (j <= n2) {
            var aline = vec_get(a, i - 1);
            var bline = vec_get(b, j - 1);
            var cellval = 0;
            if (lines_equal(aline, bline) == 1) {
                cellval = load64(T + ((i - 1) * stride + (j - 1)) * 8) + 1;
            }
            else {
                var up = load64(T + ((i - 1) * stride + j) * 8);
                var left = load64(T + (i * stride + (j - 1)) * 8);
                if (up >= left) { cellval = up; }
                else { cellval = left; }
            }
            store64(T + (i * stride + j) * 8, cellval);
            j = j + 1;
        }
        i = i + 1;
    }

    var script = vec_new();
    i = n1;
    var j = n2;
    while (i > 0) {
        if (j > 0) {
            if (lines_equal(vec_get(a, i - 1), vec_get(b, j - 1)) == 1) {
                var op = alloc(16);
                store64(op, 0);
                store64(op + 8, vec_get(a, i - 1));
                vec_push(script, op);
                i = i - 1;
                j = j - 1;
            }
            else {
                var up = load64(T + ((i - 1) * stride + j) * 8);
                var left = load64(T + (i * stride + (j - 1)) * 8);
                if (left >= up) {
                    var op = alloc(16);
                    store64(op, 2);
                    store64(op + 8, vec_get(b, j - 1));
                    vec_push(script, op);
                    j = j - 1;
                }
                else {
                    var op = alloc(16);
                    store64(op, 1);
                    store64(op + 8, vec_get(a, i - 1));
                    vec_push(script, op);
                    i = i - 1;
                }
            }
        }
        else {
            var op = alloc(16);
            store64(op, 1);
            store64(op + 8, vec_get(a, i - 1));
            vec_push(script, op);
            i = i - 1;
        }
    }
    while (j > 0) {
        var op = alloc(16);
        store64(op, 2);
        store64(op + 8, vec_get(b, j - 1));
        vec_push(script, op);
        j = j - 1;
    }

    var reversed = vec_new();
    var k = vec_len(script) - 1;
    while (k >= 0) {
        vec_push(reversed, vec_get(script, k));
        k = k - 1;
    }
    fl_free(T);
    return reversed;
}

# Annotated op layout (32 bytes):
#   0..8:   kind (0=keep, 1=del, 2=ins)
#   8..16:  line ptr
#   16..24: old_line (1-indexed; 0 if op has no presence in old)
#   24..32: new_line (1-indexed; 0 if op has no presence in new)
fn ann_kind(a) { return load64(a); }
fn ann_line(a) { return load64(a + 8); }
fn ann_old(a)  { return load64(a + 16); }
fn ann_new(a)  { return load64(a + 24); }

fn annotate_ops(ops) {
    var out = vec_new();
    var old_line = 0;
    var new_line = 0;
    var n = vec_len(ops);
    var i = 0;
    while (i < n) {
        var op = vec_get(ops, i);
        var kind = load64(op);
        var line = load64(op + 8);
        var a = alloc(32);
        store64(a, kind);
        store64(a + 8, line);
        if (kind == 0) {
            old_line = old_line + 1;
            new_line = new_line + 1;
            store64(a + 16, old_line);
            store64(a + 24, new_line);
        }
        else {
            if (kind == 1) {
                old_line = old_line + 1;
                store64(a + 16, old_line);
                store64(a + 24, 0);
            }
            else {
                new_line = new_line + 1;
                store64(a + 16, 0);
                store64(a + 24, new_line);
            }
        }
        vec_push(out, a);
        i = i + 1;
    }
    return out;
}

# Group annotated ops into hunks. Each hunk is a vec of ops.
# Algorithm: keep up to N leading-context keeps before the first change of a
# hunk; extend the hunk as long as consecutive keep-runs stay within 2N; when
# we see a (2N+1)-th keep since the last change, trim the hunk's trailing
# keeps to N and close it. The overshoot keep becomes the first of the next
# hunk's leading-context buffer.
fn group_hunks(annotated, ctx) {
    var hunks = vec_new();
    var pending = vec_new();
    var hunk = 0;
    var since_change = 0;

    var n = vec_len(annotated);
    var i = 0;
    while (i < n) {
        var op = vec_get(annotated, i);
        var kind = ann_kind(op);

        if (kind == 0) {
            if (hunk == 0) {
                vec_push(pending, op);
                if (vec_len(pending) > ctx) { vec_remove(pending, 0); }
            }
            else {
                since_change = since_change + 1;
                if (since_change <= 2 * ctx) { vec_push(hunk, op); }
                else {
                    # Close hunk: trim trailing keeps to exactly ctx.
                    var k = 0;
                    while (k < ctx) { vec_pop(hunk); k = k + 1; }
                    vec_push(hunks, hunk);
                    hunk = 0;
                    pending = vec_new();
                    vec_push(pending, op);
                    since_change = 0;
                }
            }
        }
        else {
            if (hunk == 0) {
                hunk = vec_new();
                var pi = 0;
                var pn = vec_len(pending);
                while (pi < pn) {
                    vec_push(hunk, vec_get(pending, pi));
                    pi = pi + 1;
                }
                pending = vec_new();
            }
            vec_push(hunk, op);
            since_change = 0;
        }
        i = i + 1;
    }

    if (hunk != 0) {
        var trim = since_change - ctx;
        if (trim > 0) {
            var k = 0;
            while (k < trim) { vec_pop(hunk); k = k + 1; }
        }
        vec_push(hunks, hunk);
    }
    return hunks;
}

# Compute hunk header ranges. Writes to out (32 bytes):
#   0..8:   old_start, 8..16: old_len, 16..24: new_start, 24..32: new_len
fn hunk_ranges(hunk, out) {
    var old_start = 0;
    var new_start = 0;
    var old_len = 0;
    var new_len = 0;
    var n = vec_len(hunk);
    var i = 0;
    while (i < n) {
        var op = vec_get(hunk, i);
        var kind = ann_kind(op);
        if (kind != 2) {
            if (old_start == 0) { old_start = ann_old(op); }
            old_len = old_len + 1;
        }
        if (kind != 1) {
            if (new_start == 0) { new_start = ann_new(op); }
            new_len = new_len + 1;
        }
        i = i + 1;
    }
    store64(out, old_start);
    store64(out + 8, old_len);
    store64(out + 16, new_start);
    store64(out + 24, new_len);
    return 0;
}

fn write_unsigned(n) {
    var buf[24];
    var digits = write_decimal(&buf, n);
    stdout_write(&buf, digits);
    return 0;
}

fn print_hunk_header(hunk) {
    var r[32];
    hunk_ranges(hunk, &r);
    var old_len = load64(&r + 8);
    var new_len = load64(&r + 24);
    stdout_write("@@ -", 4);
    write_unsigned(load64(&r));
    # Git convention: omit ",1" when the count is 1.
    if (old_len != 1) {
        stdout_write(",", 1);
        write_unsigned(old_len);
    }
    stdout_write(" +", 2);
    write_unsigned(load64(&r + 16));
    if (new_len != 1) {
        stdout_write(",", 1);
        write_unsigned(new_len);
    }
    stdout_write(" @@\n", 4);
    return 0;
}

# Pure compute layer: returns the annotated-ops vec for the (old, new) buffers,
# or 0 if the LCS table exceeds the 16M-cell cap. No I/O; caller owns the
# returned vec. Public API surface — consumed by `sit_diff_path` (the library
# export wrapper) so owl and other downstream consumers can walk the per-line
# annotations without paying for stringification + stdout writes.
fn compute_file_diff(old_buf, old_len, new_buf, new_len) {
    var a = split_lines(old_buf, old_len);
    var b = split_lines(new_buf, new_len);
    var ops = lcs_diff(a, b);
    if (ops == 0) { return 0; }
    return annotate_ops(ops);
}

fn print_file_diff(path, old_buf, old_len, new_buf, new_len, ctx) {
    stdout_write("--- a/", 6);
    stdout_write(path, strlen(path));
    stdout_write("\n+++ b/", 7);
    stdout_write(path, strlen(path));
    stdout_write("\n", 1);

    var annotated = compute_file_diff(old_buf, old_len, new_buf, new_len);
    if (annotated == 0) {
        eprintln("sit: diff table exceeds cap; file too large");
        return 1;
    }

    var hunks = group_hunks(annotated, ctx);

    var h = 0;
    var hn = vec_len(hunks);
    while (h < hn) {
        var hunk = vec_get(hunks, h);
        print_hunk_header(hunk);

        var ni = 0;
        var nn = vec_len(hunk);
        while (ni < nn) {
            var op = vec_get(hunk, ni);
            var kind = ann_kind(op);
            var l = ann_line(op);
            if (kind == 0) { stdout_write(" ", 1); }
            if (kind == 1) { stdout_write("-", 1); }
            if (kind == 2) { stdout_write("+", 1); }
            stdout_write(line_ptr(l), line_len(l));
            stdout_write("\n", 1);
            ni = ni + 1;
        }
        h = h + 1;
    }
    return 0;
}

# Count insertion / deletion lines between two buffers and print a diffstat
# line ` path | +N -M\n`. Writes (ins, del) to out_pair for caller totals.
fn print_file_stat(path, old_buf, old_len, new_buf, new_len, out_pair) {
    var a = split_lines(old_buf, old_len);
    var b = split_lines(new_buf, new_len);
    var ops = lcs_diff(a, b);
    if (ops == 0) {
        store64(out_pair, 0);
        store64(out_pair + 8, 0);
        eprintln("sit: diff table exceeds cap; file too large");
        return 1;
    }
    var ins = 0;
    var del = 0;
    var n = vec_len(ops);
    var i = 0;
    while (i < n) {
        var op = vec_get(ops, i);
        var kind = load64(op);
        if (kind == 1) { del = del + 1; }
        if (kind == 2) { ins = ins + 1; }
        i = i + 1;
    }
    store64(out_pair, ins);
    store64(out_pair + 8, del);
    stdout_write(" ", 1);
    stdout_write(path, strlen(path));
    stdout_write(" | +", 4);
    var nbuf[24];
    var d = write_decimal(&nbuf, ins);
    stdout_write(&nbuf, d);
    stdout_write(" -", 2);
    d = write_decimal(&nbuf, del);
    stdout_write(&nbuf, d);
    stdout_write("\n", 1);
    return 0;
}

# Read a blob object by hex hash; write (content_ptr, content_len) to out_pair.
# Returns 0 on success, negative on error.
fn read_blob_content(hex, out_pair) {
    var obj[24];
    if (read_object(hex, &obj) != 0) { return 0 - 1; }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    store64(out_pair, buf + coff);
    store64(out_pair + 8, blen - coff);
    return 0;
}

fn cmd_diff() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    # Scan args: --staged flag, -U<N> context width (default 3), optional 1-2 positional refs.
    var staged = 0;
    var ref_a = 0;
    var ref_b = 0;
    var ctx = 3;
    var ai = 2;
    while (ai < argc()) {
        var a = argv(ai);
        if (streq(a, "--staged") == 1) { staged = 1; ai = ai + 1; }
        else {
            # -U<N>: hunk context width (matches `git diff -U<N>` /
            # `diff -U<N>` posix shape). N is a non-negative decimal.
            if (strlen(a) >= 2) {
                if (load8(a) == 45) {
                    if (load8(a + 1) == 85) {
                        var nstr = a + 2;
                        if (strlen(nstr) == 0) {
                            eprintln("usage: sit diff -U<N> [...] (N is a non-negative integer)");
                            return 1;
                        }
                        ctx = atoi(nstr);
                        if (ctx < 0) {
                            eprintln("usage: sit diff -U<N> [...] (N is a non-negative integer)");
                            return 1;
                        }
                        ai = ai + 1;
                        continue;
                    }
                }
            }
            if (ref_a == 0) { ref_a = argv_heap(ai); ai = ai + 1; }
            else {
                if (ref_b == 0) { ref_b = argv_heap(ai); ai = ai + 1; }
                else {
                    eprintln("usage: sit diff [--staged] [-U<N>] [<commit> [<commit>]]");
                    return 1;
                }
            }
        }
    }

    # Resolve any refs to commit trees.
    var tree_a_entries = 0;
    var tree_b_entries = 0;
    if (ref_a != 0) {
        var r[72];
        if (resolve_hash(ref_a, &r) != 1) {
            syscall(SYS_WRITE, STDERR, "sit: cannot resolve '", 21);
            syscall(SYS_WRITE, STDERR, ref_a, strlen(ref_a));
            syscall(SYS_WRITE, STDERR, "'\n", 2);
            return 1;
        }
        var ref_a_hex = alloc(65);
        memcpy(ref_a_hex, &r, 64);
        store8(ref_a_hex + 64, 0);
        tree_a_entries = commit_tree_entries(ref_a_hex);
        if (tree_a_entries == 0) { tree_a_entries = vec_new(); }
    }
    if (ref_b != 0) {
        var r[72];
        if (resolve_hash(ref_b, &r) != 1) {
            syscall(SYS_WRITE, STDERR, "sit: cannot resolve '", 21);
            syscall(SYS_WRITE, STDERR, ref_b, strlen(ref_b));
            syscall(SYS_WRITE, STDERR, "'\n", 2);
            return 1;
        }
        var ref_b_hex = alloc(65);
        memcpy(ref_b_hex, &r, 64);
        store8(ref_b_hex + 64, 0);
        tree_b_entries = commit_tree_entries(ref_b_hex);
        if (tree_b_entries == 0) { tree_b_entries = vec_new(); }
    }

    # Mode: tree-vs-tree (two refs given).
    if (tree_b_entries != 0) {
        var an = vec_len(tree_a_entries);
        var bn = vec_len(tree_b_entries);
        # For each path in A: if B has it with different hash, diff; if B lacks it, full delete.
        var i = 0;
        while (i < an) {
            var ae = vec_get(tree_a_entries, i);
            var apath = tree_entry_name(ae);
            var ahex = tree_entry_hash(ae);
            var be = tree_find(tree_b_entries, apath);
            if (be == 0) {
                var ap[16];
                if (read_blob_content(ahex, &ap) == 0) {
                    print_file_diff(apath, load64(&ap), load64(&ap + 8), 0, 0, ctx);
                }
            }
            else {
                if (streq(tree_entry_hash(be), ahex) == 0) {
                    var ap[16];
                    var bp[16];
                    if (read_blob_content(ahex, &ap) == 0) {
                        if (read_blob_content(tree_entry_hash(be), &bp) == 0) {
                            print_file_diff(apath,
                                load64(&ap), load64(&ap + 8),
                                load64(&bp), load64(&bp + 8), ctx);
                        }
                    }
                }
            }
            i = i + 1;
        }
        # Then: any path in B not in A → full addition.
        i = 0;
        while (i < bn) {
            var be = vec_get(tree_b_entries, i);
            var bpath = tree_entry_name(be);
            if (tree_find(tree_a_entries, bpath) == 0) {
                var bp[16];
                if (read_blob_content(tree_entry_hash(be), &bp) == 0) {
                    print_file_diff(bpath, 0, 0, load64(&bp), load64(&bp + 8), ctx);
                }
            }
            i = i + 1;
        }
        return 0;
    }

    # Mode: working-vs-ref (one ref given).
    if (tree_a_entries != 0) {
        var head_entries = tree_a_entries;
        var working_files = list_working_files();

        if (head_entries != 0) {
            var hn = vec_len(head_entries);
            var hi = 0;
            while (hi < hn) {
                var he = vec_get(head_entries, hi);
                var path = tree_entry_name(he);
                var head_hex = tree_entry_hash(he);

                if (file_exists(path) == 1) {
                    var working_hex = hash_file_as_blob(path);
                    if (working_hex != 0) {
                        if (streq(head_hex, working_hex) == 0) {
                            var hp[16];
                            var wp[16];
                            if (read_blob_content(head_hex, &hp) == 0) {
                                if (read_file_heap(path, &wp) == 0) {
                                    print_file_diff(path,
                                        load64(&hp), load64(&hp + 8),
                                        load64(&wp), load64(&wp + 8), ctx);
                                }
                            }
                        }
                    }
                }
                else {
                    var hp[16];
                    if (read_blob_content(head_hex, &hp) == 0) {
                        print_file_diff(path, load64(&hp), load64(&hp + 8), 0, 0, ctx);
                    }
                }
                hi = hi + 1;
            }
        }

        var wn = vec_len(working_files);
        var wi = 0;
        while (wi < wn) {
            var wpath = vec_get(working_files, wi);
            if (tree_find(head_entries, wpath) == 0) {
                var wp[16];
                if (read_file_heap(wpath, &wp) == 0) {
                    print_file_diff(wpath, 0, 0, load64(&wp), load64(&wp + 8), ctx);
                }
            }
            wi = wi + 1;
        }
        return 0;
    }

    var index_entries = parse_index();
    if (index_entries != 0) {
        sort_entries(index_entries);
        index_entries = dedupe_entries(index_entries);
    }

    var head_entries = 0;
    if (staged == 1) { head_entries = read_head_tree_entries(); }

    # Under --staged, emit full-file deletion diffs for HEAD paths absent from index.
    if (staged == 1) {
        if (head_entries != 0) {
            var hn = vec_len(head_entries);
            var hi = 0;
            while (hi < hn) {
                var he = vec_get(head_entries, hi);
                var hpath = tree_entry_name(he);
                if (index_find(index_entries, hpath) == 0) {
                    var op[16];
                    if (read_blob_content(tree_entry_hash(he), &op) == 0) {
                        print_file_diff(hpath, load64(&op), load64(&op + 8), 0, 0, ctx);
                    }
                }
                hi = hi + 1;
            }
        }
    }

    if (index_entries == 0) { return 0; }

    var n = vec_len(index_entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(index_entries, i);
        var path = entry_path(e);
        var idx_hash_hex = hex_encode(entry_hash(e), 32);

        if (staged == 1) {
            var head_ent = tree_find(head_entries, path);
            if (head_ent == 0) {
                var ip[16];
                if (read_blob_content(idx_hash_hex, &ip) == 0) {
                    print_file_diff(path, 0, 0, load64(&ip), load64(&ip + 8), ctx);
                }
            }
            else {
                if (streq(tree_entry_hash(head_ent), idx_hash_hex) == 0) {
                    var hp[16];
                    var ip[16];
                    if (read_blob_content(tree_entry_hash(head_ent), &hp) == 0) {
                        if (read_blob_content(idx_hash_hex, &ip) == 0) {
                            print_file_diff(path,
                                load64(&hp), load64(&hp + 8),
                                load64(&ip), load64(&ip + 8), ctx);
                        }
                    }
                }
            }
        }
        else {
            if (file_exists(path) == 1) {
                var working_hex = hash_file_as_blob(path);
                if (working_hex != 0) {
                    if (streq(working_hex, idx_hash_hex) == 0) {
                        var ip[16];
                        var wp[16];
                        if (read_blob_content(idx_hash_hex, &ip) == 0) {
                            if (read_file_heap(path, &wp) == 0) {
                                print_file_diff(path,
                                    load64(&ip), load64(&ip + 8),
                                    load64(&wp), load64(&wp + 8), ctx);
                            }
                        }
                    }
                }
            }
            else {
                var ip[16];
                if (read_blob_content(idx_hash_hex, &ip) == 0) {
                    print_file_diff(path, load64(&ip), load64(&ip + 8), 0, 0, ctx);
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

# Load a commit's tree and return its flattened entries. Returns 0 on error.
fn cmd_show() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    var stat_mode = 0;
    var hash_arg = 0;
    var ctx = 3;
    var ai = 2;
    while (ai < argc()) {
        var aa = argv(ai);
        if (streq(aa, "--stat") == 1) { stat_mode = 1; ai = ai + 1; continue; }
        # -U<N>: hunk context width (matches `git show -U<N>` shape).
        if (strlen(aa) >= 2) {
            if (load8(aa) == 45) {
                if (load8(aa + 1) == 85) {
                    var nstr = aa + 2;
                    if (strlen(nstr) == 0) {
                        eprintln("usage: sit show [--stat] [-U<N>] [<hash>]");
                        return 1;
                    }
                    ctx = atoi(nstr);
                    if (ctx < 0) {
                        eprintln("usage: sit show [--stat] [-U<N>] [<hash>]");
                        return 1;
                    }
                    ai = ai + 1;
                    continue;
                }
            }
        }
        hash_arg = argv_heap(ai);
        ai = ai + 1;
    }

    var hex[72];
    if (hash_arg == 0) {
        var head = read_head_ref();
        if (head == 0) {
            eprintln("sit: no commits yet");
            return 0;
        }
        memcpy(&hex, head, 64);
        store8(&hex + 64, 0);
    }
    else {
        var rr = resolve_hash(hash_arg, &hex);
        if (rr == 0 - 2) { eprintln("sit: hash prefix too short (min 4 chars)"); return 1; }
        if (rr == 0 - 1) { eprintln("sit: ambiguous hash prefix"); return 1; }
        if (rr == 0)     { eprintln("sit: no object matches"); return 1; }
    }

    var obj[24];
    if (read_object(&hex, &obj) != 0) {
        eprintln("sit: cannot read object");
        return 1;
    }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var body = buf + coff;
    var body_len = blen - coff;

    var info[56];
    if (parse_commit_body(body, body_len, &info) != 0) {
        eprintln("sit: object is not a commit");
        return 1;
    }

    print_commit_header(&hex, &info, body, body_len);
    stdout_write("\n", 1);

    var tree_hex = load64(&info);
    var new_entries = vec_new();
    if (tree_hex != 0) { flatten_tree(tree_hex, "", new_entries); }

    var parent_hex = load64(&info + 8);
    var old_entries = vec_new();
    if (parent_hex != 0) {
        var po = commit_tree_entries(parent_hex);
        if (po != 0) { old_entries = po; }
    }

    var tot_files = 0;
    var tot_ins = 0;
    var tot_del = 0;
    var stat_pair[16];

    var n = vec_len(new_entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(new_entries, i);
        var path = tree_entry_name(e);
        var new_hash = tree_entry_hash(e);
        var old_ent = tree_find(old_entries, path);
        if (old_ent == 0) {
            var np[16];
            if (read_blob_content(new_hash, &np) == 0) {
                if (stat_mode == 1) {
                    print_file_stat(path, 0, 0, load64(&np), load64(&np + 8), &stat_pair);
                    tot_files = tot_files + 1;
                    tot_ins = tot_ins + load64(&stat_pair);
                    tot_del = tot_del + load64(&stat_pair + 8);
                }
                else {
                    print_file_diff(path, 0, 0, load64(&np), load64(&np + 8), ctx);
                }
            }
        }
        else {
            if (streq(tree_entry_hash(old_ent), new_hash) == 0) {
                var op[16];
                var np[16];
                if (read_blob_content(tree_entry_hash(old_ent), &op) == 0) {
                    if (read_blob_content(new_hash, &np) == 0) {
                        if (stat_mode == 1) {
                            print_file_stat(path,
                                load64(&op), load64(&op + 8),
                                load64(&np), load64(&np + 8),
                                &stat_pair);
                            tot_files = tot_files + 1;
                            tot_ins = tot_ins + load64(&stat_pair);
                            tot_del = tot_del + load64(&stat_pair + 8);
                        }
                        else {
                            print_file_diff(path,
                                load64(&op), load64(&op + 8),
                                load64(&np), load64(&np + 8), ctx);
                        }
                    }
                }
            }
        }
        i = i + 1;
    }

    var on = vec_len(old_entries);
    i = 0;
    while (i < on) {
        var e = vec_get(old_entries, i);
        var path = tree_entry_name(e);
        if (tree_find(new_entries, path) == 0) {
            var op[16];
            if (read_blob_content(tree_entry_hash(e), &op) == 0) {
                if (stat_mode == 1) {
                    print_file_stat(path, load64(&op), load64(&op + 8), 0, 0, &stat_pair);
                    tot_files = tot_files + 1;
                    tot_ins = tot_ins + load64(&stat_pair);
                    tot_del = tot_del + load64(&stat_pair + 8);
                }
                else {
                    print_file_diff(path, load64(&op), load64(&op + 8), 0, 0, ctx);
                }
            }
        }
        i = i + 1;
    }

    if (stat_mode == 1) {
        if (tot_files > 0) {
            var sbuf[24];
            var sd = write_decimal(&sbuf, tot_files);
            stdout_write(" ", 1);
            stdout_write(&sbuf, sd);
            if (tot_files == 1) { stdout_write(" file changed, ", 15); }
            else                { stdout_write(" files changed, ", 16); }
            sd = write_decimal(&sbuf, tot_ins);
            stdout_write(&sbuf, sd);
            if (tot_ins == 1) { stdout_write(" insertion(+), ", 15); }
            else              { stdout_write(" insertions(+), ", 16); }
            sd = write_decimal(&sbuf, tot_del);
            stdout_write(&sbuf, sd);
            if (tot_del == 1) { stdout_write(" deletion(-)\n", 13); }
            else              { stdout_write(" deletions(-)\n", 14); }
        }
    }
    return 0;
}

# =====================================================================
# Wire protocol — local-path transport (v0.5.0)
#
# A remote is another sit working-tree directory (the one containing `.sit/`).
# We open its patra object DB directly and walk refs by filesystem path.
# No pack bundles, no network. HTTP and SSH transports are v0.5.x work.
# =====================================================================

# Look up `remote.<name>.url` in the local config. Returns heap cstring or 0.

# --- commit.cyr ---

# commit.cyr — commit objects + log.
#
# Builders for signed and unsigned commit bodies, author-line parser,
# git-style header and oneline renderers, reachability helpers
# (is_ancestor, materialize_target, commit_tree_entries), and cmd_commit /
# cmd_log.

fn build_commit(tree_hex, parent_hex, message) {
    return build_commit_signed(tree_hex, parent_hex, message, 0);
}

# Same as build_commit, but when `seed` is non-zero, signs the commit with
# an ed25519 key derived from the 32-byte seed and injects a sitsig header.
fn build_commit_signed(tree_hex, parent_hex, message, seed) {
    # Priority: env → .sit/config → ~/.sitconfig → fallback
    var name = getenv("SIT_AUTHOR_NAME");
    if (name == 0) { name = config_get("user.name"); }
    if (name == 0) { name = "sit user"; }
    var email = getenv("SIT_AUTHOR_EMAIL");
    if (email == 0) { email = config_get("user.email"); }
    if (email == 0) { email = "user@localhost"; }
    var ts = clock_epoch_secs();

    var name_len = strlen(name);
    var email_len = strlen(email);
    var msg_len = strlen(message);

    var cap = 512 + msg_len + name_len * 2 + email_len * 2;
    if (parent_hex != 0) { cap = cap + 80; }
    var body = alloc_or_die(cap);
    var pos = 0;

    memcpy(body + pos, "tree ", 5); pos = pos + 5;
    memcpy(body + pos, tree_hex, 64); pos = pos + 64;
    store8(body + pos, 10); pos = pos + 1;

    if (parent_hex != 0) {
        memcpy(body + pos, "parent ", 7); pos = pos + 7;
        memcpy(body + pos, parent_hex, 64); pos = pos + 64;
        store8(body + pos, 10); pos = pos + 1;
    }

    memcpy(body + pos, "author ", 7); pos = pos + 7;
    memcpy(body + pos, name, name_len); pos = pos + name_len;
    memcpy(body + pos, " <", 2); pos = pos + 2;
    memcpy(body + pos, email, email_len); pos = pos + email_len;
    memcpy(body + pos, "> ", 2); pos = pos + 2;
    var digits = write_decimal(body + pos, ts); pos = pos + digits;
    memcpy(body + pos, " +0000\n", 7); pos = pos + 7;

    memcpy(body + pos, "committer ", 10); pos = pos + 10;
    memcpy(body + pos, name, name_len); pos = pos + name_len;
    memcpy(body + pos, " <", 2); pos = pos + 2;
    memcpy(body + pos, email, email_len); pos = pos + email_len;
    memcpy(body + pos, "> ", 2); pos = pos + 2;
    digits = write_decimal(body + pos, ts); pos = pos + digits;
    memcpy(body + pos, " +0000\n", 7); pos = pos + 7;

    store8(body + pos, 10); pos = pos + 1;
    memcpy(body + pos, message, msg_len); pos = pos + msg_len;
    if (msg_len == 0) { store8(body + pos, 10); pos = pos + 1; }
    else {
        if (load8(message + msg_len - 1) != 10) {
            store8(body + pos, 10); pos = pos + 1;
        }
    }

    if (seed != 0) {
        var new_len_slot[8];
        store64(&new_len_slot, 0);
        var signed = sign_commit_body(body, pos, seed, &new_len_slot);
        if (signed == 0) {
            return write_typed_object("commit", 6, body, pos);
        }
        return write_typed_object("commit", 6, signed, load64(&new_len_slot));
    }
    return write_typed_object("commit", 6, body, pos);
}

# Read a commit's parent hexes — the out+48 vec from parse_commit_body, or 0
# if the object is unreadable / not a parseable commit. The returned vec holds
# heap-owned 64-char NUL-terminated hex copies (safe to retain across calls).
# Consolidates the read_object → parse_commit_body → load64(out+48) boilerplate
# shared by the pure parent-graph walks (is_ancestor, find_merge_base). [v0.9.0]
fn commit_parents_of(hex) {
    var obj[24];
    if (read_object(hex, &obj) != 0) { return 0; }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var info[56];
    if (parse_commit_body(buf + coff, blen - coff, &info) != 0) { return 0; }
    return load64(&info + 48);
}

# True iff `ancestor_hex` is reachable from `descendant_hex` via any parent
# chain. BFS over the full commit DAG (every parent line, not just the last)
# with a seen-set so merge commits don't hide first-parent-only ancestors and
# diamond histories don't re-walk. Mirrors is_ancestor_in_db (wire.cyr), which
# does the same over a remote patra handle.
fn is_ancestor(ancestor_hex, descendant_hex) {
    if (streq(ancestor_hex, descendant_hex) == 1) { return 1; }

    var queue = vec_new();
    var seen = map_new();
    var start = alloc(65);
    memcpy(start, descendant_hex, 64);
    store8(start + 64, 0);
    vec_push(queue, start);

    while (vec_len(queue) > 0) {
        var cur = vec_get(queue, vec_len(queue) - 1);
        vec_pop(queue);
        if (map_has(seen, cur) == 1) { }
        else {
            map_set(seen, cur, 1);
            if (streq(cur, ancestor_hex) == 1) { return 1; }
            var pv = commit_parents_of(cur);
            if (pv != 0) {
                var pi = 0;
                while (pi < vec_len(pv)) {
                    vec_push(queue, vec_get(pv, pi));
                    pi = pi + 1;
                }
            }
        }
    }
    return 0;
}

# Overwrite working tree + index with target commit's tree. Used by both
# checkout and fast-forward merge. Does NOT update HEAD — caller does that.
fn materialize_target(target_hex) {
    var target_entries = commit_tree_entries(target_hex);
    if (target_entries == 0) { target_entries = vec_new(); }
    var curr_entries = read_head_tree_entries();
    if (curr_entries == 0) { curr_entries = vec_new(); }

    # S-03 belt-and-suspenders: `flatten_tree` concatenates prefix + name, so
    # even if parse_tree screened each component, a pre-existing bogus tree
    # in the local store still needs gating before we act on its paths.
    var cn = vec_len(curr_entries);
    var ci = 0;
    while (ci < cn) {
        var ce = vec_get(curr_entries, ci);
        var cpath = tree_entry_name(ce);
        if (tree_flat_path_valid(cpath) == 1) {
            if (tree_find(target_entries, cpath) == 0) {
                if (file_exists(cpath) == 1) {
                    # S-16: refuse to declare success when a stale file the
                    # target says shouldn't exist couldn't be removed —
                    # otherwise `sit status` after checkout would still see
                    # it as tracked.
                    if (sys_unlink(cpath) != 0) {
                        syscall(SYS_WRITE, STDERR, "sit: cannot remove stale path '", 31);
                        syscall(SYS_WRITE, STDERR, cpath, strlen(cpath));
                        syscall(SYS_WRITE, STDERR, "' — materialize aborted\n", 24);
                        return 0 - 1;
                    }
                }
            }
        }
        ci = ci + 1;
    }

    var tn = vec_len(target_entries);
    var ti = 0;
    while (ti < tn) {
        var te = vec_get(target_entries, ti);
        var tpath = tree_entry_name(te);
        var thex = tree_entry_hash(te);
        if (tree_flat_path_valid(tpath) == 0) {
            # Silently skip rather than abort — materialize runs over many
            # paths and we want the valid ones to land. Emit to stderr so
            # operator knows something was filtered.
            syscall(SYS_WRITE, STDERR, "sit: refusing unsafe tree path: ", 32);
            syscall(SYS_WRITE, STDERR, tpath, strlen(tpath));
            syscall(SYS_WRITE, STDERR, "\n", 1);
        }
        else {
            ensure_parent_dirs(tpath);
            var tp[16];
            # S-27: a blob the tree references but the object DB can't read
            # is structural corruption — leaving the file silently absent
            # would mask the failure and produce a half-materialized working
            # tree. Abort with a clear error; callers that want best-effort
            # can re-run after `sit fsck`.
            if (read_blob_content(thex, &tp) != 0) {
                syscall(SYS_WRITE, STDERR, "sit: cannot read blob ", 22);
                syscall(SYS_WRITE, STDERR, thex, strlen(thex));
                syscall(SYS_WRITE, STDERR, " for path '", 11);
                syscall(SYS_WRITE, STDERR, tpath, strlen(tpath));
                syscall(SYS_WRITE, STDERR, "' — materialize aborted (working tree may be partial)\n", 55);
                return 0 - 1;
            }
            # S-16: file_write_all returns < 0 on any write or open failure
            # (permissions, ENOSPC, EROFS). Same partial-tree problem as the
            # blob-read failure above; abort with a clear pointer to the path.
            if (file_write_all(tpath, load64(&tp), load64(&tp + 8)) < 0) {
                syscall(SYS_WRITE, STDERR, "sit: cannot write '", 19);
                syscall(SYS_WRITE, STDERR, tpath, strlen(tpath));
                syscall(SYS_WRITE, STDERR, "' — materialize aborted (working tree may be partial)\n", 55);
                return 0 - 1;
            }
        }
        ti = ti + 1;
    }

    var new_index = vec_new();
    ti = 0;
    while (ti < tn) {
        var te = vec_get(target_entries, ti);
        var tpath = tree_entry_name(te);
        var thex = tree_entry_hash(te);
        if (tree_flat_path_valid(tpath) == 1) {
            var bytes = hex_decode(thex, 64);
            if (bytes != 0) {
                var entry = alloc_or_die(40);
                memcpy(entry, bytes, 32);
                var plen = strlen(tpath);
                var pcopy = alloc_or_die(plen + 1);
                memcpy(pcopy, tpath, plen);
                store8(pcopy + plen, 0);
                store64(entry + 32, pcopy);
                vec_push(new_index, entry);
            }
        }
        ti = ti + 1;
    }
    rewrite_index(new_index);
    return 0;
}

fn parse_author_line(line, line_len, prefix_len, out) {
    var p = prefix_len;
    var found_close = 0;
    while (p < line_len) {
        if (load8(line + p) == 62) { found_close = 1; break; }
        p = p + 1;
    }
    if (found_close == 0) { return 0 - 1; }

    var ident_len = p - prefix_len + 1;
    var ident = alloc_or_die(ident_len + 1);
    memcpy(ident, line + prefix_len, ident_len);
    store8(ident + ident_len, 0);
    store64(out, ident);

    p = p + 1;
    if (p >= line_len) { return 0 - 1; }
    if (load8(line + p) != 32) { return 0 - 1; }
    p = p + 1;

    var ts = 0;
    var digit_count = 0;
    while (p < line_len) {
        var c = load8(line + p);
        if (c < 48) { break; }
        if (c > 57) { break; }
        digit_count = digit_count + 1;
        # S-18: i64 has ~19 decimal digits of range. Refuse 20+ digit
        # timestamps outright, and detect wrap on the 19th via `new < old`
        # (the only path a single decimal digit can produce a smaller value).
        if (digit_count > 19) { return 0 - 1; }
        var new_ts = ts * 10 + (c - 48);
        if (new_ts < ts) { return 0 - 1; }
        ts = new_ts;
        p = p + 1;
    }
    store64(out + 8, ts);

    if (p >= line_len) { return 0 - 1; }
    if (load8(line + p) != 32) { return 0 - 1; }
    p = p + 1;

    var tz_start = p;
    while (p < line_len) { p = p + 1; }
    var tz_len = p - tz_start;
    var tz = alloc_or_die(tz_len + 1);
    memcpy(tz, line + tz_start, tz_len);
    store8(tz + tz_len, 0);
    store64(out + 16, tz);

    return 0;
}

# Write the message portion of a commit body to stdout, indenting each
# line with four spaces (git-style).
fn print_indented_message(body, msg_start, body_len) {
    var msg_len = body_len - msg_start;
    while (msg_len > 0) {
        if (load8(body + msg_start + msg_len - 1) != 10) { break; }
        msg_len = msg_len - 1;
    }
    var mp = 0;
    while (mp < msg_len) {
        var mnl = mp;
        while (mnl < msg_len) {
            if (load8(body + msg_start + mnl) == 10) { break; }
            mnl = mnl + 1;
        }
        stdout_write("    ", 4);
        stdout_write(body + msg_start + mp, mnl - mp);
        stdout_write("\n", 1);
        mp = mnl + 1;
    }
    return 0;
}

# Parse a commit object body. Writes to out (56 bytes):
#   [0..8)   tree_hex ptr (heap, null-term 64 chars)
#   [8..16)  parent_hex ptr (or 0 for root commit) — LAST parent line seen
#   [16..24) author identity ptr (or 0)
#   [24..32) author epoch timestamp
#   [32..40) author tz ptr (or 0)
#   [40..48) msg_start (byte offset into body; 0 if no message)
#   [48..56) parents vec — EVERY parent hex, in body order; 0 for root commit
# Returns 0 on success, -1 if body has no tree line.
#
# out+8 keeps the last-parent pointer for back-compat with single-parent-chain
# readers (cmd_log, merge_base). out+48's vec is the multi-parent surface that
# reachability + ancestor walks consume so merge commits don't drop edges.
fn parse_commit_body(body, body_len, out) {
    store64(out, 0);
    store64(out + 8, 0);
    store64(out + 16, 0);
    store64(out + 24, 0);
    store64(out + 32, 0);
    store64(out + 40, 0);
    store64(out + 48, 0);

    var pos = 0;
    var in_headers = 1;
    while (pos < body_len) {
        if (in_headers == 0) { pos = body_len; }
        else {
            var nl = pos;
            while (nl < body_len) {
                if (load8(body + nl) == 10) { break; }
                nl = nl + 1;
            }
            var line_len = nl - pos;

            if (line_len == 0) {
                in_headers = 0;
                store64(out + 40, nl + 1);
            }
            else {
                if (line_len > 5) {
                    if (memeq(body + pos, "tree ", 5) == 1) {
                        var t = alloc_or_die(65);
                        memcpy(t, body + pos + 5, 64);
                        store8(t + 64, 0);
                        store64(out, t);
                    }
                }
                if (line_len > 7) {
                    if (memeq(body + pos, "parent ", 7) == 1) {
                        var p = alloc_or_die(65);
                        memcpy(p, body + pos + 7, 64);
                        store8(p + 64, 0);
                        store64(out + 8, p);
                        # Collect every parent (merge commits have 2+) into a
                        # vec at out+48 so reachability + ancestor walks follow
                        # all edges, not just the last one captured at out+8.
                        var pv = load64(out + 48);
                        if (pv == 0) { pv = vec_new(); store64(out + 48, pv); }
                        vec_push(pv, p);
                    }
                    if (memeq(body + pos, "author ", 7) == 1) {
                        var ao[24];
                        if (parse_author_line(body + pos, line_len, 7, &ao) == 0) {
                            store64(out + 16, load64(&ao));
                            store64(out + 24, load64(&ao + 8));
                            store64(out + 32, load64(&ao + 16));
                        }
                    }
                }
            }
            pos = nl + 1;
        }
    }
    if (load64(out) == 0) { return 0 - 1; }
    return 0;
}

# Print the "commit <hex> / Author: / Date: / [Signature: ...] / blank / message" block.
fn print_commit_header(commit_hex, info, body, body_len) {
    stdout_write("commit ", 7);
    stdout_write(commit_hex, 64);
    stdout_write("\n", 1);

    var pk[32];
    var vr = verify_commit_body(body, body_len, &pk);
    if (vr == 1) {
        var pk_hex = hex_encode(&pk, 32);
        stdout_write("Signature: good (key ", 21);
        stdout_write(pk_hex, 12);
        stdout_write(")\n", 2);
    }
    if (vr == 0) {
        var pk_hex = hex_encode(&pk, 32);
        stdout_write("Signature: BAD (key ", 20);
        stdout_write(pk_hex, 12);
        stdout_write(")\n", 2);
    }

    var ident = load64(info + 16);
    if (ident != 0) {
        var ts = load64(info + 24);
        stdout_write("Author: ", 8);
        # S-21: author identity is attacker-controlled in a cloned commit.
        # Scrub control chars so a crafted commit can't forge log lines
        # via \r\n or drive terminal-escape attacks via \x1b[.
        write_sanitized(STDOUT, ident, strlen(ident));
        stdout_write("\n", 1);
        var iso = iso8601(ts);
        stdout_write("Date:   ", 8);
        stdout_write(iso, strlen(iso));
        stdout_write("\n", 1);
    }

    stdout_write("\n", 1);
    var msg_start = load64(info + 40);
    if (msg_start > 0) {
        print_indented_message(body, msg_start, body_len);
    }
    return 0;
}

# Print a one-line summary of a commit: "<hex12> <first line of message>".
fn print_commit_oneline(commit_hex, body, body_len, msg_start) {
    stdout_write(commit_hex, 12);
    stdout_write(" ", 1);
    if (msg_start > 0) {
        var p = msg_start;
        while (p < body_len) {
            if (load8(body + p) == 10) { p = body_len; }
            else { p = p + 1; }
        }
        # Walk back to find the first \n after msg_start
        var first_nl = msg_start;
        while (first_nl < body_len) {
            if (load8(body + first_nl) == 10) { break; }
            first_nl = first_nl + 1;
        }
        var subj_len = first_nl - msg_start;
        if (subj_len > 0) {
            stdout_write(body + msg_start, subj_len);
        }
    }
    stdout_write("\n", 1);
    return 0;
}

# ── sit log --graph (v0.8.12) ──────────────────────────────────────
#
# An ASCII commit-DAG renderer. Unlike the default `cmd_log` (which walks
# only the first-parent chain via out+8), `--graph` walks the FULL DAG via
# `parse_commit_body`'s out+48 parents vec so merge topology is visible.
#
# Layout uses a position grid: lane k draws at column 2*k; the odd column
# 2*k-1 is the "seam" to its left where merges (`\`) and joins (`/`) connect.
# A commit row shows `*` at the emitting lane and `|` at every other active
# lane; a merge commit (≥2 parents that open a new lane) is followed by a
# `|\` connector; a commit whose parent rejoins an existing lane is followed
# by a `|/` connector. For a linear history this degrades to a column of
# `*`. Emission order is reverse-topological (a commit before its parents),
# newest-first by author timestamp — same primitive a `merge_base` walk wants.
#
# Node layout (48 bytes), keyed by commit hex in `nodes`:
#   [0..8)  parents vec (heap-owned 64-char hex copies, body order)
#   [8..16) pending_children (unemitted children; ready when 0)
#   [16..24) decompressed body ptr (retained for subject rendering)
#   [24..32) body_len
#   [32..40) msg_start (offset into body; 0 if none)
#   [40..48) author epoch timestamp (emission-order key)
#
# Documented simplifications (consistent with the v0.8.10 `.sitignore`
# approach): spacing is sit-native, not byte-identical to git (git pads a
# merge commit row with extra spaces for its lanes; sit uses a single space
# before the commit info). A commit that simultaneously opens a new lane AND
# rejoins an existing one in the same step renders best-effort. Absent
# parents (shallow-clone boundaries) are filtered, so the graph stops cleanly
# at the boundary just like the default log.

fn _graph_build_node(hex) {
    var obj[24];
    if (read_object(hex, &obj) != 0) { return 0; }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var body = buf + coff;
    var body_len = blen - coff;
    var info[56];
    if (parse_commit_body(body, body_len, &info) != 0) { return 0; }
    var node = alloc_or_die(48);
    var pv = load64(&info + 48);
    var mine = vec_new();
    if (pv != 0) {
        var i = 0;
        while (i < vec_len(pv)) {
            var c = alloc_or_die(65);
            memcpy(c, vec_get(pv, i), 64);
            store8(c + 64, 0);
            vec_push(mine, c);
            i = i + 1;
        }
    }
    store64(node, mine);
    store64(node + 8, 0);
    store64(node + 16, body);
    store64(node + 24, body_len);
    store64(node + 32, load64(&info + 40));
    store64(node + 40, load64(&info + 24));
    return node;
}

# Find hex among lanes by string value (vec_find is pointer-equality).
# Returns the lane index, or -1.
fn _graph_lane_find(lanes, hex, excl) {
    var n = vec_len(lanes);
    var i = 0;
    var found = 0 - 1;
    while (i < n) {
        if (found < 0) {
            if (i != excl) {
                if (streq(vec_get(lanes, i), hex) == 1) { found = i; }
            }
        }
        i = i + 1;
    }
    return found;
}

# Write the subject (first message line) of a graph node, sanitized
# (S-21: commit messages are attacker-controlled in a cloned repo).
fn _graph_write_subject(node) {
    var body = load64(node + 16);
    var body_len = load64(node + 24);
    var msg_start = load64(node + 32);
    if (msg_start > 0) {
        var p = msg_start;
        var go = 1;
        while (go == 1) {
            if (p >= body_len) { go = 0; }
            else {
                if (load8(body + p) == 10) { go = 0; }
                else { p = p + 1; }
            }
        }
        var slen = p - msg_start;
        if (slen > 0) { write_sanitized(STDOUT, body + msg_start, slen); }
    }
    return 0;
}

# Emit a buffer trimmed of trailing spaces, plus newline (connector rows).
fn _graph_write_trimmed(buf, width) {
    var end = width;
    var go = 1;
    while (go == 1) {
        if (end <= 0) { go = 0; }
        else {
            if (load8(buf + end - 1) == 32) { end = end - 1; }
            else { go = 0; }
        }
    }
    if (end > 0) { stdout_write(buf, end); }
    stdout_write("\n", 1);
    return 0;
}

# Commit row: `*` at `col`, `|` at every other active lane, then info.
fn _graph_commit_row(lanes, col, hex, node) {
    var nl = vec_len(lanes);
    var width = 2 * nl - 1;
    var buf = alloc_or_die(width);
    var i = 0;
    while (i < width) { store8(buf + i, 32); i = i + 1; }
    var j = 0;
    while (j < nl) {
        var g = 124;
        if (j == col) { g = 42; }
        store8(buf + 2 * j, g);
        j = j + 1;
    }
    stdout_write(buf, width);
    stdout_write(" ", 1);
    stdout_write(hex, 12);
    stdout_write(" ", 1);
    _graph_write_subject(node);
    stdout_write("\n", 1);
    return 0;
}

# Merge connector: `|` at each lane < base, `\` at the seam of each lane
# >= base (the newly opened branches).
fn _graph_merge_connector(lanes, base) {
    var nl = vec_len(lanes);
    var width = 2 * nl - 1;
    var buf = alloc_or_die(width);
    var i = 0;
    while (i < width) { store8(buf + i, 32); i = i + 1; }
    var j = 0;
    while (j < base) { store8(buf + 2 * j, 124); j = j + 1; }
    var k = base;
    # Seam sits at the odd column 2*k-1, left of the new lane. Guard k>0:
    # a branch opened at column 0 has no column to its left (defensive — the
    # join branch needs >=2 lanes so base is normally >=1, but never let the
    # index underflow to buf-1).
    while (k < nl) {
        if (k > 0) { store8(buf + 2 * k - 1, 92); }
        k = k + 1;
    }
    _graph_write_trimmed(buf, width);
    return 0;
}

# Join connector: `|` at each surviving lane, `/` at the seam of the
# collapsing lane `rcol`. Rendered against the pre-removal lane count.
fn _graph_join_connector(old_nl, rcol) {
    var width = 2 * old_nl - 1;
    var buf = alloc_or_die(width);
    var i = 0;
    while (i < width) { store8(buf + i, 32); i = i + 1; }
    var j = 0;
    while (j < old_nl) {
        if (j != rcol) { store8(buf + 2 * j, 124); }
        j = j + 1;
    }
    # Seam at 2*rcol-1 — guard rcol>0 so a lane-0 collapse (the right-lane
    # branch commit being strictly newer than the left) doesn't write buf-1.
    # With rcol==0 there is no column to the left, so no `/` is drawn.
    if (rcol > 0) { store8(buf + 2 * rcol - 1, 47); }
    _graph_write_trimmed(buf, width);
    return 0;
}

fn print_graph(start_hex, limit) {
    var nodes = map_new();
    var order = vec_new();

    # Pass 1: BFS the full DAG, building one node per reachable commit.
    var queue = vec_new();
    var sc = alloc_or_die(65);
    memcpy(sc, start_hex, 64);
    store8(sc + 64, 0);
    vec_push(queue, sc);
    while (vec_len(queue) > 0) {
        var h = vec_get(queue, vec_len(queue) - 1);
        vec_pop(queue);
        if (map_get(nodes, h) != 0) { }
        else {
            var node = _graph_build_node(h);
            if (node == 0) { }
            else {
                map_set(nodes, h, node);
                vec_push(order, h);
                var pv = load64(node);
                if (pv != 0) {
                    var pi = 0;
                    while (pi < vec_len(pv)) {
                        vec_push(queue, vec_get(pv, pi));
                        pi = pi + 1;
                    }
                }
            }
        }
    }

    # Pass 2: pending_children = number of reachable children per commit.
    var oi = 0;
    while (oi < vec_len(order)) {
        var nn = map_get(nodes, vec_get(order, oi));
        var pv2 = load64(nn);
        if (pv2 != 0) {
            var pj = 0;
            while (pj < vec_len(pv2)) {
                var pn = map_get(nodes, vec_get(pv2, pj));
                if (pn != 0) { store64(pn + 8, load64(pn + 8) + 1); }
                pj = pj + 1;
            }
        }
        oi = oi + 1;
    }

    # Emission: lanes carry the commit each column awaits. Pick the
    # ready lane (pending==0) with the newest timestamp each step.
    var lanes = vec_new();
    var lc = alloc_or_die(65);
    memcpy(lc, start_hex, 64);
    store8(lc + 64, 0);
    vec_push(lanes, lc);
    var shown = 0;
    var cont = 1;
    while (cont == 1) {
        if (vec_len(lanes) == 0) { cont = 0; }
        else { if (limit >= 0) { if (shown >= limit) { cont = 0; } } }
        if (cont == 1) {
            var nl = vec_len(lanes);
            var col = 0 - 1;
            var best = 0 - 1;
            var i = 0;
            while (i < nl) {
                var ln = map_get(nodes, vec_get(lanes, i));
                if (ln != 0) {
                    if (load64(ln + 8) == 0) {
                        var ts = load64(ln + 40);
                        if (col < 0) { col = i; best = ts; }
                        else { if (ts > best) { col = i; best = ts; } }
                    }
                }
                i = i + 1;
            }
            if (col < 0) { col = 0; }
            var cur = vec_get(lanes, col);
            var node = map_get(nodes, cur);
            if (node == 0) { vec_remove(lanes, col); }
            else {
                _graph_commit_row(lanes, col, cur, node);
                shown = shown + 1;

                # Present parents = parents that exist locally (absent =
                # shallow boundary). Decrement each so it can become ready.
                var pv = load64(node);
                var present = vec_new();
                if (pv != 0) {
                    var k = 0;
                    while (k < vec_len(pv)) {
                        var p = vec_get(pv, k);
                        var pn = map_get(nodes, p);
                        if (pn != 0) {
                            store64(pn + 8, load64(pn + 8) - 1);
                            vec_push(present, p);
                        }
                        k = k + 1;
                    }
                }
                var npp = vec_len(present);
                if (npp == 0) { vec_remove(lanes, col); }
                else {
                    var p0 = vec_get(present, 0);
                    var ex0 = _graph_lane_find(lanes, p0, col);
                    if (ex0 >= 0) {
                        _graph_join_connector(vec_len(lanes), col);
                        vec_remove(lanes, col);
                    }
                    else { vec_set(lanes, col, p0); }
                    var base = vec_len(lanes);
                    var did_merge = 0;
                    var m = 1;
                    while (m < npp) {
                        var pk = vec_get(present, m);
                        if (_graph_lane_find(lanes, pk, 0 - 1) >= 0) { }
                        else { vec_push(lanes, pk); did_merge = 1; }
                        m = m + 1;
                    }
                    if (did_merge == 1) { _graph_merge_connector(lanes, base); }
                }
            }
        }
    }
    return 0;
}

fn cmd_log() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    # argv scan: --oneline, --graph, -n <count>, and an optional positional <ref>.
    var oneline = 0;
    var graph = 0;
    var limit = 0 - 1;
    var start_ref = 0;
    var ai = 2;
    while (ai < argc()) {
        var a = argv(ai);
        if (streq(a, "--oneline") == 1) { oneline = 1; ai = ai + 1; }
        else {
          if (streq(a, "--graph") == 1) { graph = 1; ai = ai + 1; }
          else {
            if (streq(a, "-n") == 1) {
                if (ai + 1 >= argc()) {
                    eprintln("sit: -n requires a number");
                    return 1;
                }
                limit = atoi(argv(ai + 1));
                ai = ai + 2;
            }
            else {
                if (start_ref != 0) {
                    eprintln("usage: sit log [--oneline] [--graph] [-n <count>] [<ref>]");
                    return 1;
                }
                start_ref = argv_heap(ai);
                ai = ai + 1;
            }
          }
        }
    }

    var current_hex = 0;
    if (start_ref != 0) {
        var resolved[72];
        var rr = resolve_hash(start_ref, &resolved);
        if (rr != 1) {
            syscall(SYS_WRITE, STDERR, "sit: cannot resolve '", 21);
            syscall(SYS_WRITE, STDERR, start_ref, strlen(start_ref));
            syscall(SYS_WRITE, STDERR, "'\n", 2);
            return 1;
        }
        current_hex = alloc_or_die(65);
        memcpy(current_hex, &resolved, 64);
        store8(current_hex + 64, 0);
    }
    else {
        current_hex = read_head_ref();
    }
    if (current_hex == 0) {
        eprintln("sit: no commits yet");
        return 0;
    }

    # --graph walks the full DAG (out+48 parents); absent boundary parents
    # are filtered inside print_graph, so it's shallow-safe on its own.
    if (graph == 1) { return print_graph(current_hex, limit); }

    # Shallow-clone awareness (v0.8.12): `.sit/shallow` lists boundary
    # commits whose parents were not fetched. When the walk reaches one,
    # stop cleanly instead of erroring on the absent parent object.
    var shallow = map_new();
    if (file_exists(".sit/shallow") == 1) {
        var spair[16];
        if (read_file_heap(".sit/shallow", &spair) == 0) {
            var sbuf = load64(&spair);
            var slen = load64(&spair + 8);
            var sp = 0;
            while (sp + 64 <= slen) {
                var hh = alloc_or_die(65);
                memcpy(hh, sbuf + sp, 64);
                store8(hh + 64, 0);
                map_set(shallow, hh, 1);
                sp = sp + 65;
            }
        }
    }

    var first = 1;
    var shown = 0;
    while (current_hex != 0) {
        if (limit >= 0) {
            if (shown >= limit) { current_hex = 0; }
        }
        if (current_hex == 0) { return 0; }

        var obj[24];
        if (read_object(current_hex, &obj) != 0) {
            eprintln("sit: cannot read commit object");
            return 1;
        }
        var buf = load64(&obj);
        var blen = load64(&obj + 8);
        var coff = load64(&obj + 16);
        var body = buf + coff;
        var body_len = blen - coff;

        var info[56];
        if (parse_commit_body(body, body_len, &info) != 0) {
            eprintln("sit: malformed commit");
            return 1;
        }

        if (oneline == 1) {
            print_commit_oneline(current_hex, body, body_len, load64(&info + 40));
        }
        else {
            if (first == 0) { stdout_write("\n", 1); }
            first = 0;
            print_commit_header(current_hex, &info, body, body_len);
        }

        shown = shown + 1;
        if (map_has(shallow, current_hex) == 1) {
            current_hex = 0;
        }
        else {
            current_hex = load64(&info + 8);
        }
    }
    return 0;
}

# Hash arbitrary content with "blob <len>\0" framing without writing.
# Returns 64-char null-terminated hex C-string (matches `sit add`'s hash).
fn commit_tree_entries(commit_hex) {
    var obj[24];
    if (read_object(commit_hex, &obj) != 0) { return 0; }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var body = buf + coff;
    var body_len = blen - coff;

    var info[56];
    if (parse_commit_body(body, body_len, &info) != 0) { return 0; }
    var tree_hex = load64(&info);
    if (tree_hex == 0) { return 0; }

    var out = vec_new();
    flatten_tree(tree_hex, "", out);
    return out;
}

fn cmd_commit() {
    var ac = argc();
    if (ac < 3) {
        eprintln("usage: sit commit [-S] [-m] <message>");
        return 1;
    }

    # Parse flags + message — support `sit commit <msg>`, `sit commit -m <msg>`,
    # and either of those with `-S` prepended or interleaved.
    var message = 0;
    var sign = 0;
    var k = 2;
    while (k < ac) {
        var a = argv(k);
        if (streq(a, "-S") == 1) { sign = 1; k = k + 1; }
        else {
            if (streq(a, "-m") == 1) {
                if (k + 1 >= ac) {
                    eprintln("sit: -m requires a message argument");
                    return 1;
                }
                message = argv_heap(k + 1);
                k = k + 2;
            }
            else {
                if (message == 0) { message = argv_heap(k); }
                k = k + 1;
            }
        }
    }
    if (message == 0) {
        eprintln("sit: commit message required");
        return 1;
    }

    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    var seed = 0;
    if (sign == 1) {
        seed = load_signing_seed();
        if (seed == 0) {
            eprintln("sit: no signing key (run 'sit key generate')");
            return 1;
        }
    }

    var entries = parse_index();
    if (entries == 0) {
        eprintln("sit: nothing to commit (empty or missing index)");
        return 1;
    }

    sort_entries(entries);
    entries = dedupe_entries(entries);

    var tree_hex = build_tree(entries, 0);
    if (tree_hex == 0) {
        eprintln("sit: failed to write tree object");
        return 1;
    }

    var parent_hex = read_head_ref();
    var merge_parent = read_merge_head();

    var commit_hex = 0;
    if (merge_parent != 0) {
        # Resolving an in-progress merge — 2-parent commit, then clear MERGE_HEAD.
        commit_hex = build_merge_commit_signed(tree_hex, parent_hex, merge_parent, message, seed);
        if (commit_hex != 0) {
            # S-16: a stale MERGE_HEAD silently turns the NEXT `sit commit` into
            # an unintended 2-parent merge. Refuse to declare success on the
            # commit if we couldn't clear it.
            if (sys_unlink(".sit/MERGE_HEAD") != 0) {
                eprintln("sit: commit object written but failed to clear .sit/MERGE_HEAD — next commit may incorrectly become a merge; remove the file manually");
                return 1;
            }
        }
    }
    else {
        commit_hex = build_commit_signed(tree_hex, parent_hex, message, seed);
    }
    if (commit_hex == 0) {
        eprintln("sit: failed to write commit object");
        return 1;
    }

    if (write_head_ref(commit_hex) != 0) {
        eprintln("sit: failed to update HEAD's ref");
        return 1;
    }

    var branch = current_branch_name();
    stdout_write("[", 1);
    if (branch != 0) { stdout_write(branch, strlen(branch)); }
    else             { stdout_write("detached", 8); }
    stdout_write(" ", 1);
    if (merge_parent != 0) {
        stdout_write("(merge) ", 8);
    }
    else {
        if (parent_hex == 0) {
            stdout_write("(root-commit) ", 14);
        }
    }
    stdout_write(commit_hex, 12);
    stdout_write("] ", 2);
    var msg_len = strlen(message);
    stdout_write(message, msg_len);
    if (msg_len > 0) {
        if (load8(message + msg_len - 1) != 10) {
            stdout_write("\n", 1);
        }
    }
    else { stdout_write("\n", 1); }
    return 0;
}

# Parse an "author ..." or "committer ..." line. prefix_len is 7 or 10.
# Writes to out (24 bytes):
#   out[0..8):   identity ptr (heap-copy, null-terminated) — "NAME <EMAIL>"
#   out[8..16):  timestamp (epoch seconds)
#   out[16..24): tz ptr (heap-copy, null-terminated) — e.g. "+0000"
# Returns 0 on success, -1 on parse error.

# --- merge.cyr ---

# merge.cyr — 3-way line-level merge.
#
# LCS-hunk extractors, overlap detection, three_way_line_merge, conflict-file
# renderer, MERGE_HEAD marker, find_merge_base, signed/unsigned merge commit
# builders, cmd_merge (including --abort).

fn extract_hunks(ops) {
    var hunks = vec_new();
    var n = vec_len(ops);
    var i = 0;
    var base_pos = 0;
    var in_hunk = 0;
    var hunk_start = 0;
    var hunk_inserts = 0;

    while (i < n) {
        var op = vec_get(ops, i);
        var kind = load64(op);
        var line = load64(op + 8);

        if (kind == 0) {
            # Keep — close any open hunk
            if (in_hunk == 1) {
                var h = alloc_or_die(24);
                store64(h, hunk_start);
                store64(h + 8, base_pos);
                store64(h + 16, hunk_inserts);
                vec_push(hunks, h);
                in_hunk = 0;
            }
            base_pos = base_pos + 1;
        }
        else {
            if (in_hunk == 0) {
                in_hunk = 1;
                hunk_start = base_pos;
                hunk_inserts = vec_new();
            }
            if (kind == 1) { base_pos = base_pos + 1; }
            else { vec_push(hunk_inserts, line); }
        }
        i = i + 1;
    }

    if (in_hunk == 1) {
        var h = alloc_or_die(24);
        store64(h, hunk_start);
        store64(h + 8, base_pos);
        store64(h + 16, hunk_inserts);
        vec_push(hunks, h);
    }
    return hunks;
}

# Two hunks overlap iff their base ranges share at least one line OR both
# are insert-only hunks (0-length base ranges) at the same base position.
fn hunks_overlap(h1, h2) {
    var s1 = load64(h1);
    var e1 = load64(h1 + 8);
    var s2 = load64(h2);
    var e2 = load64(h2 + 8);
    # Adjacent ranges (e1 == s2 OR e2 == s1) do NOT overlap.
    if (e1 <= s2) {
        if (e1 == s2) {
            if (s1 == e1) { if (s2 == e2) { return 1; } }
            return 0;
        }
        return 0;
    }
    if (e2 <= s1) { return 0; }
    return 1;
}

# Scan two hunk lists; return 1 if any pair overlaps.
fn any_hunk_overlap(hunks_a, hunks_b) {
    var na = vec_len(hunks_a);
    var nb = vec_len(hunks_b);
    var i = 0;
    while (i < na) {
        var j = 0;
        while (j < nb) {
            if (hunks_overlap(vec_get(hunks_a, i), vec_get(hunks_b, j)) == 1) { return 1; }
            j = j + 1;
        }
        i = i + 1;
    }
    return 0;
}

# Append a line-tuple's bytes + "\n" into `buf` starting at `pos`. Returns
# the new position.
fn append_line_to_buf(buf, pos, line_tup) {
    var lp = load64(line_tup);
    var ll = load64(line_tup + 8);
    memcpy(buf + pos, lp, ll);
    store8(buf + pos + ll, 10);
    return pos + ll + 1;
}

# Find a hunk in `hunks` whose base_start == b. Returns the hunk or 0.
fn hunk_starting_at(hunks, b) {
    var n = vec_len(hunks);
    var i = 0;
    while (i < n) {
        var h = vec_get(hunks, i);
        if (load64(h) == b) { return h; }
        i = i + 1;
    }
    return 0;
}

# Three-way line-level merge. Returns a heap pointer to merged content on
# clean merge, or 0 on conflict. Writes the merged length into `out_len_ptr`.
fn three_way_line_merge(base_buf, base_len, ours_buf, ours_len, theirs_buf, theirs_len, out_len_ptr) {
    var base_lines = split_lines(base_buf, base_len);
    var ours_lines = split_lines(ours_buf, ours_len);
    var theirs_lines = split_lines(theirs_buf, theirs_len);

    var ops_bo = lcs_diff(base_lines, ours_lines);
    var ops_bt = lcs_diff(base_lines, theirs_lines);
    if (ops_bo == 0) { return 0; }
    if (ops_bt == 0) { return 0; }

    var ours_hunks = extract_hunks(ops_bo);
    var theirs_hunks = extract_hunks(ops_bt);

    if (any_hunk_overlap(ours_hunks, theirs_hunks) == 1) { return 0; }

    # Walk base; at each position, apply any starting hunk from either side.
    var bn = vec_len(base_lines);
    # Worst-case output size: base + ours_inserts + theirs_inserts + deletions
    var cap = base_len + ours_len + theirs_len + 64;
    var out = alloc_or_die(cap);
    var pos = 0;

    var b = 0;
    while (b <= bn) {
        var oh = hunk_starting_at(ours_hunks, b);
        var th = hunk_starting_at(theirs_hunks, b);

        if (oh != 0) {
            var inserts = load64(oh + 16);
            var ilen = vec_len(inserts);
            var k = 0;
            while (k < ilen) {
                pos = append_line_to_buf(out, pos, vec_get(inserts, k));
                k = k + 1;
            }
            b = load64(oh + 8);
        }
        else {
            if (th != 0) {
                var inserts = load64(th + 16);
                var ilen = vec_len(inserts);
                var k = 0;
                while (k < ilen) {
                    pos = append_line_to_buf(out, pos, vec_get(inserts, k));
                    k = k + 1;
                }
                b = load64(th + 8);
            }
            else {
                if (b < bn) {
                    pos = append_line_to_buf(out, pos, vec_get(base_lines, b));
                }
                b = b + 1;
            }
        }
    }

    store64(out_len_ptr, pos);
    return out;
}

# Write `.sit/MERGE_HEAD` pointing at the other-parent commit for an
# in-progress merge. Next `sit commit` will read this and emit a 2-parent
# commit, then unlink it.
fn write_merge_head(hex) {
    var buf = alloc_or_die(66);
    memcpy(buf, hex, 64);
    store8(buf + 64, 10);
    store8(buf + 65, 0);
    if (file_write_all(".sit/MERGE_HEAD", buf, 65) < 0) { return 0 - 1; }
    return 0;
}

# Read `.sit/MERGE_HEAD` if it exists. Returns heap-allocated 64-char hex
# cstring, or 0 if no merge is in progress.
fn read_merge_head() {
    if (file_exists(".sit/MERGE_HEAD") != 1) { return 0; }
    var fd = file_open(".sit/MERGE_HEAD", 0, 0);
    if (fd < 0) { return 0; }
    var buf = alloc_or_die(80);
    var n = file_read(fd, buf, 80);
    file_close(fd);
    if (n < 64) { return 0; }
    store8(buf + 64, 0);
    return buf;
}

# Write a file with git-style conflict markers for ours/theirs. The markers
# wrap full-file content (we're file-level 3-way, not line-level yet).
#   <<<<<<< HEAD
#   <ours content>
#   =======
#   <theirs content>
#   >>>>>>> <branch_name>
fn write_conflict_file(path, ours_hex, theirs_hex, branch_name) {
    var op[16];
    var tp[16];
    var ours_content = 0;
    var ours_len = 0;
    var theirs_content = 0;
    var theirs_len = 0;
    if (ours_hex != 0) {
        if (read_blob_content(ours_hex, &op) == 0) {
            ours_content = load64(&op);
            ours_len = load64(&op + 8);
        }
    }
    if (theirs_hex != 0) {
        if (read_blob_content(theirs_hex, &tp) == 0) {
            theirs_content = load64(&tp);
            theirs_len = load64(&tp + 8);
        }
    }

    var bn_len = strlen(branch_name);
    var cap = 64 + ours_len + theirs_len + bn_len;
    var out = alloc_or_die(cap);
    var pos = 0;

    memcpy(out + pos, "<<<<<<< HEAD\n", 13); pos = pos + 13;
    if (ours_len > 0) {
        memcpy(out + pos, ours_content, ours_len);
        pos = pos + ours_len;
        if (load8(ours_content + ours_len - 1) != 10) {
            store8(out + pos, 10); pos = pos + 1;
        }
    }
    memcpy(out + pos, "=======\n", 8); pos = pos + 8;
    if (theirs_len > 0) {
        memcpy(out + pos, theirs_content, theirs_len);
        pos = pos + theirs_len;
        if (load8(theirs_content + theirs_len - 1) != 10) {
            store8(out + pos, 10); pos = pos + 1;
        }
    }
    memcpy(out + pos, ">>>>>>> ", 8); pos = pos + 8;
    memcpy(out + pos, branch_name, bn_len); pos = pos + bn_len;
    store8(out + pos, 10); pos = pos + 1;

    ensure_parent_dirs(path);
    if (file_write_all(path, out, pos) < 0) { return 0 - 1; }
    return 0;
}

# Find the lowest common ancestor of two commits. Walks a's ancestry into a
# set, then walks b's and returns the first hit. Returns 0 if no common
# ancestor exists (disjoint histories).
# Author timestamp of a commit (out+24), or 0 if unreadable. Used only as
# a deterministic tiebreak when a criss-cross history has multiple bases.
fn _merge_commit_ts(hex) {
    var obj[24];
    if (read_object(hex, &obj) != 0) { return 0; }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var info[56];
    if (parse_commit_body(buf + coff, blen - coff, &info) != 0) { return 0; }
    return load64(&info + 24);
}

# Lowest common ancestor of two commits over the FULL commit DAG (v0.8.13).
#
# The pre-v0.8.13 implementation walked only the single first-parent chain
# (out+8) on both sides, so for any history with a merge it returned a
# too-high ancestor — e.g. in a diamond where one tip reaches the true base
# only through a merge's second parent, it fell back to the root. This walks
# every parent (out+48), so the base is correct across merges.
#
# Algorithm:
#   1. anc_a = full-DAG ancestor set of `a` (includes `a`).
#   2. BFS from `b`; the first time a path hits a commit in anc_a it's a
#      common ancestor — record it and PRUNE (don't expand its parents, they
#      can only be higher/redundant). This yields the frontier of common
#      ancestors cheaply (bounded by merge width, not history length).
#   3. Reduce: a candidate that is an ancestor of another candidate is
#      redundant (the other is lower). The maximal survivors are the merge
#      base(s); return the newest by author timestamp for determinism.
#
# Criss-cross histories can have several equally-valid bases; sit returns one
# (git would do a recursive merge). Returns a 64-char NUL-terminated hex, or
# 0 if the two commits share no ancestor.
fn find_merge_base(a_hex, b_hex) {
    # Phase 1: ancestors of a (full DAG).
    var anc_a = map_new();
    var q = vec_new();
    var sa = alloc_or_die(65);
    memcpy(sa, a_hex, 64);
    store8(sa + 64, 0);
    vec_push(q, sa);
    while (vec_len(q) > 0) {
        var cur = vec_get(q, vec_len(q) - 1);
        vec_pop(q);
        if (map_has(anc_a, cur) == 1) { }
        else {
            map_set(anc_a, cur, 1);
            var pv = commit_parents_of(cur);
            if (pv != 0) {
                var pi = 0;
                while (pi < vec_len(pv)) {
                    vec_push(q, vec_get(pv, pi));
                    pi = pi + 1;
                }
            }
        }
    }

    # Phase 2: prune-BFS from b → frontier of common ancestors.
    var candidates = vec_new();
    var seen_b = map_new();
    var q2 = vec_new();
    var sb = alloc_or_die(65);
    memcpy(sb, b_hex, 64);
    store8(sb + 64, 0);
    vec_push(q2, sb);
    while (vec_len(q2) > 0) {
        var cur = vec_get(q2, vec_len(q2) - 1);
        vec_pop(q2);
        if (map_has(seen_b, cur) == 1) { }
        else {
            map_set(seen_b, cur, 1);
            if (map_has(anc_a, cur) == 1) {
                vec_push(candidates, cur);
            }
            else {
                var pv = commit_parents_of(cur);
                if (pv != 0) {
                    var pi = 0;
                    while (pi < vec_len(pv)) {
                        vec_push(q2, vec_get(pv, pi));
                        pi = pi + 1;
                    }
                }
            }
        }
    }

    var nc = vec_len(candidates);
    if (nc == 0) { return 0; }
    if (nc == 1) { return vec_get(candidates, 0); }

    # Phase 3: drop redundant candidates (ancestor of another), keep the
    # newest maximal one.
    var best = 0;
    var best_ts = 0 - 1;
    var ci = 0;
    while (ci < nc) {
        var c = vec_get(candidates, ci);
        var redundant = 0;
        var cj = 0;
        while (cj < nc) {
            if (cj != ci) {
                var d = vec_get(candidates, cj);
                if (streq(c, d) == 0) {
                    if (is_ancestor(c, d) == 1) { redundant = 1; cj = nc; }
                }
            }
            if (cj < nc) { cj = cj + 1; }
        }
        if (redundant == 0) {
            var ts = _merge_commit_ts(c);
            if (ts > best_ts) { best = c; best_ts = ts; }
        }
        ci = ci + 1;
    }
    # In a well-formed DAG the partial order always has a maximal element, so
    # `best` is set. Guard the corrupt/cyclic case (mutual is_ancestor marks
    # every candidate redundant) — fall back to a real candidate rather than
    # reporting "no common ancestor" when common ancestors demonstrably exist.
    if (best == 0) { best = vec_get(candidates, 0); }
    return best;
}

# Plumbing: `sit merge-base <commit> <commit>` (v0.8.13). Prints the
# full-DAG lowest common ancestor — git's `git merge-base` shape. Both args
# are resolved through resolve_hash (branch / tag / hex-prefix). Exposes the
# LCA so the merge base is testable independent of a full `sit merge`.
fn cmd_merge_base() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }
    if (argc() < 4) {
        eprintln("usage: sit merge-base <commit> <commit>");
        return 1;
    }

    var resa[72];
    if (resolve_hash(argv(2), &resa) != 1) {
        syscall(SYS_WRITE, STDERR, "sit: cannot resolve '", 21);
        syscall(SYS_WRITE, STDERR, argv(2), strlen(argv(2)));
        syscall(SYS_WRITE, STDERR, "'\n", 2);
        return 1;
    }
    var ha = alloc_or_die(65);
    memcpy(ha, &resa, 64);
    store8(ha + 64, 0);

    var resb[72];
    if (resolve_hash(argv(3), &resb) != 1) {
        syscall(SYS_WRITE, STDERR, "sit: cannot resolve '", 21);
        syscall(SYS_WRITE, STDERR, argv(3), strlen(argv(3)));
        syscall(SYS_WRITE, STDERR, "'\n", 2);
        return 1;
    }
    var hb = alloc_or_die(65);
    memcpy(hb, &resb, 64);
    store8(hb + 64, 0);

    var base = find_merge_base(ha, hb);
    if (base == 0) {
        eprintln("sit: no common ancestor");
        return 1;
    }
    stdout_write(base, 64);
    stdout_write("\n", 1);
    return 0;
}

# Build + write a 2-parent merge commit. Mirrors build_commit but emits two
# `parent <hex>\n` header lines. Returns the new commit's hex hash.
fn build_merge_commit(tree_hex, p1_hex, p2_hex, message) {
    return build_merge_commit_signed(tree_hex, p1_hex, p2_hex, message, 0);
}

fn build_merge_commit_signed(tree_hex, p1_hex, p2_hex, message, seed) {
    var name = getenv("SIT_AUTHOR_NAME");
    if (name == 0) { name = config_get("user.name"); }
    if (name == 0) { name = "sit user"; }
    var email = getenv("SIT_AUTHOR_EMAIL");
    if (email == 0) { email = config_get("user.email"); }
    if (email == 0) { email = "user@localhost"; }
    var ts = clock_epoch_secs();

    var name_len = strlen(name);
    var email_len = strlen(email);
    var msg_len = strlen(message);

    var cap = 512 + msg_len + name_len * 2 + email_len * 2 + 160;
    var body = alloc_or_die(cap);
    var pos = 0;

    memcpy(body + pos, "tree ", 5); pos = pos + 5;
    memcpy(body + pos, tree_hex, 64); pos = pos + 64;
    store8(body + pos, 10); pos = pos + 1;

    memcpy(body + pos, "parent ", 7); pos = pos + 7;
    memcpy(body + pos, p1_hex, 64); pos = pos + 64;
    store8(body + pos, 10); pos = pos + 1;

    memcpy(body + pos, "parent ", 7); pos = pos + 7;
    memcpy(body + pos, p2_hex, 64); pos = pos + 64;
    store8(body + pos, 10); pos = pos + 1;

    memcpy(body + pos, "author ", 7); pos = pos + 7;
    memcpy(body + pos, name, name_len); pos = pos + name_len;
    memcpy(body + pos, " <", 2); pos = pos + 2;
    memcpy(body + pos, email, email_len); pos = pos + email_len;
    memcpy(body + pos, "> ", 2); pos = pos + 2;
    var digits = write_decimal(body + pos, ts); pos = pos + digits;
    memcpy(body + pos, " +0000\n", 7); pos = pos + 7;

    memcpy(body + pos, "committer ", 10); pos = pos + 10;
    memcpy(body + pos, name, name_len); pos = pos + name_len;
    memcpy(body + pos, " <", 2); pos = pos + 2;
    memcpy(body + pos, email, email_len); pos = pos + email_len;
    memcpy(body + pos, "> ", 2); pos = pos + 2;
    digits = write_decimal(body + pos, ts); pos = pos + digits;
    memcpy(body + pos, " +0000\n", 7); pos = pos + 7;

    store8(body + pos, 10); pos = pos + 1;
    memcpy(body + pos, message, msg_len); pos = pos + msg_len;
    if (msg_len == 0) { store8(body + pos, 10); pos = pos + 1; }
    else {
        if (load8(message + msg_len - 1) != 10) {
            store8(body + pos, 10); pos = pos + 1;
        }
    }

    if (seed != 0) {
        var new_len_slot[8];
        store64(&new_len_slot, 0);
        var signed = sign_commit_body(body, pos, seed, &new_len_slot);
        if (signed == 0) {
            return write_typed_object("commit", 6, body, pos);
        }
        return write_typed_object("commit", 6, signed, load64(&new_len_slot));
    }
    return write_typed_object("commit", 6, body, pos);
}

# Find a tree entry's hash_hex for a given path, or 0 if absent.
fn cmd_merge() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }
    if (argc() < 3) {
        eprintln("usage: sit merge [-S] <branch> | sit merge --abort");
        return 1;
    }

    # --abort: restore working tree to HEAD, clear MERGE_HEAD.
    if (streq(argv(2), "--abort") == 1) {
        if (file_exists(".sit/MERGE_HEAD") != 1) {
            eprintln("sit: no merge in progress");
            return 1;
        }
        var head = read_head_ref();
        if (head != 0) {
            # S-16: propagate materialize failure so we don't claim "merge
            # aborted" when the working tree wasn't actually restored.
            if (materialize_target(head) != 0) {
                eprintln("sit: failed to restore working tree from HEAD; .sit/MERGE_HEAD left in place");
                return 1;
            }
        }
        # S-16: a stale MERGE_HEAD silently turns the next commit into a
        # 2-parent merge. Same cliff as cmd_commit's clear path.
        if (sys_unlink(".sit/MERGE_HEAD") != 0) {
            eprintln("sit: failed to clear .sit/MERGE_HEAD — next commit may incorrectly become a merge; remove manually");
            return 1;
        }
        stdout_write("merge aborted\n", 14);
        return 0;
    }

    var merge_sign = 0;
    var merge_target_idx = 2;
    if (streq(argv(2), "-S") == 1) {
        merge_sign = 1;
        merge_target_idx = 3;
        if (argc() < 4) {
            eprintln("usage: sit merge [-S] <branch>");
            return 1;
        }
    }
    var target_name = argv_heap(merge_target_idx);
    var tnlen = strlen(target_name);

    var target_hex[72];
    var rr = resolve_hash(target_name, &target_hex);
    if (rr == 0 - 2) { eprintln("sit: merge target too short"); return 1; }
    if (rr == 0 - 1) { eprintln("sit: ambiguous merge target"); return 1; }
    if (rr == 0)     {
        syscall(SYS_WRITE, STDERR, "sit: '", 6);
        syscall(SYS_WRITE, STDERR, target_name, tnlen);
        syscall(SYS_WRITE, STDERR, "' is not a known branch, tag, or commit\n", 40);
        return 1;
    }

    var head_hex = read_head_ref();
    if (head_hex == 0) {
        eprintln("sit: current branch has no commits");
        return 1;
    }

    if (streq(&target_hex, head_hex) == 1) {
        stdout_write("already up to date\n", 19);
        return 0;
    }
    if (is_ancestor(&target_hex, head_hex) == 1) {
        stdout_write("already up to date\n", 19);
        return 0;
    }

    if (is_ancestor(head_hex, &target_hex) == 1) {
        if (is_dirty() == 1) {
            eprintln("sit: working tree has uncommitted changes");
            eprintln("sit:   commit or revert before merging");
            return 1;
        }
        if (write_head_ref(&target_hex) != 0) {
            eprintln("sit: failed to update branch ref");
            return 1;
        }
        materialize_target(&target_hex);

        stdout_write("fast-forward to ", 16);
        stdout_write(&target_hex, 12);
        stdout_write("\n", 1);
        return 0;
    }

    # Divergent → 3-way merge (file-level)
    if (is_dirty() == 1) {
        eprintln("sit: working tree has uncommitted changes");
        eprintln("sit:   commit or revert before merging");
        return 1;
    }

    var base_hex = find_merge_base(head_hex, &target_hex);
    if (base_hex == 0) {
        eprintln("sit: no common ancestor between current branch and target");
        return 1;
    }

    var base_entries = commit_tree_entries(base_hex);
    var ours_entries = commit_tree_entries(head_hex);
    var theirs_entries = commit_tree_entries(&target_hex);
    if (ours_entries == 0) { ours_entries = vec_new(); }
    if (theirs_entries == 0) { theirs_entries = vec_new(); }
    if (base_entries == 0) { base_entries = vec_new(); }

    var paths = three_way_path_set(base_entries, ours_entries, theirs_entries);
    var merged = vec_new();
    var conflicts = vec_new();

    var pn = vec_len(paths);
    var pi = 0;
    while (pi < pn) {
        var p = vec_get(paths, pi);
        var base_h = tree_find_hash(base_entries, p);
        var ours_h = tree_find_hash(ours_entries, p);
        var theirs_h = tree_find_hash(theirs_entries, p);

        # Result hash: 0 means "not in merged tree"
        var result_h = 0;
        var needs_conflict = 0;

        if (ours_h != 0) {
            if (theirs_h != 0) {
                if (streq(ours_h, theirs_h) == 1) {
                    result_h = ours_h;
                }
                else {
                    if (base_h != 0) {
                        if (streq(base_h, ours_h) == 1)   { result_h = theirs_h; }
                        else {
                            if (streq(base_h, theirs_h) == 1) { result_h = ours_h; }
                            else { needs_conflict = 1; }
                        }
                    }
                    else { needs_conflict = 1; }
                }
            }
            else {
                # theirs absent
                if (base_h != 0) {
                    if (streq(base_h, ours_h) == 1) { result_h = 0; }  # deleted by theirs
                    else { needs_conflict = 1; }  # ours modified, theirs deleted
                }
                else {
                    # Added only by ours
                    result_h = ours_h;
                }
            }
        }
        else {
            # ours absent
            if (theirs_h != 0) {
                if (base_h != 0) {
                    if (streq(base_h, theirs_h) == 1) { result_h = 0; }  # deleted by ours
                    else { needs_conflict = 1; }  # theirs modified, ours deleted
                }
                else {
                    result_h = theirs_h;
                }
            }
        }

        # Try line-level diff3 before declaring a file-level conflict.
        # Applies when base/ours/theirs all exist AND hunks don't overlap.
        if (needs_conflict == 1) {
            if (base_h != 0) {
                if (ours_h != 0) {
                    if (theirs_h != 0) {
                        var bp[16]; var op[16]; var tp[16];
                        if (read_blob_content(base_h, &bp) == 0) {
                            if (read_blob_content(ours_h, &op) == 0) {
                                if (read_blob_content(theirs_h, &tp) == 0) {
                                    var merged_len[8];
                                    var merged_buf = three_way_line_merge(
                                        load64(&bp), load64(&bp + 8),
                                        load64(&op), load64(&op + 8),
                                        load64(&tp), load64(&tp + 8),
                                        &merged_len);
                                    if (merged_buf != 0) {
                                        # Line-level merge succeeded — write as a new blob
                                        var new_hex = write_blob_object(merged_buf, load64(&merged_len));
                                        if (new_hex != 0) {
                                            result_h = new_hex;
                                            needs_conflict = 0;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        if (needs_conflict == 1) {
            var pc = alloc_or_die(strlen(p) + 1);
            memcpy(pc, p, strlen(p));
            store8(pc + strlen(p), 0);
            vec_push(conflicts, pc);
        }
        else {
            if (result_h != 0) {
                var bytes = hex_decode(result_h, 64);
                if (bytes != 0) {
                    var entry = alloc_or_die(40);
                    memcpy(entry, bytes, 32);
                    var pc = alloc_or_die(strlen(p) + 1);
                    memcpy(pc, p, strlen(p));
                    store8(pc + strlen(p), 0);
                    store64(entry + 32, pc);
                    vec_push(merged, entry);
                }
            }
        }
        pi = pi + 1;
    }

    if (vec_len(conflicts) > 0) {
        # Write auto-merged files to working tree so clean paths don't appear
        # conflicted in subsequent sit status.
        var mi = 0;
        var mn = vec_len(merged);
        while (mi < mn) {
            var me = vec_get(merged, mi);
            var mpath = load64(me + 32);
            var bytes32 = me;
            var mhex = hex_encode(bytes32, 32);
            ensure_parent_dirs(mpath);
            var mp[16];
            if (read_blob_content(mhex, &mp) == 0) {
                file_write_all(mpath, load64(&mp), load64(&mp + 8));
            }
            mi = mi + 1;
        }

        # Write conflict-marker files for each conflicting path.
        var ci = 0;
        while (ci < vec_len(conflicts)) {
            var cp = vec_get(conflicts, ci);
            var ours_h = tree_find_hash(ours_entries, cp);
            var theirs_h = tree_find_hash(theirs_entries, cp);
            write_conflict_file(cp, ours_h, theirs_h, target_name);
            ci = ci + 1;
        }

        # Track MERGE_HEAD so the next sit commit produces a 2-parent commit.
        write_merge_head(&target_hex);

        syscall(SYS_WRITE, STDERR, "sit: merge conflict in ", 23);
        var buf[24];
        var digits = write_decimal(&buf, vec_len(conflicts));
        syscall(SYS_WRITE, STDERR, &buf, digits);
        syscall(SYS_WRITE, STDERR, " file(s):\n", 10);
        ci = 0;
        while (ci < vec_len(conflicts)) {
            syscall(SYS_WRITE, STDERR, "  ", 2);
            var cp2 = vec_get(conflicts, ci);
            syscall(SYS_WRITE, STDERR, cp2, strlen(cp2));
            syscall(SYS_WRITE, STDERR, "\n", 1);
            ci = ci + 1;
        }
        eprintln("sit: edit the marked files, 'sit add' them, then 'sit commit'");
        eprintln("sit:   'sit merge --abort' to cancel and restore the working tree");
        return 1;
    }

    # Clean merge — sort entries, build tree, create 2-parent commit
    sort_entries(merged);
    var tree_hex = build_tree(merged, 0);
    if (tree_hex == 0) {
        eprintln("sit: failed to write merged tree");
        return 1;
    }

    var msg_cap = 64 + tnlen + 32;
    var msg = alloc_or_die(msg_cap);
    memcpy(msg, "Merge branch '", 14);
    memcpy(msg + 14, target_name, tnlen);
    memcpy(msg + 14 + tnlen, "'", 1);
    store8(msg + 14 + tnlen + 1, 0);

    var head_copy = alloc_or_die(65);
    memcpy(head_copy, head_hex, 64);
    store8(head_copy + 64, 0);

    var merge_seed = 0;
    if (merge_sign == 1) {
        merge_seed = load_signing_seed();
        if (merge_seed == 0) {
            eprintln("sit: no signing key (run 'sit key generate')");
            return 1;
        }
    }
    var merge_hex = build_merge_commit_signed(tree_hex, head_copy, &target_hex, msg, merge_seed);
    if (merge_hex == 0) {
        eprintln("sit: failed to write merge commit");
        return 1;
    }

    if (write_head_ref(merge_hex) != 0) {
        eprintln("sit: failed to update branch ref");
        return 1;
    }
    materialize_target(merge_hex);

    stdout_write("merge ", 6);
    stdout_write(merge_hex, 12);
    stdout_write(": Merge branch '", 16);
    stdout_write(target_name, tnlen);
    stdout_write("'\n", 2);
    return 0;
}

# --- sign.cyr ---

# sign.cyr — ed25519 signing over commit bodies.
#
# Key material lives at ~/.sit/signing_key (32B seed hex, chmod 0600) plus
# ~/.sit/signing_key.pub (32B pubkey hex). Signed commits splice a single
# `sitsig <sig-hex> <pub-hex>\n` header line between `committer` and the
# blank separator — the signed payload is the body WITHOUT that line, so
# verification is self-consistent. See ADR 0002.

# Path helpers for ~/.sit/ signing keys. Return heap cstrings or 0 if HOME unset.
fn signing_home_dir() {
    var home = getenv("HOME");
    if (home == 0) { return 0; }
    var hlen = strlen(home);
    var p = alloc(hlen + 6);
    memcpy(p, home, hlen);
    memcpy(p + hlen, "/.sit", 5);
    store8(p + hlen + 5, 0);
    return p;
}
fn signing_key_path() {
    var home = getenv("HOME");
    if (home == 0) { return 0; }
    var hlen = strlen(home);
    var p = alloc(hlen + 18);
    memcpy(p, home, hlen);
    memcpy(p + hlen, "/.sit/signing_key", 17);
    store8(p + hlen + 17, 0);
    return p;
}
fn signing_pub_path() {
    var home = getenv("HOME");
    if (home == 0) { return 0; }
    var hlen = strlen(home);
    var p = alloc(hlen + 22);
    memcpy(p, home, hlen);
    memcpy(p + hlen, "/.sit/signing_key.pub", 21);
    store8(p + hlen + 21, 0);
    return p;
}

# Load 32B seed from ~/.sit/signing_key (hex-encoded, 64 chars). Returns
# heap ptr on success, 0 if missing or malformed.
fn load_signing_seed() {
    var p = signing_key_path();
    if (p == 0) { return 0; }
    if (file_exists(p) != 1) { return 0; }
    var buf = alloc(80);
    var n = file_read_all(p, buf, 80);
    if (n < 64) { return 0; }
    return hex_decode(buf, 64);
}

# Load 32B pubkey from ~/.sit/signing_key.pub (hex-encoded, 64 chars).
fn load_signing_pubkey() {
    var p = signing_pub_path();
    if (p == 0) { return 0; }
    if (file_exists(p) != 1) { return 0; }
    var buf = alloc(80);
    var n = file_read_all(p, buf, 80);
    if (n < 64) { return 0; }
    return hex_decode(buf, 64);
}

# Sign `body` (the full unsigned commit body) with the 32-byte seed,
# returning a new heap buffer that splices a `sitsig <sig-hex> <pub-hex>\n`
# line in after the last header (just before the blank line separating
# headers from message). Writes the new length to *out_len.
#
# Layout in the returned buffer:
#   <headers up through committer\n>
#   sitsig <128 hex sig> <64 hex pub>\n
#   \n
#   <message>
#
# The signed payload is the input `body` verbatim (i.e. without the sitsig
# line) — so verification just re-parses, strips the sitsig line, and calls
# ed25519_verify against what's left.
fn sign_commit_body(body, body_len, seed, out_len) {
    # Find blank line "\n\n" separating headers from message. We know it
    # exists because build_commit always writes one.
    var split = 0;
    var i = 0;
    while (i + 1 < body_len) {
        if (load8(body + i) == 10) {
            if (load8(body + i + 1) == 10) { split = i + 1; i = body_len; }
            else { i = i + 1; }
        }
        else { i = i + 1; }
    }
    if (split == 0) { return 0; }

    var sk[64];
    var pk[32];
    ed25519_keypair(seed, &sk, &pk);
    var sig[64];
    ed25519_sign(&sk, body, body_len, &sig);
    var sig_hex = hex_encode(&sig, 64);
    var pk_hex = hex_encode(&pk, 32);

    # "sitsig " (7) + 128 sig + " " (1) + 64 pub + "\n" (1) = 201
    var sitsig_len = 201;
    var new_len = body_len + sitsig_len;
    var out = alloc(new_len + 1);
    memcpy(out, body, split);
    var pos = split;
    memcpy(out + pos, "sitsig ", 7); pos = pos + 7;
    memcpy(out + pos, sig_hex, 128); pos = pos + 128;
    store8(out + pos, 32); pos = pos + 1;
    memcpy(out + pos, pk_hex, 64); pos = pos + 64;
    store8(out + pos, 10); pos = pos + 1;
    memcpy(out + pos, body + split, body_len - split);
    pos = pos + (body_len - split);
    store64(out_len, pos);
    return out;
}

# Scan `body` for a `sitsig <sig-hex> <pub-hex>\n` line in the header block.
# On match: decodes sig (64B) into out_sig, pub (32B) into out_pub, and builds
# a stripped-body heap buffer (with that line removed) at *out_stripped_ptr
# with length written to *out_stripped_len. Returns 1 on match, 0 otherwise.
fn extract_sitsig(body, body_len, out_sig, out_pub, out_stripped_ptr, out_stripped_len) {
    # S-19: a sitsig line is exactly 200 bytes plus its trailing newline (201).
    # Bodies shorter than that can't carry one, and the inner `body_len - 201`
    # would underflow to ~2^64 if reached.
    if (body_len < 201) { return 0; }
    var pos = 0;
    var in_headers = 1;
    while (pos < body_len) {
        if (in_headers == 0) { pos = body_len; }
        else {
            var nl = pos;
            while (nl < body_len) {
                if (load8(body + nl) == 10) { break; }
                nl = nl + 1;
            }
            var line_len = nl - pos;
            if (line_len == 0) { in_headers = 0; }
            else {
                if (line_len == 200) {
                    if (memeq(body + pos, "sitsig ", 7) == 1) {
                        if (load8(body + pos + 135) == 32) {
                            # S-20: belt-and-suspenders. sigil's hex_decode
                            # already returns null on invalid chars, but
                            # gating on hex_is_valid first locks in the
                            # "validate before decode" invariant against
                            # any future loosening of hex_decode's contract.
                            var sig_ok = hex_is_valid(body + pos + 7, 128);
                            var pub_ok = hex_is_valid(body + pos + 136, 64);
                            var sig_bytes = 0;
                            var pub_bytes = 0;
                            if (sig_ok == 1) { if (pub_ok == 1) {
                                sig_bytes = hex_decode(body + pos + 7, 128);
                                pub_bytes = hex_decode(body + pos + 136, 64);
                            } }
                            if (sig_bytes != 0) {
                                if (pub_bytes != 0) {
                                    memcpy(out_sig, sig_bytes, 64);
                                    memcpy(out_pub, pub_bytes, 32);
                                    var stripped_len = body_len - 201;
                                    var out = alloc(stripped_len + 1);
                                    memcpy(out, body, pos);
                                    memcpy(out + pos, body + nl + 1, body_len - (nl + 1));
                                    store8(out + stripped_len, 0);
                                    store64(out_stripped_ptr, out);
                                    store64(out_stripped_len, stripped_len);
                                    return 1;
                                }
                            }
                        }
                    }
                }
                pos = nl + 1;
            }
            if (in_headers == 1) { pos = nl + 1; }
        }
    }
    return 0;
}

# Verify a commit body that may contain a sitsig line. Returns:
#   1 = sitsig present and signature valid
#   0 = sitsig present but signature invalid
#  -1 = no sitsig present
# When 1 or 0 are returned, out_pub (32B buffer) is filled.
fn verify_commit_body(body, body_len, out_pk) {
    var sig[64];
    var pk[32];
    var stripped_ptr_slot[8];
    var stripped_len_slot[8];
    store64(&stripped_ptr_slot, 0);
    store64(&stripped_len_slot, 0);
    var r = extract_sitsig(body, body_len, &sig, &pk, &stripped_ptr_slot, &stripped_len_slot);
    if (r == 0) { return 0 - 1; }
    memcpy(out_pk, &pk, 32);
    var stripped = load64(&stripped_ptr_slot);
    var slen = load64(&stripped_len_slot);
    return ed25519_verify(&pk, stripped, slen, &sig);
}

fn cmd_key_generate() {
    var dir = signing_home_dir();
    if (dir == 0) { eprintln("sit: HOME not set"); return 1; }
    if (ensure_dir(dir) != 0) {
        eprintln("sit: cannot create ~/.sit/");
        return 1;
    }
    var priv_path = signing_key_path();
    var pub_path = signing_pub_path();
    if (file_exists(priv_path) == 1) {
        eprintln("sit: signing key already exists (delete ~/.sit/signing_key to regenerate)");
        return 1;
    }

    var sk[64];
    var pk[32];
    var gen = ed25519_generate_keypair(&sk, &pk);
    if (gen != 1) {
        eprintln("sit: entropy error generating key");
        return 1;
    }
    # sk layout is seed||pk; store only the 32-byte seed (hex).
    var seed_hex = hex_encode(&sk, 32);
    # S-12: O_EXCL closes the symlink-plant TOCTOU between the
    # file_exists() check above and this open. O_EXCL is 0x80 on Linux.
    if (path_is_symlink(priv_path) == 1) {
        eprintln("sit: refusing to overwrite symlink at signing key path");
        return 1;
    }
    var fd = sys_open(priv_path, O_WRONLY | O_CREAT | O_TRUNC | 0x80, 0x180);
    if (fd < 0) { eprintln("sit: cannot write signing key"); return 1; }
    syscall(SYS_WRITE, fd, seed_hex, 64);
    syscall(SYS_WRITE, fd, "\n", 1);
    sys_close(fd);

    var pub_hex = hex_encode(&pk, 32);
    var pub_out = alloc(66);
    memcpy(pub_out, pub_hex, 64);
    store8(pub_out + 64, 10);
    if (file_write_all(pub_path, pub_out, 65) < 0) {
        eprintln("sit: cannot write public key");
        return 1;
    }

    stdout_write("generated ed25519 key ", 22);
    stdout_write(pub_hex, 12);
    stdout_write("\n  private: ", 12);
    stdout_write(priv_path, strlen(priv_path));
    stdout_write(" (0600)\n  public:  ", 19);
    stdout_write(pub_path, strlen(pub_path));
    stdout_write("\n", 1);
    return 0;
}

fn cmd_key_show() {
    var pk = load_signing_pubkey();
    if (pk == 0) {
        eprintln("sit: no signing key (run 'sit key generate')");
        return 1;
    }
    var hex = hex_encode(pk, 32);
    stdout_write(hex, 64);
    stdout_write("\n", 1);
    return 0;
}

fn cmd_key() {
    if (argc() < 3) {
        eprintln("usage: sit key generate | sit key show");
        return 1;
    }
    var sub = argv(2);
    if (streq(sub, "generate") == 1) { return cmd_key_generate(); }
    if (streq(sub, "show")     == 1) { return cmd_key_show(); }
    eprintln("sit: unknown key subcommand");
    return 1;
}

fn cmd_verify_commit() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }
    var hex[72];
    if (argc() < 3) {
        var head = read_head_ref();
        if (head == 0) { eprintln("sit: no commits yet"); return 1; }
        memcpy(&hex, head, 64);
        store8(&hex + 64, 0);
    }
    else {
        var prefix = argv_heap(2);
        var rr = resolve_hash(prefix, &hex);
        if (rr == 0 - 2) { eprintln("sit: hash prefix too short (min 4 chars)"); return 1; }
        if (rr == 0 - 1) { eprintln("sit: ambiguous hash prefix"); return 1; }
        if (rr == 0)     { eprintln("sit: no object matches"); return 1; }
    }
    var obj[24];
    if (read_object(&hex, &obj) != 0) {
        eprintln("sit: cannot read object");
        return 1;
    }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var body = buf + coff;
    var body_len = blen - coff;

    var pk[32];
    var vr = verify_commit_body(body, body_len, &pk);
    if (vr == 0 - 1) {
        stdout_write("no signature on ", 16);
        stdout_write(&hex, 12);
        stdout_write("\n", 1);
        return 1;
    }
    var pk_hex = hex_encode(&pk, 32);
    if (vr == 1) {
        stdout_write("good signature on ", 18);
        stdout_write(&hex, 12);
        stdout_write(" (key ", 6);
        stdout_write(pk_hex, 64);
        stdout_write(")\n", 2);
        return 0;
    }
    stdout_write("BAD signature on ", 17);
    stdout_write(&hex, 12);
    stdout_write(" (key ", 6);
    stdout_write(pk_hex, 64);
    stdout_write(")\n", 2);
    return 1;
}

# --- wire.cyr ---

# wire.cyr — local-path wire protocol.
#
# Remote config helpers (remote.<name>.url), db_* parameterized object readers
# so the same reachability walker runs against local or remote patra stores,
# BFS reachability, object copy loop, fast-forward check, and all five wire
# commands: remote, fetch, pull, push, clone.

fn remote_url(name) {
    var nlen = strlen(name);
    var key = alloc(nlen + 12);
    memcpy(key, "remote.", 7);
    memcpy(key + 7, name, nlen);
    memcpy(key + 7 + nlen, ".url", 4);
    store8(key + 7 + nlen + 4, 0);
    return config_get(key);
}

# Transport dispatch — split into read / write since http unlocks in
# two separate v0.7.x patches: read in 0.7.3 (fetch/clone), write in
# 0.7.6 (push). SSH unlocks read-side in v0.8.2; SSH push lands in a
# follow-on. HTTPS is blocked on first-party Cyrius TLS (ADR 0007).
# Caller pattern:
#   if (wire_transport_check_readable(url) != 0) { return 1; }
#   if (wire_transport_check_writable(url) != 0) { return 1; }

fn wire_transport_check_readable(url) {
    var s = url_scheme(url);
    if (s == URL_SCHEME_FILE) { return 0; }
    if (s == URL_SCHEME_HTTP) { return 0; }   # v0.7.3
    if (s == URL_SCHEME_SSH)  { return 0; }   # v0.8.2
    if (s == URL_SCHEME_HTTPS) { return 0; }  # TLS 1.3 via tls_native, TOFU-pinned (read-only client)
    eprintln("sit: unrecognized URL scheme");
    return 1;
}

fn wire_transport_check_writable(url) {
    var s = url_scheme(url);
    if (s == URL_SCHEME_FILE) { return 0; }
    if (s == URL_SCHEME_HTTP) { return 0; }   # v0.7.6
    if (s == URL_SCHEME_SSH)  { return 0; }   # v0.8.3
    if (s == URL_SCHEME_HTTPS) { return 0; }  # TLS 1.3 via tls_native, TOFU-pinned (push, v0.8.9)
    eprintln("sit: unrecognized URL scheme");
    return 1;
}

# Strip a `file://` scheme prefix if present; otherwise return a heap copy.
fn remote_normalize(url) {
    var ulen = strlen(url);
    var start = 0;
    if (ulen > 7) {
        if (memeq(url, "file://", 7) == 1) { start = 7; }
    }
    var out_len = ulen - start;
    var out = alloc(out_len + 1);
    memcpy(out, url + start, out_len);
    store8(out + out_len, 0);
    return out;
}

# Join repo_path + "/.sit/objects.patra" → heap cstring.
fn remote_objects_path(repo_path) {
    var rl = strlen(repo_path);
    var p = alloc(rl + 24);
    memcpy(p, repo_path, rl);
    memcpy(p + rl, "/.sit/objects.patra", 19);
    store8(p + rl + 19, 0);
    return p;
}

# Open (or create) a patra objects DB at `<repo_path>/.sit/objects.patra`.
# S-04: refuse to follow a symlink at either `.sit/` or the patra file itself.
# Blocks the CVE-2023-22490 shape where a malicious remote's .sit points at
# /etc/shadow or similar.
fn remote_objects_open(repo_path) {
    patra_init();
    var rl = strlen(repo_path);
    var sit_dir = alloc(rl + 6);
    memcpy(sit_dir, repo_path, rl);
    memcpy(sit_dir + rl, "/.sit", 5);
    store8(sit_dir + rl + 5, 0);
    if (path_is_symlink(sit_dir) == 1) {
        eprintln("sit: refusing to follow symlink at remote's .sit/");
        return 0;
    }
    var p = remote_objects_path(repo_path);
    if (path_is_symlink(p) == 1) {
        eprintln("sit: refusing to follow symlink at remote's .sit/objects.patra");
        return 0;
    }
    var db = patra_open(p);
    if (db == 0) { return 0; }
    patra_exec(db, "CREATE TABLE objects (hash STR, ty INT, content BYTES)");
    return db;
}

# Return 1 if `hex` exists in the given opened object DB, else 0.
fn db_object_has(db, hex) {
    var sql = alloc(128);
    memcpy(sql, "SELECT hash FROM objects WHERE hash = '", 39);
    memcpy(sql + 39, hex, 64);
    memcpy(sql + 39 + 64, "'", 1);
    store8(sql + 39 + 64 + 1, 0);
    var rs = patra_query(db, sql);
    if (rs == 0) { return 0; }
    var cnt = patra_result_count(rs);
    patra_result_free(rs);
    if (cnt > 0) { return 1; }
    return 0;
}

# Read compressed bytes + type code from an opened db by hex.
# Layout at out: 0..8 = compressed_ptr, 8..16 = clen, 16..24 = ty.
fn db_object_read_raw(db, hex, out) {
    var sql = alloc(128);
    memcpy(sql, "SELECT content, ty FROM objects WHERE hash = '", 46);
    memcpy(sql + 46, hex, 64);
    memcpy(sql + 46 + 64, "'", 1);
    store8(sql + 46 + 64 + 1, 0);
    var rs = patra_query(db, sql);
    if (rs == 0) { return 0 - 1; }
    if (patra_result_count(rs) == 0) { patra_result_free(rs); return 0 - 2; }
    var blen = patra_result_get_bytes_len(rs, 0, 0);
    if (blen <= 0) { patra_result_free(rs); return 0 - 3; }
    var compressed = alloc(blen);
    if (patra_result_read_bytes(db, rs, 0, 0, compressed) != 0) {
        patra_result_free(rs);
        return 0 - 4;
    }
    var ty = patra_result_get_int(rs, 0, 1);
    patra_result_free(rs);
    store64(out, compressed);
    store64(out + 8, blen);
    store64(out + 16, ty);
    return 0;
}

# Read + decompress from an opened db. Same out-layout as read_object.
fn db_object_read_decompressed(db, hex, out) {
    var raw[24];
    return db_object_read_both(db, hex, &raw, out);
}

# v0.7.5: decompress a {compressed, clen, ty} 24-byte struct into a
# 24-byte decompressed view {ptr, dlen, content_offset_after_NUL}.
# Same 4×-initial / 16 MiB-ceiling sizing as db_object_read_both —
# extracted so cache-hit paths in the phased walker can decompress
# without re-reading the compressed bytes from the transport.
# Returns 0 on success, negative on decompression failure / OOM.
fn _decompress_raw_into(raw, deco_out) {
    var compressed = load64(raw);
    var clen = load64(raw + 8);
    var dec_cap = clen * 4;
    if (dec_cap < 4096) { dec_cap = 4096; }
    if (dec_cap > 16 * 1024 * 1024) { dec_cap = 16 * 1024 * 1024; }
    var decompressed = alloc(dec_cap);
    if (decompressed == 0) { return 0 - 2; }
    var dlen = zlib_decompress(compressed, clen, decompressed, dec_cap);
    if (dlen == 0 - ERR_BUFFER_TOO_SMALL) {
        if (dec_cap < 16 * 1024 * 1024) {
            dec_cap = 16 * 1024 * 1024;
            decompressed = alloc(dec_cap);
            if (decompressed == 0) { return 0 - 2; }
            dlen = zlib_decompress(compressed, clen, decompressed, dec_cap);
        }
    }
    if (dlen <= 0) { return 0 - 3; }
    var nul = 0;
    while (nul < dlen) {
        if (load8(decompressed + nul) == 0) { break; }
        nul = nul + 1;
    }
    if (nul >= dlen) { return 0 - 4; }
    store64(deco_out,      decompressed);
    store64(deco_out +  8, dlen);
    store64(deco_out + 16, nul + 1);
    return 0;
}

# Variant that returns BOTH the compressed bytes (raw_out, 24 bytes:
# {compressed_ptr, clen, ty}) and the decompressed view (deco_out, 24 bytes:
# {decompressed_ptr, dlen, content_offset}). Used by walk_reachable_* so the
# compressed bytes can be cached and reused by copy_objects without a second
# source-DB read (P-04).
fn db_object_read_both(db, hex, raw_out, deco_out) {
    if (db_object_read_raw(db, hex, raw_out) != 0) { return 0 - 1; }
    var compressed = load64(raw_out);
    var clen = load64(raw_out + 8);
    # S-08 + P-06 (v0.6.9): 4× initial; retry at the 16 MiB ceiling only
    # on confirmed -ERR_BUFFER_TOO_SMALL. Matches read_object's policy so
    # reachability walks and local reads see the same failure modes.
    var dec_cap = clen * 4;
    if (dec_cap < 4096) { dec_cap = 4096; }
    if (dec_cap > 16 * 1024 * 1024) { dec_cap = 16 * 1024 * 1024; }
    var decompressed = alloc(dec_cap);
    if (decompressed == 0) { return 0 - 2; }
    var dlen = zlib_decompress(compressed, clen, decompressed, dec_cap);
    if (dlen == 0 - ERR_BUFFER_TOO_SMALL) {
        if (dec_cap < 16 * 1024 * 1024) {
            dec_cap = 16 * 1024 * 1024;
            decompressed = alloc(dec_cap);
            if (decompressed == 0) { return 0 - 2; }
            dlen = zlib_decompress(compressed, clen, decompressed, dec_cap);
        }
    }
    if (dlen <= 0) { return 0 - 3; }
    var nul = 0;
    while (nul < dlen) {
        if (load8(decompressed + nul) == 0) { break; }
        nul = nul + 1;
    }
    if (nul >= dlen) { return 0 - 4; }
    store64(deco_out, decompressed);
    store64(deco_out + 8, dlen);
    store64(deco_out + 16, nul + 1);
    return 0;
}

# Insert a pre-compressed object (hex key, type code, zlib bytes) into db.
# Returns 0 if a new row was inserted; 1 if the object was already present
# (caller can use this to count "actually new" inserts vs. all attempts);
# negative on error from patra_insert_row.
fn db_object_insert_raw(db, hex, type_code, compressed, clen) {
    if (db_object_has(db, hex) == 1) { return 1; }
    var types[24];
    store64(&types +  0, 1);
    store64(&types +  8, 0);
    store64(&types + 16, 2);
    var ivals[24];
    store64(&ivals + 8, type_code);
    var sptrs[24];
    store64(&sptrs + 0, hex);
    var slens[24];
    store64(&slens + 0, 64);
    var bptrs[24];
    store64(&bptrs + 16, compressed);
    var blens[24];
    store64(&blens + 16, clen);
    return patra_insert_row(db, "objects", 7, 3,
        &types, &ivals, &sptrs, &slens, &bptrs, &blens);
}

# ── obj_src abstraction (v0.7.3) ───────────────────────────────────
#
# walk_reachable_* and copy_objects need to operate against either a
# local patra DB (file:// fetch + push, both ends of clone) or an
# HTTP remote (http:// fetch + clone). An obj_src wraps either kind
# in a 16-byte tagged handle so the callers don't carry transport
# knowledge:
#
#   0..8  : kind tag (OBJ_SRC_DB / OBJ_SRC_HTTP)
#   8..16 : payload (patra db ptr OR http_remote handle)
#
# Lifetime: the underlying handle is owned by the obj_src caller.
# obj_src_close is a no-op today; explicit patra_close /
# wire_http_close on the underlying payload still happens at the
# caller per the existing fetch/push shape.

var OBJ_SRC_DB = 0;
var OBJ_SRC_HTTP = 1;
var OBJ_SRC_SSH = 2;

fn obj_src_for_db(db) {
    var s = alloc(16);
    store64(s, OBJ_SRC_DB);
    store64(s + 8, db);
    return s;
}

fn obj_src_for_http(handle) {
    var s = alloc(16);
    store64(s, OBJ_SRC_HTTP);
    store64(s + 8, handle);
    return s;
}

fn obj_src_for_ssh(handle) {
    var s = alloc(16);
    store64(s, OBJ_SRC_SSH);
    store64(s + 8, handle);
    return s;
}

fn obj_src_kind(s) { return load64(s); }
fn obj_src_payload(s) { return load64(s + 8); }

fn obj_src_read_raw(src, hex, raw_out) {
    var k = obj_src_kind(src);
    if (k == OBJ_SRC_DB)   { return db_object_read_raw(obj_src_payload(src), hex, raw_out); }
    if (k == OBJ_SRC_HTTP) { return http_remote_read_raw(obj_src_payload(src), hex, raw_out); }
    if (k == OBJ_SRC_SSH)  { return ssh_remote_read_raw(obj_src_payload(src), hex, raw_out); }
    return 0 - 99;
}

fn obj_src_read_both(src, hex, raw_out, deco_out) {
    var k = obj_src_kind(src);
    if (k == OBJ_SRC_DB)   { return db_object_read_both(obj_src_payload(src), hex, raw_out, deco_out); }
    if (k == OBJ_SRC_HTTP) { return http_remote_read_both(obj_src_payload(src), hex, raw_out, deco_out); }
    if (k == OBJ_SRC_SSH)  { return ssh_remote_read_both(obj_src_payload(src), hex, raw_out, deco_out); }
    return 0 - 99;
}

# v0.7.4 batch-prefetch — for HTTP sources that advertise batch
# support, pull every cache-miss hex in `hashes` via POST /sit/v1/want
# and stuff the results into raw_cache. Subsequent copy_objects loop
# iterations then hit the cache instead of paying for one GET per
# object. No-op for OBJ_SRC_DB (local DB doesn't benefit from batch
# at this layer; patra's `WHERE hash IN (...)` batching is filed
# separately on the patra roadmap).
#
# Best-effort: batch failures (server doesn't support it after all,
# malformed frame stream, network blip) demote to per-object fallback
# — copy_objects's existing obj_src_read_raw call covers anything
# that didn't make it into the cache. So a partial / failing batch
# still yields a correct clone, just slower.
fn obj_src_batch_prefetch(src, hashes, raw_cache) {
    if (raw_cache == 0) { return 0; }
    if (obj_src_kind(src) != OBJ_SRC_HTTP) { return 0; }
    var h = obj_src_payload(src);
    if (http_remote_check_batch(h) != 1) { return 0; }

    # Walk hashes, collect every cache-miss into a per-call vec.
    # Send in WIRE_HTTP_BATCH_CHUNK-sized POSTs.
    var misses = vec_new();
    var n = vec_len(hashes);
    var i = 0;
    while (i < n) {
        var hex = vec_get(hashes, i);
        if (map_has(raw_cache, hex) == 0) {
            vec_push(misses, hex);
        }
        i = i + 1;
    }

    var m = vec_len(misses);
    var off = 0;
    while (off < m) {
        var chunk = WIRE_HTTP_BATCH_CHUNK;
        if (off + chunk > m) { chunk = m - off; }
        var rc = http_remote_read_batch(h, misses, off, chunk, raw_cache);
        if (rc < 0) {
            # Stop trying — per-object fallback covers the rest.
            off = m;
        }
        else {
            off = off + chunk;
        }
    }
    return 0;
}

# Walk every object reachable from `root_commit_hex` in `src` (an obj_src) and
# append each object's hex hash to `out`. Uses `seen` (map_new) for dedup.
# S-14: depth cap via module-level counter; same limit as flatten_tree.
#
# P-04 (v0.6.7): the walk decompresses every commit + tree, which internally
# pulls the compressed bytes from src via db_object_read_raw / http
# equivalent. Without the `raw_cache` parameter, copy_objects later re-reads
# the same compressed bytes — every commit + tree is a redundant source
# round trip (over local SQL or over the wire). With the cache, walk stuffs
# (hex → 24-byte raw struct) entries; copy_objects checks the cache first and
# only falls back to read_raw for the blobs that walk didn't visit. Saves
# ~200 source ops on a 100-commit fixture.
var _WIRE_MAX_DEPTH = 256;
var _wire_walk_depth = 0;

# Shallow-clone state (v0.8.12). `_wire_clone_depth` caps the phase-1
# commit-chain walk in `walk_reachable_phased`: 0 = unlimited (the normal
# case for fetch / pull / push), N = stop after N commits back from the
# tip. cmd_clone sets it around its do_fetch call and resets it after.
# `_wire_shallow_boundary`, when non-zero, is a vec the walker appends each
# boundary commit hex to (a present commit whose parents were NOT fetched);
# cmd_clone writes that set to `.sit/shallow` so `sit log` stops cleanly at
# the boundary instead of erroring on the absent parent. Module globals
# (not params) so the four walk_reachable_phased call sites stay unchanged —
# same idiom as `_wire_walk_depth`.
var _wire_clone_depth = 0;
var _wire_shallow_boundary = 0;

# Helper: store a copy of a 24-byte raw struct into the cache, keyed by hex.
# The hex pointer must already be a heap-owned cstring (the walk uses the
# `hex_copy` it just pushed onto `out`, so map_set can safely retain it).
fn _walk_cache_insert(raw_cache, hex, raw_struct_ptr) {
    if (raw_cache == 0) { return 0; }
    var slot = alloc_or_die(24);
    memcpy(slot, raw_struct_ptr, 24);
    map_set(raw_cache, hex, slot);
    return 0;
}

# ── Walk-side phasing (v0.7.5) ─────────────────────────────────────
#
# Same reachability + same `out` contents as `walk_reachable_from_commit`,
# but reorganised into phases so HTTP transports can batch the tree
# reads via `POST /sit/v1/want`. Three phases:
#
#   Phase 1: walk the commit chain sequentially, collecting tree hexes.
#            The chain-of-parents has no parallelism — must read commit N
#            to learn commit N-1's hex. Each commit hex goes into `out`
#            and is cached; tree hexes accumulate into a side vec for
#            phase 2.
#
#   Phase 2: one batch-prefetch of every tree hex from phase 1.
#            For OBJ_SRC_HTTP with `"batch":true`, this collapses N tree
#            GETs into ⌈N/256⌉ POSTs (WIRE_HTTP_BATCH_CHUNK). For
#            OBJ_SRC_DB or non-batch HTTP, this is a no-op and phase 3
#            falls back to per-tree reads.
#
#   Phase 3: walk each tree from cache. For sub-trees discovered at a
#            given depth, the walker collects ALL sub-trees at that
#            level FIRST, then batch-prefetches them as a single chunk
#            before recursing — so deep hierarchies still benefit from
#            per-level batching, not just the top level.
#
# Invariant: `out` ends up with the same set of hashes as
# `walk_reachable_from_commit` would have produced (just possibly in a
# different order — copy_objects iterates the vec linearly and order
# doesn't affect correctness).
#
# Why not always use phased: for OBJ_SRC_DB the work is identical (just
# more allocations for the side vecs). It's slightly worse in the
# common file:// case. We keep `walk_reachable_from_commit` as the
# fallback path and dispatch on src kind in `do_fetch` / `cmd_push`.

fn walk_reachable_phased(src, root_hex, out, seen, raw_cache) {
    # Phase 1: commit chain walk (sequential).
    # `qdepth` shadows `queue` 1:1 carrying each commit's distance from the
    # tip, so the v0.8.12 shallow cap (`_wire_clone_depth`) can stop the
    # walk N commits back. For unlimited walks the depth is tracked but
    # never gates anything, so the object set is identical to pre-v0.8.12.
    var trees = vec_new();
    var queue = vec_new();
    var qdepth = vec_new();
    var hex_copy = alloc(65);
    memcpy(hex_copy, root_hex, 64);
    store8(hex_copy + 64, 0);
    vec_push(queue, hex_copy);
    vec_push(qdepth, 0);
    while (vec_len(queue) > 0) {
        var cur = vec_get(queue, vec_len(queue) - 1);
        var cdep = vec_get(qdepth, vec_len(qdepth) - 1);
        vec_pop(queue);
        vec_pop(qdepth);
        if (map_has(seen, cur) == 1) { }
        else {
            map_set(seen, cur, 1);
            vec_push(out, cur);

            var raw[24];
            var obj[24];
            if (obj_src_read_both(src, cur, &raw, &obj) == 0) {
                _walk_cache_insert(raw_cache, cur, &raw);
                var buf = load64(&obj);
                var blen = load64(&obj + 8);
                var coff = load64(&obj + 16);
                var body = buf + coff;
                var body_len = blen - coff;
                var info[56];
                if (parse_commit_body(body, body_len, &info) == 0) {
                    var tree_hex = load64(&info);
                    if (tree_hex != 0) {
                        # Defer the tree walk to phase 3; just collect.
                        # Don't dedup against `seen` here — the per-level
                        # batcher does that and we want the full list of
                        # tree references for phase 2 to maximise the
                        # batch size.
                        var tree_copy = alloc(65);
                        memcpy(tree_copy, tree_hex, 64);
                        store8(tree_copy + 64, 0);
                        vec_push(trees, tree_copy);
                    }
                    # Enqueue EVERY parent (merge commits have 2+) so the
                    # clone/fetch/push object set isn't missing the subgraph
                    # reachable only via a non-last parent edge.
                    #
                    # Shallow cap (v0.8.12): if `_wire_clone_depth` is set and
                    # this commit sits at the depth boundary, DON'T enqueue its
                    # parents — record it as a shallow boundary instead. Depth
                    # is exact for linear history (the success-gate shape); for
                    # merges the cut is approximate (the first pop of a commit
                    # wins via `seen`), matching git's own shallow fuzziness.
                    var pv = load64(&info + 48);
                    if (pv != 0) {
                        var allow_parents = 1;
                        if (_wire_clone_depth != 0) {
                            if (cdep + 1 >= _wire_clone_depth) { allow_parents = 0; }
                        }
                        if (allow_parents == 1) {
                            var pi = 0;
                            while (pi < vec_len(pv)) {
                                vec_push(queue, vec_get(pv, pi));
                                vec_push(qdepth, cdep + 1);
                                pi = pi + 1;
                            }
                        }
                        else {
                            if (_wire_shallow_boundary != 0) {
                                vec_push(_wire_shallow_boundary, cur);
                            }
                        }
                    }
                }
            }
        }
    }

    # Phase 2: batch-prefetch every collected tree hex.
    obj_src_batch_prefetch(src, trees, raw_cache);

    # Phase 3: walk each top-level tree (per-level batched recursion).
    var ti = 0;
    while (ti < vec_len(trees)) {
        walk_reachable_tree_batched(src, vec_get(trees, ti), out, seen, raw_cache);
        ti = ti + 1;
    }
    return 0;
}

# Per-level-batched tree walker. Collects all sub-tree hashes at the
# current depth, batch-prefetches them in one POST, then recurses. Same
# `out` semantics as `walk_reachable_tree`. Blobs go straight to `out`
# without any read; copy_objects's own batch-prefetch covers them.
fn walk_reachable_tree_batched(src, tree_hex, out, seen, raw_cache) {
    if (_wire_walk_depth >= _WIRE_MAX_DEPTH) {
        eprintln("sit: remote tree depth exceeds 256 — refusing to walk further");
        return 0;
    }
    if (map_has(seen, tree_hex) == 1) { return 0; }
    map_set(seen, tree_hex, 1);
    var hex_copy = alloc(65);
    memcpy(hex_copy, tree_hex, 64);
    store8(hex_copy + 64, 0);
    vec_push(out, hex_copy);

    _wire_walk_depth = _wire_walk_depth + 1;
    var raw[24];
    var obj[24];
    # v0.7.5: cache-first read. Phase 2 of walk_reachable_phased
    # populated raw_cache for every tree hex referenced by the commit
    # chain; this hit path lets us decompress without going back to
    # the transport for trees that were just batched.
    var cached = 0;
    if (raw_cache != 0) {
        var cached_raw = map_get(raw_cache, hex_copy);
        if (cached_raw != 0) {
            memcpy(&raw, cached_raw, 24);
            if (_decompress_raw_into(&raw, &obj) == 0) {
                cached = 1;
            }
        }
    }
    if (cached == 0) {
        if (obj_src_read_both(src, tree_hex, &raw, &obj) != 0) {
            _wire_walk_depth = _wire_walk_depth - 1;
            return 0;
        }
    }
    _walk_cache_insert(raw_cache, hex_copy, &raw);
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var entries = parse_tree(buf + coff, blen - coff);
    var n = vec_len(entries);

    # First pass: collect sub-tree hashes for the level batch; emit
    # blob hashes into out as we go (no read needed for those).
    var sub_trees = vec_new();
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        var mode = tree_entry_mode(e);
        var hash = tree_entry_hash(e);
        if (streq(mode, "40000") == 1) {
            if (map_has(seen, hash) == 0) {
                var sc = alloc(65);
                memcpy(sc, hash, 64);
                store8(sc + 64, 0);
                vec_push(sub_trees, sc);
            }
        }
        else {
            if (map_has(seen, hash) == 0) {
                map_set(seen, hash, 1);
                var bcopy = alloc(65);
                memcpy(bcopy, hash, 64);
                store8(bcopy + 64, 0);
                vec_push(out, bcopy);
            }
        }
        i = i + 1;
    }

    # Batch-prefetch every sub-tree at this level before recursing.
    if (vec_len(sub_trees) > 0) {
        obj_src_batch_prefetch(src, sub_trees, raw_cache);
    }

    # Recurse — sub-tree reads now come from cache (when batch fired).
    var si = 0;
    while (si < vec_len(sub_trees)) {
        walk_reachable_tree_batched(src, vec_get(sub_trees, si), out, seen, raw_cache);
        si = si + 1;
    }
    _wire_walk_depth = _wire_walk_depth - 1;
    return 0;
}

# Copy every hex in `hashes` that isn't already present in `dst_db` from
# `src` (an obj_src). Returns the count of objects newly written.
fn copy_objects(src, dst_db, hashes, raw_cache) {
    var n = vec_len(hashes);
    var i = 0;
    var copied = 0;
    # P-03: wrap the insert loop in a single patra transaction so the N
    # individual writes share one WAL fsync at commit instead of N. On a
    # 100-commit/100-file clone fixture, this collapses ~300 fsyncs into 1.
    # Removed the outer db_object_has check that duplicates the one already
    # inside db_object_insert_raw — every object was paying for two SELECTs
    # plus an insert. Batched WHERE hash IN (...) pre-filter is deferred to
    # a later release (would need 60-hash chunking per patra's SQL parser
    # limits).
    #
    # P-04 (v0.6.7): raw_cache is the (hex → 24-byte raw struct) map populated
    # during walk_reachable_*. For commits + trees (everything walk visited),
    # we get the compressed bytes from cache and skip the source-DB read
    # entirely. For blobs (walk doesn't visit them) the cache misses and we
    # fall back to db_object_read_raw. raw_cache may be 0 for callers that
    # don't have a walk to draw from.
    #
    # v0.7.5: batch-prefetch — for HTTP sources advertising "batch":true,
    # pull every cache-miss hex in `hashes` via POST /sit/v1/want before
    # the per-object loop runs. After v0.7.5's walk-side phasing, commits
    # AND trees are already in cache; the misses are blobs, which dominate
    # clone bytes. For OBJ_SRC_DB the call is a no-op. Failures demote to
    # per-object fallback (the existing obj_src_read_raw call below).
    obj_src_batch_prefetch(src, hashes, raw_cache);

    patra_begin(dst_db);
    while (i < n) {
        var hex = vec_get(hashes, i);
        var raw[24];
        var got = 0;
        if (raw_cache != 0) {
            var cached = map_get(raw_cache, hex);
            if (cached != 0) {
                memcpy(&raw, cached, 24);
                got = 1;
            }
        }
        if (got == 0) {
            if (obj_src_read_raw(src, hex, &raw) == 0) { got = 1; }
        }
        if (got == 1) {
            var compressed = load64(&raw);
            var clen = load64(&raw + 8);
            var ty = load64(&raw + 16);
            if (db_object_insert_raw(dst_db, hex, ty, compressed, clen) == 0) {
                copied = copied + 1;
            }
        }
        i = i + 1;
    }
    patra_commit(dst_db);
    return copied;
}

# v0.8.4: read the remote repo's .sit/HEAD and extract the branch
# name if it's a symbolic ref ("ref: refs/heads/<name>"). Returns the
# bare branch name (e.g. "main") as a heap cstring, or 0 for detached
# HEAD / unreadable / non-symbolic. Used by cmd_push's file:// arm to
# match the denyCurrentBranch check `serve_handle_put_ref` does for
# http:// / ssh://.
fn _remote_current_branch(repo_path) {
    var rl = strlen(repo_path);
    var p = alloc(rl + 16);
    memcpy(p, repo_path, rl);
    memcpy(p + rl, "/.sit/HEAD", 10);
    store8(p + rl + 10, 0);
    if (file_exists(p) != 1) { return 0; }
    var buf = alloc(256);
    var n = file_read_all(p, buf, 255);
    if (n < 16) { return 0; }                     # too short to be "ref: refs/heads/X\n"
    if (memeq(buf, "ref: ", 5) == 0) { return 0; }
    if (memeq(buf + 5, "refs/heads/", 11) == 0) { return 0; }
    var name_start = buf + 16;
    var end = 16;
    while (end < n) {
        var c = load8(buf + end);
        if (c == 10) { break; }
        if (c == 13) { break; }
        end = end + 1;
    }
    var name_len = end - 16;
    if (name_len <= 0) { return 0; }
    var name = alloc(name_len + 1);
    memcpy(name, name_start, name_len);
    store8(name + name_len, 0);
    return name;
}

# Read a ref file at `<repo_path>/.sit/refs/heads/<branch>` — 64 hex chars.
# Returns heap 65-byte cstring on success, 0 on missing/malformed.
fn read_remote_ref(repo_path, branch) {
    var rl = strlen(repo_path);
    var bl = strlen(branch);
    var p = alloc(rl + bl + 32);
    memcpy(p, repo_path, rl);
    memcpy(p + rl, "/.sit/refs/heads/", 17);
    memcpy(p + rl + 17, branch, bl);
    store8(p + rl + 17 + bl, 0);
    if (file_exists(p) != 1) { return 0; }
    # S-04 belt-and-suspenders: refuse symlinks at the ref file itself.
    if (path_is_symlink(p) == 1) {
        eprintln("sit: refusing to follow symlink at remote ref file");
        return 0;
    }
    var buf = alloc(128);
    var n = file_read_all(p, buf, 128);
    if (n < 64) { return 0; }
    # S-11: validate hex before treating the bytes as a hash.
    if (hex_prefix_valid(buf, 64) == 0) { return 0; }
    var out = alloc(65);
    memcpy(out, buf, 64);
    store8(out + 64, 0);
    return out;
}

# Write `hex\n` (65 bytes) to `<repo_path>/.sit/refs/heads/<branch>`.
fn write_remote_ref(repo_path, branch, hex) {
    var rl = strlen(repo_path);
    var bl = strlen(branch);
    var p = alloc(rl + bl + 32);
    memcpy(p, repo_path, rl);
    memcpy(p + rl, "/.sit/refs/heads/", 17);
    memcpy(p + rl + 17, branch, bl);
    store8(p + rl + 17 + bl, 0);
    var buf = alloc(66);
    memcpy(buf, hex, 64);
    store8(buf + 64, 10);
    return file_write_all(p, buf, 65);
}

# Write 65-byte hex to `.sit/refs/remotes/<remote>/<branch>`.
fn write_remote_tracking(remote, branch, hex) {
    # S-02 / S-26: branch came from the remote's advertisement — validate
    # before it becomes a filesystem path. S-13: size the staging buffer
    # from the actual lengths rather than a fixed 128 bytes.
    if (refname_valid(remote) == 0) { return 0 - 1; }
    if (refname_valid(branch) == 0) { return 0 - 1; }
    var rl = strlen(remote);
    var bl = strlen(branch);
    var dir = alloc(18 + rl + 1);
    memcpy(dir, ".sit/refs/remotes/", 18);
    memcpy(dir + 18, remote, rl);
    store8(dir + 18 + rl, 0);
    ensure_dir(".sit/refs/remotes");
    ensure_dir(dir);
    var p = alloc(18 + rl + 1 + bl + 1);
    memcpy(p, ".sit/refs/remotes/", 18);
    memcpy(p + 18, remote, rl);
    memcpy(p + 18 + rl, "/", 1);
    memcpy(p + 18 + rl + 1, branch, bl);
    store8(p + 18 + rl + 1 + bl, 0);
    ensure_parent_dirs(p);
    var buf = alloc(66);
    memcpy(buf, hex, 64);
    store8(buf + 64, 10);
    return file_write_all(p, buf, 65);
}

# Return 1 if `ancestor_hex` is reachable from `desc_hex` (ff check).
fn is_ancestor_in_db(db, ancestor_hex, desc_hex) {
    if (streq(ancestor_hex, desc_hex) == 1) { return 1; }
    var queue = vec_new();
    var seen = map_new();
    var start = alloc(65);
    memcpy(start, desc_hex, 64);
    store8(start + 64, 0);
    vec_push(queue, start);
    while (vec_len(queue) > 0) {
        var cur = vec_get(queue, vec_len(queue) - 1);
        vec_pop(queue);
        if (map_has(seen, cur) == 1) { }
        else {
            map_set(seen, cur, 1);
            if (streq(cur, ancestor_hex) == 1) { return 1; }
            var obj[24];
            if (db_object_read_decompressed(db, cur, &obj) == 0) {
                var buf = load64(&obj);
                var blen = load64(&obj + 8);
                var coff = load64(&obj + 16);
                var info[56];
                if (parse_commit_body(buf + coff, blen - coff, &info) == 0) {
                    # Walk every parent edge so the FF gate doesn't falsely
                    # report non-ancestor across a merge commit.
                    var pv = load64(&info + 48);
                    if (pv != 0) {
                        var pi = 0;
                        while (pi < vec_len(pv)) {
                            vec_push(queue, vec_get(pv, pi));
                            pi = pi + 1;
                        }
                    }
                }
            }
        }
    }
    return 0;
}

fn cmd_remote_add() {
    if (argc() < 5) {
        eprintln("usage: sit remote add <name> <url>");
        return 1;
    }
    var name = argv_heap(3);
    var url = argv_heap(4);
    # S-02: remote name becomes a config-key fragment and part of the
    # .sit/refs/remotes/<name>/... path. Same grammar as a branch.
    if (refname_valid(name) == 0) {
        eprintln("sit: invalid remote name (see git check-ref-format rules)");
        return 1;
    }
    # S-04: validator accepts file://, bare paths, and http(s)/ssh URL shapes.
    # cmd_remote_add does not dispatch transport, so stored URLs may name a
    # scheme whose transport ships in a later v0.7.x patch.
    if (remote_url_valid(url) == 0) {
        eprintln("sit: invalid or unsupported remote URL");
        return 1;
    }
    var nlen = strlen(name);
    var key = alloc(nlen + 12);
    memcpy(key, "remote.", 7);
    memcpy(key + 7, name, nlen);
    memcpy(key + 7 + nlen, ".url", 4);
    store8(key + 7 + nlen + 4, 0);
    if (config_file_set(".sit/config", key, url) != 0) {
        eprintln("sit: failed to write .sit/config");
        return 1;
    }
    return 0;
}

fn cmd_remote_list() {
    if (file_exists(".sit/config") != 1) { return 0; }
    var pair[16];
    if (read_file_heap(".sit/config", &pair) != 0) { return 0; }
    var data = load64(&pair);
    var len = load64(&pair + 8);
    var pos = 0;
    while (pos < len) {
        var le = pos;
        while (le < len) {
            if (load8(data + le) == 10) { break; }
            le = le + 1;
        }
        var stop = le;
        if (stop > pos) {
            if (load8(data + stop - 1) == 13) { stop = stop - 1; }
        }
        var start = skip_ws(data, pos, stop);
        # Match lines shaped "remote.<name>.url = <url>"
        if (stop - start > 8) {
            if (memeq(data + start, "remote.", 7) == 1) {
                # find closing ".url"
                var dot = start + 7;
                while (dot < stop) {
                    if (load8(data + dot) == 46) { break; }
                    dot = dot + 1;
                }
                if (dot < stop) {
                    if (dot + 4 <= stop) {
                        if (memeq(data + dot, ".url", 4) == 1) {
                            stdout_write(data + start + 7, dot - (start + 7));
                            stdout_write("\t", 1);
                            # skip past " = "
                            var eq = dot + 4;
                            while (eq < stop) {
                                if (load8(data + eq) == 61) { eq = eq + 1; break; }
                                eq = eq + 1;
                            }
                            eq = skip_ws(data, eq, stop);
                            stdout_write(data + eq, stop - eq);
                            stdout_write("\n", 1);
                        }
                    }
                }
            }
        }
        pos = le + 1;
    }
    return 0;
}

fn cmd_remote_remove() {
    if (argc() < 4) {
        eprintln("usage: sit remote remove <name>");
        return 1;
    }
    var name = argv_heap(3);
    var nlen = strlen(name);
    var key = alloc(nlen + 12);
    memcpy(key, "remote.", 7);
    memcpy(key + 7, name, nlen);
    memcpy(key + 7 + nlen, ".url", 4);
    store8(key + 7 + nlen + 4, 0);
    var r = config_file_unset(".sit/config", key);
    if (r == 0 - 2) {
        eprintln("sit: no such remote");
        return 1;
    }
    if (r != 0) {
        eprintln("sit: failed to update .sit/config");
        return 1;
    }
    return 0;
}

fn cmd_remote() {
    if (argc() < 3) { return cmd_remote_list(); }
    var sub = argv(2);
    if (streq(sub, "add")    == 1) { return cmd_remote_add(); }
    if (streq(sub, "list")   == 1) { return cmd_remote_list(); }
    if (streq(sub, "remove") == 1) { return cmd_remote_remove(); }
    eprintln("sit: unknown remote subcommand (add | list | remove)");
    return 1;
}

# Copy reachable objects + write remote-tracking ref. Returns the 65-byte
# fetched tip hex on success, or 0 on failure (with an eprintln already emitted).
# Shared between cmd_fetch, cmd_pull, and cmd_clone.
#
# v0.7.3: branches on URL scheme. file:// + bare paths open a patra DB
# remotely as before; http:// constructs a wire_http handle and uses
# the obj_src abstraction so walk_reachable_* / copy_objects don't see
# transport-specific code paths.
fn do_fetch(name, branch) {
    var url = remote_url(name);
    if (url == 0) {
        eprintln("sit: no such remote");
        return 0;
    }
    if (wire_transport_check_readable(url) != 0) { return 0; }

    var dst_db = get_object_db();
    if (dst_db == 0) {
        eprintln("sit: cannot open local object db");
        return 0;
    }

    var s = url_scheme(url);
    var src = 0;
    var src_db_local = 0;
    var http_handle = 0;
    var ssh_handle = 0;
    var remote_tip = 0;

    if (s == URL_SCHEME_FILE) {
        var repo_path = remote_normalize(url);
        remote_tip = read_remote_ref(repo_path, branch);
        if (remote_tip == 0) {
            eprintln("sit: remote has no such branch");
            return 0;
        }
        src_db_local = remote_objects_open(repo_path);
        if (src_db_local == 0) {
            eprintln("sit: cannot open remote object db");
            return 0;
        }
        src = obj_src_for_db(src_db_local);
    }
    else {
        if (_url_is_http_family(s) == 1) {
            http_handle = wire_http_open(url);
            if (http_handle == 0) { return 0; }
            remote_tip = http_remote_resolve_branch(http_handle, branch);
            if (remote_tip == 0) {
                wire_http_close(http_handle);
                eprintln("sit: remote has no such branch");
                return 0;
            }
            src = obj_src_for_http(http_handle);
        }
        else {
            # URL_SCHEME_SSH — spawns `ssh user@host -- sit serve <path>
            # --stdio` and tunnels the same HTTP/1.1 wire over the
            # SSH-managed stdin/stdout. v0.8.2 read-only; push lives
            # in v0.8.3+. The readable-check already gated everything
            # else upstream.
            ssh_handle = wire_ssh_open(url);
            if (ssh_handle == 0) { return 0; }
            remote_tip = ssh_remote_resolve_branch(ssh_handle, branch);
            if (remote_tip == 0) {
                wire_ssh_close(ssh_handle);
                eprintln("sit: remote has no such branch");
                return 0;
            }
            src = obj_src_for_ssh(ssh_handle);
        }
    }

    var seen = map_new();
    var hashes = vec_new();
    # P-04 (v0.6.7): raw_cache lets copy_objects skip the source read for
    # commits + trees that walk_reachable already pulled. The cache is
    # transport-independent (compressed bytes are bytes); HTTP fetches
    # benefit from it identically to local fetches.
    #
    # v0.7.5: walk_reachable_phased replaces walk_reachable_from_commit.
    # Phase 1 walks the commit chain sequentially (unavoidable —
    # parent-of-parent has no parallelism), phase 2 batch-prefetches all
    # trees referenced by the chain in one POST /sit/v1/want, phase 3
    # walks each tree from cache with per-level sub-tree batching.
    # For OBJ_SRC_DB the batch hooks are no-ops so the work degrades to
    # the same SQL reads in slightly different order.
    var raw_cache = map_new();
    walk_reachable_phased(src, remote_tip, hashes, seen, raw_cache);
    var copied = copy_objects(src, dst_db, hashes, raw_cache);

    if (src_db_local != 0) { patra_close(src_db_local); }
    if (http_handle != 0)  { wire_http_close(http_handle); }
    if (ssh_handle != 0)   { wire_ssh_close(ssh_handle); }

    # S-16: a write_remote_tracking failure leaves origin/<branch> stale,
    # which silently desyncs subsequent fetches (FF logic compares against
    # the stale ref). Refuse to declare a successful fetch on failure.
    if (write_remote_tracking(name, branch, remote_tip) < 0) {
        eprintln("sit: fetched objects but failed to update remote-tracking ref");
        return 0;
    }

    stdout_write("fetched ", 8);
    stdout_write(name, strlen(name));
    stdout_write("/", 1);
    stdout_write(branch, strlen(branch));
    stdout_write(" at ", 4);
    stdout_write(remote_tip, 12);
    var nbuf[24];
    var d = write_decimal(&nbuf, copied);
    stdout_write(" (", 2);
    stdout_write(&nbuf, d);
    stdout_write(" new objects)\n", 14);
    return remote_tip;
}

fn cmd_fetch() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository");
        return 1;
    }
    if (argc() < 3) {
        eprintln("usage: sit fetch <remote> [<branch>]");
        return 1;
    }
    var name = argv_heap(2);
    var branch = "main";
    if (argc() >= 4) { branch = argv_heap(3); }
    if (do_fetch(name, branch) == 0) { return 1; }
    return 0;
}

# Pull = fetch + fast-forward merge. Non-ff divergence tells the user to run
# `sit merge` manually rather than attempting an automatic 3-way here — keeps
# the semantics narrow and predictable.
fn cmd_pull() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository");
        return 1;
    }
    if (argc() < 3) {
        eprintln("usage: sit pull <remote> [<branch>]");
        return 1;
    }
    var name = argv_heap(2);
    var branch = "main";
    if (argc() >= 4) { branch = argv_heap(3); }

    var tip = do_fetch(name, branch);
    if (tip == 0) { return 1; }

    var head_hex = read_head_ref();
    if (head_hex == 0) {
        # No local commits yet — adopt the fetched tip as HEAD, materialize.
        if (write_head_ref(tip) != 0) {
            eprintln("sit: failed to update HEAD");
            return 1;
        }
        materialize_target(tip);
        stdout_write("initialized from ", 17);
        stdout_write(name, strlen(name));
        stdout_write("/", 1);
        stdout_write(branch, strlen(branch));
        stdout_write("\n", 1);
        return 0;
    }

    if (streq(tip, head_hex) == 1) {
        stdout_write("already up to date\n", 19);
        return 0;
    }
    if (is_ancestor(tip, head_hex) == 1) {
        stdout_write("already up to date\n", 19);
        return 0;
    }
    if (is_ancestor(head_hex, tip) == 1) {
        if (is_dirty() == 1) {
            eprintln("sit: working tree has uncommitted changes; commit or revert before pulling");
            return 1;
        }
        if (write_head_ref(tip) != 0) {
            eprintln("sit: failed to update HEAD");
            return 1;
        }
        materialize_target(tip);
        stdout_write("fast-forward to ", 16);
        stdout_write(tip, 12);
        stdout_write("\n", 1);
        return 0;
    }
    eprintln("sit: local and remote have diverged");
    syscall(SYS_WRITE, STDERR, "sit:   run 'sit merge ", 22);
    syscall(SYS_WRITE, STDERR, name, strlen(name));
    syscall(SYS_WRITE, STDERR, "/", 1);
    syscall(SYS_WRITE, STDERR, branch, strlen(branch));
    syscall(SYS_WRITE, STDERR, "' to resolve\n", 13);
    return 1;
}

# Clone = mkdir + chdir + init + remote-add + fetch + HEAD ref + materialize.
# Target directory defaults to the last '/'-delimited segment of the URL.
# Write `.sit/shallow` (v0.8.12): one boundary commit hex per line. A
# boundary commit is present in the clone but its parent(s) were not
# fetched (depth cap). `sit log` reads this set and stops cleanly at the
# boundary instead of erroring on the absent parent. No-op when `boundary`
# is 0 or empty (a full clone leaves no `.sit/shallow`). Mirrors git's
# `.git/shallow`.
fn _write_shallow_file(boundary) {
    if (boundary == 0) { return 0; }
    var n = vec_len(boundary);
    if (n == 0) { return 0; }
    var total = n * 65;
    var buf = alloc_or_die(total);
    var off = 0;
    var i = 0;
    while (i < n) {
        var h = vec_get(boundary, i);
        memcpy(buf + off, h, 64);
        store8(buf + off + 64, 10);
        off = off + 65;
        i = i + 1;
    }
    if (file_write_all(".sit/shallow", buf, total) < 0) {
        eprintln("sit: warning — failed to write .sit/shallow (log may error at boundary)");
    }
    return 0;
}

fn cmd_clone() {
    if (argc() < 3) {
        eprintln("usage: sit clone [--force-absolute] [--depth <n>] <url> [<dir>]");
        return 1;
    }
    # S-23: --force-absolute is the explicit opt-in to clone into a path
    # starting with `/`. Without it, an absolute target is refused (so
    # `sit clone <url> /etc/cron.d/x` doesn't silently mkdir + chdir into
    # a system path the invoking user happens to have write access to).
    var force_absolute = 0;
    var depth = 0;
    var url = 0;
    var target = 0;
    var ai = 2;
    while (ai < argc()) {
        var a = argv(ai);
        if (streq(a, "--force-absolute") == 1) { force_absolute = 1; }
        else {
            if (streq(a, "--depth") == 1) {
                if (ai + 1 >= argc()) {
                    eprintln("sit: --depth requires a number");
                    return 1;
                }
                depth = atoi(argv(ai + 1));
                if (depth < 1) {
                    eprintln("sit: --depth must be a positive integer");
                    return 1;
                }
                ai = ai + 1;
            }
            else {
                if (url == 0) { url = argv_heap(ai); }
                else {
                    if (target == 0) { target = argv_heap(ai); }
                    else {
                        eprintln("usage: sit clone [--force-absolute] [--depth <n>] <url> [<dir>]");
                        return 1;
                    }
                }
            }
        }
        ai = ai + 1;
    }
    if (url == 0) {
        eprintln("usage: sit clone [--force-absolute] [--depth <n>] <url> [<dir>]");
        return 1;
    }
    # S-04: reject malformed URLs up-front so we fail cleanly instead of
    # trying to open them as filesystem paths.
    if (remote_url_valid(url) == 0) {
        eprintln("sit: invalid or unsupported clone URL");
        return 1;
    }
    if (wire_transport_check_readable(url) != 0) { return 1; }

    if (target == 0) {
        # Derive target from URL. file:// + bare paths take the last
        # path segment. http URLs take the host (drop port + path) —
        # really a placeholder; users should pass <dir> explicitly when
        # cloning multiple http remotes from the same host, but a
        # reasonable default beats refusing the command.
        var sch = url_scheme(url);
        var derived = 0;
        if (_url_is_http_family(sch) == 1) {
            var p = 7;                                  # past "http://"
            if (sch == URL_SCHEME_HTTPS) { p = 8; }     # past "https://"
            var ulen = strlen(url);
            # Scan to the first ':' (port) or '/' (path). Flag-driven,
            # not `break`: a `break` after an in-loop `var` declaration
            # is unreliable in cyrius (CLAUDE.md). host_end lands on the
            # delimiter, or on ulen for a bare host.
            var host_end = p;
            var scanning = 1;
            while (scanning == 1) {
                if (host_end >= ulen) { scanning = 0; }
                if (scanning == 1) {
                    var c = load8(url + host_end);
                    if (c == 58) { scanning = 0; }
                    if (c == 47) { scanning = 0; }
                }
                if (scanning == 1) { host_end = host_end + 1; }
            }
            var hl = host_end - p;
            if (hl > 0) {
                derived = alloc(hl + 1);
                memcpy(derived, url + p, hl);
                store8(derived + hl, 0);
            }
        }
        else {
            var src_str = remote_normalize(url);
            var slen = strlen(src_str);
            while (slen > 0) {
                if (load8(src_str + slen - 1) != 47) { break; }
                slen = slen - 1;
            }
            var tail = slen;
            while (tail > 0) {
                if (load8(src_str + tail - 1) == 47) { break; }
                tail = tail - 1;
            }
            var tlen = slen - tail;
            if (tlen > 0) {
                derived = alloc(tlen + 1);
                memcpy(derived, src_str + tail, tlen);
                store8(derived + tlen, 0);
            }
        }
        if (derived == 0) {
            eprintln("sit: cannot derive target dir from url (pass one explicitly)");
            return 1;
        }
        target = derived;
    }

    # S-23: opt-in gate on absolute target paths.
    if (load8(target) == 47) {
        if (force_absolute == 0) {
            eprintln("sit: refusing absolute clone target without --force-absolute");
            return 1;
        }
    }

    # S-04: if target already exists, make sure it's a directory and not a
    # symlink pointing somewhere surprising.
    var existing_kind = path_lstat_kind(target);
    if (existing_kind >= 0) {
        if (existing_kind == 0xA000) {
            eprintln("sit: target path is a symlink — refusing to clone into it");
            return 1;
        }
        if (existing_kind != 0x4000) {
            eprintln("sit: target exists and is not a directory");
            return 1;
        }
    }
    if (ensure_dir(target) != 0) {
        eprintln("sit: cannot create target directory");
        return 1;
    }
    # Reject non-empty target to avoid clobbering. dir_list returns entries including
    # '.' / '..' in some stdlib variants; count anything else as populated.
    var listing = dir_list(str_from(target));
    var ln = vec_len(listing);
    var li = 0;
    var real_entries = 0;
    while (li < ln) {
        var s = vec_get(listing, li);
        var sd = str_data(s);
        var slen2 = str_len(s);
        var is_dot = 0;
        if (slen2 == 1) { if (load8(sd) == 46) { is_dot = 1; } }
        if (slen2 == 2) {
            if (load8(sd) == 46) {
                if (load8(sd + 1) == 46) { is_dot = 1; }
            }
        }
        if (is_dot == 0) { real_entries = real_entries + 1; }
        li = li + 1;
    }
    if (real_entries > 0) {
        eprintln("sit: target directory is not empty");
        return 1;
    }

    if (syscall(SYS_CHDIR, target) != 0) {
        eprintln("sit: cannot chdir into target");
        return 1;
    }

    # Inline init — same shape as cmd_init.
    ensure_dir(".sit");
    ensure_dir(".sit/objects");
    ensure_dir(".sit/refs");
    ensure_dir(".sit/refs/heads");
    var head = "ref: refs/heads/main\n";
    if (file_write_all(".sit/HEAD", head, 21) < 0) {
        eprintln("sit: failed to write .sit/HEAD");
        return 1;
    }

    # Register origin, fetch, set local main to the fetched tip, materialize.
    if (config_file_set(".sit/config", "remote.origin.url", url) != 0) {
        eprintln("sit: failed to write .sit/config");
        return 1;
    }

    # Shallow clone (v0.8.12): arm the walker's depth cap + boundary
    # collector for the duration of this fetch, then write `.sit/shallow`
    # and disarm. fetch / pull leave `_wire_clone_depth` at 0 (unlimited).
    if (depth > 0) {
        _wire_clone_depth = depth;
        _wire_shallow_boundary = vec_new();
    }
    var tip = do_fetch("origin", "main");
    if (depth > 0) {
        _write_shallow_file(_wire_shallow_boundary);
        _wire_clone_depth = 0;
        _wire_shallow_boundary = 0;
    }
    if (tip == 0) { return 1; }

    if (write_head_ref(tip) != 0) {
        eprintln("sit: failed to update HEAD");
        return 1;
    }
    materialize_target(tip);

    stdout_write("cloned ", 7);
    stdout_write(url, strlen(url));
    stdout_write(" into ", 6);
    stdout_write(target, strlen(target));
    stdout_write("\n", 1);
    return 0;
}

fn cmd_push() {
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository");
        return 1;
    }
    if (argc() < 3) {
        eprintln("usage: sit push <remote> [<branch>]");
        return 1;
    }
    var name = argv_heap(2);
    var branch = current_branch_name();
    if (argc() >= 4) { branch = argv_heap(3); }
    if (branch == 0) { branch = "main"; }

    var url = remote_url(name);
    if (url == 0) {
        eprintln("sit: no such remote");
        return 1;
    }
    if (wire_transport_check_writable(url) != 0) { return 1; }

    var local_tip = read_head_ref();
    if (local_tip == 0) {
        eprintln("sit: no commits to push");
        return 1;
    }

    # v0.6.4: local source via the cache; remote dst stays per-call.
    var src_db = get_object_db();
    if (src_db == 0) {
        eprintln("sit: cannot open local object db");
        return 1;
    }

    var s = url_scheme(url);
    if (_url_is_http_family(s) == 1) {        # http:// + https:// (v0.8.9)
        return _do_push_http(name, branch, url, src_db, local_tip);
    }
    if (s == URL_SCHEME_SSH) {
        return _do_push_ssh(name, branch, url, src_db, local_tip);
    }

    # File:// + bare path push (the v0.7.5-and-prior path).
    var repo_path = remote_normalize(url);
    var dst_db = remote_objects_open(repo_path);
    if (dst_db == 0) {
        eprintln("sit: cannot open remote object db");
        return 1;
    }

    var remote_tip = read_remote_ref(repo_path, branch);

    # v0.8.4: denyCurrentBranch over file://. Symmetric to the
    # serve_handle_put_ref check that gates http:// / ssh:// pushes.
    # Read the remote's .sit/HEAD; if it's a symbolic ref to the
    # branch we're pushing AND the ref already exists (i.e. NOT an
    # initial push to an empty remote), refuse. Initial pushes to a
    # fresh remote — even one with HEAD pointing at the target branch —
    # are allowed, matching git's denyCurrentBranch default.
    if (remote_tip != 0) {
        var remote_head_branch = _remote_current_branch(repo_path);
        if (remote_head_branch != 0) {
            if (streq(remote_head_branch, branch) == 1) {
                patra_close(dst_db);
                eprintln("sit: remote refuses to update its checked-out branch (denyCurrentBranch)");
                return 1;
            }
        }
    }

    if (remote_tip != 0) {
        # Fast-forward check: remote_tip must be an ancestor of local_tip.
        if (is_ancestor_in_db(src_db, remote_tip, local_tip) == 0) {
            patra_close(dst_db);
            eprintln("sit: non-fast-forward push rejected (remote has diverged)");
            return 1;
        }
    }

    var seen = map_new();
    var hashes = vec_new();
    # P-04 (v0.6.7): raw_cache shared between walk and copy.
    # v0.7.5: phased walker. Push is local→remote; over file:// the
    # batch hooks are no-ops, but using phased keeps the file://
    # codepath identical in shape to do_fetch + the http push path.
    var raw_cache = map_new();
    var src = obj_src_for_db(src_db);
    walk_reachable_phased(src, local_tip, hashes, seen, raw_cache);
    var copied = copy_objects(src, dst_db, hashes, raw_cache);

    patra_close(dst_db);

    if (write_remote_ref(repo_path, branch, local_tip) < 0) {
        eprintln("sit: failed to update remote ref");
        return 1;
    }

    _print_push_summary(branch, name, local_tip, copied);
    return 0;
}

# v0.7.6 push over http. Walks reachable objects from local_tip,
# POSTs each to /sit/v1/objects/<hex> (server rehashes — trust
# boundary), then POSTs the new tip to /sit/v1/refs/<refname>.
# Pre-flight: read remote refs to detect non-FF before sending any
# objects (saves a round-trip-per-object on a doomed push).
fn _do_push_http(name, branch, url, src_db, local_tip) {
    var http = wire_http_open(url);
    if (http == 0) { return 1; }

    # Probe capabilities once to learn batch + auth posture. The probe
    # is also what populates the handle's batch_supported / requires_auth
    # flags. Discard the return; we consult the flags directly so the
    # auth-only case (server advertises bearer but not batch) doesn't
    # accidentally short-circuit auth loading.
    http_remote_check_batch(http);
    if (_http_remote_requires_auth(http) == 1) {
        var tok = _wire_http_load_client_token();
        if (tok == 0) {
            wire_http_close(http);
            eprintln("sit: server requires bearer auth but ~/.sit/serve.token is missing or unreadable");
            return 1;
        }
        _http_remote_set_token(http, tok);
    }

    # FF preflight via GET /sit/v1/refs. resolve_branch returns 0 if
    # the branch doesn't exist on the remote (initial push).
    var remote_tip = http_remote_resolve_branch(http, branch);
    if (remote_tip != 0) {
        if (is_ancestor_in_db(src_db, remote_tip, local_tip) == 0) {
            wire_http_close(http);
            eprintln("sit: non-fast-forward push rejected (remote has diverged)");
            return 1;
        }
        if (streq(remote_tip, local_tip) == 1) {
            # Already up-to-date. Skip the work entirely.
            wire_http_close(http);
            stdout_write("everything up-to-date\n", 22);
            return 0;
        }
    }

    # Walk reachable objects from local_tip — same shape as fetch but
    # the source is local (OBJ_SRC_DB, batch is no-op).
    var seen = map_new();
    var hashes = vec_new();
    var raw_cache = map_new();
    var src = obj_src_for_db(src_db);
    walk_reachable_phased(src, local_tip, hashes, seen, raw_cache);

    # Push each object. The server idempotently returns 200 for
    # already-present hashes (per ADR 0006's spirit; serve_handle_put_object
    # mirrors db_object_insert_raw's already-present semantics) and
    # 201 for fresh inserts. Both are success; non-2xx stops the push.
    var n = vec_len(hashes);
    var i = 0;
    var pushed = 0;
    while (i < n) {
        var hex = vec_get(hashes, i);
        # Pull the {compressed, clen, ty} 24-byte struct: cache hit
        # for commits + trees that walk_reachable visited; fallback
        # to db_object_read_raw for blobs.
        var raw[24];
        var got = 0;
        if (raw_cache != 0) {
            var cached = map_get(raw_cache, hex);
            if (cached != 0) {
                memcpy(&raw, cached, 24);
                got = 1;
            }
        }
        if (got == 0) {
            if (db_object_read_raw(src_db, hex, &raw) == 0) { got = 1; }
        }
        if (got == 0) {
            wire_http_close(http);
            eprintln("sit: failed to read local object during push");
            return 1;
        }
        var compressed = load64(&raw);
        var clen = load64(&raw + 8);
        var ty = load64(&raw + 16);
        # Returns: 1 = newly inserted (201), 0 = already present (200),
        # -1 = server rejected. Count only fresh inserts in the summary
        # so the user sees how much actually moved.
        var rc = http_remote_push_object(http, hex, ty, compressed, clen);
        if (rc < 0) {
            wire_http_close(http);
            eprintln("sit: server rejected object during push");
            return 1;
        }
        if (rc == 1) { pushed = pushed + 1; }
        i = i + 1;
    }

    # Update the ref. refs/heads/<branch> is the only push target the
    # server accepts for the v0.7.6 surface (refs/tags/* is technically
    # accepted but immutable; sit push only ships heads).
    var bl = strlen(branch);
    var rname = alloc(11 + bl + 1);
    memcpy(rname, "refs/heads/", 11);
    memcpy(rname + 11, branch, bl);
    store8(rname + 11 + bl, 0);
    var ref_rc = http_remote_push_ref(http, rname, local_tip);
    wire_http_close(http);
    if (ref_rc == 1) {
        eprintln("sit: server rejected ref update (non-fast-forward)");
        return 1;
    }
    if (ref_rc == 2) {
        eprintln("sit: server refuses to update its checked-out branch (denyCurrentBranch)");
        return 1;
    }
    if (ref_rc != 0) {
        eprintln("sit: server rejected ref update");
        return 1;
    }

    _print_push_summary(branch, name, local_tip, pushed);
    return 0;
}

fn _print_push_summary(branch, name, local_tip, copied) {
    stdout_write("pushed ", 7);
    stdout_write(branch, strlen(branch));
    stdout_write(" -> ", 4);
    stdout_write(name, strlen(name));
    stdout_write(" at ", 4);
    stdout_write(local_tip, 12);
    var nbuf[24];
    var d = write_decimal(&nbuf, copied);
    stdout_write(" (", 2);
    stdout_write(&nbuf, d);
    stdout_write(" new objects)\n", 14);
    return 0;
}

# v0.8.3 push over ssh. Same pipeline as _do_push_http but layered
# onto v0.8.2's persistent stdio session — wire_ssh_open spawns
# `ssh user@host -- sit serve <repo> --stdio` once and pipelines
# capabilities / refs / per-object POST / ref POST through the
# single SSH-encrypted pipe.
#
# Bearer auth: skipped in v0.8.3. SSH already authenticates the
# user end-to-end via key exchange + authorized_keys, so an extra
# server-side `--require-auth` token doesn't add a meaningful
# trust boundary for the canonical case. _ssh_handle_auth_token
# returns 0 today; if a v0.8.3.x patch wires belt-and-suspenders
# auth, _wire_ssh_post_xhdr will inject Authorization headers as
# soon as the handle has a token loaded — no caller-side change.
fn _do_push_ssh(name, branch, url, src_db, local_tip) {
    var sh = wire_ssh_open(url);
    if (sh == 0) { return 1; }

    # FF preflight via /sit/v1/refs over the same SSH pipe.
    # resolve_branch returns 0 if the branch doesn't exist on the
    # remote (initial push).
    var remote_tip = ssh_remote_resolve_branch(sh, branch);
    if (remote_tip != 0) {
        if (is_ancestor_in_db(src_db, remote_tip, local_tip) == 0) {
            wire_ssh_close(sh);
            eprintln("sit: non-fast-forward push rejected (remote has diverged)");
            return 1;
        }
        if (streq(remote_tip, local_tip) == 1) {
            wire_ssh_close(sh);
            stdout_write("everything up-to-date\n", 22);
            return 0;
        }
    }

    # Walk reachable objects from local_tip — source is local
    # (OBJ_SRC_DB), so phased's batch hooks are no-ops.
    var seen = map_new();
    var hashes = vec_new();
    var raw_cache = map_new();
    var src = obj_src_for_db(src_db);
    walk_reachable_phased(src, local_tip, hashes, seen, raw_cache);

    var n = vec_len(hashes);
    var i = 0;
    var pushed = 0;
    while (i < n) {
        var hex = vec_get(hashes, i);
        var raw[24];
        var got = 0;
        if (raw_cache != 0) {
            var cached = map_get(raw_cache, hex);
            if (cached != 0) {
                memcpy(&raw, cached, 24);
                got = 1;
            }
        }
        if (got == 0) {
            if (db_object_read_raw(src_db, hex, &raw) == 0) { got = 1; }
        }
        if (got == 0) {
            wire_ssh_close(sh);
            eprintln("sit: failed to read local object during push");
            return 1;
        }
        var compressed = load64(&raw);
        var clen = load64(&raw + 8);
        var ty = load64(&raw + 16);
        # rc: 1 = newly inserted (201), 0 = already present (200),
        # -1 = server rejected. Count only fresh inserts.
        var rc = ssh_remote_push_object(sh, hex, ty, compressed, clen);
        if (rc < 0) {
            wire_ssh_close(sh);
            eprintln("sit: server rejected object during push");
            return 1;
        }
        if (rc == 1) { pushed = pushed + 1; }
        i = i + 1;
    }

    # Update the ref. Same shape as HTTP push — refs/heads/<branch>
    # only; refs/tags/* and refs/remotes/* are server-side gated.
    var bl = strlen(branch);
    var rname = alloc(11 + bl + 1);
    memcpy(rname, "refs/heads/", 11);
    memcpy(rname + 11, branch, bl);
    store8(rname + 11 + bl, 0);
    var ref_rc = ssh_remote_push_ref(sh, rname, local_tip);
    wire_ssh_close(sh);
    if (ref_rc == 1) {
        eprintln("sit: server rejected ref update (non-fast-forward)");
        return 1;
    }
    if (ref_rc == 2) {
        eprintln("sit: server refuses to update its checked-out branch (denyCurrentBranch)");
        return 1;
    }
    if (ref_rc != 0) {
        eprintln("sit: server rejected ref update");
        return 1;
    }

    _print_push_summary(branch, name, local_tip, pushed);
    return 0;
}

# --- wire_http.cyr ---

# wire_http.cyr — HTTP transport (client side).
#
# v0.7.3 — read-only fetch / clone over `http://...` URLs that
# resolve to a `sit serve` process speaking the `/sit/v1/...` wire
# protocol.
#
# Why we don't reach for stdlib `http_get` / `http_get_a`:
#   * Both hard-cap the response body at 64 KiB. Sit's compressed
#     objects routinely exceed that (a 1 MiB blob with low entropy
#     compresses to ~300 KiB), so the cap is a hard blocker.
#   * `_http_parse_url` parses host as a cstring then hands it to
#     `sock_connect(fd, addr, port)` which expects a packed-int
#     IPv4 — works only by accident for raw IP literals.
# This module talks directly to lib/net.cyr socket primitives so
# we can grow the recv buffer to sit's 16 MiB ceiling and resolve
# host strings deliberately. When stdlib http_get grows past 64KB
# (filed informally), wire_http_request can switch back.
#
# Plain-HTTP transport notes (current):
#   * plain http opens a fresh TCP socket per request (HTTP/1.0 +
#     `Connection: close`); the https path is keep-alive (v0.8.9).
#   * https / TLS landed in v0.8.8 — `wire_http_open` accepts
#     https:// (see wire_https.cyr); POST /want batching landed in
#     v0.7.4/v0.7.5, push-side POST /objects + /refs in v0.7.6.
#   * non-loopback host resolution (anything other than the
#     "127.0.0.1" literal or "localhost" rewrite) is still parked —
#     DNS / non-loopback serve is the 1.5.0 transport-trust minor.
#
# Hash trust boundary: the client does NOT re-hash incoming
# objects. The compressed bytes are persisted into the local
# objects.patra under the requested hex key; `sit fsck` is the
# canonical roundtrip per CLAUDE.md ("SHA-256 roundtrips belong in
# fsck, not the hot path"). Identical to the local-clone trust
# model where the source patra DB is similarly trusted.

# Maximum response body the client will accept on any single
# /sit/v1/* request. Matches db_object_read_both's decompression
# ceiling so the failure modes line up: anything that can fit
# through local read can fit through HTTP read.
var WIRE_HTTP_MAX_BODY = 16 * 1024 * 1024;
var WIRE_HTTP_INITIAL_BUF = 65536;

# v0.7.4 batch sizing — chunk size for POST /sit/v1/want. Server
# pins SIT_WANT_MAX_COUNT = 512 (sandhi's HSV_REQ_BUF_SIZE = 64 KiB
# is the binding constraint). 256 leaves headroom and keeps the
# response body comfortably under WIRE_HTTP_MAX_BODY for typical
# sit objects (~5 KiB compressed × 256 = ~1.3 MiB).
var WIRE_HTTP_BATCH_CHUNK = 256;

# http_remote handle layout (48 bytes):
#   0..8   : host addr packed-int IPv4 (network byte order, sock_connect-ready)
#   8..16  : port (TCP)
#   16..24 : batch_probed (0 = not yet, 1 = capabilities GET completed)
#   24..32 : batch_supported (0/1, only meaningful if batch_probed == 1)
#   32..40 : server_requires_auth (0 = anonymous OK, 1 = bearer required;
#            populated alongside batch_supported by the capabilities probe)
#   40..48 : auth_token cstring pointer (0 = none loaded; non-zero pointer
#            sent as "Authorization: Bearer <token>\r\n" on every POST)
#   48..56 : is_tls (1 = https/TLS, 0 = plain http). The per-request socket
#            path wraps the connection in tls_native when set (bite 2).
#   56..64 : host cstring pointer (for TLS SNI + TOFU pin lookup; the numeric
#            addr at 0..8 drives sock_connect, the name drives the handshake)
#   64..72 : keepalive socket fd (0 = no live connection) — v0.8.9 https keep-alive
#   72..80 : keepalive tls_native ctx (0 = none); the persistent TLS connection
#            reused across requests so one handshake serves a whole clone/fetch
fn _http_remote_alloc(addr, port, is_tls, host) {
    var h = alloc(80);
    store64(h,      addr);
    store64(h +  8, port);
    store64(h + 16, 0);
    store64(h + 24, 0);
    store64(h + 32, 0);
    store64(h + 40, 0);
    store64(h + 48, is_tls);
    store64(h + 56, host);
    store64(h + 64, 0);
    store64(h + 72, 0);
    return h;
}

fn _http_remote_addr(h)  { return load64(h); }
fn _http_remote_port(h)  { return load64(h + 8); }
fn _http_remote_probed(h)        { return load64(h + 16); }
fn _http_remote_set_probed(h, v) { store64(h + 16, v); return 0; }
fn _http_remote_batch(h)         { return load64(h + 24); }
fn _http_remote_set_batch(h, v)  { store64(h + 24, v); return 0; }
fn _http_remote_set_requires_auth(h, v) { store64(h + 32, v); return 0; }
fn _http_remote_requires_auth(h) { return load64(h + 32); }
fn _http_remote_token(h)         { return load64(h + 40); }
fn _http_remote_set_token(h, t)  { store64(h + 40, t); return 0; }
fn _http_remote_ka_fd(h)         { return load64(h + 64); }
fn _http_remote_set_ka_fd(h, v)  { store64(h + 64, v); return 0; }
fn _http_remote_ka_tls(h)        { return load64(h + 72); }
fn _http_remote_set_ka_tls(h, v) { store64(h + 72, v); return 0; }
fn _http_remote_is_tls(h)        { return load64(h + 48); }
fn _http_remote_host(h)          { return load64(h + 56); }

# Parse an http:// URL into (host_addr, port). Returns the handle
# pointer on success, 0 on any failure. v0.7.3 accepts:
#
#   http://127.0.0.1[:port][/]
#   http://localhost[:port][/]
#
# Anything else (a different host, a non-trivial path) is rejected
# with an eprintln so the user gets a precise message.

fn wire_http_open(url) {
    var s = url_scheme(url);
    var is_tls = 0;
    var p = 7;                  # past "http://"
    if (s == URL_SCHEME_HTTPS) {
        is_tls = 1;
        p = 8;                  # past "https://"
    }
    else {
        if (s != URL_SCHEME_HTTP) {
            eprintln("sit: wire_http_open expected http:// or https:// URL");
            return 0;
        }
    }
    var ulen = strlen(url);
    var host_start = p;
    while (p < ulen) {
        var c = load8(url + p);
        if (c == 58) { break; }   # ':'
        if (c == 47) { break; }   # '/'
        p = p + 1;
    }
    var host_len = p - host_start;
    if (host_len == 0) {
        eprintln("sit: empty host in http URL");
        return 0;
    }
    var host = alloc(host_len + 1);
    memcpy(host, url + host_start, host_len);
    store8(host + host_len, 0);

    var port = 80;
    if (is_tls == 1) { port = 443; }
    if (p < ulen) {
        if (load8(url + p) == 58) {
            p = p + 1;
            var port_start = p;
            while (p < ulen) {
                var c2 = load8(url + p);
                if (c2 < 48) { break; }
                if (c2 > 57) { break; }
                p = p + 1;
            }
            if (p == port_start) {
                eprintln("sit: empty port in http URL");
                return 0;
            }
            port = 0;
            var pi = port_start;
            while (pi < p) {
                port = port * 10 + (load8(url + pi) - 48);
                if (port > 65535) {
                    eprintln("sit: port out of range in http URL");
                    return 0;
                }
                pi = pi + 1;
            }
            if (port < 1) {
                eprintln("sit: port out of range in http URL");
                return 0;
            }
        }
    }

    # v0.7.3 path component: only "" or "/" accepted. A non-trivial
    # base path (e.g. http://host/repos/foo) needs server-side
    # routing changes — deferred. Refusing here keeps the surface
    # honest instead of silently appending /sit/v1/* to user input.
    if (p < ulen) {
        var path_len = ulen - p;
        if (path_len > 1) {
            eprintln("sit: http base paths are not supported (use http://host:port)");
            return 0;
        }
        if (load8(url + p) != 47) {
            eprintln("sit: malformed http URL (expected ':' or '/' after host)");
            return 0;
        }
    }

    # Host resolution: numeric IPv4 literal first, then "localhost"
    # shortcut — the v0.7.3 success gate is loopback only.
    var addr = sandhi_net_parse_ipv4(host);
    if (addr < 0) {
        if (streq(host, "localhost") == 1) {
            addr = INADDR_LOOPBACK();
        }
        else {
            eprintln("sit: host resolution requires a numeric IPv4 literal or 'localhost'");
            return 0;
        }
    }

    return _http_remote_alloc(addr, port, is_tls, host);
}

fn wire_http_close(h) {
    # v0.8.9: tear down the persistent https keep-alive connection if one is
    # live (no-op for plain http, which holds no persistent socket).
    _wire_https_teardown(h);
    return 0;
}

# ── Low-level request loop ─────────────────────────────────────────
#
# Issue `GET <sub_path> HTTP/1.0` against the handle and collect the
# whole response into a freelist-backed buffer. `out_quad` (32 bytes)
# is filled on return:
#   0..8  : body pointer (into the same alloc as the rest of the
#           response — DO NOT fl_free until the caller is done with
#           the body bytes; caller calls _wire_http_response_free)
#   8..16 : body length
#  16..24 : status code (HTTP "NNN" — 0 on parse failure)
#  24..32 : X-Sit-Type integer value (-1 if header absent)
#
# The buffer pointer is stashed at out_quad[32..40] so caller can
# fl_free it after consuming the body. (40-byte caller buffer.)
#
# Returns 0 on success (where success means "we got a response we
# could parse", not "status was 2xx"), -1 on socket errors.

fn _wire_http_request(h, sub_path, out_quad) {
    # https:// → persistent keep-alive connection (one handshake per clone/fetch).
    if (_http_remote_is_tls(h) == 1) {
        return _wire_https_exchange(h, 0, sub_path, 0, 0, 0, out_quad);
    }
    var fd_r = tcp_socket();
    if (is_err_result(fd_r) == 1) {
        eprintln("sit: tcp_socket failed");
        return 0 - 1;
    }
    var fd = payload(fd_r);
    var c_r = sock_connect(fd, _http_remote_addr(h), _http_remote_port(h));
    if (is_err_result(c_r) == 1) {
        sys_close(fd);
        eprintln("sit: sock_connect failed (is sit serve running?)");
        return 0 - 1;
    }

    # https:// → TLS 1.3 handshake + TOFU pin over the connected socket.
    var tls = 0;
    if (_http_remote_is_tls(h) == 1) {
        tls = _wire_https_connect(_http_remote_host(h), _http_remote_port(h), fd);
        if (tls == 0) { sys_close(fd); return 0 - 1; }
    }

    # Build "GET <path> HTTP/1.0\r\nHost: 127.0.0.1\r\nConnection: close\r\n\r\n".
    # Host: literal "127.0.0.1" — RFC 7230 allows any host so long as the
    # server doesn't vhost on it; sit serve doesn't, so this is fine.
    var sp_len = strlen(sub_path);
    var req_cap = 64 + sp_len;
    var req = alloc(req_cap);
    var pos = 0;
    memcpy(req + pos, "GET ", 4); pos = pos + 4;
    memcpy(req + pos, sub_path, sp_len); pos = pos + sp_len;
    memcpy(req + pos, " HTTP/1.0\r\nHost: 127.0.0.1\r\nConnection: close\r\n\r\n", 49);
    pos = pos + 49;
    _wire_io_send(tls, fd, req, pos);

    # Recv loop with growing fl_alloc buffer.
    var cap = WIRE_HTTP_INITIAL_BUF;
    var buf = fl_alloc(cap);
    if (buf == 0) {
        sys_close(fd);
        eprintln("sit: out of memory allocating http recv buffer");
        return 0 - 1;
    }
    var used = 0;
    var rgo = 1;
    while (rgo == 1) {
        if (used == cap) {
            if (cap >= WIRE_HTTP_MAX_BODY) {
                # Body cap reached. Treat as a parse failure rather than
                # silently truncating. Server should not have shipped > 16 MiB.
                fl_free(buf);
                sys_close(fd);
                eprintln("sit: http response exceeds 16 MiB cap");
                return 0 - 1;
            }
            var new_cap = cap * 2;
            if (new_cap > WIRE_HTTP_MAX_BODY) { new_cap = WIRE_HTTP_MAX_BODY; }
            var new_buf = fl_alloc(new_cap);
            if (new_buf == 0) {
                fl_free(buf);
                sys_close(fd);
                eprintln("sit: out of memory growing http recv buffer");
                return 0 - 1;
            }
            memcpy(new_buf, buf, used);
            fl_free(buf);
            buf = new_buf;
            cap = new_cap;
        }
        var n = _wire_io_recv(tls, fd, buf + used, cap - used);
        if (n <= 0) { rgo = 0; }
        else { used = used + n; }
    }
    if (tls != 0) { tls_native_close(tls); }
    sys_close(fd);

    # Parse status line: "HTTP/1.x SSS ..."
    var status = 0;
    if (used >= 12) {
        if (memeq(buf, "HTTP/1.", 7) == 1) {
            status = (load8(buf + 9) - 48) * 100
                   + (load8(buf + 10) - 48) * 10
                   + (load8(buf + 11) - 48);
        }
    }

    # Walk headers. Identify body start (after \r\n\r\n) and X-Sit-Type
    # if present. Header name compare is case-sensitive; sandhi emits
    # the canonical "X-Sit-Type:" form.
    var i = 0;
    var body_off = 0 - 1;
    var ty = 0 - 1;
    while (i + 3 < used) {
        if (load8(buf + i) == 13) {
            if (load8(buf + i + 1) == 10) {
                if (load8(buf + i + 2) == 13) {
                    if (load8(buf + i + 3) == 10) {
                        body_off = i + 4;
                        i = used;  # break the outer loop
                    }
                }
            }
        }
        if (i < used) {
            # Header-line probe: if buf[i..i+11] is "X-Sit-Type:" record
            # the integer value that follows (skipping spaces). Done in
            # the same pass to avoid a second walk.
            if (i + 11 < used) {
                if (memeq(buf + i, "X-Sit-Type:", 11) == 1) {
                    # Skip OWS (sandhi emits exactly one space after the
                    # colon; we tolerate either 0x20 or 0x09 in case a
                    # future intermediary normalises differently).
                    var hp = i + 11;
                    var skipping = 1;
                    while (skipping == 1) {
                        skipping = 0;
                        if (hp < used) {
                            var hc = load8(buf + hp);
                            if (hc == 32) { hp = hp + 1; skipping = 1; }
                            if (hc == 9)  { hp = hp + 1; skipping = 1; }
                        }
                    }
                    var v = 0;
                    var saw = 0;
                    var collecting = 1;
                    while (collecting == 1) {
                        collecting = 0;
                        if (hp < used) {
                            var d = load8(buf + hp) & 0xFF;
                            if (d >= 48) {
                                if (d <= 57) {
                                    v = v * 10 + (d - 48);
                                    saw = 1;
                                    hp = hp + 1;
                                    collecting = 1;
                                }
                            }
                        }
                    }
                    if (saw == 1) { ty = v; }
                }
            }
            i = i + 1;
        }
    }

    if (body_off < 0) {
        fl_free(buf);
        eprintln("sit: malformed http response (no header terminator)");
        return 0 - 1;
    }

    store64(out_quad,      buf + body_off);
    store64(out_quad +  8, used - body_off);
    store64(out_quad + 16, status);
    store64(out_quad + 24, ty);
    store64(out_quad + 32, buf);
    store64(out_quad + 40, cap);
    return 0;
}

fn _wire_http_response_free(out_quad) {
    var buf = load64(out_quad + 32);
    var cap = load64(out_quad + 40);
    if (buf != 0) { fl_free(buf); }
    return 0;
}

# ── HTTPS keep-alive (v0.8.9) ──
#
# For https:// the TLS handshake dominates per-request cost, so the handle holds
# ONE persistent socket + tls_native ctx and reuses it across every request of a
# clone/fetch/push (one handshake instead of N). Plain http keeps its proven
# per-request path (the sandhi server closes after each response anyway).
#
# The reused connection requires exact-Content-Length response framing (read
# precisely status+headers+body, never to-EOF) so the next request stays aligned.
# sit's server always emits Content-Length, so this is well-defined.

# Establish (or reuse) the handle's persistent TLS connection. Returns 1 on a
# live connection, 0 on failure.
fn _wire_https_acquire(h) {
    if (_http_remote_ka_fd(h) != 0) { return 1; }
    var fd_r = tcp_socket();
    if (is_err_result(fd_r) == 1) { eprintln("sit: tcp_socket failed"); return 0; }
    var fd = payload(fd_r);
    if (is_err_result(sock_connect(fd, _http_remote_addr(h), _http_remote_port(h))) == 1) {
        sys_close(fd);
        eprintln("sit: sock_connect failed (is sit serve running?)");
        return 0;
    }
    var tls = _wire_https_connect(_http_remote_host(h), _http_remote_port(h), fd);
    if (tls == 0) { sys_close(fd); return 0; }
    _http_remote_set_ka_fd(h, fd);
    _http_remote_set_ka_tls(h, tls);
    return 1;
}

# Close + clear the persistent connection (on I/O error, or at handle close).
fn _wire_https_teardown(h) {
    var tls = _http_remote_ka_tls(h);
    var fd = _http_remote_ka_fd(h);
    if (tls != 0) { tls_native_close(tls); }
    if (fd != 0) { sys_close(fd); }
    _http_remote_set_ka_fd(h, 0);
    _http_remote_set_ka_tls(h, 0);
    return 0;
}

# One request/response over the persistent TLS connection. is_post selects
# GET vs POST; extra_hdr (or 0) is an already-CRLF-terminated header line
# (e.g. "X-Sit-Type: 1\r\n"). out_quad matches _wire_http_request. Returns 0 on
# success, -1 on I/O error (tearing the connection down so the next call redials).
fn _wire_https_exchange(h, is_post, sub_path, body, body_len, extra_hdr, out_quad) {
    if (_wire_https_acquire(h) == 0) { return 0 - 1; }
    var fd = _http_remote_ka_fd(h);
    var tls = _http_remote_ka_tls(h);

    var sp_len = strlen(sub_path);
    var token = _http_remote_token(h);
    var tlen = 0;
    if (token != 0) { tlen = strlen(token); }
    var ehl = 0;
    if (extra_hdr != 0) { ehl = strlen(extra_hdr); }
    var clen_buf[24];
    var clen_digits = 0;
    if (is_post == 1) { clen_digits = write_decimal(&clen_buf, body_len); }

    var hdr = alloc(192 + sp_len + clen_digits + ehl + tlen);
    var pos = 0;
    if (is_post == 1) { memcpy(hdr + pos, "POST ", 5); pos = pos + 5; }
    else { memcpy(hdr + pos, "GET ", 4); pos = pos + 4; }
    memcpy(hdr + pos, sub_path, sp_len); pos = pos + sp_len;
    memcpy(hdr + pos, " HTTP/1.1\r\nHost: 127.0.0.1\r\nConnection: keep-alive\r\n", 52); pos = pos + 52;
    if (is_post == 1) {
        memcpy(hdr + pos, "Content-Type: application/octet-stream\r\nContent-Length: ", 56); pos = pos + 56;
        memcpy(hdr + pos, &clen_buf, clen_digits); pos = pos + clen_digits;
        memcpy(hdr + pos, "\r\n", 2); pos = pos + 2;
    }
    if (ehl > 0) { memcpy(hdr + pos, extra_hdr, ehl); pos = pos + ehl; }
    if (token != 0) {
        memcpy(hdr + pos, "Authorization: Bearer ", 22); pos = pos + 22;
        memcpy(hdr + pos, token, tlen); pos = pos + tlen;
        memcpy(hdr + pos, "\r\n", 2); pos = pos + 2;
    }
    memcpy(hdr + pos, "\r\n", 2); pos = pos + 2;   # end of request headers

    if (_wire_io_send(tls, fd, hdr, pos) != 0) { _wire_https_teardown(h); return 0 - 1; }
    if (is_post == 1) {
        if (body_len > 0) {
            if (_wire_io_send(tls, fd, body, body_len) != 0) { _wire_https_teardown(h); return 0 - 1; }
        }
    }

    # Read EXACTLY one response: status + headers + Content-Length body.
    var cap = WIRE_HTTP_INITIAL_BUF;
    var buf = fl_alloc(cap);
    if (buf == 0) {
        _wire_https_teardown(h);
        eprintln("sit: out of memory allocating https recv buffer");
        return 0 - 1;
    }
    var used = 0;
    var body_off = 0 - 1;
    var content_len = 0;
    var rgo = 1;
    while (rgo == 1) {
        if (used == cap) {
            if (cap >= WIRE_HTTP_MAX_BODY) {
                fl_free(buf); _wire_https_teardown(h);
                eprintln("sit: https response exceeds 16 MiB cap"); return 0 - 1;
            }
            var new_cap = cap * 2;
            if (new_cap > WIRE_HTTP_MAX_BODY) { new_cap = WIRE_HTTP_MAX_BODY; }
            var new_buf = fl_alloc(new_cap);
            if (new_buf == 0) { fl_free(buf); _wire_https_teardown(h); return 0 - 1; }
            memcpy(new_buf, buf, used);
            fl_free(buf);
            buf = new_buf;
            cap = new_cap;
        }
        var n = _wire_io_recv(tls, fd, buf + used, cap - used);
        if (n <= 0) {
            fl_free(buf); _wire_https_teardown(h);
            eprintln("sit: https connection closed mid-response"); return 0 - 1;
        }
        used = used + n;
        if (body_off < 0) {
            body_off = sandhi_server_body_offset(buf, used);
            if (body_off > 0) { content_len = sandhi_server_content_length(buf, used); }
        }
        if (body_off > 0) {
            if (used >= body_off + content_len) { rgo = 0; }
        }
    }

    var status = 0;
    if (used >= 12) {
        if (memeq(buf, "HTTP/1.", 7) == 1) {
            status = (load8(buf + 9) - 48) * 100 + (load8(buf + 10) - 48) * 10 + (load8(buf + 11) - 48);
        }
    }
    var ty = 0 - 1;
    var tyv = sandhi_server_find_header(buf, used, "X-Sit-Type");
    if (tyv != 0) {
        var ti = 0;
        var skipping = 1;
        while (skipping == 1) {
            skipping = 0;
            var tc = load8(tyv + ti) & 0xFF;
            if (tc == 32) { ti = ti + 1; skipping = 1; }
            if (tc == 9)  { ti = ti + 1; skipping = 1; }
        }
        var tv = 0;
        var saw = 0;
        var collecting = 1;
        while (collecting == 1) {
            collecting = 0;
            var d = load8(tyv + ti) & 0xFF;
            if (d >= 48) {
                if (d <= 57) { tv = tv * 10 + (d - 48); saw = 1; ti = ti + 1; collecting = 1; }
            }
        }
        if (saw == 1) { ty = tv; }
    }

    store64(out_quad,      buf + body_off);
    store64(out_quad +  8, content_len);
    store64(out_quad + 16, status);
    store64(out_quad + 24, ty);
    store64(out_quad + 32, buf);
    store64(out_quad + 40, cap);
    return 0;
}

# POST variant of _wire_http_request: same response-parsing shape,
# different request-build path. Sends a fixed-shape body with
# Content-Type: application/octet-stream + Content-Length. Out-quad
# layout matches GET. Introduced for /sit/v1/want in v0.7.4; now has
# live callers — http_remote_read_batch (want batching, since v0.7.5)
# and http_remote_push_ref (push, since v0.7.6). See ADR 0006 for the
# wire format.

fn _wire_http_post(h, sub_path, body, body_len, out_quad) {
    if (_http_remote_is_tls(h) == 1) {
        return _wire_https_exchange(h, 1, sub_path, body, body_len, 0, out_quad);
    }
    var fd_r = tcp_socket();
    if (is_err_result(fd_r) == 1) {
        eprintln("sit: tcp_socket failed");
        return 0 - 1;
    }
    var fd = payload(fd_r);
    var c_r = sock_connect(fd, _http_remote_addr(h), _http_remote_port(h));
    if (is_err_result(c_r) == 1) {
        sys_close(fd);
        eprintln("sit: sock_connect failed (is sit serve running?)");
        return 0 - 1;
    }

    # https:// → TLS 1.3 handshake + TOFU pin over the connected socket.
    var tls = 0;
    if (_http_remote_is_tls(h) == 1) {
        tls = _wire_https_connect(_http_remote_host(h), _http_remote_port(h), fd);
        if (tls == 0) { sys_close(fd); return 0 - 1; }
    }

    # Request line + framing headers. body_len rendered as decimal
    # via write_decimal (src/util.cyr). Authorization header injected
    # if the handle has a token loaded (v0.7.6 bearer auth).
    var sp_len = strlen(sub_path);
    var clen_buf[24];
    var clen_digits = write_decimal(&clen_buf, body_len);
    var token = _http_remote_token(h);
    var tlen = 0;
    if (token != 0) { tlen = strlen(token); }
    var hdr_cap = 128 + sp_len + clen_digits + tlen + 32;
    var hdr = alloc(hdr_cap);
    var pos = 0;
    memcpy(hdr + pos, "POST ", 5); pos = pos + 5;
    memcpy(hdr + pos, sub_path, sp_len); pos = pos + sp_len;
    memcpy(hdr + pos, " HTTP/1.0\r\nHost: 127.0.0.1\r\nContent-Type: application/octet-stream\r\nContent-Length: ", 84);
    pos = pos + 84;
    memcpy(hdr + pos, &clen_buf, clen_digits); pos = pos + clen_digits;
    memcpy(hdr + pos, "\r\n", 2); pos = pos + 2;
    if (token != 0) {
        memcpy(hdr + pos, "Authorization: Bearer ", 22); pos = pos + 22;
        memcpy(hdr + pos, token, tlen); pos = pos + tlen;
        memcpy(hdr + pos, "\r\n", 2); pos = pos + 2;
    }
    memcpy(hdr + pos, "Connection: close\r\n\r\n", 21); pos = pos + 21;
    _wire_io_send(tls, fd, hdr, pos);
    if (body_len > 0) { _wire_io_send(tls, fd, body, body_len); }

    # Response read — identical loop to _wire_http_request.
    var cap = WIRE_HTTP_INITIAL_BUF;
    var buf = fl_alloc(cap);
    if (buf == 0) {
        sys_close(fd);
        eprintln("sit: out of memory allocating http recv buffer");
        return 0 - 1;
    }
    var used = 0;
    var rgo = 1;
    while (rgo == 1) {
        if (used == cap) {
            if (cap >= WIRE_HTTP_MAX_BODY) {
                fl_free(buf);
                sys_close(fd);
                eprintln("sit: http response exceeds 16 MiB cap");
                return 0 - 1;
            }
            var new_cap = cap * 2;
            if (new_cap > WIRE_HTTP_MAX_BODY) { new_cap = WIRE_HTTP_MAX_BODY; }
            var new_buf = fl_alloc(new_cap);
            if (new_buf == 0) {
                fl_free(buf);
                sys_close(fd);
                eprintln("sit: out of memory growing http recv buffer");
                return 0 - 1;
            }
            memcpy(new_buf, buf, used);
            fl_free(buf);
            buf = new_buf;
            cap = new_cap;
        }
        var n = _wire_io_recv(tls, fd, buf + used, cap - used);
        if (n <= 0) { rgo = 0; }
        else { used = used + n; }
    }
    if (tls != 0) { tls_native_close(tls); }
    sys_close(fd);

    # Status + body parse — identical to GET path. ty is N/A here
    # (the X-Sit-Type header doesn't apply to /want responses;
    # frames carry their own ty).
    var status = 0;
    if (used >= 12) {
        if (memeq(buf, "HTTP/1.", 7) == 1) {
            status = (load8(buf + 9) - 48) * 100
                   + (load8(buf + 10) - 48) * 10
                   + (load8(buf + 11) - 48);
        }
    }
    var i = 0;
    var body_off = 0 - 1;
    while (i + 3 < used) {
        if (load8(buf + i) == 13) {
            if (load8(buf + i + 1) == 10) {
                if (load8(buf + i + 2) == 13) {
                    if (load8(buf + i + 3) == 10) {
                        body_off = i + 4;
                        i = used;
                    }
                }
            }
        }
        if (i < used) { i = i + 1; }
    }
    if (body_off < 0) {
        fl_free(buf);
        eprintln("sit: malformed http response (no header terminator)");
        return 0 - 1;
    }

    store64(out_quad,      buf + body_off);
    store64(out_quad +  8, used - body_off);
    store64(out_quad + 16, status);
    store64(out_quad + 24, 0 - 1);   # ty: not applicable for POST responses
    store64(out_quad + 32, buf);
    store64(out_quad + 40, cap);
    return 0;
}

# ── Capabilities probe (v0.7.4) ────────────────────────────────────
#
# One-time GET /sit/v1/capabilities; record whether the server
# advertises "batch":true. Idempotent — the handle's batch_probed
# flag short-circuits subsequent calls. Fail-closed: any error
# (network, parse, missing field) → batch=0. The caller then falls
# back to per-object GET, which is the v0.7.3 path.
#
# Parsing is hand-rolled because the response shape is small,
# entirely under our control, and pulling lib/json.cyr's parser
# into the cap-probe critical path buys nothing. Looks for the
# byte sequence `"batch":true` anywhere in the body.

fn http_remote_check_batch(h) {
    if (_http_remote_probed(h) == 1) { return _http_remote_batch(h); }
    _http_remote_set_probed(h, 1);
    _http_remote_set_batch(h, 0);
    _http_remote_set_requires_auth(h, 0);

    var quad[48];
    if (_wire_http_request(h, "/sit/v1/capabilities", &quad) != 0) { return 0; }
    var status = load64(&quad + 16);
    if (status != 200) {
        _wire_http_response_free(&quad);
        return 0;
    }
    var body = load64(&quad);
    var blen = load64(&quad + 8);
    var found_batch = 0;
    var found_auth_bearer = 0;
    var i = 0;
    while (i + 17 < blen) {
        if (memeq(body + i, "\"batch\":true", 12) == 1) {
            found_batch = 1;
            i = i + 12;
        }
        else {
            if (memeq(body + i, "\"auth\":[\"bearer\"", 16) == 1) {
                found_auth_bearer = 1;
                i = i + 16;
            }
            else { i = i + 1; }
        }
    }
    _wire_http_response_free(&quad);
    if (found_auth_bearer == 1) { _http_remote_set_requires_auth(h, 1); }
    if (found_batch == 1) { _http_remote_set_batch(h, 1); return 1; }
    return 0;
}

# Load a serve.token from disk in the same format the server's
# `_serve_load_token` accepts (16+ chars, no control bytes,
# trailing-whitespace stripped). Used by cmd_push when the server's
# capabilities advertise `"auth":["bearer"]`. Path is
# `~/.sit/serve.token` by convention; clients can override with
# `--token` on cmd_push (plumbed through wire_http_open variants
# in a follow-on patch — v0.7.6 ships the default-path-only shape).
#
# Returns the heap-owned cstring on success, 0 on any failure.
# Callers must error out on 0 if the server requires bearer; sit
# never silently sends an empty Authorization header.

fn _wire_http_load_client_token() {
    var home = getenv("HOME");
    if (home == 0) { return 0; }
    var hl = strlen(home);
    var p = alloc(hl + 18);
    memcpy(p, home, hl);
    memcpy(p + hl, "/.sit/serve.token", 17);
    store8(p + hl + 17, 0);
    if (file_exists(p) != 1) { return 0; }
    var pair[16];
    if (read_file_heap(p, &pair) != 0) { return 0; }
    var data = load64(&pair);
    var len = load64(&pair + 8);
    var stripping = 1;
    while (stripping == 1) {
        stripping = 0;
        if (len > 0) {
            var lc = load8(data + len - 1) & 0xFF;
            if (lc == 10) { len = len - 1; stripping = 1; }
            if (lc == 13) { len = len - 1; stripping = 1; }
            if (lc == 32) { len = len - 1; stripping = 1; }
            if (lc == 9)  { len = len - 1; stripping = 1; }
        }
    }
    if (len < 16) { return 0; }
    var i = 0;
    while (i < len) {
        var c = load8(data + i) & 0xFF;
        if (c < 33)   { return 0; }   # control + space → reject
        if (c == 127) { return 0; }
        i = i + 1;
    }
    var tok = alloc(len + 1);
    memcpy(tok, data, len);
    store8(tok + len, 0);
    return tok;
}

# ── /sit/v1/want batched object fetch (v0.7.4) ─────────────────────
#
# Build the request body per ADR 0006: i64 LE count, then count
# 64-byte ASCII hex hashes. Send POST /sit/v1/want. Walk the
# response stream, decode each frame, and cache-insert the
# {compressed, clen, ty} triple keyed by hash.
#
# Hashes the server didn't have are silently absent from the
# response — the cache miss persists and the existing copy_objects
# fallback (per-object GET via obj_src_read_raw) handles them. So
# a partial response is safe; the worst case is one round trip
# wasted before falling back.
#
# Frame validation:
#   * hex passes hex_prefix_valid (rejects non-hex bytes; flips an
#     attacker server's chance of getting a corrupt key into the
#     local DB to 0)
#   * ty is one of {0, 1, 2}; anything else stops the parse
#     mid-stream (return -1)
#   * clen is positive and the declared frame fits in the body
#     remaining; otherwise stop the parse
#
# Returns the count of frames successfully cached (≤ count
# requested), or -1 on framing failure. Server malformed responses
# fail loudly rather than silently — they signal a wire-protocol
# violation that the user should know about.

fn http_remote_read_batch(h, hashes, start_idx, count, raw_cache) {
    if (count <= 0) { return 0; }

    # Build request body: 8-byte count + count*64 hashes. Allocated
    # via fl_alloc since the size is bounded (count <= ~512 → ≤ 32 KiB).
    var body_len = 8 + count * 64;
    var body = fl_alloc(body_len);
    if (body == 0) {
        eprintln("sit: out of memory building batch request");
        return 0 - 1;
    }
    store64(body, count);
    var bi = 0;
    while (bi < count) {
        var hex = vec_get(hashes, start_idx + bi);
        memcpy(body + 8 + bi * 64, hex, 64);
        bi = bi + 1;
    }

    var quad[48];
    var post_rc = _wire_http_post(h, "/sit/v1/want", body, body_len, &quad);
    fl_free(body);
    if (post_rc != 0) { return 0 - 1; }

    var status = load64(&quad + 16);
    if (status != 200) {
        _wire_http_response_free(&quad);
        if (status == 404) {
            # Server doesn't actually implement /want despite the
            # capability flag — disable batch on this handle so
            # subsequent calls fall back without retrying.
            _http_remote_set_batch(h, 0);
        }
        return 0 - 1;
    }

    var resp = load64(&quad);
    var rlen = load64(&quad + 8);
    var cached = _wire_http_decode_frames(resp, rlen, raw_cache);
    _wire_http_response_free(&quad);
    if (cached < 0) {
        eprintln("sit: malformed /sit/v1/want frame stream");
        return 0 - 1;
    }
    return cached;
}

# ── Frame stream decoder (v0.7.5) ──────────────────────────────────
#
# Walks a `buf[0..blen]` byte stream of `[64 hex][8B i64 LE ty][8B
# i64 LE clen][clen bytes compressed]` frames per ADR 0006. For each
# successfully-validated frame, copies the compressed payload to a
# fresh heap alloc (lifetime-detached from `buf`) and inserts a
# {compressed, clen, ty} entry into `raw_cache` keyed by the hex
# string.
#
# Validation per frame (any failure → return -1; the caller then
# treats the whole batch as failed and falls back to per-object GET):
#   * `off + 80 <= blen` — header fits in remaining bytes
#   * `hex_prefix_valid(hex, 64)` — hash slot is 64 ASCII hex chars
#   * `ty >= 0 && ty <= 2` — known patra type code (0=blob, 1=tree,
#     2=commit). Negative ty also rules out the wraparound case where
#     a malicious server tried to smuggle a >2^63-byte payload via
#     i64 underflow.
#   * `clen > 0` — empty payload is meaningless and lets a malicious
#     stream advance `off` by exactly 80 in a tight loop
#   * `clen <= WIRE_HTTP_MAX_BODY` — bounds the alloc + matches the
#     db_object_read_both decompression ceiling
#   * `off + 80 + clen <= blen` — payload fits in remaining bytes
#
# This function is the v0.7.5 fuzz target. Adversarial bytes go in;
# the parser must terminate on every input without OOB reads, infinite
# loops, or oversized allocs. Pulled out of http_remote_read_batch
# specifically so tests/sit.fcyr can drive it without standing up
# a TCP socket.
#
# Returns the count of successfully-cached frames (>= 0) on a
# well-formed stream, or -1 on any validation failure mid-stream.
# A buffer of length 0 returns 0 (zero frames is valid).

fn _wire_http_decode_frames(buf, blen, raw_cache) {
    var off = 0;
    var cached = 0;
    var failed = 0;
    while (off < blen) {
        if (failed == 1) { off = blen; }
        else {
            if (off + 80 > blen) { failed = 1; }
            else {
                var hex = buf + off;
                if (hex_prefix_valid(hex, 64) == 0) { failed = 1; }
                else {
                    var ty = load64(buf + off + 64);
                    var clen = load64(buf + off + 72);
                    if (ty < 0) { failed = 1; }
                    else {
                        if (ty > 2) { failed = 1; }
                        else {
                            if (clen <= 0) { failed = 1; }
                            else {
                                if (clen > WIRE_HTTP_MAX_BODY) { failed = 1; }
                                else {
                                    if (off + 80 + clen > blen) { failed = 1; }
                                    else {
                                        var compressed = alloc(clen);
                                        memcpy(compressed, buf + off + 80, clen);
                                        var raw[24];
                                        store64(&raw,      compressed);
                                        store64(&raw +  8, clen);
                                        store64(&raw + 16, ty);
                                        var key = alloc(65);
                                        memcpy(key, hex, 64);
                                        store8(key + 64, 0);
                                        _walk_cache_insert(raw_cache, key, &raw);
                                        cached = cached + 1;
                                        off = off + 80 + clen;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    if (failed == 1) { return 0 - 1; }
    return cached;
}

# ── /sit/v1/refs JSON parser ───────────────────────────────────────
#
# Body shape (per serve_build_refs):
#   {"refs":[{"name":"...","hash":"..."}, ...]}
#
# Hand-rolled parser: scan for "name":"..." then "hash":"...".
# refname_valid + hex_prefix_valid gate every value before it
# enters anything path- or DB-shaped. Out vec is populated with
# alternating heap cstrings: name0, hex0, name1, hex1, ...
#
# Returns -1 on parse failure, 0 otherwise (zero entries is valid).

fn _wire_http_parse_refs(body, blen, out_pairs) {
    var i = 0;
    while (i < blen) {
        # Find the next `"name":"`.
        if (i + 8 < blen) {
            if (memeq(body + i, "\"name\":\"", 8) == 1) {
                var name_start = i + 8;
                var name_end = name_start;
                while (name_end < blen) {
                    if (load8(body + name_end) == 34) { break; }  # "
                    if (load8(body + name_end) == 92) { return 0 - 1; }  # backslash — refname doesn't need escaping
                    name_end = name_end + 1;
                }
                if (name_end >= blen) { return 0 - 1; }
                var nlen = name_end - name_start;
                # Look forward for the matching "hash":"<64hex>".
                var j = name_end;
                while (j + 8 < blen) {
                    if (memeq(body + j, "\"hash\":\"", 8) == 1) { break; }
                    j = j + 1;
                }
                if (j + 8 >= blen) { return 0 - 1; }
                var hash_start = j + 8;
                if (hash_start + 64 > blen) { return 0 - 1; }
                if (load8(body + hash_start + 64) != 34) { return 0 - 1; }
                # Validate name + hash.
                var name = alloc(nlen + 1);
                memcpy(name, body + name_start, nlen);
                store8(name + nlen, 0);
                if (refname_valid(name) == 0) { return 0 - 1; }
                if (hex_prefix_valid(body + hash_start, 64) == 0) { return 0 - 1; }
                var hex = alloc(65);
                memcpy(hex, body + hash_start, 64);
                store8(hex + 64, 0);
                vec_push(out_pairs, name);
                vec_push(out_pairs, hex);
                i = hash_start + 65;
            }
            else {
                i = i + 1;
            }
        }
        else {
            i = i + 1;
        }
    }
    return 0;
}

fn http_remote_read_refs(h, out_pairs) {
    var quad[48];
    if (_wire_http_request(h, "/sit/v1/refs", &quad) != 0) { return 0 - 1; }
    var status = load64(&quad + 16);
    if (status != 200) {
        _wire_http_response_free(&quad);
        eprintln("sit: GET /sit/v1/refs returned non-200");
        return 0 - 1;
    }
    var body = load64(&quad);
    var blen = load64(&quad + 8);
    var rc = _wire_http_parse_refs(body, blen, out_pairs);
    _wire_http_response_free(&quad);
    if (rc != 0) {
        eprintln("sit: malformed /sit/v1/refs JSON");
        return 0 - 1;
    }
    return 0;
}

# Look up `branch_name` in the refs vec. Returns the hex cstring or 0.
fn http_remote_resolve_branch(h, branch) {
    # `branch` is "main", "feature/foo", etc.; the server emits
    # "refs/heads/<branch>". Compose the wanted name once.
    var blen = strlen(branch);
    var want = alloc(11 + blen + 1);
    memcpy(want, "refs/heads/", 11);
    memcpy(want + 11, branch, blen);
    store8(want + 11 + blen, 0);

    var pairs = vec_new();
    if (http_remote_read_refs(h, pairs) != 0) { return 0; }
    var n = vec_len(pairs);
    var i = 0;
    while (i + 1 < n) {
        var name = vec_get(pairs, i);
        if (streq(name, want) == 1) { return vec_get(pairs, i + 1); }
        i = i + 2;
    }
    return 0;
}

# ── Object fetch ───────────────────────────────────────────────────
#
# Issue GET /sit/v1/objects/<hex>; populate raw_out with
# {compressed_ptr@0, clen@8, ty@16}. The compressed bytes are
# COPIED out of the response buffer (which is fl_freed before
# return) into a fresh heap allocation owned by the caller —
# matches db_object_read_raw's lifetime contract so callers can
# treat the two interchangeably.
#
# Returns 0 on success, negative on any failure.

fn http_remote_read_raw(h, hex, raw_out) {
    if (hex_prefix_valid(hex, 64) == 0) { return 0 - 1; }
    var sub = alloc(16 + 64 + 1);
    memcpy(sub, "/sit/v1/objects/", 16);
    memcpy(sub + 16, hex, 64);
    store8(sub + 16 + 64, 0);

    var quad[48];
    if (_wire_http_request(h, sub, &quad) != 0) { return 0 - 2; }
    var status = load64(&quad + 16);
    var ty = load64(&quad + 24);
    if (status != 200) {
        _wire_http_response_free(&quad);
        return 0 - 3;
    }
    if (ty < 0) {
        _wire_http_response_free(&quad);
        eprintln("sit: server response missing X-Sit-Type header");
        return 0 - 4;
    }
    if (ty > 2) {
        # 0=blob, 1=tree, 2=commit. Unknown types should never reach
        # the local DB — refuse before we'd have to migrate later.
        _wire_http_response_free(&quad);
        eprintln("sit: server returned unrecognized X-Sit-Type");
        return 0 - 5;
    }
    var body = load64(&quad);
    var blen = load64(&quad + 8);
    if (blen <= 0) {
        _wire_http_response_free(&quad);
        return 0 - 6;
    }
    var compressed = alloc(blen);
    memcpy(compressed, body, blen);
    _wire_http_response_free(&quad);
    store64(raw_out,      compressed);
    store64(raw_out +  8, blen);
    store64(raw_out + 16, ty);
    return 0;
}

# Mirror of db_object_read_both for HTTP: read raw, then decompress
# with the same 4×-initial / 16 MiB-ceiling sizing policy so
# walk_reachable_* sees identical failure modes regardless of
# transport.

fn http_remote_read_both(h, hex, raw_out, deco_out) {
    if (http_remote_read_raw(h, hex, raw_out) != 0) { return 0 - 1; }
    var compressed = load64(raw_out);
    var clen = load64(raw_out + 8);
    var dec_cap = clen * 4;
    if (dec_cap < 4096) { dec_cap = 4096; }
    if (dec_cap > 16 * 1024 * 1024) { dec_cap = 16 * 1024 * 1024; }
    var decompressed = alloc(dec_cap);
    if (decompressed == 0) { return 0 - 2; }
    var dlen = zlib_decompress(compressed, clen, decompressed, dec_cap);
    if (dlen == 0 - ERR_BUFFER_TOO_SMALL) {
        if (dec_cap < 16 * 1024 * 1024) {
            dec_cap = 16 * 1024 * 1024;
            decompressed = alloc(dec_cap);
            if (decompressed == 0) { return 0 - 2; }
            dlen = zlib_decompress(compressed, clen, decompressed, dec_cap);
        }
    }
    if (dlen <= 0) { return 0 - 3; }
    var nul = 0;
    while (nul < dlen) {
        if (load8(decompressed + nul) == 0) { break; }
        nul = nul + 1;
    }
    if (nul >= dlen) { return 0 - 4; }
    store64(deco_out,      decompressed);
    store64(deco_out +  8, dlen);
    store64(deco_out + 16, nul + 1);
    return 0;
}

# ── Push primitives (v0.7.6) ───────────────────────────────────────
#
# `http_remote_push_object` uploads one compressed sit object via
# POST /sit/v1/objects/<hex> with the patra type code in an
# X-Sit-Type request header. The server rehashes the decompressed
# payload (sigil) and refuses with 400 if the claimed hex doesn't
# match. Idempotent on the wire — the server returns 201 Created
# for a fresh insert, 200 OK if the object was already present.
# Both are success from the client's POV; non-2xx is failure.
#
# Returns 0 on 200/201; -1 on any other status, network failure,
# or response framing failure. Caller can stop the push immediately
# on -1 (per-object retry isn't worth the complexity at v0.7.6).
#
# Lifetime: `compressed` must live until the call returns. The
# bytes are sent as the request body verbatim — sit's bump-heap
# allocations are program-lifetime so this is automatically true
# for anything walked out of the local objects.patra.

fn http_remote_push_object(h, hex, ty, compressed, clen) {
    if (hex_prefix_valid(hex, 64) == 0) { return 0 - 1; }
    if (ty < 0) { return 0 - 1; }
    if (ty > 2) { return 0 - 1; }
    if (clen <= 0) { return 0 - 1; }

    var sub = alloc(16 + 64 + 1);
    memcpy(sub, "/sit/v1/objects/", 16);
    memcpy(sub + 16, hex, 64);
    store8(sub + 16 + 64, 0);

    # Build the X-Sit-Type extra header. Same shape as the GET handler
    # emits on the response side (server-side serve_handle_object).
    var ty_buf[24];
    var ty_digits = write_decimal(&ty_buf, ty);
    var hdr = alloc(16 + ty_digits + 4);
    memcpy(hdr, "X-Sit-Type: ", 12);
    memcpy(hdr + 12, &ty_buf, ty_digits);
    store8(hdr + 12 + ty_digits, 13);
    store8(hdr + 12 + ty_digits + 1, 10);
    store8(hdr + 12 + ty_digits + 2, 0);

    var quad[48];
    var rc = _wire_http_post_xhdr(h, sub, compressed, clen, hdr, &quad);
    if (rc != 0) { return 0 - 1; }
    var status = load64(&quad + 16);
    _wire_http_response_free(&quad);
    if (status == 201) { return 1; }   # newly inserted
    if (status == 200) { return 0; }   # already present (idempotent)
    return 0 - 1;
}

# `http_remote_push_ref(h, refname, hex)` updates a single ref via
# POST /sit/v1/refs/<refname>. Body is the new 64-hex tip + `\n`.
# Server fast-forward gates the update for refs/heads/* and refuses
# with 409 if the new tip isn't a descendant of the existing tip;
# refs/tags/* are immutable on the server (any non-equal update
# also returns 409). 400 means the server rejected the request
# shape (bad refname, bad hex, tip not in objects DB).
#
# Returns:
#   0  — success (200 OK)
#   1  — non-FF (409 Conflict)
#   -1 — any other failure (400, 401, network, etc.)

fn http_remote_push_ref(h, refname, hex) {
    if (refname_valid(refname) == 0) { return 0 - 1; }
    if (hex_prefix_valid(hex, 64) == 0) { return 0 - 1; }

    var rl = strlen(refname);
    var sub = alloc(13 + rl + 1);
    memcpy(sub, "/sit/v1/refs/", 13);
    memcpy(sub + 13, refname, rl);
    store8(sub + 13 + rl, 0);

    var body = alloc(65);
    memcpy(body, hex, 64);
    store8(body + 64, 10);

    var quad[48];
    var rc = _wire_http_post(h, sub, body, 65, &quad);
    if (rc != 0) { return 0 - 1; }
    var status = load64(&quad + 16);
    _wire_http_response_free(&quad);
    if (status == 200) { return 0; }
    if (status == 409) { return 1; }
    if (status == 423) { return 2; }            # v0.8.4 denyCurrentBranch
    return 0 - 1;
}

# Variant of `_wire_http_post` that also injects an extra request
# header (e.g. `X-Sit-Type: 2\r\n` for /objects). Identical recv
# loop + response parsing; only the request-line build differs.
# Public-ish since `http_remote_push_object` is its only caller and
# the X-Sit-Type ride-along is specific to the /objects endpoint;
# kept as a separate function rather than threading a generic
# `extra_headers` arg through every call site.

fn _wire_http_post_xhdr(h, sub_path, body, body_len, extra_hdr, out_quad) {
    if (_http_remote_is_tls(h) == 1) {
        return _wire_https_exchange(h, 1, sub_path, body, body_len, extra_hdr, out_quad);
    }
    var fd_r = tcp_socket();
    if (is_err_result(fd_r) == 1) {
        eprintln("sit: tcp_socket failed");
        return 0 - 1;
    }
    var fd = payload(fd_r);
    var c_r = sock_connect(fd, _http_remote_addr(h), _http_remote_port(h));
    if (is_err_result(c_r) == 1) {
        sys_close(fd);
        eprintln("sit: sock_connect failed (is sit serve running?)");
        return 0 - 1;
    }

    # https:// → TLS 1.3 handshake + TOFU pin (used by https push, a later
    # bite; check_writable gates https off today so tls stays 0 for now).
    var tls = 0;
    if (_http_remote_is_tls(h) == 1) {
        tls = _wire_https_connect(_http_remote_host(h), _http_remote_port(h), fd);
        if (tls == 0) { sys_close(fd); return 0 - 1; }
    }

    var sp_len = strlen(sub_path);
    var clen_buf[24];
    var clen_digits = write_decimal(&clen_buf, body_len);
    var ehl = 0;
    if (extra_hdr != 0) { ehl = strlen(extra_hdr); }
    var token = _http_remote_token(h);
    var tlen = 0;
    if (token != 0) { tlen = strlen(token); }
    var hdr_cap = 128 + sp_len + clen_digits + ehl + tlen + 32;
    var hdr = alloc(hdr_cap);
    var pos = 0;
    memcpy(hdr + pos, "POST ", 5); pos = pos + 5;
    memcpy(hdr + pos, sub_path, sp_len); pos = pos + sp_len;
    memcpy(hdr + pos, " HTTP/1.0\r\nHost: 127.0.0.1\r\nContent-Type: application/octet-stream\r\nContent-Length: ", 84);
    pos = pos + 84;
    memcpy(hdr + pos, &clen_buf, clen_digits); pos = pos + clen_digits;
    memcpy(hdr + pos, "\r\n", 2); pos = pos + 2;
    if (ehl > 0) { memcpy(hdr + pos, extra_hdr, ehl); pos = pos + ehl; }
    if (token != 0) {
        memcpy(hdr + pos, "Authorization: Bearer ", 22); pos = pos + 22;
        memcpy(hdr + pos, token, tlen); pos = pos + tlen;
        memcpy(hdr + pos, "\r\n", 2); pos = pos + 2;
    }
    memcpy(hdr + pos, "Connection: close\r\n\r\n", 21); pos = pos + 21;
    _wire_io_send(tls, fd, hdr, pos);
    if (body_len > 0) { _wire_io_send(tls, fd, body, body_len); }

    var cap = WIRE_HTTP_INITIAL_BUF;
    var buf = fl_alloc(cap);
    if (buf == 0) { sys_close(fd); return 0 - 1; }
    var used = 0;
    var rgo = 1;
    while (rgo == 1) {
        if (used == cap) {
            if (cap >= WIRE_HTTP_MAX_BODY) { fl_free(buf); sys_close(fd); return 0 - 1; }
            var new_cap = cap * 2;
            if (new_cap > WIRE_HTTP_MAX_BODY) { new_cap = WIRE_HTTP_MAX_BODY; }
            var new_buf = fl_alloc(new_cap);
            if (new_buf == 0) { fl_free(buf); sys_close(fd); return 0 - 1; }
            memcpy(new_buf, buf, used);
            fl_free(buf);
            buf = new_buf;
            cap = new_cap;
        }
        var n = _wire_io_recv(tls, fd, buf + used, cap - used);
        if (n <= 0) { rgo = 0; }
        else { used = used + n; }
    }
    if (tls != 0) { tls_native_close(tls); }
    sys_close(fd);

    var status = 0;
    if (used >= 12) {
        if (memeq(buf, "HTTP/1.", 7) == 1) {
            status = (load8(buf + 9) - 48) * 100
                   + (load8(buf + 10) - 48) * 10
                   + (load8(buf + 11) - 48);
        }
    }
    var i = 0;
    var body_off = 0 - 1;
    while (i + 3 < used) {
        if (load8(buf + i) == 13) {
            if (load8(buf + i + 1) == 10) {
                if (load8(buf + i + 2) == 13) {
                    if (load8(buf + i + 3) == 10) {
                        body_off = i + 4;
                        i = used;
                    }
                }
            }
        }
        if (i < used) { i = i + 1; }
    }
    if (body_off < 0) { fl_free(buf); return 0 - 1; }
    store64(out_quad,      buf + body_off);
    store64(out_quad +  8, used - body_off);
    store64(out_quad + 16, status);
    store64(out_quad + 24, 0 - 1);
    store64(out_quad + 32, buf);
    store64(out_quad + 40, cap);
    return 0;
}

# --- serve.cyr ---

# serve.cyr — sit's HTTP daemon.
#
# Read-only endpoints — exposes an opened sit repo over the
# `/sit/v1/...` wire protocol per the v0.7.x plan.
#
#   GET /sit/v1/capabilities    → server identity + advertised limits
#   GET /sit/v1/refs            → all heads + tags as JSON
#   GET /sit/v1/objects/<hash>  → raw compressed object bytes;
#                                 X-Sit-Type: <patra-ty> header
#                                 carries the type code
#
# Later patches added: POST /want batched stream (v0.7.4), POST
# /objects + POST /refs + bearer auth (v0.7.6), TLS / HTTPS (v0.8.8);
# mTLS is deferred to the 1.5.0 transport-trust minor.
#
# Bound to 127.0.0.1 only — listening on 0.0.0.0 / a routable
# interface needs explicit threat-model review (a no-auth read path
# leaks ref topology + object content; bearer auth — v0.7.6 — guards
# writes only). Lifting the loopback lock is the 1.5.0 minor.

var SIT_SERVE_DEFAULT_PORT = 8484;
var SIT_SERVE_MAX_BODY = 16777216;  # 16 MiB — advertised in capabilities
# v0.7.4: cap on the count field of a single POST /want body. The
# binding constraint is sandhi's per-process HSV_REQ_BUF_SIZE = 64 KiB
# request buffer; pinning to 512 keeps the request body ≤ 32 KiB
# even with the full 8-byte count + 512×64-byte hashes, leaving
# ample headroom for HTTP headers. See ADR 0006.
var SIT_WANT_MAX_COUNT = 512;

# v0.7.6: bearer auth. ~/.sit/serve.token is the canonical path;
# operators may pin a different file with --token. Token must be
# 16+ hex chars (64-bit minimum entropy assuming random-hex input)
# and the file must be 0600 — anything else is a config bug we
# refuse to start with rather than silently accept a weaker posture.
# `_serve_token` is the loaded value; `_serve_require_auth` is 1
# when --require-auth was set on the command line. POST handlers
# consult both before doing any DB work; GET endpoints stay
# anonymous (the per-ADR-0007 deployment surface assumes loopback
# anyway, so anonymous read is a feature, not a vulnerability).
var SIT_TOKEN_MIN_LEN = 16;
var _serve_require_auth = 0;
var _serve_token = 0;

# Per-connection TLS context for the response path (bite 3). 0 = plain HTTP
# (responses go through sandhi's raw-socket senders); non-zero = an active
# tls_native server ctx, so the _serve_send_* wrappers build the HTTP/1.0 bytes
# and write them through TLS. The serve loop is single-threaded (sequential
# accept), so a process-global is safe: set before handling a connection,
# cleared after. Default 0 keeps the plain http:// path byte-identical.
var _serve_tls_ctx = 0;
fn _serve_set_tls_ctx(ctx) { _serve_tls_ctx = ctx; return 0; }

# ── Ref-file reader ────────────────────────────────────────────────
#
# Read a ref file's content as a 64-char SHA-256 hex string. Strips
# the trailing newline conventionally written by `write_head_ref`
# and friends; rejects anything that doesn't pass `hex_prefix_valid`.
# Returns 0 on any failure (so callers can skip the entry instead of
# aborting the response).

fn serve_read_ref_file(path) {
    var pair = alloc(16);  # [data_ptr, len]
    var rc = read_file_heap(path, pair);
    if (rc < 0) { return 0; }
    var data = load64(pair);
    var len = load64(pair + 8);
    while (len > 0) {
        var lc = load8(data + len - 1) & 0xFF;
        if (lc != 10) {
            if (lc != 13) { break; }
        }
        len = len - 1;
    }
    if (len != 64) { return 0; }
    if (hex_prefix_valid(data, 64) == 0) { return 0; }
    var out = alloc(65);
    memcpy(out, data, 64);
    store8(out + 64, 0);
    return out;
}

# ── JSON builders ──────────────────────────────────────────────────
#
# Hand-rolled JSON because the response shapes are tiny and
# entirely under our control — every field name we emit is a
# constant, and every value either passes `refname_valid` (no
# JSON-escapable bytes) or `hex_prefix_valid` (digits + a-f only).
# Pulling `lib/json.cyr` here would buy nothing and add a dep
# surface inside the hot serve loop.

fn serve_build_capabilities() {
    var sb = str_builder_new();
    # The "sit" string identifies the wire-protocol release line the
    # server promises; it tracks VERSION. The CI "Verify version
    # consistency" step asserts this literal == VERSION so it cannot
    # silently drift (it had drifted to 0.8.10 through v1.0.3 before
    # the guard landed).
    # TODO: derive from VERSION at build time once cyrius exposes a
    # source-level VERSION constant — the manifest ${file:VERSION} is
    # build-metadata only. Until then it is bumped by hand at each tag.
    str_builder_add_cstr(sb, "{\"sit\":\"1.0.3\",\"max_body\":");
    str_builder_add_int(sb, SIT_SERVE_MAX_BODY);
    str_builder_add_cstr(sb, ",\"auth\":[");
    if (_serve_require_auth == 1) {
        str_builder_add_cstr(sb, "\"bearer\"");
    }
    else {
        str_builder_add_cstr(sb, "\"none\"");
    }
    str_builder_add_cstr(sb, "],\"objects\":true,\"batch\":true,\"batch_max\":");
    str_builder_add_int(sb, SIT_WANT_MAX_COUNT);
    str_builder_add_cstr(sb, ",\"push\":true}");
    return str_data(str_builder_build(sb));
}

# Recursively walk one refs subtree (`.sit/refs/heads` or
# `.sit/refs/tags`) appending one JSON object per ref to `sb`.
# `prefix` is the ref namespace ("refs/heads/" / "refs/tags/");
# `dir` is the on-disk path to the corresponding directory;
# `first_ref_cell` is a heap-allocated i64 used as a shared "is
# this the first entry across BOTH subtrees?" flag — toggled to
# 0 after the first emission so subsequent entries get a leading
# comma.
#
# Errors (missing dir, malformed ref content, refnames that fail
# `refname_valid`) silently omit the entry rather than fail the
# whole response. `sit fsck` is the right tool to surface a broken
# ref file; `serve` should keep listing what it can.

fn serve_emit_refs_subtree(sb, prefix, dir, first_ref_cell) {
    if (file_exists(dir) != 1) { return 0; }
    # dir_walk expects a Str object (it does str_data internally) and pushes
    # Str objects into the results vec. Convert at the boundary.
    var files = vec_new();
    dir_walk(str_from(dir), files);
    var i = 0;
    var dlen = strlen(dir);
    var plen = strlen(prefix);
    while (i < vec_len(files)) {
        var fp_str = vec_get(files, i);
        var fp_len = str_len(fp_str);
        var fp_data = str_data(fp_str);
        # Strip the dir prefix + leading '/' to get the in-namespace name.
        var rel_offset = dlen;
        if (rel_offset < fp_len) {
            if (load8(fp_data + rel_offset) == 47) { rel_offset = rel_offset + 1; }
        }
        var rel_len = fp_len - rel_offset;
        if (rel_len > 0) {
            var name = alloc(plen + rel_len + 1);
            memcpy(name, prefix, plen);
            memcpy(name + plen, fp_data + rel_offset, rel_len);
            store8(name + plen + rel_len, 0);
            var ok_name = refname_valid(name);
            if (ok_name == 1) {
                # serve_read_ref_file is cstring-based; materialize the Str.
                var fs_cstr = alloc(fp_len + 1);
                memcpy(fs_cstr, fp_data, fp_len);
                store8(fs_cstr + fp_len, 0);
                var hex = serve_read_ref_file(fs_cstr);
                if (hex != 0) {
                    if (load64(first_ref_cell) == 0) { str_builder_add_cstr(sb, ","); }
                    str_builder_add_cstr(sb, "{\"name\":\"");
                    str_builder_add_cstr(sb, name);
                    str_builder_add_cstr(sb, "\",\"hash\":\"");
                    str_builder_add_cstr(sb, hex);
                    str_builder_add_cstr(sb, "\"}");
                    store64(first_ref_cell, 0);
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn serve_build_refs() {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"refs\":[");
    var first_cell = alloc(8);
    store64(first_cell, 1);
    serve_emit_refs_subtree(sb, "refs/heads/", ".sit/refs/heads", first_cell);
    serve_emit_refs_subtree(sb, "refs/tags/",  ".sit/refs/tags",  first_cell);
    str_builder_add_cstr(sb, "]}");
    return str_data(str_builder_build(sb));
}

# ── TLS-aware response senders (bite 3) ──
#
# Every serve handler emits through these instead of sandhi_server_send_*
# directly. On a plain HTTP connection (_serve_tls_ctx == 0) they delegate
# verbatim to sandhi (byte-identical to the pre-bite-3 behavior). On a TLS
# connection they build the same HTTP/1.0 response and write it through
# tls_native via _wire_io_send (which fragments into <= 16 KB records). The
# `extra` header string (e.g. "X-Sit-Type: <n>\r\n") already carries its own
# trailing CRLF, so it is appended verbatim.

# Emit "HTTP/1.0 <code> <msg>\r\n" into buf at pos; returns the new pos.
fn _serve_emit_status_line(buf, pos, code, msg) {
    memcpy(buf + pos, "HTTP/1.0 ", 9); pos = pos + 9;
    pos = pos + write_decimal(buf + pos, code);
    store8(buf + pos, 32); pos = pos + 1;          # ' '
    var ml = strlen(msg);
    memcpy(buf + pos, msg, ml); pos = pos + ml;
    store8(buf + pos, 13); pos = pos + 1;          # \r
    store8(buf + pos, 10); pos = pos + 1;          # \n
    return pos;
}

fn _serve_send_status(cfd, code, msg) {
    if (_serve_tls_ctx == 0) { return sandhi_server_send_status(cfd, code, msg); }
    var ml = strlen(msg);
    var buf = alloc(64 + ml);
    var pos = _serve_emit_status_line(buf, 0, code, msg);
    memcpy(buf + pos, "Content-Length: 0\r\nConnection: keep-alive\r\n\r\n", 45);
    pos = pos + 45;
    _wire_io_send(_serve_tls_ctx, cfd, buf, pos);
    return 0;
}

fn _serve_send_response(cfd, code, msg, ctype, body, body_len, extra) {
    if (_serve_tls_ctx == 0) {
        return sandhi_server_send_response(cfd, code, msg, ctype, body, body_len, extra);
    }
    var ctl = strlen(ctype);
    var el = 0;
    if (extra != 0) { el = strlen(extra); }
    var clen_buf[24];
    var clen_digits = write_decimal(&clen_buf, body_len);
    var hdr = alloc(96 + ctl + el + clen_digits);
    var pos = _serve_emit_status_line(hdr, 0, code, msg);
    memcpy(hdr + pos, "Content-Type: ", 14); pos = pos + 14;
    memcpy(hdr + pos, ctype, ctl); pos = pos + ctl;
    store8(hdr + pos, 13); pos = pos + 1; store8(hdr + pos, 10); pos = pos + 1;
    memcpy(hdr + pos, "Content-Length: ", 16); pos = pos + 16;
    memcpy(hdr + pos, &clen_buf, clen_digits); pos = pos + clen_digits;
    store8(hdr + pos, 13); pos = pos + 1; store8(hdr + pos, 10); pos = pos + 1;
    if (el > 0) { memcpy(hdr + pos, extra, el); pos = pos + el; }   # extra carries its own CRLF
    memcpy(hdr + pos, "Connection: keep-alive\r\n\r\n", 26); pos = pos + 26;
    _wire_io_send(_serve_tls_ctx, cfd, hdr, pos);
    if (body_len > 0) { _wire_io_send(_serve_tls_ctx, cfd, body, body_len); }
    return 0;
}

# ── /sit/v1/objects/<hash> handler ────────────────────────────────
#
# Returns the raw compressed bytes of an object addressed by its
# 64-hex SHA-256. The patra type code rides on an X-Sit-Type
# response header so the client can persist it in its local
# objects.patra without re-deriving from the decompressed body.
#
# The request hash is validated as 64-hex via hex_prefix_valid
# before any DB lookup — we won't hand attacker-controlled bytes
# to a string-concatenated SQL statement, even though
# db_object_read_raw embeds it inside single quotes (the validator
# is the trust boundary; the SQL shape is a defence in depth).
#
# 400 if the path tail isn't 64 hex chars; 404 if the object isn't
# present; 200 with the compressed bytes otherwise. No retry/range
# semantics in v0.7.3 — the body is sent in one shot under the
# advertised SIT_SERVE_MAX_BODY ceiling. Decompression bombs are
# not a serve concern: the bytes are the bytes the repo already
# stores, and the server-side store has already accepted them.

var SIT_OBJECT_PATH_PREFIX = "/sit/v1/objects/";
var SIT_OBJECT_PATH_PREFIX_LEN = 16;

fn serve_handle_object(cfd, path) {
    var plen = strlen(path);
    if (plen != SIT_OBJECT_PATH_PREFIX_LEN + 64) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var hex = path + SIT_OBJECT_PATH_PREFIX_LEN;
    if (hex_prefix_valid(hex, 64) == 0) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var db = get_object_db();
    if (db == 0) {
        _serve_send_status(cfd, 500, "Internal Server Error");
        return 0;
    }
    # db_object_read_raw is in wire.cyr; out layout is
    # {compressed_ptr@0, clen@8, ty@16}. Returns 0 on success,
    # negative on missing/error — we map both to 404 so we don't
    # leak whether the row missed vs the read error'd.
    var raw[24];
    if (db_object_read_raw(db, hex, &raw) != 0) {
        _serve_send_status(cfd, 404, "Not Found");
        return 0;
    }
    var compressed = load64(&raw);
    var clen = load64(&raw + 8);
    var ty = load64(&raw + 16);
    if (clen <= 0) {
        _serve_send_status(cfd, 404, "Not Found");
        return 0;
    }
    if (clen > SIT_SERVE_MAX_BODY) {
        # An object larger than the advertised cap means the repo
        # has accreted state newer than this server promises to
        # serve. Refuse rather than misadvertise.
        _serve_send_status(cfd, 413, "Payload Too Large");
        return 0;
    }
    # Build "X-Sit-Type: <int>\r\n" — sandhi appends extra_headers
    # verbatim to the response, so the trailing CRLF is on us.
    var ty_buf[24];
    var ty_digits = write_decimal(&ty_buf, ty);
    var hdr_len = 13 + ty_digits + 2;
    var hdr = alloc(hdr_len + 1);
    memcpy(hdr, "X-Sit-Type: ", 12);
    memcpy(hdr + 12, &ty_buf, ty_digits);
    store8(hdr + 12 + ty_digits, 13);
    store8(hdr + 12 + ty_digits + 1, 10);
    store8(hdr + 12 + ty_digits + 2, 0);
    _serve_send_response(cfd, 200, "OK", "application/octet-stream",
                                 compressed, clen, hdr);
    return 0;
}

# ── /sit/v1/want batched object stream (v0.7.4) ────────────────────
#
# Request body shape (per ADR 0006):
#   8 bytes  : count (i64 LE)
#   count*64 : ASCII hex hashes
#
# Response body: concatenation of per-object frames:
#   64 bytes : ASCII hex hash
#    8 bytes : ty (i64 LE) — 0=blob, 1=tree, 2=commit
#    8 bytes : clen (i64 LE) — compressed payload length
#    clen B  : zlib-compressed object content
#
# Hashes the server doesn't have are silently omitted from the
# response. The client compares response frame count to the request
# count to detect missing objects (and fall back to per-object GET
# for those, or report failure to the user).
#
# Validation: any malformed input → 400. Body length must equal
# 8 + count*64 exactly; count must fit in [0, SIT_WANT_MAX_COUNT];
# every 64-byte hash slot must pass hex_prefix_valid before any DB
# lookup. Endianness: native LE on x86_64/aarch64 — load64/store64
# do the right thing without explicit byteswaps.

fn serve_handle_want(cfd, buf, n) {
    var body_off = sandhi_server_body_offset(buf, n);
    if (body_off < 0) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var clen = sandhi_server_content_length(buf, n);
    if (clen <= 0) {
        _serve_send_status(cfd, 411, "Length Required");
        return 0;
    }
    if (clen < 8) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    if (body_off + clen > n) {
        # sandhi_server_recv_request reads until full body; if we land
        # here the request was malformed at the framing layer.
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var body = buf + body_off;
    var count = load64(body);
    if (count < 0) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    if (count > SIT_WANT_MAX_COUNT) {
        _serve_send_status(cfd, 413, "Payload Too Large");
        return 0;
    }
    var expected_clen = 8 + count * 64;
    if (clen != expected_clen) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }

    # Pre-validate every hash before any DB work — keeps the failure
    # mode "all 400 or full success", no half-emitted response.
    var i = 0;
    while (i < count) {
        if (hex_prefix_valid(body + 8 + i * 64, 64) == 0) {
            _serve_send_status(cfd, 400, "Bad Request");
            return 0;
        }
        i = i + 1;
    }

    var db = get_object_db();
    if (db == 0) {
        _serve_send_status(cfd, 500, "Internal Server Error");
        return 0;
    }

    # Build the response stream into a growing fl_alloc buffer.
    var resp_cap = 65536;
    var resp = fl_alloc(resp_cap);
    if (resp == 0) {
        _serve_send_status(cfd, 500, "Internal Server Error");
        return 0;
    }
    var resp_used = 0;
    i = 0;
    while (i < count) {
        var hex = body + 8 + i * 64;
        var raw[24];
        if (db_object_read_raw(db, hex, &raw) == 0) {
            var compressed = load64(&raw);
            var obj_clen = load64(&raw + 8);
            var ty = load64(&raw + 16);
            if (obj_clen > 0) {
                var frame_len = 64 + 8 + 8 + obj_clen;
                # Grow response buffer if needed.
                var grow_done = 0;
                while (grow_done == 0) {
                    grow_done = 1;
                    if (resp_used + frame_len > resp_cap) {
                        var new_cap = resp_cap * 2;
                        if (new_cap > SIT_SERVE_MAX_BODY) {
                            new_cap = SIT_SERVE_MAX_BODY;
                        }
                        if (resp_used + frame_len > new_cap) {
                            # Already at the ceiling and it still
                            # doesn't fit — refuse rather than
                            # serve a truncated stream.
                            fl_free(resp);
                            _serve_send_status(cfd, 413, "Payload Too Large");
                            return 0;
                        }
                        var new_resp = fl_alloc(new_cap);
                        if (new_resp == 0) {
                            fl_free(resp);
                            _serve_send_status(cfd, 500, "Internal Server Error");
                            return 0;
                        }
                        memcpy(new_resp, resp, resp_used);
                        fl_free(resp);
                        resp = new_resp;
                        resp_cap = new_cap;
                        if (resp_used + frame_len > resp_cap) { grow_done = 0; }
                    }
                }
                memcpy(resp + resp_used, hex, 64);
                store64(resp + resp_used + 64, ty);
                store64(resp + resp_used + 72, obj_clen);
                memcpy(resp + resp_used + 80, compressed, obj_clen);
                resp_used = resp_used + frame_len;
            }
        }
        # else: object missing from this DB — silently omit.
        i = i + 1;
    }

    _serve_send_response(cfd, 200, "OK", "application/octet-stream",
                                 resp, resp_used, 0);
    fl_free(resp);
    return 0;
}

# ── Bearer auth (v0.7.6) ──────────────────────────────────────────
#
# `_serve_load_token(path)` — read a token file from disk. Returns
# the heap-allocated cstring on success, 0 on any failure (missing
# file, wrong perms, too-short content, embedded NUL/control bytes).
# Caller (cmd_serve) refuses to start the server if 0 is returned
# so the auth posture is "strictly enforced or absent" — never a
# silent fall-through to no-auth.
#
# Perm check: must be 0600 exactly. fstat via newfstatat (validate.cyr's
# AT_FDCWD shape). Stricter than git's "<= 0600" — sit's token file
# has no legitimate group/world-readable use, so any wider mode is
# a configuration mistake worth refusing.
fn _serve_load_token(path) {
    if (path_is_symlink(path) == 1) {
        eprintln("sit: refusing to follow symlink for serve token");
        return 0;
    }
    var stbuf[144];
    var rc = syscall(262, VAL_AT_FDCWD, path, &stbuf, 0);
    if (rc < 0) {
        eprintln("sit: cannot stat serve token");
        return 0;
    }
    var mode = load32(&stbuf + 24);
    var perm = mode & 0xFFF;
    if (perm != 384) {        # 0600 octal = 384 decimal
        eprintln("sit: serve token file must be mode 0600");
        return 0;
    }
    var pair[16];
    if (read_file_heap(path, &pair) != 0) {
        eprintln("sit: failed to read serve token");
        return 0;
    }
    var data = load64(&pair);
    var len = load64(&pair + 8);
    # Strip trailing whitespace (trailing newline from `echo` is the
    # canonical form). Flag-driven loop because Cyrius's `break` in
    # while-with-var is unreliable per CLAUDE.md.
    var stripping = 1;
    while (stripping == 1) {
        stripping = 0;
        if (len > 0) {
            var lc = load8(data + len - 1) & 0xFF;
            if (lc == 10) { len = len - 1; stripping = 1; }
            if (lc == 13) { len = len - 1; stripping = 1; }
            if (lc == 32) { len = len - 1; stripping = 1; }
            if (lc == 9)  { len = len - 1; stripping = 1; }
        }
    }

    if (len < SIT_TOKEN_MIN_LEN) {
        eprintln("sit: serve token shorter than 16 chars — generate a stronger one");
        return 0;
    }
    # Reject control bytes / NUL inside the token; tokens travel via
    # an HTTP header so CR/LF would smuggle headers.
    var i = 0;
    while (i < len) {
        var c = load8(data + i) & 0xFF;
        if (c == 0)  { eprintln("sit: serve token contains NUL"); return 0; }
        if (c == 10) { eprintln("sit: serve token contains LF"); return 0; }
        if (c == 13) { eprintln("sit: serve token contains CR"); return 0; }
        if (c == 32) { eprintln("sit: serve token contains space"); return 0; }
        if (c == 9)  { eprintln("sit: serve token contains TAB"); return 0; }
        if (c < 32)  { eprintln("sit: serve token contains control byte"); return 0; }
        if (c == 127) { eprintln("sit: serve token contains DEL"); return 0; }
        i = i + 1;
    }
    var tok = alloc(len + 1);
    memcpy(tok, data, len);
    store8(tok + len, 0);
    return tok;
}

# Returns 1 if the request carries a valid `Authorization: Bearer <token>`
# header that constant-time-equals the loaded `_serve_token`. Returns 0
# otherwise. Consulted by POST handlers when `_serve_require_auth == 1`.
# Constant-time comparison: walk the full minimum length even on a length
# mismatch so the timing doesn't reveal the prefix the attacker got right.
fn _serve_auth_ok(buf, n) {
    if (_serve_require_auth == 0) { return 1; }
    if (_serve_token == 0) { return 0; }
    var hdr = sandhi_server_find_header(buf, n, "Authorization");
    if (hdr == 0) { return 0; }
    # Expect literal "Bearer " prefix (case-sensitive, matching git's
    # http.extraHeader convention). Eight bytes including the space.
    var hlen = strlen(hdr);
    if (hlen <= 7) { return 0; }
    if (memeq(hdr, "Bearer ", 7) == 0) { return 0; }
    var presented = hdr + 7;
    var plen = hlen - 7;
    var tlen = strlen(_serve_token);
    # Constant-time compare across max(plen, tlen) — works even when
    # lengths differ. Mismatch-flag accumulates via OR across all bytes.
    var max_len = plen;
    if (tlen > max_len) { max_len = tlen; }
    var mismatch = 0;
    if (plen != tlen) { mismatch = 1; }
    var ci = 0;
    while (ci < max_len) {
        var pc = 0;
        var tc = 0;
        if (ci < plen) { pc = load8(presented + ci) & 0xFF; }
        if (ci < tlen) { tc = load8(_serve_token + ci) & 0xFF; }
        if ((pc ^ tc) != 0) { mismatch = 1; }
        ci = ci + 1;
    }
    if (mismatch == 0) { return 1; }
    return 0;
}

# ── /sit/v1/objects/<hash> POST handler (v0.7.6) ──────────────────
#
# Accepts a single compressed sit object from a pushing client.
# Trust boundary: the server REHASHES every uploaded object. The
# claimed hex in the URL must match the SHA-256 of the decompressed
# content (in its full `<type> <len>\0<content>` framed form, the
# same shape that `write_typed_object` hashes locally). The X-Sit-
# Type request header must also agree with the type prefix on the
# decompressed body. Either mismatch → 400.
#
# The rehash is the only place sit pays SHA-256 cost on the wire
# path (CLAUDE.md "SHA-256 roundtrips belong in fsck, not the hot
# path") — but accepted-from-the-network bytes are precisely the
# point where the trust boundary lives. fetch + clone copy raw
# compressed bytes from a server we already trust; push has no such
# upstream trust and must verify what the client claims to be
# uploading.
#
# Returns: 201 Created on success (object stored); 200 OK if already
# present (idempotent); 400 on any validation failure (hex format,
# ty range, body framing, hash mismatch, type-prefix mismatch);
# 401/403 from the caller-side auth wrapper if not authenticated;
# 500 on DB / OOM. Body of any error response is empty (don't leak
# which validation step failed — the caller can compare locally).

fn _serve_rehash_and_insert(cfd, hex, claimed_ty, compressed, clen) {
    # Decompress to verify framing + recompute hash. _decompress_raw_into
    # (src/wire.cyr) handles the 4×-initial / 16 MiB-ceiling sizing
    # mirror of db_object_read_both. raw[24] = {compressed, clen, ty}.
    var raw[24];
    store64(&raw,      compressed);
    store64(&raw +  8, clen);
    store64(&raw + 16, claimed_ty);
    var deco[24];
    if (_decompress_raw_into(&raw, &deco) != 0) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var dbuf = load64(&deco);
    var dlen = load64(&deco + 8);
    var coff = load64(&deco + 16);

    # Verify the decompressed framing's type matches the claimed ty.
    # `coff - 1` is the index of the NUL; the type-string runs from
    # 0 to the first space (which must be at coff - 1 - <digits>).
    if (coff < 5) { _serve_send_status(cfd, 400, "Bad Request"); return 0; }
    var sp = 0;
    var found_sp = 0;
    while (sp < coff) {
        if (load8(dbuf + sp) == 32) { found_sp = 1; sp = coff; }
        else { sp = sp + 1; }
    }
    if (found_sp == 0) { _serve_send_status(cfd, 400, "Bad Request"); return 0; }
    # Recompute sp as the actual space index.
    sp = 0;
    while (sp < coff) {
        if (load8(dbuf + sp) == 32) { break; }
        sp = sp + 1;
    }
    var declared_ty = type_code_of(dbuf, sp);
    if (declared_ty < 0) { _serve_send_status(cfd, 400, "Bad Request"); return 0; }
    if (declared_ty != claimed_ty) { _serve_send_status(cfd, 400, "Bad Request"); return 0; }

    # Recompute the hash over the full framed bytes (type + space +
    # decimal-len + NUL + content) — what write_typed_object uses to
    # compute the canonical sit hash for any new object. hash_data
    # returns a heap-owned cstring of 64 lowercase hex chars.
    var actual_hex = hash_data(dbuf, dlen);
    if (actual_hex == 0) { _serve_send_status(cfd, 500, "Internal Server Error"); return 0; }
    if (memeq(actual_hex, hex, 64) == 0) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }

    # Hash matches. Insert the original compressed bytes. db_object_insert_raw
    # returns 0 on actual insert, 1 on already-present, negative on error.
    var db = get_object_db();
    if (db == 0) { _serve_send_status(cfd, 500, "Internal Server Error"); return 0; }
    var rc = db_object_insert_raw(db, hex, claimed_ty, compressed, clen);
    if (rc < 0) { _serve_send_status(cfd, 500, "Internal Server Error"); return 0; }
    if (rc == 1) { _serve_send_status(cfd, 200, "OK"); return 0; }
    _serve_send_status(cfd, 201, "Created");
    return 0;
}

fn serve_handle_put_object(cfd, path, buf, n) {
    var plen = strlen(path);
    if (plen != SIT_OBJECT_PATH_PREFIX_LEN + 64) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var hex = path + SIT_OBJECT_PATH_PREFIX_LEN;
    if (hex_prefix_valid(hex, 64) == 0) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var ty_hdr = sandhi_server_find_header(buf, n, "X-Sit-Type");
    if (ty_hdr == 0) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    # Parse decimal int from header value. Accept exactly one of "0", "1", "2".
    var ty_len = strlen(ty_hdr);
    if (ty_len != 1) { _serve_send_status(cfd, 400, "Bad Request"); return 0; }
    var ty_c = load8(ty_hdr);
    if (ty_c < 48) { _serve_send_status(cfd, 400, "Bad Request"); return 0; }
    if (ty_c > 50) { _serve_send_status(cfd, 400, "Bad Request"); return 0; }
    var ty = ty_c - 48;

    var body_off = sandhi_server_body_offset(buf, n);
    if (body_off < 0) { _serve_send_status(cfd, 400, "Bad Request"); return 0; }
    var clen = sandhi_server_content_length(buf, n);
    if (clen <= 0) { _serve_send_status(cfd, 411, "Length Required"); return 0; }
    if (clen > SIT_SERVE_MAX_BODY) { _serve_send_status(cfd, 413, "Payload Too Large"); return 0; }
    if (body_off + clen > n) { _serve_send_status(cfd, 400, "Bad Request"); return 0; }

    var compressed = buf + body_off;
    return _serve_rehash_and_insert(cfd, hex, ty, compressed, clen);
}

# ── /sit/v1/refs/<name> POST handler (v0.7.6) ─────────────────────
#
# Updates a single ref. Path tail is the ref name (without the
# `refs/heads/` or `refs/tags/` prefix that GET /refs returns —
# clients pass the namespace); body is the new 64-hex tip optionally
# followed by `\n`. Refs in `refs/remotes/...` are server-side
# state that clients can't directly write — refused with 400.
#
# Fast-forward gate: if the ref already exists, the new tip must be
# a descendant of the current tip. Non-FF returns 409 Conflict.
# Refs that don't exist yet are created (initial push).
#
# The new tip's commit must already be in objects.patra — push
# clients are expected to upload all reachable objects before the
# ref update. We don't transitively walk to verify completeness
# (that's the client's job per ADR 0006's protocol shape); we DO
# require the tip to exist locally, which is a cheap defense
# against accidentally pointing a ref at a hash the server has
# never seen.

var SIT_REF_PUT_PREFIX = "/sit/v1/refs/";
var SIT_REF_PUT_PREFIX_LEN = 13;

fn serve_handle_put_ref(cfd, path, buf, n) {
    var plen = strlen(path);
    if (plen <= SIT_REF_PUT_PREFIX_LEN) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    var rname_start = path + SIT_REF_PUT_PREFIX_LEN;
    var rname_len = plen - SIT_REF_PUT_PREFIX_LEN;
    # Materialize as a cstring for refname_valid.
    var rname = alloc(rname_len + 1);
    memcpy(rname, rname_start, rname_len);
    store8(rname + rname_len, 0);
    if (refname_valid(rname) == 0) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    # Refuse refs/remotes/* — those are local state for tracking other
    # remotes; they have no meaning on the server side and would let a
    # malicious client smuggle a fake remote-tracking entry.
    if (rname_len >= 12) {
        if (memeq(rname, "refs/remotes/", 13) == 1) {
            _serve_send_status(cfd, 400, "Bad Request");
            return 0;
        }
    }
    # Restrict v0.7.6 to refs/heads/* and refs/tags/* explicitly. Other
    # namespaces (refs/notes/*, refs/keep/*) aren't part of sit's wire
    # vocabulary today.
    var is_head = 0;
    var is_tag = 0;
    if (rname_len > 11) { if (memeq(rname, "refs/heads/", 11) == 1) { is_head = 1; } }
    if (rname_len > 10) { if (memeq(rname, "refs/tags/",  10) == 1) { is_tag  = 1; } }
    if (is_head == 0) {
        if (is_tag == 0) {
            _serve_send_status(cfd, 400, "Bad Request");
            return 0;
        }
    }

    # v0.8.4: denyCurrentBranch. Mirrors git's default behavior — refuse
    # pushes whose target branch is the server's checked-out HEAD. Pushing
    # to the checked-out branch silently advances the ref while leaving the
    # working tree stale, which surprises anyone editing on the remote.
    # 423 Locked distinguishes this from 409 Conflict (non-FF) on the wire
    # so the client can surface the right error.
    #
    # Only matters for refs/heads/* — tags don't have a "checked-out"
    # concept. Detached HEAD (HEAD content is a raw hash, not "ref:") makes
    # read_head_ref_path return 0, so the check no-ops in that state.
    #
    # Initial pushes to empty remotes: if the target ref file doesn't
    # exist yet, allow — matches git's denyCurrentBranch behavior.
    # First push to a fresh remote is the canonical way to bootstrap.
    # The existence check happens against the on-disk ref path which we
    # compute below; mirror that compute here so the bypass is precise.
    if (is_head == 1) {
        var server_head = read_head_ref_path();
        if (server_head != 0) {
            if (streq(server_head, rname) == 1) {
                # Probe the on-disk ref to gate the bypass. Same path
                # shape used by the FF check below; ensure_parent_dirs
                # happens at write time so this read is safe pre-write.
                var probe_path = alloc(rname_len + 6);
                memcpy(probe_path, ".sit/", 5);
                memcpy(probe_path + 5, rname, rname_len);
                store8(probe_path + 5 + rname_len, 0);
                if (file_exists(probe_path) == 1) {
                    var msg = "refusing to update checked-out branch (denyCurrentBranch)\n";
                    _serve_send_response(cfd, 423, "Locked", "text/plain",
                                                 msg, strlen(msg), 0);
                    return 0;
                }
            }
        }
    }

    var body_off = sandhi_server_body_offset(buf, n);
    if (body_off < 0) { _serve_send_status(cfd, 400, "Bad Request"); return 0; }
    var clen = sandhi_server_content_length(buf, n);
    # Body must be exactly 64 hex chars, optionally followed by '\n'.
    if (clen != 64) {
        if (clen != 65) {
            _serve_send_status(cfd, 400, "Bad Request");
            return 0;
        }
    }
    if (body_off + clen > n) { _serve_send_status(cfd, 400, "Bad Request"); return 0; }
    var body = buf + body_off;
    if (hex_prefix_valid(body, 64) == 0) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }
    if (clen == 65) {
        if (load8(body + 64) != 10) {
            _serve_send_status(cfd, 400, "Bad Request");
            return 0;
        }
    }
    var new_hex = alloc(65);
    memcpy(new_hex, body, 64);
    store8(new_hex + 64, 0);

    # The new tip must already be in objects.patra (pushed by the
    # client via /sit/v1/objects before this call). No transitive
    # check.
    var db = get_object_db();
    if (db == 0) { _serve_send_status(cfd, 500, "Internal Server Error"); return 0; }
    if (db_object_has(db, new_hex) == 0) {
        _serve_send_status(cfd, 400, "Bad Request");
        return 0;
    }

    # Build the on-disk path: ".sit/<rname>". rname already
    # passed refname_valid so no traversal possible.
    var disk_path = alloc(rname_len + 6);
    memcpy(disk_path, ".sit/", 5);
    memcpy(disk_path + 5, rname, rname_len);
    store8(disk_path + 5 + rname_len, 0);

    # Existing tip? FF check via is_ancestor_in_db.
    if (file_exists(disk_path) == 1) {
        # Refuse to follow a symlink on the ref file itself (S-04).
        if (path_is_symlink(disk_path) == 1) {
            _serve_send_status(cfd, 500, "Internal Server Error");
            return 0;
        }
        var rbuf = alloc(128);
        var nr = file_read_all(disk_path, rbuf, 128);
        if (nr < 64) { _serve_send_status(cfd, 500, "Internal Server Error"); return 0; }
        if (hex_prefix_valid(rbuf, 64) == 0) { _serve_send_status(cfd, 500, "Internal Server Error"); return 0; }
        var cur = alloc(65);
        memcpy(cur, rbuf, 64);
        store8(cur + 64, 0);
        if (memeq(cur, new_hex, 64) == 1) {
            # No-op update — tip already at the new hex.
            _serve_send_status(cfd, 200, "OK");
            return 0;
        }
        # Heads must be FF; tags are immutable (any update — including
        # the same value — is a no-op above; a different value is
        # refused).
        if (is_tag == 1) {
            _serve_send_status(cfd, 409, "Conflict");
            return 0;
        }
        if (is_ancestor_in_db(db, cur, new_hex) == 0) {
            _serve_send_status(cfd, 409, "Conflict");
            return 0;
        }
    }

    # Write atomically (write to .tmp then rename). file_write_all
    # already does a single write call — for sit's ref file size
    # (65 bytes) that's atomic on every Linux fs the workflow targets.
    var wbuf = alloc(66);
    memcpy(wbuf, new_hex, 64);
    store8(wbuf + 64, 10);
    ensure_parent_dirs(disk_path);
    if (file_write_all(disk_path, wbuf, 65) < 0) {
        _serve_send_status(cfd, 500, "Internal Server Error");
        return 0;
    }
    _serve_send_status(cfd, 200, "OK");
    return 0;
}

# ── Request dispatcher ─────────────────────────────────────────────
#
# Signature dictated by sandhi: (ctx, cfd, req_buf, req_len) → 0.
# `ctx` is unused in v0.7.3; v0.7.5+ will pass the bearer-token
# config + auth state through it.

fn serve_handle_request(ctx, cfd, buf, n) {
    var method = sandhi_server_get_method(buf, n);
    var path_with_query = sandhi_server_get_path(buf, n);
    var path = sandhi_server_path_only(path_with_query);

    if (streq(method, "GET") == 1) {
        if (streq(path, "/sit/v1/capabilities") == 1) {
            var b1 = serve_build_capabilities();
            _serve_send_response(cfd, 200, "OK", "application/json",
                                         b1, strlen(b1), 0);
            return 0;
        }
        if (streq(path, "/sit/v1/refs") == 1) {
            var b2 = serve_build_refs();
            _serve_send_response(cfd, 200, "OK", "application/json",
                                         b2, strlen(b2), 0);
            return 0;
        }
        # /sit/v1/objects/<64-hex>: prefix-match (path is the path-only
        # form, query string already stripped by sandhi_server_path_only).
        var plen = strlen(path);
        if (plen >= SIT_OBJECT_PATH_PREFIX_LEN) {
            if (memeq(path, SIT_OBJECT_PATH_PREFIX,
                      SIT_OBJECT_PATH_PREFIX_LEN) == 1) {
                return serve_handle_object(cfd, path);
            }
        }
    }
    if (streq(method, "POST") == 1) {
        # /want is read-shaped (bulk fetch) so it stays anonymous in
        # both auth modes. /objects + /refs (push) are auth-gated when
        # --require-auth is set.
        if (streq(path, "/sit/v1/want") == 1) {
            return serve_handle_want(cfd, buf, n);
        }
        var plen3 = strlen(path);
        var is_put_object = 0;
        var is_put_ref = 0;
        if (plen3 >= SIT_OBJECT_PATH_PREFIX_LEN) {
            if (memeq(path, SIT_OBJECT_PATH_PREFIX,
                      SIT_OBJECT_PATH_PREFIX_LEN) == 1) { is_put_object = 1; }
        }
        if (plen3 >= SIT_REF_PUT_PREFIX_LEN) {
            if (memeq(path, SIT_REF_PUT_PREFIX,
                      SIT_REF_PUT_PREFIX_LEN) == 1) { is_put_ref = 1; }
        }
        if (is_put_object == 1) {
            if (_serve_auth_ok(buf, n) == 0) {
                _serve_send_status(cfd, 401, "Unauthorized");
                return 0;
            }
            return serve_handle_put_object(cfd, path, buf, n);
        }
        if (is_put_ref == 1) {
            if (_serve_auth_ok(buf, n) == 0) {
                _serve_send_status(cfd, 401, "Unauthorized");
                return 0;
            }
            return serve_handle_put_ref(cfd, path, buf, n);
        }
    }
    _serve_send_status(cfd, 404, "Not Found");
    return 0;
}

# ── --listen parser ────────────────────────────────────────────────
#
# Parses "<addr>:<port>". Only "127.0.0.1:<n>" is accepted today —
# any other address is rejected at parse time so users don't
# accidentally expose the no-auth daemon. Non-loopback exposure
# unlocks alongside bearer auth in v0.7.5. Writes the parsed port
# to *out_port and returns 1 on success, 0 on any malformation.

fn serve_parse_listen(arg, out_port) {
    var alen = strlen(arg);
    var colon = 0 - 1;
    var i = 0;
    var seen = 0;
    while (i < alen) {
        if (seen == 0) {
            if (load8(arg + i) == 58) {
                colon = i;
                seen = 1;
            }
        }
        i = i + 1;
    }
    if (colon < 0) { return 0; }
    if (colon != 9) { return 0; }
    if (memeq(arg, "127.0.0.1", 9) != 1) { return 0; }
    var port = 0;
    var j = colon + 1;
    var saw_digit = 0;
    while (j < alen) {
        var c = load8(arg + j) & 0xFF;
        if (c < 48) { return 0; }
        if (c > 57) { return 0; }
        port = port * 10 + (c - 48);
        if (port > 65535) { return 0; }
        saw_digit = 1;
        j = j + 1;
    }
    if (saw_digit == 0) { return 0; }
    if (port < 1) { return 0; }
    store64(out_port, port);
    return 1;
}

# ── --stdio dispatch loop (v0.8.2) ─────────────────────────────────
#
# When invoked as `sit serve <repo> --stdio`, sit reads HTTP/1.1
# requests from STDIN and writes responses to STDOUT — no socket. The
# canonical use case is being exec'd as the remote side of an SSH
# connection: `ssh user@host -- sit serve <repo> --stdio` pipes the
# wire over SSH's stdin/stdout channel. SSH owns encryption + auth;
# sit's wire (the same HTTP/1.1 we already speak over TCP) just rides
# the bytes through. Process boundary, not FFI — sit consumes the
# ssh binary, no crypto in sit's address space.
#
# Framing: each request carries Content-Length, so the server reads
# until headers + body are complete, dispatches one request, writes
# one response (with Content-Length), and loops. Client closes STDIN
# to signal end-of-session; recv returns 0, loop exits.
#
# Reuses sandhi's send/recv functions because `sock_send` / `sock_recv`
# are just `sys_write` / `sys_read` (see lib/net.cyr) — they work
# unchanged on pipe fds. The fd we pass to dispatch is STDOUT_FILENO=1.
var STDIN_FILENO = 0;
var STDOUT_FILENO = 1;

# Pipelining-safe stdin recv. Reads until one HTTP request is complete
# (headers + Content-Length body), preserving any trailing bytes that
# belong to a subsequent request. `start_have` is the carryover count
# from the previous iteration; if non-zero, those bytes are already at
# the head of `buf` and we try to parse the header against them before
# blocking on another sys_read.
#
# Returns the total bytes in buf belonging to the first request (the
# caller computes the request boundary via body_offset + content_length
# and moves the trailing bytes to offset 0 for the next call). 0 on
# clean EOF, -1 on read error.
fn _stdio_recv_request(buf, max, start_have) {
    var have = start_have;
    var need_body = 0 - 1;

    if (have > 0) {
        store8(buf + have, 0);
        var bo0 = sandhi_server_body_offset(buf, have);
        if (bo0 >= 0) {
            var clen0 = sandhi_server_content_length(buf, have);
            need_body = bo0 + clen0;
            if (have >= need_body) { return have; }
        }
    }

    while (have < max) {
        var r = sock_recv(STDIN_FILENO, buf + have, max - have);
        if (is_err_result(r) == 1) { return 0 - 1; }
        var n = payload(r);
        if (n <= 0) {
            store8(buf + have, 0);
            return have;
        }
        have = have + n;

        if (need_body == 0 - 1) {
            store8(buf + have, 0);
            var bo = sandhi_server_body_offset(buf, have);
            if (bo >= 0) {
                var clen = sandhi_server_content_length(buf, have);
                need_body = bo + clen;
            }
        }
        if (need_body != 0 - 1) {
            if (have >= need_body) {
                store8(buf + have, 0);
                return have;
            }
        }
    }
    store8(buf + have, 0);
    return have;
}

fn _serve_run_stdio() {
    # Lazily allocate the same 64 KiB request buffer sandhi's
    # accept-loop uses, sized to HSV_REQ_BUF_SIZE so the existing
    # body-cap math in serve_handle_request / serve_handle_want
    # carries over unchanged.
    var buf = alloc(HSV_REQ_BUF_SIZE);
    var carry = 0;

    while (1 == 1) {
        var n = _stdio_recv_request(buf, HSV_REQ_BUF_SIZE - 1, carry);
        if (n <= 0) {
            stdout_flush();
            if (n < 0) { return 1; }
            return 0;
        }

        # Compute the request-1 boundary so any pipelined request-2
        # bytes can carry over to the next iteration. Malformed
        # headers (no body offset) abort the session.
        var bo = sandhi_server_body_offset(buf, n);
        if (bo < 0) {
            _serve_send_status(STDOUT_FILENO, 400, "Bad Request");
            stdout_flush();
            return 1;
        }
        var clen = sandhi_server_content_length(buf, n);
        var req_end = bo + clen;
        var leftover = n - req_end;
        if (leftover < 0) { leftover = 0; }

        # Dispatch just request-1's bytes. The sandhi parsers take
        # `(buf, n)` and bound their reads by `n`, so any pipelined
        # request-2 bytes sitting in `buf[req_end:]` are ignored — we
        # MUST NOT NUL-terminate at req_end, that would overwrite the
        # first byte of request 2 before the carryover memcpy.
        serve_handle_request(0, STDOUT_FILENO, buf, req_end);
        stdout_flush();

        # Shift carryover to the front of buf for the next iteration.
        # memcpy is safe here because dst (buf) < src (buf + req_end);
        # forward-copy semantics never overwrite a yet-to-be-read source byte.
        if (leftover > 0) {
            memcpy(buf, buf + req_end, leftover);
        }
        carry = leftover;
    }
    return 0;
}

# ── Top-level command ──────────────────────────────────────────────

# ── TLS server (bite 3b) ──
#
# `sit serve --tls --cert <file> --key <file>`. The cert is DER, or PEM (auto-
# decoded via sigil's pem_decode_certs); the key is PEM or DER (tls_native
# detects). Per ADR 0007 the only TLS is tls_native (first-party Cyrius) — no
# libssl. Read-only over TLS today: GET (capabilities/refs/objects) + POST /want
# fit the 64 KiB request buffer. POST push bodies (up to 16 MiB) would overflow
# it, but https push stays gated at wire_transport_check_writable so it cannot
# reach here.

var SERVE_TLS_REQ_MAX = 65536;   # 64 KiB request buffer (matches sandhi's HSV cap)

# Load a certificate file as DER. Accepts PEM (decoded via pem_decode_certs) or
# raw DER. Writes [der_ptr, der_len] to out_pair (16 bytes). Returns 0 on
# success, negative on read failure.
fn _serve_load_cert(path, out_pair) {
    var fp[16];
    if (read_file_heap(path, &fp) != 0) { return 0 - 1; }
    var data = load64(&fp);
    var len = load64(&fp + 8);
    var chain[16];
    var nc = pem_decode_certs(data, len, &chain, 1);
    if (nc >= 1) {
        store64(out_pair, load64(&chain));
        store64(out_pair + 8, load64(&chain + 8));
        return 0;
    }
    store64(out_pair, data);          # not PEM → assume DER
    store64(out_pair + 8, len);
    return 0;
}

# Read a full HTTP/1.0 request off a TLS connection into buf (cap `max`). Reads
# records until the header terminator is seen and the declared body is present,
# or the stream ends / the cap is hit. Returns total bytes read.
fn _serve_tls_recv_request(ctx, buf, max) {
    var used = 0;
    var headers_end = 0 - 1;
    var content_len = 0;
    var rgo = 1;
    while (rgo == 1) {
        if (used >= max) { rgo = 0; }
        else {
            var n = tls_native_read(ctx, buf + used, max - used);
            if (n <= 0) { rgo = 0; }
            else {
                used = used + n;
                if (headers_end < 0) {
                    headers_end = sandhi_server_body_offset(buf, used);
                    if (headers_end > 0) {
                        content_len = sandhi_server_content_length(buf, used);
                    }
                }
                if (headers_end > 0) {
                    if (used >= headers_end + content_len) { rgo = 0; }
                }
            }
        }
    }
    return used;
}

# TLS accept loop. One TLS connection per HTTP/1.0 request (Connection: close):
# accept → fresh server ctx (re-parses creds per connection) → handshake → recv
# request → dispatch with _serve_tls_ctx set so the response goes back over TLS →
# close. Single-threaded/sequential like sandhi_server_run, so the global ctx is
# connection-safe. cert/key DER buffers are loaded once by the caller.
fn _serve_run_tls(port, cert, cert_len, key, key_len) {
    var sfd_r = tcp_socket();
    if (is_err_result(sfd_r) == 1) { eprintln("sit: tcp_socket failed"); return 1; }
    var sfd = payload(sfd_r);
    sock_reuse(sfd);
    if (is_err_result(sock_bind(sfd, INADDR_LOOPBACK(), port)) == 1) {
        eprintln("sit: bind failed"); return 1;
    }
    if (is_err_result(sock_listen(sfd, 16)) == 1) {
        eprintln("sit: listen failed"); return 1;
    }
    var reqbuf = alloc(SERVE_TLS_REQ_MAX);
    while (1 == 1) {
        var cr = sock_accept(sfd);
        if (is_err_result(cr) == 0) {
            var cfd = payload(cr);
            # 30s recv timeout per connection — slowloris bound on the TLS
            # handshake + request read (v0.8.9 hardening; mirrors what
            # sandhi_server_run_opts does for the plain-http path).
            sock_set_recv_timeout(cfd, 30, 0);
            var ctx = tls_native_new_server(cert, cert_len, key, key_len);
            if (ctx != 0) {
                if (tls_native_server_load_creds(ctx) == TLS_OK) {
                    if (tls_native_accept(ctx, cfd) == TLS_OK) {
                        # v0.8.9 keep-alive: serve every request on this TLS
                        # connection until the client closes (recv returns 0) or
                        # the 30s SO_RCVTIMEO fires. The client (wire_https) reads
                        # each response by exact Content-Length, so the stream
                        # stays framed across requests.
                        var alive = 1;
                        while (alive == 1) {
                            var n = _serve_tls_recv_request(ctx, reqbuf, SERVE_TLS_REQ_MAX);
                            if (n <= 0) { alive = 0; }
                            else {
                                _serve_set_tls_ctx(ctx);
                                serve_handle_request(0, cfd, reqbuf, n);
                                _serve_set_tls_ctx(0);
                            }
                        }
                    }
                    tls_native_close(ctx);
                }
            }
            sock_close(cfd);
        }
    }
    return 0;
}

fn cmd_serve() {
    if (argc() < 3) {
        eprintln("usage: sit serve <repo-path> [--stdio | --listen 127.0.0.1:<port>] [--tls --cert <f> --key <f>] [--require-auth] [--token <path>]");
        return 1;
    }
    var repo_path = argv_heap(2);
    var port = SIT_SERVE_DEFAULT_PORT;
    var stdio_mode = 0;
    var token_path = "~/.sit/serve.token";   # default; overridable via --token
    var custom_token_path = 0;
    var tls_mode = 0;
    var cert_path = 0;
    var key_path = 0;
    var cert_pair[16];
    var key_pair[16];
    var ai = 3;
    while (ai < argc()) {
        var a = argv(ai);
        if (streq(a, "--stdio") == 1) {
            stdio_mode = 1;
            ai = ai + 1;
            continue;
        }
        if (streq(a, "--listen") == 1) {
            if (ai + 1 >= argc()) {
                eprintln("sit: --listen requires an argument");
                return 1;
            }
            var port_cell = alloc(8);
            store64(port_cell, 0);
            if (serve_parse_listen(argv(ai + 1), port_cell) != 1) {
                eprintln("sit: --listen requires 127.0.0.1:<port> (non-loopback waits on first-party TLS, ADR 0007)");
                return 1;
            }
            port = load64(port_cell);
            ai = ai + 2;
        }
        else {
            if (streq(a, "--require-auth") == 1) {
                _serve_require_auth = 1;
                ai = ai + 1;
            }
            else {
                if (streq(a, "--token") == 1) {
                    if (ai + 1 >= argc()) {
                        eprintln("sit: --token requires a path argument");
                        return 1;
                    }
                    token_path = argv_heap(ai + 1);
                    custom_token_path = 1;
                    ai = ai + 2;
                }
                else {
                    if (streq(a, "--tls") == 1) {
                        tls_mode = 1;
                        ai = ai + 1;
                    }
                    else {
                        if (streq(a, "--cert") == 1) {
                            if (ai + 1 >= argc()) {
                                eprintln("sit: --cert requires a path argument");
                                return 1;
                            }
                            cert_path = argv_heap(ai + 1);
                            ai = ai + 2;
                        }
                        else {
                            if (streq(a, "--key") == 1) {
                                if (ai + 1 >= argc()) {
                                    eprintln("sit: --key requires a path argument");
                                    return 1;
                                }
                                key_path = argv_heap(ai + 1);
                                ai = ai + 2;
                            }
                            else {
                                eprintln("sit: unknown serve option");
                                return 1;
                            }
                        }
                    }
                }
            }
        }
    }

    # --stdio + --listen are mutually exclusive transport modes.
    if (stdio_mode == 1) {
        if (port != SIT_SERVE_DEFAULT_PORT) {
            eprintln("sit: --stdio and --listen are mutually exclusive");
            return 1;
        }
    }

    # If --require-auth: load the token before chdir'ing into the repo
    # (default token path is ~/.sit/serve.token, which is HOME-relative,
    # not repo-relative). Refuse to start if the token doesn't load —
    # the auth posture is "strictly enforced or absent" per ADR 0007.
    if (_serve_require_auth == 1) {
        var resolved = token_path;
        if (custom_token_path == 0) {
            var home = getenv("HOME");
            if (home == 0) {
                eprintln("sit: $HOME not set; pass --token <path> explicitly");
                return 1;
            }
            var hl = strlen(home);
            resolved = alloc(hl + 18);
            memcpy(resolved, home, hl);
            memcpy(resolved + hl, "/.sit/serve.token", 17);
            store8(resolved + hl + 17, 0);
        }
        _serve_token = _serve_load_token(resolved);
        if (_serve_token == 0) {
            eprintln("sit: --require-auth set but token failed to load — refusing to start");
            return 1;
        }
    }

    # Load TLS creds before chdir — --cert/--key are relative to the invocation
    # cwd, not the repo (same reasoning as the token path above).
    if (tls_mode == 1) {
        if (stdio_mode == 1) {
            eprintln("sit: --tls and --stdio are mutually exclusive");
            return 1;
        }
        if (cert_path == 0) {
            eprintln("sit: --tls requires --cert <file>");
            return 1;
        }
        if (key_path == 0) {
            eprintln("sit: --tls requires --key <file>");
            return 1;
        }
        if (_serve_load_cert(cert_path, &cert_pair) != 0) {
            eprintln("sit: cannot read --cert file");
            return 1;
        }
        if (read_file_heap(key_path, &key_pair) != 0) {
            eprintln("sit: cannot read --key file");
            return 1;
        }
    }

    # chdir into the repo so .sit/refs/* and .sit/objects.patra
    # resolve as relative paths in every dependent helper.
    if (syscall(SYS_CHDIR, repo_path) != 0) {
        eprintln("sit: cannot chdir to repo path");
        return 1;
    }
    if (file_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository at given path");
        return 1;
    }

    # In --stdio mode any chatter on stdout would land between HTTP
    # responses and corrupt the wire — log the listening posture to
    # stderr instead. Bearer auth still applies; it just runs over
    # the SSH-encrypted pipe rather than a TCP socket.
    if (stdio_mode == 1) {
        if (_serve_require_auth == 1) {
            eprintln("sit serve --stdio (auth: bearer)");
        }
        else {
            eprintln("sit serve --stdio (auth: none)");
        }
        return _serve_run_stdio();
    }

    if (tls_mode == 1) {
        if (_serve_require_auth == 1) {
            println("sit serve listening on 127.0.0.1 (tls, auth: bearer)");
        }
        else {
            println("sit serve listening on 127.0.0.1 (tls, auth: none)");
        }
        stdout_flush();
        return _serve_run_tls(port, load64(&cert_pair), load64(&cert_pair + 8),
                              load64(&key_pair), load64(&key_pair + 8));
    }

    if (_serve_require_auth == 1) {
        println("sit serve listening on 127.0.0.1 (auth: bearer)");
    }
    else {
        println("sit serve listening on 127.0.0.1 (auth: none)");
    }
    stdout_flush();
    return sandhi_server_run(INADDR_LOOPBACK(), port, &serve_handle_request, 0);
}

# --- api.cyr ---

# api.cyr — sit's stable public API surface for Cyrius consumers.
#
# Downstream Cyrius projects consume sit as a dep:
#
#     [deps.sit]
#     git = "https://github.com/MacCracken/sit.git"
#     tag = "0.8.1"
#     modules = ["dist/sit.cyr"]
#
# Stable surface (governed by ADR 0009):
#   - sit_repo_open(cwd)        — open a sit repository, returns 1 / 0
#   - sit_repo_close(repo)      — release the handle (no-op in v0.8.1)
#   - sit_diff_path(repo, path) — HEAD-blob vs working-tree, returns
#                                 an annotated-ops vec (or 0)
#   - ann_kind / ann_line / ann_old / ann_new — accessors on the
#                                 annotated-op records returned by
#                                 sit_diff_path (defined in diff.cyr)
#
# Identifier convention: any name `_`-prefixed is internal and may
# change without notice. Public names use the `sit_` / `ann_` prefix.
# Breaking changes to anything in this file require a major bump.

# Open a sit repository at `cwd`. Returns 1 on success, 0 on failure (cwd
# doesn't exist, isn't readable, or doesn't contain a `.sit/HEAD`).
#
# v0.8.1 behavior: chdirs the calling process into `cwd`. Multiple
# concurrent repo handles in a single process aren't supported — the
# `repo` return value is opaque and will gain real semantics in a
# future release. Callers should treat it as a token to pass to
# `sit_repo_close` and `sit_diff_path`, not inspect its contents.
fn sit_repo_open(cwd) {
    if (cwd == 0) { return 0; }
    if (syscall(SYS_CHDIR, cwd) != 0) { return 0; }
    if (file_exists(".sit/HEAD") != 1) { return 0; }
    return 1;
}

# Release the sit repository handle. v0.8.1: no-op (no per-repo state).
# Reserved for future use; callers should still call it for forward
# compatibility.
fn sit_repo_close(repo) {
    return 0;
}

# Compute the diff between `path`'s HEAD blob and its working-tree contents.
# Returns a vec of annotated-op records (use `ann_kind` / `ann_line` /
# `ann_old` / `ann_new` to inspect each), or 0 if the file is either
# unchanged, absent from both HEAD and the working tree, or the LCS table
# exceeds its cap (16M cells; see diff.cyr P-15).
#
# Shape: ops are line-level (one per old + new line, per LCS edit script).
# `kind` is 0 = keep / 1 = delete (was in HEAD, removed from working) /
# 2 = add (in working, not in HEAD). Caller owns the returned vec.
fn sit_diff_path(repo, path) {
    if (path == 0) { return 0; }

    # Resolve HEAD's blob hash for `path`. Treat "no HEAD" / "path absent
    # from HEAD" the same as "old buffer is empty" so an all-added file
    # still yields useful annotations.
    var head_entries = read_head_tree_entries();
    var old_buf = 0;
    var old_len = 0;
    var hp[16];
    if (head_entries != 0) {
        var he = tree_find(head_entries, path);
        if (he != 0) {
            var head_hex = tree_entry_hash(he);
            if (read_blob_content(head_hex, &hp) == 0) {
                old_buf = load64(&hp);
                old_len = load64(&hp + 8);
            }
        }
    }

    # Resolve working-tree contents. Path missing from disk → empty new
    # buffer (yields an all-delete diff against HEAD).
    var new_buf = 0;
    var new_len = 0;
    var wp[16];
    if (file_exists(path) == 1) {
        if (read_file_heap(path, &wp) == 0) {
            new_buf = load64(&wp);
            new_len = load64(&wp + 8);
        }
    }

    # Nothing on either side: no diff to report.
    if (old_buf == 0) {
        if (new_buf == 0) { return 0; }
    }

    return compute_file_diff(old_buf, old_len, new_buf, new_len);
}
