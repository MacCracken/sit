# --- util.cyr ---

# util.cyr — universal helpers.
#
# Everything here is consumed by two or more domain modules. Keep this file
# free of sit-specific domain knowledge — no refs, no objects, no patra.

var SEEK_SET = 0;
var SEEK_END = 2;

# ================================================================
# Repo-root prefixing (agnos support).
# ================================================================
# AGNOS's frozen syscall floor has NO chdir/getcwd/openat — "CWD is
# userland-owned, absolute paths" (ABI §3.2). sit historically leaned
# on process-cwd (`chdir` into the repo, then read ".sit/..." relative).
# That is portability-hostile. The fix: carry an explicit repo root and
# funnel every repo-relative FS access through sit_abs(), which prefixes
# it.
#
# `_repo_root` == 0 is the LINUX DEFAULT: no prefix, cwd-relative,
# byte-identical to pre-refactor behavior. On agnos, entry points set it
# to an absolute repo-root cstring so reads resolve without a cwd.
var _repo_root = 0;

# Store the repo root (an absolute-path cstring), or 0 to clear it.
fn sit_set_repo_root(root) {
    _repo_root = root;
    return 0;
}

# The ONE prefix point. Rules, in order:
#   (1) rel already absolute (byte 0 == '/') → return UNCHANGED.
#       (cert/token/HOME paths pass straight through.)
#   (2) _repo_root == 0 (Linux default) → return rel UNCHANGED
#       (preserves cwd-relative behavior exactly — a true no-op).
#   (3) else → heap-alloc "<_repo_root>/<rel>" and return it.
#       Caller-owns the result.
# On Linux and for already-absolute paths this is a no-op, so the whole
# change is behavior-preserving there.
fn sit_abs(rel) {
    if (rel == 0) { return rel; }
    if (load8(rel) == 47) { return rel; }            # '/'
    if (_repo_root == 0) { return rel; }
    # A "." root means "current directory" — prefixing "./" is redundant
    # and would break Linux byte-for-byte parity. Treat it as no-prefix so
    # cmd_init's explicit sit_set_repo_root(".") stays a Linux no-op.
    if (load8(_repo_root) == 46) { if (load8(_repo_root + 1) == 0) { return rel; } }
    var rlen = strlen(_repo_root);
    var plen = strlen(rel);
    # "<root>" + "/" + "<rel>" + NUL
    var out = alloc_or_die(rlen + 1 + plen + 1);
    memcpy(out, _repo_root, rlen);
    store8(out + rlen, 47);                          # '/'
    memcpy(out + rlen + 1, rel, plen);
    store8(out + rlen + 1 + plen, 0);
    return out;
}

# Str-aware variant of sit_abs for FS primitives that take a Str
# (e.g. dir_list). Applies the same prefixing rules to the Str's bytes
# and returns a new Str; a no-op case returns the input Str unchanged.
fn sit_abs_str(rel) {
    if (rel == 0) { return rel; }
    var data = str_data(rel);
    if (str_len(rel) > 0) { if (load8(data) == 47) { return rel; } }
    if (_repo_root == 0) { return rel; }
    return str_from(sit_abs(str_cstr(rel)));
}

# ----------------------------------------------------------------
# sit-owned FS wrappers (sf_*). Every repo FS access funnels through
# one of these so the prefixing lives in a single place. The inner
# calls keep the real stdlib names — the sf_ names are new, so no
# self-shadowing. Absolute/HOME/cert/token paths pass through sit_abs
# unchanged (rule 1), and on Linux (_repo_root == 0) every wrapper is a
# transparent forward (rule 2).
# ----------------------------------------------------------------
fn sf_exists(p) {
    return file_exists(sit_abs(p));
}

fn sf_write_all(p, buf, len) {
    return file_write_all(sit_abs(p), buf, len);
}

fn sf_open(p, flags, mode) {
    return file_open(sit_abs(p), flags, mode);
}

fn sf_read_all(p, buf, maxlen) {
    return file_read_all(sit_abs(p), buf, maxlen);
}

fn sf_append_locked(p, buf, len) {
    return file_append_locked(sit_abs(p), buf, len);
}

fn sf_mkdir(p, mode) {
    return sys_mkdir(sit_abs(p), mode);
}

# NOTE: no sf_ensure_dir / sf_ensure_parent_dirs / sf_read_file_heap —
# those three sit-owned fns prefix INTERNALLY (see below), so their
# existing callers stay unchanged. Wrapping them here would double-prefix.

fn sf_unlink(p) {
    return sys_unlink(sit_abs(p));
}

fn sf_rmdir(p) {
    return sys_rmdir(sit_abs(p));
}

fn sf_stat(p, buf) {
    return sys_stat(sit_abs(p), buf);
}

# dir_list takes a Str; route through the Str-aware prefixer.
fn sf_dir_list(p) {
    return dir_list(sit_abs_str(p));
}

# patra_open takes a cstring path (external dep).
fn sf_patra_open(p) {
    return patra_open(sit_abs(p));
}

fn eprintln(s) {
    var len = strlen(s);
    syscall(SYS_WRITE, STDERR, s, len);
    syscall(SYS_WRITE, STDERR, "\n", 1);
    return 0;
}

# P-17: buffered stdout. Without this, sit's command output is dozens to
# thousands of separate syscall(SYS_WRITE, STDOUT, ...) calls — `cmd_diff`
# on a 500-line edit emits 3000+ writes. With a single 64KB heap buffer +
# explicit flush at command end, the same workload lands in a handful of
# syscalls. STDERR (eprintln) stays direct so error output is immediate
# even when the process is being killed mid-command.
var STDOUT_BUF_SIZE = 65536;
var _stdout_buf = 0;
var _stdout_pos = 0;

fn stdout_write(data, len) {
    if (len <= 0) { return 0; }
    if (_stdout_buf == 0) {
        _stdout_buf = alloc_or_die(STDOUT_BUF_SIZE);
    }
    # Writes larger than the buffer go straight to the kernel after a flush
    # of any pending bytes — no point copying into a buffer we'd just empty.
    if (len >= STDOUT_BUF_SIZE) {
        stdout_flush();
        syscall(SYS_WRITE, STDOUT, data, len);
        return 0;
    }
    if (_stdout_pos + len > STDOUT_BUF_SIZE) {
        stdout_flush();
    }
    memcpy(_stdout_buf + _stdout_pos, data, len);
    _stdout_pos = _stdout_pos + len;
    return 0;
}

fn stdout_flush() {
    if (_stdout_pos == 0) { return 0; }
    syscall(SYS_WRITE, STDOUT, _stdout_buf, _stdout_pos);
    _stdout_pos = 0;
    return 0;
}

# S-17: alloc-or-die wrapper for the common case where OOM is unrecoverable
# (no transactional rollback in sit; a half-filled buffer will be memcpy'd
# from address 0 if alloc returns null and we don't notice). Use this at
# every fixed-shape `alloc(N)` site in object_db / tree / commit / merge
# instead of bare alloc; reserve bare alloc for the few callers that
# genuinely have a propagation path (read_file_heap, read_object).
fn alloc_or_die(size) {
    var p = alloc(size);
    if (p == 0) {
        eprintln("sit: out of memory");
        syscall(SYS_EXIT, 1);
    }
    return p;
}

# mkdir(path, 0o755), tolerating EEXIST (-17).
# sit-owned: prefixes `path` with the repo root (sit_abs) INTERNALLY so
# every caller (incl. ensure_parent_dirs) can pass a repo-relative path.
fn ensure_dir(path) {
    var r = sys_mkdir(sit_abs(path), 0x1ED);
    if (r == 0) { return 0; }
    if (r == 0 - 17) { return 0; }
    return r;
}

# Walk `path`, mkdir every '/'-delimited directory prefix. Used by ref writers
# so `.sit/refs/heads/feature/foo` creates `.sit/refs/heads/feature/` on demand.
# sit-owned: each derived segment is repo-relative and gets prefixed by
# ensure_dir's internal sit_abs — so this fn stays cwd-relative here and
# must NOT prefix `path` itself (that would double-prefix each segment).
fn ensure_parent_dirs(path) {
    var len = strlen(path);
    var i = 0;
    while (i < len) {
        if (load8(path + i) == 47) {
            if (i > 0) {
                var segment = alloc(i + 1);
                memcpy(segment, path, i);
                store8(segment + i, 0);
                ensure_dir(segment);
            }
        }
        i = i + 1;
    }
    return 0;
}

# Write decimal representation of n into buf. Returns digit count.
fn write_decimal(buf, n) {
    if (n == 0) { store8(buf, 48); return 1; }
    var digits = 0;
    var m = n;
    while (m > 0) { digits = digits + 1; m = m / 10; }
    m = n;
    var i = digits - 1;
    while (m > 0) {
        store8(buf + i, 48 + m % 10);
        i = i - 1;
        m = m / 10;
    }
    return digits;
}

# Copy argv(n) into a heap-owned, null-terminated string. See
# docs/architecture/001 — argv pointers alias post-return stack memory,
# so we must copy before doing anything stack-heavy.
fn argv_heap(n) {
    var raw = argv(n);
    var len = strlen(raw);
    var s = alloc(len + 1);
    memcpy(s, raw, len);
    store8(s + len, 0);
    return s;
}

# Advance past any run of spaces or tabs in [pos, stop).
fn skip_ws(data, pos, stop) {
    var i = pos;
    var scanning = 1;
    while (scanning == 1) {
        if (i >= stop) { scanning = 0; }
        else {
            var c = load8(data + i);
            if (c == 32) { i = i + 1; }
            else {
                if (c == 9) { i = i + 1; }
                else { scanning = 0; }
            }
        }
    }
    return i;
}

fn strcmp_cstr(a, b) {
    var i = 0;
    var done = 0;
    var result = 0;
    while (done == 0) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        if (ca != cb) {
            if (ca < cb) { result = 0 - 1; }
            else { result = 1; }
            done = 1;
        }
        else {
            if (ca == 0) { done = 1; }
            else { i = i + 1; }
        }
    }
    return result;
}

# Insertion-sort a vec of cstrings in place (ascending).
fn sort_cstrings(vec) {
    var n = vec_len(vec);
    var i = 1;
    while (i < n) {
        var cur = vec_get(vec, i);
        var j = i - 1;
        var placed = 0;
        while (placed == 0) {
            if (j < 0) { placed = 1; }
            else {
                var prev = vec_get(vec, j);
                if (strcmp_cstr(cur, prev) >= 0) { placed = 1; }
                else {
                    vec_set(vec, j + 1, prev);
                    j = j - 1;
                }
            }
        }
        vec_set(vec, j + 1, cur);
        i = i + 1;
    }
    return 0;
}

# Write a sanitized copy of `bytes[len]` to `fd`, replacing ASCII control
# chars (< 0x20 except \t, plus \x7f) with '?'. Used (S-21) for attacker-
# controlled commit body fragments like Author identity so a malicious commit
# can't emit ANSI escape sequences that forge log output or manipulate the
# terminal. Builds the sanitized output into a heap buffer in one pass and
# emits via a single write — both for perf (no per-char syscall) and so the
# STDOUT path stays in order with the surrounding stdout_write calls (P-17).
fn write_sanitized(fd, bytes, len) {
    if (len <= 0) { return 0; }
    var out = alloc_or_die(len);
    var i = 0;
    while (i < len) {
        var c = load8(bytes + i) & 0xFF;
        var emit = c;
        if (c < 32) {
            if (c == 9) { }              # allow tab
            else { emit = 63; }           # '?'
        }
        if (c == 127) { emit = 63; }
        store8(out + i, emit);
        i = i + 1;
    }
    if (fd == STDOUT) { stdout_write(out, len); }
    else { syscall(SYS_WRITE, fd, out, len); }
    return 0;
}

# Read an entire file into a heap buffer. Writes (ptr, len) to out_pair.
# Returns 0 on success, negative on failure.
# sit-owned: prefixes `path` with the repo root (sit_abs) INTERNALLY so
# its many callers need no change.
fn read_file_heap(path, out_pair) {
    var fd = file_open(sit_abs(path), 0, 0);
    if (fd < 0) { return 0 - 1; }
    var size = syscall(SYS_LSEEK, fd, 0, SEEK_END);
    syscall(SYS_LSEEK, fd, 0, SEEK_SET);
    if (size < 0) { file_close(fd); return 0 - 2; }
    # S-06: read_file_heap is used for config files and ref files, which should
    # never exceed a few KB. Cap at 64 MiB to keep a hostile / accidentally-huge
    # file from triggering a multi-GB allocation here.
    if (size > 67108864) { file_close(fd); return 0 - 4; }
    var buf = alloc(size + 1);
    if (buf == 0) { file_close(fd); return 0 - 3; }
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var n = file_read(fd, buf + total, size - total);
        if (n <= 0) { rgo = 0; }
        else { total = total + n; if (total >= size) { rgo = 0; } }
    }
    file_close(fd);
    store64(out_pair, buf);
    store64(out_pair + 8, total);
    return 0;
}

# --- validate.cyr ---

# validate.cyr — input validators for the P(-1) audit fixes.
#
# Every validator is PURE: returns 1 if the input is acceptable, 0 otherwise.
# No stdout, no side effects. Callers decide the error message and disposition.
#
# See docs/audit/2026-04-24-audit.md for the finding-by-finding rationale.

# Length caps picked to match git conventions where they exist and to avoid
# pathological allocations where they don't.
var VAL_REFNAME_MAX = 255;         # S-02 / S-26
var VAL_TREE_NAME_MAX = 255;       # S-03
var VAL_CONFIG_VALUE_MAX = 1024;   # S-05
var VAL_CONFIG_KEY_MAX = 128;      # S-05
var VAL_REMOTE_URL_MAX = 4096;     # S-04

# ── Hex prefix (S-01) ───────────────────────────────────────────────
#
# Accept only [0-9a-f], length 4..64. Used by resolve_hash before interpolating
# the prefix into `LIKE '<prefix>%'`. Preserves sit's existing "too short" (-2)
# behavior by letting the caller check length separately first; this validator
# only checks the CHARACTER set so callers can distinguish "too short" from
# "has bogus characters".

fn hex_prefix_valid(s, len) {
    if (len == 0) { return 0; }
    if (len > 64) { return 0; }
    var i = 0;
    while (i < len) {
        var c = load8(s + i) & 0xFF;
        var ok = 0;
        if (c >= 48) { if (c <= 57) { ok = 1; } }  # 0-9
        if (c >= 97) { if (c <= 102) { ok = 1; } } # a-f
        if (ok == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# ── Ref name (S-02, S-26) ───────────────────────────────────────────
#
# Enforces git check-ref-format rules:
#   - non-empty, <= VAL_REFNAME_MAX
#   - no component begins with '.'
#   - no component ends with '.lock'
#   - no '..' anywhere
#   - no ASCII control chars (< 0x20 or == 0x7F)
#   - no space, '~', '^', ':', '?', '*', '['
#   - cannot begin or end with '/', no '//'
#   - cannot end with '.'
#   - no '@{'
#   - cannot be the single '@'
#   - no '\'

fn _ref_is_bad_char(c) {
    if (c < 32) { return 1; }
    if (c == 127) { return 1; }
    if (c == 32) { return 1; }       # space
    if (c == 126) { return 1; }      # ~
    if (c == 94) { return 1; }       # ^
    if (c == 58) { return 1; }       # :
    if (c == 63) { return 1; }       # ?
    if (c == 42) { return 1; }       # *
    if (c == 91) { return 1; }       # [
    if (c == 92) { return 1; }       # backslash
    return 0;
}

fn refname_valid(name) {
    if (name == 0) { return 0; }
    var len = strlen(name);
    if (len == 0) { return 0; }
    if (len > VAL_REFNAME_MAX) { return 0; }

    # Single-char '@' rejected
    if (len == 1) {
        if (load8(name) == 64) { return 0; }
    }

    # First or last char cannot be '/'
    if (load8(name) == 47) { return 0; }
    if (load8(name + len - 1) == 47) { return 0; }
    # Last char cannot be '.'
    if (load8(name + len - 1) == 46) { return 0; }

    var i = 0;
    var comp_start = 0;  # Start offset of current '/'-separated component
    while (i < len) {
        var c = load8(name + i) & 0xFF;
        if (_ref_is_bad_char(c) == 1) { return 0; }

        # Check for '@{' sequence. This rejects '@{' in ref-NAME context so
        # a name like main@{0} never becomes a .sit/refs/.../main@{0} file.
        # It does NOT gate '@{N}' in REVISION context — that ordinal reflog
        # selector is parsed in resolve_reflog_spec (refs.cyr) before any ref
        # lookup, so `sit reset --hard HEAD@{1}` resolves via .sit/logs/.
        if (c == 64) {
            if (i + 1 < len) {
                if (load8(name + i + 1) == 123) { return 0; }
            }
        }

        # Check for '..' sequence
        if (c == 46) {
            if (i + 1 < len) {
                if (load8(name + i + 1) == 46) { return 0; }
            }
        }

        if (c == 47) {
            # End of a component: validate it was nonempty (i.e. no '//'),
            # didn't end with .lock, didn't start with '.', etc.
            if (i == comp_start) { return 0; }  # '//'
            # Component-start checks already handled at the boundary transition below.
            # Component-end .lock check: does component end with ".lock"?
            var comp_len = i - comp_start;
            if (comp_len >= 5) {
                if (memeq(name + i - 5, ".lock", 5) == 1) { return 0; }
            }
            # Next component starts right after the '/'
            comp_start = i + 1;
            # Must not start with '.'
            if (comp_start < len) {
                if (load8(name + comp_start) == 46) { return 0; }
            }
        }
        i = i + 1;
    }

    # First component: name cannot begin with '.'
    if (load8(name) == 46) { return 0; }

    # Final component .lock check
    var final_len = len - comp_start;
    if (final_len >= 5) {
        if (memeq(name + len - 5, ".lock", 5) == 1) { return 0; }
    }

    return 1;
}

# ── Tree entry name (S-03) ──────────────────────────────────────────
#
# Called by parse_tree on each entry, AND by materialize_target before the
# write, so attackers have to clear two hurdles. Belt-and-suspenders.
#
# Rejects:
#   - empty
#   - ".", ".."
#   - any '/' or '\' or NUL
#   - any ':' (NTFS ADS + Windows drive letter)
#   - any ASCII control char (< 0x20 or == 0x7F)
#   - trailing space or dot (Windows)
#   - case-fold-equal to ".sit", ".git", ".ssh"
#   - NTFS reserved names (CON, PRN, NUL, AUX, COM1-9, LPT1-9)
#   - length > VAL_TREE_NAME_MAX
#
# HFS-ignorable Unicode codepoints are not handled byte-level here — they
# belong in a higher-level check that operates on decoded Unicode. Flagged
# as a v0.7 follow-up.

fn _ascii_tolower(c) {
    if (c >= 65) { if (c <= 90) { return c + 32; } }
    return c;
}

# Case-insensitive match: is `name` equal to `lower_ref` ignoring ASCII case?
# `lower_ref` must already be lowercase (saves an op per char).
fn _name_iequal_ascii(name, name_len, lower_ref, ref_len) {
    if (name_len != ref_len) { return 0; }
    var i = 0;
    while (i < name_len) {
        var nc = _ascii_tolower(load8(name + i) & 0xFF);
        var rc = load8(lower_ref + i) & 0xFF;
        if (nc != rc) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn _is_ntfs_reserved(name, name_len) {
    # Strip trailing extension for comparison: CON, CON.txt both reserved.
    var stem_len = name_len;
    var i = 0;
    while (i < name_len) {
        if (load8(name + i) == 46) { stem_len = i; i = name_len; }
        else { i = i + 1; }
    }
    if (stem_len == 3) {
        if (_name_iequal_ascii(name, 3, "con", 3) == 1) { return 1; }
        if (_name_iequal_ascii(name, 3, "prn", 3) == 1) { return 1; }
        if (_name_iequal_ascii(name, 3, "nul", 3) == 1) { return 1; }
        if (_name_iequal_ascii(name, 3, "aux", 3) == 1) { return 1; }
    }
    if (stem_len == 4) {
        # COM1..COM9, LPT1..LPT9
        var c0 = _ascii_tolower(load8(name) & 0xFF);
        var c1 = _ascii_tolower(load8(name + 1) & 0xFF);
        var c2 = _ascii_tolower(load8(name + 2) & 0xFF);
        var c3 = load8(name + 3) & 0xFF;
        if (c3 >= 49) {
            if (c3 <= 57) {
                if (c0 == 99) {
                    if (c1 == 111) {
                        if (c2 == 109) { return 1; }  # com1..com9
                    }
                }
                if (c0 == 108) {
                    if (c1 == 112) {
                        if (c2 == 116) { return 1; }  # lpt1..lpt9
                    }
                }
            }
        }
    }
    return 0;
}

fn tree_entry_name_valid(name) {
    if (name == 0) { return 0; }
    var len = strlen(name);
    if (len == 0) { return 0; }
    if (len > VAL_TREE_NAME_MAX) { return 0; }

    # Reject "." and ".."
    if (len == 1) {
        if (load8(name) == 46) { return 0; }
    }
    if (len == 2) {
        if (load8(name) == 46) {
            if (load8(name + 1) == 46) { return 0; }
        }
    }

    # Character-by-character sweep
    var i = 0;
    while (i < len) {
        var c = load8(name + i) & 0xFF;
        if (c == 0) { return 0; }       # embedded NUL
        if (c < 32) { return 0; }       # control char
        if (c == 127) { return 0; }     # DEL
        if (c == 47) { return 0; }      # /
        if (c == 92) { return 0; }      # \
        if (c == 58) { return 0; }      # :
        i = i + 1;
    }

    # Trailing space or dot (Windows)
    var last = load8(name + len - 1) & 0xFF;
    if (last == 32) { return 0; }
    if (last == 46) { return 0; }

    # Case-fold comparison to dot-directories we guard
    if (_name_iequal_ascii(name, len, ".sit", 4) == 1) { return 0; }
    if (_name_iequal_ascii(name, len, ".git", 4) == 1) { return 0; }
    if (_name_iequal_ascii(name, len, ".ssh", 4) == 1) { return 0; }

    # NTFS reserved names
    if (_is_ntfs_reserved(name, len) == 1) { return 0; }

    return 1;
}

# Flattened tree path (S-03 second gate).
#
# `flatten_tree` concatenates prefix + entry-name producing paths like
# "src/main.cyr". Each segment between '/'s must individually pass
# tree_entry_name_valid; the full path must also be relative and capped.

var VAL_TREE_PATH_MAX = 4096;

fn tree_flat_path_valid(path) {
    if (path == 0) { return 0; }
    var len = strlen(path);
    if (len == 0) { return 0; }
    if (len > VAL_TREE_PATH_MAX) { return 0; }

    # Cannot be absolute — no leading '/'
    if (load8(path) == 47) { return 0; }

    # Walk '/'-separated segments; each must pass tree_entry_name_valid.
    var seg_start = 0;
    var i = 0;
    while (i <= len) {
        var at_end = 0;
        if (i == len) { at_end = 1; }
        else {
            if (load8(path + i) == 47) { at_end = 1; }
        }
        if (at_end == 1) {
            var seg_len = i - seg_start;
            if (seg_len == 0) { return 0; }  # leading/trailing/consecutive '/'
            # Copy segment to a nul-terminated scratch buffer for the validator.
            var seg = alloc(seg_len + 1);
            memcpy(seg, path + seg_start, seg_len);
            store8(seg + seg_len, 0);
            if (tree_entry_name_valid(seg) == 0) { return 0; }
            seg_start = i + 1;
        }
        i = i + 1;
    }
    return 1;
}

# Tree entry mode allowlist (S-03). Only "100644" (regular file) and "40000"
# (directory) are accepted. Reject symlinks (120000), submodules (160000),
# executable (100755) — sit doesn't emit those today; accepting them from a
# remote tree gives an attacker surface we don't need.

fn tree_entry_mode_valid(mode) {
    if (mode == 0) { return 0; }
    if (streq(mode, "100644") == 1) { return 1; }
    if (streq(mode, "40000") == 1) { return 1; }
    return 0;
}

# ── Config key / value (S-05) ───────────────────────────────────────
#
# Reject control chars (includes \n, \r, \0), cap lengths, and for the key
# require dot-separated tokens that look reasonable.

fn config_value_valid(v) {
    if (v == 0) { return 0; }
    var len = strlen(v);
    if (len > VAL_CONFIG_VALUE_MAX) { return 0; }
    var i = 0;
    while (i < len) {
        var c = load8(v + i) & 0xFF;
        if (c == 0) { return 0; }
        if (c == 10) { return 0; }
        if (c == 13) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn config_key_valid(k) {
    if (k == 0) { return 0; }
    var len = strlen(k);
    if (len == 0) { return 0; }
    if (len > VAL_CONFIG_KEY_MAX) { return 0; }
    var i = 0;
    while (i < len) {
        var c = load8(k + i) & 0xFF;
        # Keys may contain ASCII letters, digits, '.', '_', '-'
        var ok = 0;
        if (c >= 97) { if (c <= 122) { ok = 1; } }  # a-z
        if (c >= 65) { if (c <= 90) { ok = 1; } }   # A-Z
        if (c >= 48) { if (c <= 57) { ok = 1; } }   # 0-9
        if (c == 46) { ok = 1; }  # .
        if (c == 95) { ok = 1; }  # _
        if (c == 45) { ok = 1; }  # -
        if (ok == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# ── Remote URL (S-04) ───────────────────────────────────────────────
#
# Scheme-aware validator. v0.6.x accepted only local-path schemes; v0.7.1
# extends acceptance to http://, https://, ssh:// (transport itself lands in
# v0.7.2+, but URLs validate at remote-add time so users can wire config in
# advance without seeing parse errors when transport ships).
#
# Per-scheme strictness is deliberately conservative: control-char / NUL /
# leading-dash gates apply uniformly; the network-scheme path then runs the
# authority+path body through a whitelist character set. v0.7.3 (HTTP fetch)
# and v0.7.8 (SSH transport) tighten further as those code paths land —
# e.g. RFC3986 host-label rules, port range enforcement, no-`..`-segments.
#
# CVE-2017-1000117 prophylactic: any URL with a leading '-' is rejected so
# the day a transport forks a subprocess, an attacker-controlled URL cannot
# masquerade as a flag.

var URL_SCHEME_INVALID = 0 - 1;
var URL_SCHEME_FILE = 0;
var URL_SCHEME_HTTP = 1;
var URL_SCHEME_HTTPS = 2;
var URL_SCHEME_SSH = 3;

# Classify a URL by its scheme prefix. Path-shaped inputs ('/abs', './rel',
# '../rel') classify as FILE so callers can dispatch with a single switch.
# Returns INVALID for empty / NULL / unrecognized-scheme inputs. Does NOT
# perform body validation — pair with remote_url_valid for the full check.
fn url_scheme(url) {
    if (url == 0) { return URL_SCHEME_INVALID; }
    var len = strlen(url);
    if (len == 0) { return URL_SCHEME_INVALID; }
    if (len >= 8) {
        if (memeq(url, "https://", 8) == 1) { return URL_SCHEME_HTTPS; }
    }
    if (len >= 7) {
        if (memeq(url, "file://", 7) == 1) { return URL_SCHEME_FILE; }
        if (memeq(url, "http://",  7) == 1) { return URL_SCHEME_HTTP;  }
    }
    if (len >= 6) {
        if (memeq(url, "ssh://",   6) == 1) { return URL_SCHEME_SSH;   }
    }
    # Bare paths: absolute (/…) or relative (./…, ../…).
    if (load8(url) == 47) { return URL_SCHEME_FILE; }
    if (load8(url) == 46) { return URL_SCHEME_FILE; }
    return URL_SCHEME_INVALID;
}

# Whitelist body validator for the authority+path of a network URL. Accepts
# alphanumeric plus . - _ / : @ % ~ — sufficient to express
# user@host:port/path-with-encoded-segments without admitting shell or SQL
# metachars. Empty body and leading '-' are rejected (the latter as a second
# layer of CVE-2017-1000117 defense if the scheme prefix was 7+ bytes long).
fn url_authority_path_valid(s, len) {
    if (len == 0) { return 0; }
    if (load8(s) == 45) { return 0; }
    var i = 0;
    while (i < len) {
        var c = load8(s + i) & 0xFF;
        var ok = 0;
        if (c >= 48) { if (c <=  57) { ok = 1; } }  # 0-9
        if (c >= 65) { if (c <=  90) { ok = 1; } }  # A-Z
        if (c >= 97) { if (c <= 122) { ok = 1; } }  # a-z
        if (c == 46) { ok = 1; }  # .
        if (c == 45) { ok = 1; }  # -
        if (c == 95) { ok = 1; }  # _
        if (c == 47) { ok = 1; }  # /
        if (c == 58) { ok = 1; }  # :
        if (c == 64) { ok = 1; }  # @
        if (c == 37) { ok = 1; }  # %
        if (c == 126) { ok = 1; } # ~
        if (ok == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn remote_url_valid(url) {
    if (url == 0) { return 0; }
    var len = strlen(url);
    if (len == 0) { return 0; }
    if (len > VAL_REMOTE_URL_MAX) { return 0; }

    # CVE-2017-1000117 prophylactic
    if (load8(url) == 45) { return 0; }

    # Control chars / NUL
    var i = 0;
    while (i < len) {
        var c = load8(url + i) & 0xFF;
        if (c == 0) { return 0; }
        if (c == 10) { return 0; }
        if (c == 13) { return 0; }
        i = i + 1;
    }

    var s = url_scheme(url);
    if (s == URL_SCHEME_FILE) {
        # Already passed control-char + leading-dash gates above; file://
        # plus bare absolute/relative paths are accepted as-is.
        return 1;
    }
    if (s == URL_SCHEME_HTTP) {
        return url_authority_path_valid(url + 7, len - 7);
    }
    if (s == URL_SCHEME_HTTPS) {
        return url_authority_path_valid(url + 8, len - 8);
    }
    if (s == URL_SCHEME_SSH) {
        return url_authority_path_valid(url + 6, len - 6);
    }
    return 0;
}

# ── Filesystem symlink guard (S-04, S-12) ──────────────────────────
#
# Calls newfstatat(AT_FDCWD, path, &stat, AT_SYMLINK_NOFOLLOW) and returns:
#   1 if path exists and is a SYMLINK
#   0 if path exists and is NOT a symlink (regular file, dir, etc.)
#  -1 if path does not exist or stat failed
#
# struct stat layout on Linux x86_64: st_mode is u32 at offset 24.
# S_IFMT = 0xF000, S_IFLNK = 0xA000.

var VAL_AT_FDCWD = 0 - 100;
var VAL_AT_SYMLINK_NOFOLLOW = 256;

fn path_is_symlink(path) {
    var stbuf[144];
    var rc = syscall(262, VAL_AT_FDCWD, path, &stbuf, VAL_AT_SYMLINK_NOFOLLOW);
    if (rc < 0) { return 0 - 1; }
    var mode = load32(&stbuf + 24);
    var fmt = mode & 0xF000;
    if (fmt == 0xA000) { return 1; }
    return 0;
}

# Return the file-type bits (S_IFMT-masked mode) for a path via lstat, or -1
# if stat failed. Caller compares against 0xA000 (symlink), 0x4000 (dir),
# 0x8000 (regular), etc. Useful for S-04's "is this a directory" and for
# S-25's "does target already exist as something other than a dir".

fn path_lstat_kind(path) {
    var stbuf[144];
    var rc = syscall(262, VAL_AT_FDCWD, path, &stbuf, VAL_AT_SYMLINK_NOFOLLOW);
    if (rc < 0) { return 0 - 1; }
    var mode = load32(&stbuf + 24);
    return mode & 0xF000;
}

# --- config.cyr ---

# config.cyr — sit config file parsing + cmd_config.
#
# Flat `key = value` format. Local at .sit/config; global at ~/.sitconfig.
# Resolution priority: env (at call sites) → local → global → fallback.

# Advance past any run of spaces or tabs in [pos, stop).
# Parse a `key = value` line in [start, stop). Returns heap cstring value
# if the key matches, else 0. Tolerates arbitrary whitespace and skips
# `#`-comment / blank lines.
fn config_parse_value(data, start, stop, key, key_len) {
    var i = skip_ws(data, start, stop);
    if (i >= stop) { return 0; }
    if (load8(data + i) == 35) { return 0; }

    if (stop - i < key_len) { return 0; }
    if (memeq(data + i, key, key_len) == 0) { return 0; }
    i = i + key_len;

    i = skip_ws(data, i, stop);
    if (i >= stop) { return 0; }
    if (load8(data + i) != 61) { return 0; }
    i = i + 1;

    i = skip_ws(data, i, stop);

    var end = stop;
    var trimming = 1;
    while (trimming == 1) {
        if (end <= i) { trimming = 0; }
        else {
            var c = load8(data + end - 1);
            if (c == 32) { end = end - 1; }
            else {
                if (c == 9) { end = end - 1; }
                else { trimming = 0; }
            }
        }
    }

    var value_len = end - i;
    var val = alloc(value_len + 1);
    memcpy(val, data + i, value_len);
    store8(val + value_len, 0);
    return val;
}

# Look up `key` in a single config file. Returns heap cstring value or 0.
fn config_file_get(path, key) {
    if (sf_exists(path) != 1) { return 0; }
    var pair[16];
    if (read_file_heap(path, &pair) != 0) { return 0; }
    var data = load64(&pair);
    var len = load64(&pair + 8);
    var key_len = strlen(key);

    var pos = 0;
    while (pos < len) {
        var le = pos;
        var finding = 1;
        while (finding == 1) {
            if (le >= len) { finding = 0; }
            else {
                if (load8(data + le) == 10) { finding = 0; }
                else { le = le + 1; }
            }
        }
        var stop = le;
        if (stop > pos) {
            if (load8(data + stop - 1) == 13) { stop = stop - 1; }
        }
        var v = config_parse_value(data, pos, stop, key, key_len);
        if (v != 0) { return v; }
        pos = le + 1;
    }
    return 0;
}

# Look up `key` in .sit/config (local, higher precedence) then ~/.sitconfig.
fn config_get(key) {
    var v = config_file_get(".sit/config", key);
    if (v != 0) { return v; }
    var home = getenv("HOME");
    if (home == 0) { return 0; }
    var hlen = strlen(home);
    var path = alloc(hlen + 12);
    memcpy(path, home, hlen);
    memcpy(path + hlen, "/.sitconfig", 11);
    store8(path + hlen + 11, 0);
    return config_file_get(path, key);
}

# Upsert `key = value` in a config file. Replaces the first matching line
# or appends a new one. Returns 0 on success, negative on write failure.
#
# S-05: reject newlines/NUL/control chars in both key and value. Prevents
# `sit remote add origin $'foo\nother = attacker'`-shape injection
# (CVE-2023-29007 / CVE-2025-48384).
fn config_file_set(path, key, value) {
    if (config_key_valid(key) == 0) { return 0 - 2; }
    if (config_value_valid(value) == 0) { return 0 - 2; }
    var key_len = strlen(key);
    var val_len = strlen(value);

    var data = 0;
    var len = 0;
    if (sf_exists(path) == 1) {
        var pair[16];
        if (read_file_heap(path, &pair) == 0) {
            data = load64(&pair);
            len = load64(&pair + 8);
        }
    }

    var out = alloc(len + key_len + val_len + 8);
    var out_pos = 0;
    var replaced = 0;

    var pos = 0;
    while (pos < len) {
        var le = pos;
        var finding = 1;
        while (finding == 1) {
            if (le >= len) { finding = 0; }
            else {
                if (load8(data + le) == 10) { finding = 0; }
                else { le = le + 1; }
            }
        }
        var stop = le;
        if (stop > pos) {
            if (load8(data + stop - 1) == 13) { stop = stop - 1; }
        }

        var v = config_parse_value(data, pos, stop, key, key_len);
        if (v != 0) {
            memcpy(out + out_pos, key, key_len);
            out_pos = out_pos + key_len;
            memcpy(out + out_pos, " = ", 3);
            out_pos = out_pos + 3;
            memcpy(out + out_pos, value, val_len);
            out_pos = out_pos + val_len;
            store8(out + out_pos, 10);
            out_pos = out_pos + 1;
            replaced = 1;
        }
        else {
            var copy_len = le - pos;
            if (le < len) { copy_len = copy_len + 1; }
            memcpy(out + out_pos, data + pos, copy_len);
            out_pos = out_pos + copy_len;
        }
        pos = le + 1;
    }

    if (replaced == 0) {
        if (out_pos > 0) {
            if (load8(out + out_pos - 1) != 10) {
                store8(out + out_pos, 10);
                out_pos = out_pos + 1;
            }
        }
        memcpy(out + out_pos, key, key_len);
        out_pos = out_pos + key_len;
        memcpy(out + out_pos, " = ", 3);
        out_pos = out_pos + 3;
        memcpy(out + out_pos, value, val_len);
        out_pos = out_pos + val_len;
        store8(out + out_pos, 10);
        out_pos = out_pos + 1;
    }

    if (sf_write_all(path, out, out_pos) < 0) { return 0 - 1; }
    return 0;
}

# Print every non-blank, non-comment line of a config file to stdout.
fn config_file_list(path) {
    if (sf_exists(path) != 1) { return 0; }
    var pair[16];
    if (read_file_heap(path, &pair) != 0) { return 0; }
    var data = load64(&pair);
    var len = load64(&pair + 8);
    var pos = 0;
    while (pos < len) {
        var le = pos;
        var finding = 1;
        while (finding == 1) {
            if (le >= len) { finding = 0; }
            else {
                if (load8(data + le) == 10) { finding = 0; }
                else { le = le + 1; }
            }
        }
        var stop = le;
        if (stop > pos) {
            if (load8(data + stop - 1) == 13) { stop = stop - 1; }
        }
        var start = skip_ws(data, pos, stop);
        if (start < stop) {
            if (load8(data + start) != 35) {
                stdout_write(data + pos, le - pos);
                if (le < len) { stdout_write("\n", 1); }
            }
        }
        pos = le + 1;
    }
    return 0;
}

# Remove the first line matching `key = value` from a config file.
# Returns 0 on success, -1 on I/O failure, -2 if the key wasn't present.
fn config_file_unset(path, key) {
    var key_len = strlen(key);
    if (sf_exists(path) != 1) { return 0 - 2; }
    var pair[16];
    if (read_file_heap(path, &pair) != 0) { return 0 - 1; }
    var data = load64(&pair);
    var len = load64(&pair + 8);

    var out = alloc(len + 1);
    var out_pos = 0;
    var removed = 0;
    var pos = 0;
    while (pos < len) {
        var le = pos;
        var finding = 1;
        while (finding == 1) {
            if (le >= len) { finding = 0; }
            else {
                if (load8(data + le) == 10) { finding = 0; }
                else { le = le + 1; }
            }
        }
        var stop = le;
        if (stop > pos) {
            if (load8(data + stop - 1) == 13) { stop = stop - 1; }
        }
        var v = config_parse_value(data, pos, stop, key, key_len);
        if (v != 0) {
            removed = 1;
        }
        else {
            var copy_len = le - pos;
            if (le < len) { copy_len = copy_len + 1; }
            memcpy(out + out_pos, data + pos, copy_len);
            out_pos = out_pos + copy_len;
        }
        pos = le + 1;
    }
    if (removed == 0) { return 0 - 2; }
    if (sf_write_all(path, out, out_pos) < 0) { return 0 - 1; }
    return 0;
}

fn cmd_config() {
    var global = 0;
    var arg_base = 2;
    if (argc() >= 3) {
        if (streq(argv(2), "--global") == 1) {
            global = 1;
            arg_base = 3;
        }
    }

    var path = 0;
    if (global == 1) {
        var home = getenv("HOME");
        if (home == 0) {
            eprintln("sit: HOME not set");
            return 1;
        }
        var hlen = strlen(home);
        path = alloc(hlen + 12);
        memcpy(path, home, hlen);
        memcpy(path + hlen, "/.sitconfig", 11);
        store8(path + hlen + 11, 0);
    }
    else {
        if (sf_exists(".sit/HEAD") != 1) {
            eprintln("sit: not a sit repository (run 'sit init')");
            return 1;
        }
        path = ".sit/config";
    }

    if (argc() < arg_base + 1) {
        eprintln("usage: sit config [--global] [--list | --unset <key> | <key> [<value>]]");
        return 1;
    }

    # --list: dump all entries (or nothing if file missing)
    if (streq(argv(arg_base), "--list") == 1) {
        config_file_list(path);
        return 0;
    }

    # --unset <key>: remove key
    if (streq(argv(arg_base), "--unset") == 1) {
        if (argc() < arg_base + 2) {
            eprintln("sit: --unset requires a key");
            return 1;
        }
        var ukey = argv_heap(arg_base + 1);
        var r = config_file_unset(path, ukey);
        if (r == 0 - 2) {
            syscall(SYS_WRITE, STDERR, "sit: '", 6);
            syscall(SYS_WRITE, STDERR, ukey, strlen(ukey));
            syscall(SYS_WRITE, STDERR, "' not set in ", 13);
            syscall(SYS_WRITE, STDERR, path, strlen(path));
            syscall(SYS_WRITE, STDERR, "\n", 1);
            return 1;
        }
        if (r == 0 - 2) {
            eprintln("sit: invalid key or value (no newlines, control chars, or NULs)");
            return 1;
        }
        if (r < 0) {
            eprintln("sit: failed to write config");
            return 1;
        }
        return 0;
    }

    var key = argv_heap(arg_base);
    if (argc() < arg_base + 2) {
        var val = 0;
        if (global == 1) { val = config_file_get(path, key); }
        else             { val = config_get(key); }
        if (val == 0) { return 1; }
        stdout_write(val, strlen(val));
        stdout_write("\n", 1);
        return 0;
    }

    var value = argv_heap(arg_base + 1);
    var set_r = config_file_set(path, key, value);
    if (set_r == 0 - 2) {
        eprintln("sit: invalid key or value (no newlines, control chars, or NULs)");
        return 1;
    }
    if (set_r < 0) {
        eprintln("sit: failed to write config");
        return 1;
    }
    return 0;
}

# --- reflog.cyr ---

# reflog.cyr — ref-movement journal (.sit/logs/), git-compatible.
#
# Every ref movement appends one line to a per-ref log under .sit/logs/,
# mirroring the ref tree: .sit/logs/HEAD, .sit/logs/refs/heads/<name>,
# .sit/logs/refs/remotes/<remote>/<name>. (Tags are not logged, matching
# git's default.) A branch-tip move that HEAD points at logs TWICE — once
# to the branch log and once to logs/HEAD — see docs/architecture/005.
#
# Line format (byte-compatible with git's SHA-256 reflog):
#   <old64> SP <new64> SP <name> " <" <email> "> " <unixts> " +0000" TAB <msg> LF
# Creation uses 64 ASCII '0' for <old64>. Entries are append-only, newest
# LAST; <ref>@{0} = the last line (current value), @{N} = N moves ago =
# the NEW oid recorded at line (count-1-N). Identity + timestamp + tz
# mirror build_commit_signed (commit.cyr) so the journal matches commits.
#
# This module is intentionally I/O-thin: the pure formatting / indexing
# core (reflog_format_line, _reflog_nth_in_buf, _reflog_count_in_buf) is
# unit-tested directly; the file wrappers (reflog_append, reflog_read_nth)
# are exercised by the CI smoke suite.

# ── Identity (mirrors build_commit_signed's resolution chain) ──────────
# env SIT_AUTHOR_* → .sit/config / ~/.sitconfig user.* → fallback.
# NOTE: commit.cyr and merge.cyr inline this same chain; this is the third
# copy — a shared author_ident() helper is the natural next refactor.
fn _reflog_user_name() {
    var name = getenv("SIT_AUTHOR_NAME");
    if (name == 0) { name = config_get("user.name"); }
    if (name == 0) { name = "sit user"; }
    return name;
}

fn _reflog_user_email() {
    var email = getenv("SIT_AUTHOR_EMAIL");
    if (email == 0) { email = config_get("user.email"); }
    if (email == 0) { email = "user@localhost"; }
    return email;
}

# Copy `len` bytes of message into dst, replacing any control byte
# (< 0x20 or 0x7f) with a space so the entry stays a single line and
# can't forge extra reflog records. Returns bytes written (== len).
fn _reflog_san_into(dst, src, len) {
    var i = 0;
    var o = 0;
    while (i < len) {
        var c = load8(src + i) & 0xFF;
        var bad = 0;
        if (c < 32) { bad = 1; }
        if (c == 127) { bad = 1; }
        if (bad == 1) { store8(dst + o, 32); }
        else { store8(dst + o, c); }
        o = o + 1;
        i = i + 1;
    }
    return o;
}

# Format one reflog line into buf. old_hex == 0 → 64 zeros (creation).
# new_hex must be a 64-char hex cstring. Returns the line length.
# buf must be sized >= 200 + strlen(name) + strlen(email) + strlen(msg).
fn reflog_format_line(buf, old_hex, new_hex, name, email, ts, msg) {
    var pos = 0;
    if (old_hex == 0) {
        var z = 0;
        while (z < 64) { store8(buf + pos, 48); pos = pos + 1; z = z + 1; }
    } else {
        memcpy(buf + pos, old_hex, 64); pos = pos + 64;
    }
    store8(buf + pos, 32); pos = pos + 1;

    memcpy(buf + pos, new_hex, 64); pos = pos + 64;
    store8(buf + pos, 32); pos = pos + 1;

    # Identity is sanitized exactly like the message: a control byte (LF/TAB/
    # …) in SIT_AUTHOR_NAME/EMAIL or a hand-edited config must NOT be able to
    # forge or shift a reflog line. _reflog_san_into preserves length.
    var nl = _reflog_san_into(buf + pos, name, strlen(name)); pos = pos + nl;
    memcpy(buf + pos, " <", 2); pos = pos + 2;
    var el = _reflog_san_into(buf + pos, email, strlen(email)); pos = pos + el;
    memcpy(buf + pos, "> ", 2); pos = pos + 2;

    var d = write_decimal(buf + pos, ts); pos = pos + d;
    memcpy(buf + pos, " +0000", 6); pos = pos + 6;

    store8(buf + pos, 9); pos = pos + 1;            # TAB before message
    var ml = _reflog_san_into(buf + pos, msg, strlen(msg)); pos = pos + ml;
    store8(buf + pos, 10); pos = pos + 1;           # LF terminator
    return pos;
}

# ── Reflog message builders ──────────────

# "<prefix><first line of message>" as a heap cstring for a reflog entry.
# The subject stops at the first LF; reflog_append later sanitizes any
# remaining control bytes. Used for commit/reset entries.
fn reflog_msg_subject(prefix, message) {
    var pl = strlen(prefix);
    var sl = 0;
    var scanning = 1;
    while (scanning == 1) {
        var c = load8(message + sl);
        if (c == 0) { scanning = 0; }
        else {
            if (c == 10) { scanning = 0; }
            else { sl = sl + 1; }
        }
    }
    var out = alloc(pl + sl + 1);
    memcpy(out, prefix, pl);
    memcpy(out + pl, message, sl);
    store8(out + pl + sl, 0);
    return out;
}

# "<a><b><c>" as a heap cstring — e.g. ("merge ", name, ": Fast-forward").
fn reflog_msg_join(a, b, c) {
    var al = strlen(a);
    var bl = strlen(b);
    var cl = strlen(c);
    var out = alloc(al + bl + cl + 1);
    memcpy(out, a, al);
    memcpy(out + al, b, bl);
    memcpy(out + al + bl, c, cl);
    store8(out + al + bl + cl, 0);
    return out;
}

# ── Pure indexing core (LF-terminated, append-only log buffers) ────────

# Count entries (LF-terminated lines) in a log buffer.
fn _reflog_count_in_buf(buf, len) {
    var i = 0;
    var c = 0;
    while (i < len) {
        if (load8(buf + i) == 10) { c = c + 1; }
        i = i + 1;
    }
    return c;
}

# Byte offset where line `idx` (0-based) starts, or -1 if absent.
fn _reflog_line_start(buf, len, idx) {
    if (idx == 0) { return 0; }
    var i = 0;
    var seen = 0;
    var found = 0 - 1;
    var scanning = 1;
    while (scanning == 1) {
        if (i >= len) { scanning = 0; }
        else {
            if (load8(buf + i) == 10) {
                seen = seen + 1;
                if (seen == idx) { found = i + 1; scanning = 0; }
            }
            i = i + 1;
        }
    }
    return found;
}

# Resolve <ref>@{n} within a log buffer: write the new-oid (field 2) of the
# entry n moves ago into out (65 bytes, nul-terminated). n == 0 is the last
# (current) entry. Returns 1 on success, 0 if n is out of range or the
# target line is malformed. Never reads past `len`.
fn _reflog_nth_in_buf(buf, len, n, out) {
    if (n < 0) { return 0; }
    var c = _reflog_count_in_buf(buf, len);
    if (n >= c) { return 0; }
    var target = c - 1 - n;
    var s = _reflog_line_start(buf, len, target);
    if (s < 0) { return 0; }
    # Layout: old(64) SP new(64) SP ... — need new-oid at [s+65, s+129).
    if (s + 129 > len) { return 0; }
    if (load8(buf + s + 64) != 32) { return 0; }
    if (hex_prefix_valid(buf + s + 65, 64) == 0) { return 0; }
    memcpy(out, buf + s + 65, 64);
    store8(out + 64, 0);
    return 1;
}

# Message field of one line (everything after the first TAB, up to LF).
# Writes {ptr, len} into out_pair (16 bytes). Returns 1 if a TAB was found,
# else 0 (ptr/len zeroed). Used by cmd_reflog rendering.
fn _reflog_line_msg(line, len, out_pair) {
    var i = 0;
    var tab = 0 - 1;
    var scanning = 1;
    while (scanning == 1) {
        if (i >= len) { scanning = 0; }
        else {
            var c = load8(line + i);
            if (c == 9) { tab = i; scanning = 0; }
            else {
                if (c == 10) { scanning = 0; }
                else { i = i + 1; }
            }
        }
    }
    if (tab < 0) { store64(out_pair, 0); store64(out_pair + 8, 0); return 0; }
    var mstart = tab + 1;
    var mend = mstart;
    var scan2 = 1;
    while (scan2 == 1) {
        if (mend >= len) { scan2 = 0; }
        else {
            if (load8(line + mend) == 10) { scan2 = 0; }
            else { mend = mend + 1; }
        }
    }
    store64(out_pair, line + mstart);
    store64(out_pair + 8, mend - mstart);
    return 1;
}

# Parse a "<base>@{<N>}" ordinal selector. On success writes the base ref
# into out (24 bytes: [0]=ptr into `name`, [8]=base byte-length, [16]=N)
# and returns 1. Returns 0 if the string isn't a well-formed @{N} selector:
# no "@{", empty base, no closing "}", a non-digit / empty index, or junk
# after the "}". Only the bare-integer ordinal form is accepted (the
# @{<date>} time form is intentionally unsupported in 1.1.0). Pure — no I/O.
fn _reflog_spec_parse(name, out) {
    var nlen = strlen(name);
    var at = 0 - 1;
    var i = 0;
    var scanning = 1;
    while (scanning == 1) {
        if (i + 1 >= nlen) { scanning = 0; }
        else {
            if (load8(name + i) == 64) {
                if (load8(name + i + 1) == 123) { at = i; scanning = 0; }
                else { i = i + 1; }
            } else { i = i + 1; }
        }
    }
    if (at <= 0) { return 0; }                 # no "@{" or empty base
    var j = at + 2;
    var num = 0;
    var ndig = 0;
    var ok = 1;
    var parsing = 1;
    while (parsing == 1) {
        if (j >= nlen) { ok = 0; parsing = 0; }
        else {
            var c = load8(name + j);
            if (c == 125) { parsing = 0; }     # '}'
            else {
                if (c < 48) { ok = 0; parsing = 0; }
                else {
                    if (c > 57) { ok = 0; parsing = 0; }
                    else { num = num * 10 + (c - 48); ndig = ndig + 1; j = j + 1; }
                }
            }
        }
    }
    if (ok == 0) { return 0; }
    if (ndig == 0) { return 0; }               # "@{}" rejected
    if (j != nlen - 1) { return 0; }           # "}" must be the final byte
    store64(out, name);
    store64(out + 8, at);
    store64(out + 16, num);
    return 1;
}

# Push a 64-hex oid at `p` into the `roots` vec as a fresh 65-byte cstring,
# unless it's invalid hex or the all-zeros creation sentinel. Used by fsck
# to treat reflog entries as reachability roots (prune grace).
fn _reflog_push_oid_if_valid(p, roots) {
    if (hex_prefix_valid(p, 64) == 0) { return 0; }
    var allzero = 1;
    var k = 0;
    while (k < 64) {
        if (load8(p + k) != 48) { allzero = 0; k = 64; }
        else { k = k + 1; }
    }
    if (allzero == 1) { return 0; }
    var hex = alloc(65);
    memcpy(hex, p, 64);
    store8(hex + 64, 0);
    vec_push(roots, hex);
    return 0;
}

# Collect every old+new oid from a reflog buffer into `roots` (skipping the
# all-zeros creation sentinel). Pure parse over one log file's bytes.
fn _reflog_collect_oids(buf, len, roots) {
    var count = _reflog_count_in_buf(buf, len);
    var d = 0;
    while (d < count) {
        var s = _reflog_line_start(buf, len, d);
        if (s >= 0) {
            if (s + 129 <= len) {
                if (load8(buf + s + 64) == 32) {
                    _reflog_push_oid_if_valid(buf + s, roots);        # old
                    _reflog_push_oid_if_valid(buf + s + 65, roots);   # new
                }
            }
        }
        d = d + 1;
    }
    return 0;
}

# ── File wrappers ──────────────

# ".sit/logs/<refpath>" as a heap cstring. refpath is e.g. "HEAD" or
# "refs/heads/main" or "refs/remotes/origin/main".
fn reflog_log_path(refpath) {
    var rl = strlen(refpath);
    var p = alloc(10 + rl + 1);
    memcpy(p, ".sit/logs/", 10);
    memcpy(p + 10, refpath, rl);
    store8(p + 10 + rl, 0);
    return p;
}

# Append one entry to .sit/logs/<refpath> with caller-supplied identity +
# timestamp. old_hex == 0 → creation (zeros). Returns 0 on success, -1 on
# failure. Best-effort: callers log AFTER the ref moves, so a failed append
# never blocks the operation. reflog_head_move uses this to stamp the HEAD
# log and the branch log with ONE identical (ts, name, email) per move.
fn _reflog_append_full(refpath, old_hex, new_hex, msg, name, email, ts) {
    if (new_hex == 0) { return 0 - 1; }
    var cap = 200 + strlen(name) + strlen(email) + strlen(msg);
    var buf = alloc(cap);
    var llen = reflog_format_line(buf, old_hex, new_hex, name, email, ts, msg);
    var path = reflog_log_path(refpath);
    ensure_parent_dirs(path);
    if (sf_append_locked(path, buf, llen) < 0) { return 0 - 1; }
    return 0;
}

# Append one entry, resolving identity + timestamp now. Single-ref convenience
# wrapper around _reflog_append_full (branch-create, fetch remote-tracking).
fn reflog_append(refpath, old_hex, new_hex, msg) {
    return _reflog_append_full(refpath, old_hex, new_hex, msg,
        _reflog_user_name(), _reflog_user_email(), clock_epoch_secs());
}

# Resolve <ref>@{n}: read .sit/logs/<refpath>, write the new-oid of entry n
# into out (65 bytes). Returns 1 on success, 0 if no log / out of range.
fn reflog_read_nth(refpath, n, out) {
    var path = reflog_log_path(refpath);
    var pair[16];
    if (read_file_heap(path, &pair) != 0) { return 0; }
    var buf = load64(&pair);
    var len = load64(&pair + 8);
    return _reflog_nth_in_buf(buf, len, n, out);
}

# ── `sit reflog` command ───────

# Map a user-facing ref label to its log refpath under .sit/logs/. HEAD →
# "HEAD"; otherwise prefer an existing logs/refs/heads/<label>, then
# logs/refs/remotes/<label>; default to refs/heads/<label> (yields no
# entries if absent). Tags are never logged, so no tags branch.
fn _reflog_log_refpath_for(label) {
    if (streq(label, "HEAD") == 1) { return "HEAD"; }
    var ll = strlen(label);
    var hp = alloc(11 + ll + 1);
    memcpy(hp, "refs/heads/", 11);
    memcpy(hp + 11, label, ll);
    store8(hp + 11 + ll, 0);
    if (sf_exists(reflog_log_path(hp)) == 1) { return hp; }
    var rp = alloc(13 + ll + 1);
    memcpy(rp, "refs/remotes/", 13);
    memcpy(rp + 13, label, ll);
    store8(rp + 13 + ll, 0);
    if (sf_exists(reflog_log_path(rp)) == 1) { return rp; }
    return hp;
}

# sit reflog [-n <count>] [<ref>]
# Print a ref's movement history newest-first, git-shaped:
#   <short-new-oid> <ref>@{N}: <message>
# Defaults to HEAD. Silent (exit 0) when the ref has no log yet.
fn cmd_reflog() {
    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    var ref_label = "HEAD";
    var refpath = "HEAD";
    var limit = 0 - 1;                # -1 = no limit
    var ai = 2;
    while (ai < argc()) {
        var a = argv(ai);
        if (streq(a, "-n") == 1) {
            if (ai + 1 < argc()) { limit = atoi(argv(ai + 1)); ai = ai + 1; }
        } else {
            ref_label = argv_heap(ai);
            # S-02: the label becomes a .sit/logs/ path component; reject
            # traversal ('..', leading '/') and control chars. "HEAD" is the
            # one literal that isn't a refname_valid ref.
            if (streq(ref_label, "HEAD") == 0) {
                if (refname_valid(ref_label) == 0) {
                    eprintln("sit: invalid ref name");
                    return 1;
                }
            }
            refpath = _reflog_log_refpath_for(ref_label);
        }
        ai = ai + 1;
    }

    var path = reflog_log_path(refpath);
    var pair[16];
    if (read_file_heap(path, &pair) != 0) { return 0; }
    var buf = load64(&pair);
    var len = load64(&pair + 8);
    var count = _reflog_count_in_buf(buf, len);
    if (count == 0) { return 0; }

    var label_len = strlen(ref_label);
    var shown = 0;
    var d = 0;
    while (d < count) {
        var stop = 0;
        if (limit >= 0) { if (shown >= limit) { stop = 1; } }
        if (stop == 1) { d = count; }       # terminate (no break with vars)
        else {
            var s = _reflog_line_start(buf, len, count - 1 - d);
            if (s >= 0) {
                if (s + 77 <= len) {
                    # Display sanitization: .sit/logs is on-disk data that
                    # could be corrupt or hand-crafted, so scrub control bytes
                    # (terminal-escape injection) out of the echoed oid + msg
                    # before they hit the terminal. Sanitize into a buffer so
                    # the buffered stdout ordering is preserved (S-21 class).
                    var oidbuf[16];
                    _reflog_san_into(&oidbuf, buf + s + 65, 12);
                    stdout_write(&oidbuf, 12);          # short new-oid
                    stdout_write(" ", 1);
                    stdout_write(ref_label, label_len);
                    stdout_write("@{", 2);
                    var nb[24];
                    var nd = write_decimal(&nb, d);
                    stdout_write(&nb, nd);
                    stdout_write("}: ", 3);
                    var mp[16];
                    if (_reflog_line_msg(buf + s, len - s, &mp) == 1) {
                        var mlen = load64(&mp + 8);
                        var sanmsg = alloc(mlen + 1);
                        _reflog_san_into(sanmsg, load64(&mp), mlen);
                        stdout_write(sanmsg, mlen);
                    }
                    stdout_write("\n", 1);
                    shown = shown + 1;
                }
            }
            d = d + 1;
        }
    }
    stdout_flush();
    return 0;
}

# --- git_read.cyr ---

# git_read.cyr — read-only .git/ backend (roadmap 1.2.0).
#
# Reads an EXISTING git repository (SHA-1 default / SHA-256, loose objects +
# refs; packfiles land in bite 2) through the same readers sit uses for its
# native .sit/ store. Strictly read-only: .git/ is consumed, never mutated —
# sit stays .sit/-native for its own repos. See ADR 0011.
#
# STORAGE SEAM: sit_repo_open() calls _detect_repo_backend() to set the
# process-global `_repo_backend`; the three storage-touching primitives
# (read_object / read_head_ref / resolve_ref_name) dispatch on it. Every layer
# above them (tree walk, diff, status, log) stays storage-agnostic. The only
# format divergence a caller could see is object-id WIDTH — handled centrally
# by _id_hexlen() / _id_rawlen() so the 64-hex / 32-raw literals scattered
# across the read path collapse to two helpers.
#
# One-repo-per-process contract (api.cyr:26-30): the backend is a global, not a
# per-handle field, matching the existing "sit_repo_open chdirs the process"
# model. A future multi-handle API would move these onto a repo struct.

# --- Backend state -----------------------------------------------------------
# _repo_backend: 0 = SIT (.sit/, patra, SHA-256), 1 = GIT (.git/, loose+pack).
# Default 0 so every pre-1.2.0 code path is byte-identical until a .git/ repo
# is opened.
var _repo_backend = 0;
# _git_hash_algo (GIT mode only): 0 = SHA-1 (git default), 1 = SHA-256.
var _git_hash_algo = 0;

# --- Active-backend object-id widths ----------------------------------------
# SIT is always SHA-256 (32 raw / 64 hex). GIT is SHA-1 (20/40) unless the repo
# declares extensions.objectFormat = sha256 (32/64). These two helpers replace
# every hardcoded 64 / 32 in the read path.
fn _id_hexlen() {
    if (_repo_backend == 1) {
        if (_git_hash_algo == 1) { return 64; }
        return 40;
    }
    return 64;
}
fn _id_rawlen() {
    if (_repo_backend == 1) {
        if (_git_hash_algo == 1) { return 32; }
        return 20;
    }
    return 32;
}

# --- .git/config hash-algo detection ----------------------------------------
# SHA-256 git repos carry `[extensions]\n\tobjectFormat = sha256` (and
# repositoryFormatVersion = 1). A whole-file substring scan for "sha256" is
# sufficient — the token appears nowhere else in a normal config. Best-effort:
# an unreadable config falls back to SHA-1 (git's default), which is correct
# for the overwhelming majority of repos.
fn _git_detect_hash_algo() {
    var pair[16];
    if (read_file_heap(".git/config", &pair) != 0) { return 0; }
    var buf = load64(&pair);
    var len = load64(&pair + 8);
    var i = 0;
    var found = 0;
    while (i + 6 <= len) {
        if (found == 0) {
            if (memeq(buf + i, "sha256", 6) == 1) { found = 1; }
        }
        i = i + 1;
    }
    return found;
}

# --- Loose-object path -------------------------------------------------------
# .git/objects/<xx>/<rest> — the id split mirrors object_path()'s .sit layout,
# but the tail is _id_hexlen()-2 chars (38 for SHA-1, 62 for SHA-256) instead
# of a fixed 62. `buf` must hold at least 13 + 2 + 1 + 62 + 1 = 79 bytes.
fn _git_object_path(buf, hex) {
    memcpy(buf, ".git/objects/", 13);
    store8(buf + 13, load8(hex));
    store8(buf + 14, load8(hex + 1));
    store8(buf + 15, 47);
    var rest = _id_hexlen() - 2;
    memcpy(buf + 16, hex + 2, rest);
    store8(buf + 16 + rest, 0);
    return 16 + rest;
}

# --- Loose-object read -------------------------------------------------------
# Reads .git/objects/<xx>/<rest>, zlib-inflates the whole file (git loose
# objects are one RFC-1950 zlib stream of "<type> <len>\0<content>"), and
# writes read_object()'s exact 24-byte out contract:
#   out[0]  = decompressed buffer pointer
#   out[8]  = decompressed length (framing + content)
#   out[16] = content offset (first byte past the framing NUL)
# so every downstream reader (parse_tree, read_blob_content, commit parse) is
# reused unchanged. Decompression sizing + 16 MiB ceiling + retry-on-
# BUFFER_TOO_SMALL mirror read_object() so failure modes line up.
# Returns 0 on success, negative on error.
fn _git_read_loose(hex, out) {
    var path[96];
    _git_object_path(&path, hex);

    var pair[16];
    if (read_file_heap(&path, &pair) != 0) { return 0 - 1; }
    var compressed = load64(&pair);
    var blen = load64(&pair + 8);
    if (blen <= 0) { return 0 - 2; }

    var dec_cap = blen * 4;
    if (dec_cap < 4096) { dec_cap = 4096; }
    if (dec_cap > 16 * 1024 * 1024) { dec_cap = 16 * 1024 * 1024; }
    var decompressed = alloc_or_die(dec_cap);
    if (decompressed == 0) { return 0 - 3; }
    var dlen = zlib_decompress(compressed, blen, decompressed, dec_cap);
    if (dlen == 0 - ERR_BUFFER_TOO_SMALL) {
        if (dec_cap < 16 * 1024 * 1024) {
            dec_cap = 16 * 1024 * 1024;
            decompressed = alloc_or_die(dec_cap);
            if (decompressed == 0) { return 0 - 3; }
            dlen = zlib_decompress(compressed, blen, decompressed, dec_cap);
        }
    }
    if (dlen <= 0) { return 0 - 4; }

    var nul = 0;
    while (nul < dlen) {
        if (load8(decompressed + nul) == 0) { break; }
        nul = nul + 1;
    }
    if (nul >= dlen) { return 0 - 5; }

    store64(out, decompressed);
    store64(out + 8, dlen);
    store64(out + 16, nul + 1);
    return 0;
}

# --- Backend detection -------------------------------------------------------
# Probe order: .sit/ wins over .git/ so a repo that is somehow both stays
# sit-native (sit never writes .git/). Sets the process-globals and returns the
# selected backend id, or -1 if neither store is present.
fn _detect_repo_backend() {
    if (sf_exists(".sit/HEAD") == 1) {
        _repo_backend = 0;
        _git_hash_algo = 0;
        return 0;
    }
    if (sf_exists(".git/HEAD") == 1) {
        _repo_backend = 1;
        _git_hash_algo = _git_detect_hash_algo();
        return 1;
    }
    return 0 - 1;
}

# --- Ref backend -------------------------------------------------------------
# The active store's 5-char directory prefix. ".sit/" and ".git/" are both
# exactly 5 bytes and the ref/HEAD subpaths are length-identical, so only the
# middle three bytes ever differ — read_head_ref_path builds the HEAD path from
# this, and the git-side ref readers below hardcode ".git/".
fn _repo_dir() {
    if (_repo_backend == 1) { return ".git/"; }
    return ".sit/";
}

# The active backend's ignore-file name. load_sitignore reads this so the
# working-tree walk honours .gitignore on a git repo (top-level only for v1 —
# nested .gitignore / info/exclude / global excludes are not consulted).
fn _ignore_filename() {
    if (_repo_backend == 1) { return ".gitignore"; }
    return ".sitignore";
}

# Read a loose ref file .git/<refpath> as a bare OID. Returns a heap cstring of
# _id_hexlen() hex chars (NUL-terminated) or 0 if the file is absent / not hex.
# Simplification: a loose ref that is itself a "ref: <path>" symref (rare
# outside HEAD) is treated as a miss — HEAD is the only symref sit follows.
fn _git_read_loose_ref(refpath) {
    var rp_len = strlen(refpath);
    var full = alloc(5 + rp_len + 1);
    memcpy(full, ".git/", 5);
    memcpy(full + 5, refpath, rp_len);
    store8(full + 5 + rp_len, 0);
    if (sf_exists(full) != 1) { return 0; }
    var fd = sf_open(full, 0, 0);
    if (fd < 0) { return 0; }
    var buf = alloc(96);
    var n = file_read(fd, buf, 96);
    file_close(fd);
    var hexlen = _id_hexlen();
    if (n < hexlen) { return 0; }
    if (hex_prefix_valid(buf, hexlen) == 0) { return 0; }
    store8(buf + hexlen, 0);
    return buf;
}

# Look up a full refname (e.g. "refs/heads/main") in .git/packed-refs. Writes
# _id_hexlen() hex chars + NUL into out_buf and returns 1 on hit, else 0. Lines:
# "<oid> <refname>\n"; '#' header/comment lines and '^' peeled-tag lines are
# skipped (a ref name resolves to its own object, not a tag's peeled target).
fn _git_packed_ref_lookup(refname, out_buf) {
    var pair[16];
    if (read_file_heap(".git/packed-refs", &pair) != 0) { return 0; }
    var buf = load64(&pair);
    var len = load64(&pair + 8);
    var hexlen = _id_hexlen();
    var rn_len = strlen(refname);

    var pos = 0;
    var result = 0;
    while (pos < len) {
        if (result == 0) {
            var eol = pos;
            while (eol < len) {
                if (load8(buf + eol) == 10) { break; }
                eol = eol + 1;
            }
            var line_len = eol - pos;
            var first = load8(buf + pos);
            # A ref line is exactly "<hexlen hex> <refname>": length matches and
            # a space sits at the OID boundary. '#' (35) and '^' (94) are skipped.
            if (first != 35) {
                if (first != 94) {
                    if (line_len == hexlen + 1 + rn_len) {
                        if (load8(buf + pos + hexlen) == 32) {
                            if (hex_prefix_valid(buf + pos, hexlen) == 1) {
                                if (memeq(buf + pos + hexlen + 1, refname, rn_len) == 1) {
                                    memcpy(out_buf, buf + pos, hexlen);
                                    store8(out_buf + hexlen, 0);
                                    result = 1;
                                }
                            }
                        }
                    }
                }
            }
            pos = eol + 1;
        } else {
            pos = len;
        }
    }
    return result;
}

# git-mode read_head_ref: resolve .git/HEAD. Symref → loose ref then packed-refs;
# detached (bare OID in HEAD) → that OID. Returns heap hex cstring or 0.
fn _git_read_head_ref() {
    var ref_path = read_head_ref_path();
    if (ref_path == 0) {
        # Detached HEAD: .git/HEAD holds a bare OID (no "ref: " prefix).
        var pair[16];
        if (read_file_heap(".git/HEAD", &pair) != 0) { return 0; }
        var hb = load64(&pair);
        var hn = load64(&pair + 8);
        var hexlen = _id_hexlen();
        if (hn < hexlen) { return 0; }
        if (hex_prefix_valid(hb, hexlen) == 0) { return 0; }
        var oid = alloc(hexlen + 1);
        memcpy(oid, hb, hexlen);
        store8(oid + hexlen, 0);
        return oid;
    }
    var loose = _git_read_loose_ref(ref_path);
    if (loose != 0) { return loose; }
    var out = alloc(96);
    if (_git_packed_ref_lookup(ref_path, out) == 1) { return out; }
    return 0;
}

# Try a full refname (loose then packed-refs), writing hex+NUL into out_buf.
# Returns 1 on hit, 0 miss.
fn _git_try_full_ref(refname, out_buf) {
    var loose = _git_read_loose_ref(refname);
    if (loose != 0) {
        var hexlen = _id_hexlen();
        memcpy(out_buf, loose, hexlen);
        store8(out_buf + hexlen, 0);
        return 1;
    }
    if (_git_packed_ref_lookup(refname, out_buf) == 1) { return 1; }
    return 0;
}

# git-mode resolve_ref_name: HEAD, then refs/tags|heads|remotes/<name> (loose or
# packed), matching the .sit resolution order. Writes hex+NUL, returns 1/0.
fn _git_resolve_ref_name(name, out_buf) {
    if (streq(name, "HEAD") == 1) {
        var h = read_head_ref();
        if (h == 0) { return 0; }
        var hexlen = _id_hexlen();
        memcpy(out_buf, h, hexlen);
        store8(out_buf + hexlen, 0);
        return 1;
    }

    var name_len = strlen(name);

    var tag_ref = alloc(10 + name_len + 1);
    memcpy(tag_ref, "refs/tags/", 10);
    memcpy(tag_ref + 10, name, name_len);
    store8(tag_ref + 10 + name_len, 0);
    if (_git_try_full_ref(tag_ref, out_buf) == 1) { return 1; }

    var head_ref = alloc(11 + name_len + 1);
    memcpy(head_ref, "refs/heads/", 11);
    memcpy(head_ref + 11, name, name_len);
    store8(head_ref + 11 + name_len, 0);
    if (_git_try_full_ref(head_ref, out_buf) == 1) { return 1; }

    var rem_ref = alloc(13 + name_len + 1);
    memcpy(rem_ref, "refs/remotes/", 13);
    memcpy(rem_ref + 13, name, name_len);
    store8(rem_ref + 13 + name_len, 0);
    if (_git_try_full_ref(rem_ref, out_buf) == 1) { return 1; }

    return 0;
}

# --- git_pack.cyr ---

# git_pack.cyr — read-only git packfile decode (roadmap 1.2.0, bite 2).
#
# Reads objects out of .git/objects/pack/*.{idx,pack}: binary-search the v2
# .idx for an oid -> pack offset, parse the pack v2 object header, inflate
# non-delta objects (sankoch zlib — no new dep), and reconstruct OFS_DELTA /
# REF_DELTA objects via a self-written copy/insert delta interpreter. Byte
# formats per gitformat-pack. Ordered AFTER git_read.cyr (uses _id_hexlen /
# _id_rawlen / _git_read_loose) and BEFORE object_db.cyr (read_object dispatches
# to _git_read_any) so the single-pass dist bundle stays forward-only.
#
# Shifts are written as * / to avoid any dependence on << / >>. All the object
# out-params use read_object's 24-byte contract {content_ptr, content_len,
# content_off}; pack objects carry no loose framing, so content_off is 0.

# One-entry pack-file cache: a sit invocation reads many objects from the same
# pack, so hold the last-loaded pack in memory rather than re-reading per object.
var _pack_cache_path = 0;
var _pack_cache_data = 0;
var _pack_cache_len = 0;

# Delta-chain recursion guard (git's pack.depth default is 50; 64 is slack).
var _pack_delta_depth = 0;

# Reject an absurd object size from a hostile pack header before allocating.
var _PACK_MAX_OBJ = 268435456;   # 256 MiB

# --- big-endian readers ------------------------------------------------------
fn _be32(p) {
    var v = load8(p) & 0xFF;
    v = v * 256 + (load8(p + 1) & 0xFF);
    v = v * 256 + (load8(p + 2) & 0xFF);
    v = v * 256 + (load8(p + 3) & 0xFF);
    return v;
}
fn _be64(p) {
    var v = load8(p) & 0xFF;
    var i = 1;
    while (i < 8) {
        v = v * 256 + (load8(p + i) & 0xFF);
        i = i + 1;
    }
    return v;
}

# Lexicographic compare of n bytes. <0 / 0 / >0 (sign of first differing byte).
fn _memcmp_n(a, b, n) {
    var i = 0;
    var result = 0;
    while (i < n) {
        if (result == 0) {
            var av = load8(a + i) & 0xFF;
            var bv = load8(b + i) & 0xFF;
            if (av != bv) { result = av - bv; }
        }
        i = i + 1;
    }
    return result;
}

# Read one byte at the cursor and advance it.
fn _next_byte(data, curptr) {
    var b = load8(data + load64(curptr)) & 0xFF;
    store64(curptr, load64(curptr) + 1);
    return b;
}

# --- .idx v2 lookup ----------------------------------------------------------
# Binary-search idx_path (v2) for oid_raw (rawlen bytes) -> pack byte offset.
# Returns the offset (>= 12) on hit, or -1 (miss / unreadable / v1 idx / bad
# magic). rawlen is 20 (SHA-1) or 32 (SHA-256).
fn _git_idx_lookup(idx_path, oid_raw, rawlen) {
    var pr[16];
    if (read_file_heap(idx_path, &pr) != 0) { return 0 - 1; }
    var d = load64(&pr);
    var len = load64(&pr + 8);
    if (len < 1032) { return 0 - 1; }
    # magic 0xFF 't' 'O' 'c'; absence => v1 idx (unsupported here).
    if ((load8(d) & 0xFF) != 255) { return 0 - 1; }
    if ((load8(d + 1) & 0xFF) != 116) { return 0 - 1; }
    if ((load8(d + 2) & 0xFF) != 79) { return 0 - 1; }
    if ((load8(d + 3) & 0xFF) != 99) { return 0 - 1; }
    if (_be32(d + 4) != 2) { return 0 - 1; }

    var fanout = d + 8;
    var N = _be32(fanout + 255 * 4);
    var b0 = load8(oid_raw) & 0xFF;
    var lo = 0;
    if (b0 != 0) { lo = _be32(fanout + (b0 - 1) * 4); }
    var hi = _be32(fanout + b0 * 4);
    var oid_table = d + 1032;

    var mid = 0;
    var found = 0 - 1;
    while (lo < hi) {
        if (found < 0) {
            mid = (lo + hi) / 2;
            var cmp = _memcmp_n(oid_table + mid * rawlen, oid_raw, rawlen);
            if (cmp == 0) { found = mid; lo = hi; }
            else {
                if (cmp < 0) { lo = mid + 1; }
                else { hi = mid; }
            }
        }
        else { lo = hi; }
    }
    if (found < 0) { return 0 - 1; }

    var off_table = oid_table + N * rawlen + N * 4;   # skip oids + CRCs
    var off32 = _be32(off_table + found * 4);
    if ((off32 & 2147483648) == 0) { return off32; }
    var large_table = off_table + N * 4;
    var idx2 = off32 & 2147483647;
    return _be64(large_table + idx2 * 8);
}

# --- pack load (cached) ------------------------------------------------------
fn _git_load_pack(path, out_pair) {
    if (_pack_cache_path != 0) {
        if (streq(_pack_cache_path, path) == 1) {
            store64(out_pair, _pack_cache_data);
            store64(out_pair + 8, _pack_cache_len);
            return 0;
        }
    }
    var pr[16];
    if (read_file_heap(path, &pr) != 0) { return 0 - 1; }
    _pack_cache_data = load64(&pr);
    _pack_cache_len = load64(&pr + 8);
    var pl = strlen(path);
    var pc = alloc(pl + 1);
    memcpy(pc, path, pl);
    store8(pc + pl, 0);
    _pack_cache_path = pc;
    store64(out_pair, _pack_cache_data);
    store64(out_pair + 8, _pack_cache_len);
    return 0;
}

# --- varint decoders (cursor is an i64 slot, advanced in place) --------------
# Pack object header: byte0 = [cont|3-bit type|4-bit size-low]; continuation
# bytes add 7 bits each (little-endian). Writes type to out_type, returns size.
fn _pack_obj_header(data, curptr, out_type) {
    var c = load8(data + load64(curptr)) & 0xFF;
    store64(curptr, load64(curptr) + 1);
    var type = (c / 16) & 7;
    var size = c & 0x0F;
    var mult = 16;
    var cont = c & 0x80;
    while (cont != 0) {
        var b = load8(data + load64(curptr)) & 0xFF;
        store64(curptr, load64(curptr) + 1);
        size = size + (b & 0x7F) * mult;
        mult = mult * 128;
        cont = b & 0x80;
    }
    store64(out_type, type);
    return size;
}

# OFS_DELTA base-offset varint (the ((ofs+1)<<7)|next biased big-endian scheme).
fn _ofs_varint(data, curptr) {
    var b = load8(data + load64(curptr)) & 0xFF;
    store64(curptr, load64(curptr) + 1);
    var ofs = b & 0x7F;
    var cont = b & 0x80;
    while (cont != 0) {
        b = load8(data + load64(curptr)) & 0xFF;
        store64(curptr, load64(curptr) + 1);
        ofs = (ofs + 1) * 128 + (b & 0x7F);
        cont = b & 0x80;
    }
    return ofs;
}

# Delta size varint: pure 7-bit little-endian chunks from byte 0.
fn _delta_varint(data, curptr) {
    var val = 0;
    var mult = 1;
    var cont = 1;
    while (cont != 0) {
        var b = load8(data + load64(curptr)) & 0xFF;
        store64(curptr, load64(curptr) + 1);
        val = val + (b & 0x7F) * mult;
        mult = mult * 128;
        cont = b & 0x80;
    }
    return val;
}

# --- delta apply -------------------------------------------------------------
# Reconstruct a target object from base + delta instruction stream. Writes the
# read_object contract into out24 (content_off 0). Returns 0 or negative.
fn _git_apply_delta(base, base_len, delta, delta_len, out24) {
    var cur[8];
    store64(&cur, 0);
    _delta_varint(delta, &cur);              # base-size (unused sanity field)
    var result_size = _delta_varint(delta, &cur);
    if (result_size <= 0) { return 0 - 1; }
    if (result_size > _PACK_MAX_OBJ) { return 0 - 1; }
    var out = alloc(result_size);
    if (out == 0) { return 0 - 2; }
    var op_out = 0;
    var err = 0;
    while (load64(&cur) < delta_len) {
        if (err == 0) {
            var op = load8(delta + load64(&cur)) & 0xFF;
            store64(&cur, load64(&cur) + 1);
            if ((op & 0x80) != 0) {
                var coff = 0;
                var csize = 0;
                if ((op & 0x01) != 0) { coff = coff + _next_byte(delta, &cur); }
                if ((op & 0x02) != 0) { coff = coff + _next_byte(delta, &cur) * 256; }
                if ((op & 0x04) != 0) { coff = coff + _next_byte(delta, &cur) * 65536; }
                if ((op & 0x08) != 0) { coff = coff + _next_byte(delta, &cur) * 16777216; }
                if ((op & 0x10) != 0) { csize = csize + _next_byte(delta, &cur); }
                if ((op & 0x20) != 0) { csize = csize + _next_byte(delta, &cur) * 256; }
                if ((op & 0x40) != 0) { csize = csize + _next_byte(delta, &cur) * 65536; }
                if (csize == 0) { csize = 65536; }
                if (coff + csize > base_len) { err = 0 - 3; }
                else {
                    if (op_out + csize > result_size) { err = 0 - 4; }
                    else {
                        memcpy(out + op_out, base + coff, csize);
                        op_out = op_out + csize;
                    }
                }
            }
            else {
                if (op != 0) {
                    var lit = op & 0x7F;
                    if (op_out + lit > result_size) { err = 0 - 5; }
                    else {
                        memcpy(out + op_out, delta + load64(&cur), lit);
                        store64(&cur, load64(&cur) + lit);
                        op_out = op_out + lit;
                    }
                }
                else { err = 0 - 6; }
            }
        }
        else { store64(&cur, delta_len); }
    }
    if (err != 0) { return err; }
    if (op_out != result_size) { return 0 - 7; }
    store64(out24, out);
    store64(out24 + 8, result_size);
    store64(out24 + 16, 0);
    return 0;
}

# --- pack object reconstruct (recursive for deltas) --------------------------
# Reconstruct the object at `offset` in the in-memory pack {pdata,plen}. Writes
# read_object contract into out24 (content_off 0). Recurses through delta bases.
fn _git_pack_obj(pdata, plen, offset, out24) {
    var cur[8];
    store64(&cur, offset);
    var type_slot[8];
    var size = _pack_obj_header(pdata, &cur, &type_slot);
    var type = load64(&type_slot);
    if (size > _PACK_MAX_OBJ) { return 0 - 10; }

    if (type >= 1) {
        if (type <= 4) {
            var body = load64(&cur);
            var content = alloc(size + 16);
            if (content == 0) { return 0 - 11; }
            var got = zlib_decompress(pdata + body, plen - body, content, size + 16);
            if (got <= 0) { return 0 - 12; }
            store64(out24, content);
            store64(out24 + 8, got);
            store64(out24 + 16, 0);
            return 0;
        }
    }

    if (_pack_delta_depth >= 64) { return 0 - 13; }

    if (type == 6) {
        var ofs = _ofs_varint(pdata, &cur);
        var base_off = offset - ofs;
        if (base_off < 0) { return 0 - 14; }
        var base24[24];
        _pack_delta_depth = _pack_delta_depth + 1;
        var br = _git_pack_obj(pdata, plen, base_off, &base24);
        _pack_delta_depth = _pack_delta_depth - 1;
        if (br != 0) { return 0 - 15; }
        var dbody = load64(&cur);
        var delta = alloc(size + 16);
        if (delta == 0) { return 0 - 16; }
        var dgot = zlib_decompress(pdata + dbody, plen - dbody, delta, size + 16);
        if (dgot <= 0) { return 0 - 17; }
        return _git_apply_delta(load64(&base24), load64(&base24 + 8), delta, dgot, out24);
    }

    if (type == 7) {
        var rawlen = _id_rawlen();
        var base_hex = hex_encode(pdata + load64(&cur), rawlen);
        store64(&cur, load64(&cur) + rawlen);
        var base24[24];
        _pack_delta_depth = _pack_delta_depth + 1;
        var br = _git_read_any(base_hex, &base24);
        _pack_delta_depth = _pack_delta_depth - 1;
        if (br != 0) { return 0 - 18; }
        # normalize base to raw content (loose base carries framing at +16)
        var bbuf = load64(&base24) + load64(&base24 + 16);
        var blen = load64(&base24 + 8) - load64(&base24 + 16);
        var dbody = load64(&cur);
        var delta = alloc(size + 16);
        if (delta == 0) { return 0 - 19; }
        var dgot = zlib_decompress(pdata + dbody, plen - dbody, delta, size + 16);
        if (dgot <= 0) { return 0 - 20; }
        return _git_apply_delta(bbuf, blen, delta, dgot, out24);
    }

    return 0 - 21;
}

# --- top-level packfile read -------------------------------------------------
# Look up `hex` across every .git/objects/pack/*.idx; on a hit, reconstruct the
# object from the matching .pack. Writes read_object contract to out24. Returns
# 0 on success, negative if not found in any pack (or no pack dir).
fn _git_read_pack(hex, out24) {
    var packdir = ".git/objects/pack";
    if (is_dir(str_from(packdir)) != 1) { return 0 - 1; }
    var entries = sf_dir_list(str_from(packdir));
    if (entries == 0) { return 0 - 1; }
    var n = vec_len(entries);
    var rawlen = _id_rawlen();
    var oid_raw[32];
    if (hex_decode_into(hex, _id_hexlen(), &oid_raw) == 0) { return 0 - 2; }
    var dlen = strlen(packdir);

    var i = 0;
    var rc = 0 - 3;
    var done = 0;
    while (i < n) {
        if (done == 0) {
            var s = vec_get(entries, i);
            var sd = str_data(s);
            var sl = str_len(s);
            if (sl > 4) {
                if (memeq(sd + sl - 4, ".idx", 4) == 1) {
                    var ipath = alloc(dlen + 1 + sl + 1);
                    memcpy(ipath, packdir, dlen);
                    store8(ipath + dlen, 47);
                    memcpy(ipath + dlen + 1, sd, sl);
                    store8(ipath + dlen + 1 + sl, 0);
                    var offset = _git_idx_lookup(ipath, &oid_raw, rawlen);
                    if (offset >= 0) {
                        var nb = sl - 4;   # name minus ".idx"
                        var ppath = alloc(dlen + 1 + nb + 5 + 1);
                        memcpy(ppath, packdir, dlen);
                        store8(ppath + dlen, 47);
                        memcpy(ppath + dlen + 1, sd, nb);
                        memcpy(ppath + dlen + 1 + nb, ".pack", 5);
                        store8(ppath + dlen + 1 + nb + 5, 0);
                        var pkp[16];
                        if (_git_load_pack(ppath, &pkp) == 0) {
                            rc = _git_pack_obj(load64(&pkp), load64(&pkp + 8), offset, out24);
                            done = 1;
                        }
                    }
                }
            }
        }
        i = i + 1;
    }
    return rc;
}

# Loose-first, then packfile: the git-mode object read used by read_object and
# by REF_DELTA base resolution. On-disk (non-thin) packs are self-contained, so
# a REF_DELTA base is always present as loose or in some pack.
fn _git_read_any(hex, out24) {
    if (_git_read_loose(hex, out24) == 0) { return 0; }
    return _git_read_pack(hex, out24);
}

# --- object_db.cyr ---

# object_db.cyr — patra object store, compression / framing, read commands.
#
# Content-addressed via sigil SHA-256 over the git-SHA-256-compatible framing
# "<type> <len>\0<content>". Zlib compression via sankoch. Objects live in
# .sit/objects.patra (`objects(hash STR, ty INT, content BYTES)`). Legacy
# loose-file layout auto-migrates on first access. Read verbs: cat-file,
# owl-file, fsck. Also the blob-hash primitives used by add + status.

fn object_path(buf, hex) {
    memcpy(buf, ".sit/objects/", 13);
    store8(buf + 13, load8(hex));
    store8(buf + 14, load8(hex + 1));
    store8(buf + 15, 47);
    memcpy(buf + 16, hex + 2, 62);
    store8(buf + 78, 0);
    return 78;
}

# Try to resolve `name` as a ref: HEAD, refs/tags/<name>, or refs/heads/<name>
# in that order. On success, writes the 64-char hash into out_buf and returns 1.
# Returns 0 if no ref matches.
fn resolve_hash(prefix, out_buf) {
    var plen = strlen(prefix);
    var hexlen = _id_hexlen();
    if (plen == hexlen) {
        # S-01: a full-length hash must still be hex — otherwise the
        # short-circuit here would pass garbage bytes straight through.
        if (hex_prefix_valid(prefix, hexlen) == 0) { return 0; }
        memcpy(out_buf, prefix, hexlen);
        store8(out_buf + hexlen, 0);
        return 1;
    }

    # Try as a ref name first (HEAD, tags, branches)
    if (resolve_ref_name(prefix, out_buf) == 1) { return 1; }

    # git mode (roadmap 1.2.0): objects live on the loose/pack filesystem, not
    # patra. Short-prefix disambiguation over loose fanout + pack .idx is a later
    # enhancement — a git object must be named by full oid or a ref for now.
    if (_repo_backend == 1) { return 0; }

    if (plen < 4) { return 0 - 2; }

    # S-01: reject any non-hex character before interpolating into LIKE.
    # Without this, a prefix containing `'` would break / inject the SQL.
    if (hex_prefix_valid(prefix, plen) == 0) { return 0; }

    var db = get_object_db();
    if (db == 0) { return 0; }

    # S-24: SQL strings on the freelist instead of bump heap so they don't
    # accumulate per-call.
    var sql = fl_alloc(64 + plen);
    memcpy(sql, "SELECT hash FROM objects WHERE hash LIKE '", 42);
    memcpy(sql + 42, prefix, plen);
    memcpy(sql + 42 + plen, "%'", 2);
    store8(sql + 42 + plen + 2, 0);

    var rs = patra_query(db, sql);
    fl_free(sql);
    if (rs == 0) { return 0; }
    var count = patra_result_count(rs);
    var ret = 0;
    if (count == 1) {
        var hash_str = patra_result_get_str(rs, 0, 0);
        memcpy(out_buf, hash_str, 64);
        store8(out_buf + 64, 0);
        ret = 1;
    }
    else {
        if (count > 1) { ret = 0 - 1; }
    }
    patra_result_free(rs);
    return ret;
}

# Read and decompress an object by full 64-char hex hash.
# On success, writes to out (24 bytes):
#   out[0..8)    decompressed buffer ptr
#   out[8..16)   decompressed length (framing + content)
#   out[16..24)  content offset (first byte past framing \0)
# Returns 0 on success, negative on error.
fn read_object(hex, out) {
    # Storage seam (roadmap 1.2.0): a .git/ repo has no patra store — objects
    # are loose files or packed. _git_read_any tries loose then every packfile.
    # Dispatch on the backend set by sit_repo_open's _detect_repo_backend.
    # SIT mode (default) is unchanged.
    if (_repo_backend == 1) {
        return _git_read_any(hex, out);
    }

    var db = get_object_db();
    if (db == 0) { return 0 - 1; }

    # S-24: SQL string via fl_alloc + fl_free; freed before any non-trivial
    # work below so we don't hold both the buffer and the result-set.
    var sql = fl_alloc(128);
    memcpy(sql, "SELECT content FROM objects WHERE hash = '", 42);
    memcpy(sql + 42, hex, 64);
    memcpy(sql + 42 + 64, "'", 1);
    store8(sql + 42 + 64 + 1, 0);

    var rs = patra_query(db, sql);
    fl_free(sql);
    if (rs == 0) { return 0 - 2; }
    if (patra_result_count(rs) == 0) {
        patra_result_free(rs);
        return 0 - 3;
    }

    var blen = patra_result_get_bytes_len(rs, 0, 0);
    if (blen <= 0) {
        patra_result_free(rs);
        return 0 - 4;
    }

    var compressed = alloc_or_die(blen);
    if (patra_result_read_bytes(db, rs, 0, 0, compressed) != 0) {
        patra_result_free(rs);
        return 0 - 5;
    }
    patra_result_free(rs);

    # S-08 + P-06: multiplier history is 256× (pre-audit) → 16× (S-08, v0.6.0)
    # → 4× (P-06, v0.6.9). 4× covers the typical sit object (commits, trees,
    # source code blobs all sit at ratio ~2-3); legitimately high-ratio
    # outliers retry at the 16 MiB ceiling. Critically, retry only on a
    # confirmed -ERR_BUFFER_TOO_SMALL (-2) — other negative codes mean the
    # stream is actually corrupt and more memory won't help. Fail fast.
    var dec_cap = blen * 4;
    if (dec_cap < 4096) { dec_cap = 4096; }
    if (dec_cap > 16 * 1024 * 1024) { dec_cap = 16 * 1024 * 1024; }
    var decompressed = alloc_or_die(dec_cap);
    if (decompressed == 0) { return 0 - 6; }
    var dlen = zlib_decompress(compressed, blen, decompressed, dec_cap);
    if (dlen == 0 - ERR_BUFFER_TOO_SMALL) {
        if (dec_cap < 16 * 1024 * 1024) {
            dec_cap = 16 * 1024 * 1024;
            decompressed = alloc_or_die(dec_cap);
            if (decompressed == 0) { return 0 - 6; }
            dlen = zlib_decompress(compressed, blen, decompressed, dec_cap);
        }
    }
    if (dlen <= 0) { return 0 - 7; }

    var nul = 0;
    while (nul < dlen) {
        if (load8(decompressed + nul) == 0) { break; }
        nul = nul + 1;
    }
    if (nul >= dlen) { return 0 - 8; }

    store64(out, decompressed);
    store64(out + 8, dlen);
    store64(out + 16, nul + 1);
    return 0;
}

fn write_typed_object(type_str, type_len, content, content_len) {
    var hdr_max = 32;
    var full_cap = hdr_max + content_len;
    var full = alloc_or_die(full_cap);
    memcpy(full, type_str, type_len);
    store8(full + type_len, 32);
    var digits = write_decimal(full + type_len + 1, content_len);
    store8(full + type_len + 1 + digits, 0);
    var hdr_len = type_len + 1 + digits + 1;
    memcpy(full + hdr_len, content, content_len);
    var full_len = hdr_len + content_len;

    var hex = hash_data(full, full_len);

    var out_cap = full_len + 64 + full_len / 10;
    if (out_cap < 128) { out_cap = 128; }
    var compressed = alloc_or_die(out_cap);
    var clen = zlib_compress(full, full_len, compressed, out_cap);
    if (clen <= 0) { return 0; }

    var db = get_object_db();
    if (db == 0) { return 0; }

    # Content-addressed — skip if hash already present.
    # S-24: SQL on the freelist; freed before the insert path runs.
    var check_sql = fl_alloc(128);
    memcpy(check_sql, "SELECT hash FROM objects WHERE hash = '", 39);
    memcpy(check_sql + 39, hex, 64);
    memcpy(check_sql + 39 + 64, "'", 1);
    store8(check_sql + 39 + 64 + 1, 0);
    var rs = patra_query(db, check_sql);
    fl_free(check_sql);
    var exists = 0;
    if (rs != 0) {
        if (patra_result_count(rs) > 0) { exists = 1; }
        patra_result_free(rs);
    }

    if (exists == 0) {
        var type_code = type_code_of(type_str, type_len);
        var types[24];
        store64(&types + 0, 1);
        store64(&types + 8, 0);
        store64(&types + 16, 2);
        var ivals[24];
        store64(&ivals + 8, type_code);
        var sptrs[24];
        store64(&sptrs + 0, hex);
        var slens[24];
        store64(&slens + 0, 64);
        var bptrs[24];
        store64(&bptrs + 16, compressed);
        var blens[24];
        store64(&blens + 16, clen);
        patra_insert_row(db, "objects", 7, 3,
            &types, &ivals, &sptrs, &slens, &bptrs, &blens);
    }
    return hex;
}

fn write_blob_object(content, content_len) {
    return write_typed_object("blob", 4, content, content_len);
}

fn resolve_and_read(obj_out, hex_out) {
    # Backend detection (roadmap 1.2.0): read verbs work on a native .sit/ or an
    # existing .git/ repo; sets the process-global backend that read_object /
    # resolve_hash dispatch on. Non-repos still error as before.
    if (_detect_repo_backend() < 0) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    var prefix = argv_heap(2);
    var rr = resolve_hash(prefix, hex_out);
    if (rr == 0 - 2) { eprintln("sit: hash prefix too short (min 4 chars)"); return 1; }
    if (rr == 0 - 1) { eprintln("sit: ambiguous hash prefix"); return 1; }
    if (rr == 0)     { eprintln("sit: no object matches"); return 1; }

    var er = read_object(hex_out, obj_out);
    if (er != 0) {
        eprintln("sit: cannot read object (corrupt or missing)");
        return 1;
    }
    return 0;
}

fn cmd_cat_file() {
    if (argc() < 3) {
        eprintln("usage: sit cat-file <hash>");
        return 1;
    }

    var hex[72];
    var obj[24];
    var r = resolve_and_read(&obj, &hex);
    if (r != 0) { return r; }

    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    stdout_write(buf + coff, blen - coff);
    return 0;
}

# Locate the owl binary. Priority: SIT_OWL env var (explicit override) →
# /usr/local/bin/owl → /usr/bin/owl → /opt/owl/bin/owl. Returns a C-string
# path or 0 if not found. S-09: each candidate is lstat-checked; symlinks
# are accepted (owl is usually installed this way via package managers)
# but anything in a world-writable directory is logged and rejected.
#
# Writable-dir detection is coarse today — we only check the candidate path
# lstat mode, not the directory's perms up the chain. That's a best-effort
# defense-in-depth; a properly locked-down system has /usr/bin etc. already
# root-owned 0755.
fn find_owl() {
    var env_owl = getenv("SIT_OWL");
    if (env_owl != 0) {
        if (file_exists(env_owl) == 1) { return env_owl; }
        eprintln("sit: SIT_OWL points at a nonexistent file — falling back to system paths");
    }
    if (file_exists("/usr/local/bin/owl") == 1) { return "/usr/local/bin/owl"; }
    if (file_exists("/usr/bin/owl") == 1)       { return "/usr/bin/owl"; }
    if (file_exists("/opt/owl/bin/owl") == 1)   { return "/opt/owl/bin/owl"; }
    return 0;
}

fn cmd_owl_file() {
    if (argc() < 3) {
        eprintln("usage: sit owl-file <hash>");
        return 1;
    }

    var hex[72];
    var obj[24];
    var r = resolve_and_read(&obj, &hex);
    if (r != 0) { return r; }

    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var content = buf + coff;
    var content_len = blen - coff;

    # S-10: write content to $XDG_RUNTIME_DIR (or $HOME/.cache/sit as fallback)
    # with O_CREAT | O_EXCL | O_WRONLY and mode 0600, so we can't be tricked
    # into writing through an attacker-planted symlink at /tmp and other local
    # users can't read the blob.
    var xdg = getenv("XDG_RUNTIME_DIR");
    var home = getenv("HOME");
    var dir_base = 0;
    if (xdg != 0) { dir_base = xdg; }
    else {
        if (home != 0) {
            var hlen = strlen(home);
            var cache = alloc_or_die(hlen + 12);
            memcpy(cache, home, hlen);
            memcpy(cache + hlen, "/.cache/sit", 11);
            store8(cache + hlen + 11, 0);
            var parent = alloc_or_die(hlen + 8);
            memcpy(parent, home, hlen);
            memcpy(parent + hlen, "/.cache", 7);
            store8(parent + hlen + 7, 0);
            ensure_dir(parent);
            ensure_dir(cache);
            dir_base = cache;
        }
        else {
            dir_base = "/tmp";
        }
    }
    var db_len = strlen(dir_base);
    var tmppath = alloc_or_die(db_len + 32);
    memcpy(tmppath, dir_base, db_len);
    memcpy(tmppath + db_len, "/sit-owl-", 9);
    memcpy(tmppath + db_len + 9, &hex, 12);
    store8(tmppath + db_len + 9 + 12, 0);

    # O_WRONLY | O_CREAT | O_EXCL = 1 | 64 | 128 = 193. Mode 0o600 = 0x180.
    # O_EXCL refuses to follow a pre-existing symlink and refuses EEXIST,
    # closing the TOCTOU window.
    var tfd = sys_open(tmppath, 193, 0x180);
    if (tfd < 0) {
        eprintln("sit: cannot create tempfile");
        return 1;
    }
    if (syscall(SYS_WRITE, tfd, content, content_len) < 0) {
        sys_close(tfd);
        # S-16: best-effort tempfile cleanup. Tempfiles live in
        # $XDG_RUNTIME_DIR/sit/ so a leak gets reaped eventually; a stderr
        # warning makes it loud rather than silent.
        if (sys_unlink(tmppath) != 0) {
            eprintln("sit: warning: failed to remove owl tempfile after write error");
        }
        eprintln("sit: cannot write tempfile");
        return 1;
    }
    sys_close(tfd);

    var owl = find_owl();
    if (owl == 0) {
        eprintln("sit: owl not installed — emitting raw content");
        eprintln("sit:   (owl is pre-1.0; https://github.com/MacCracken/owl)");
        stdout_write(content, content_len);
        if (sys_unlink(tmppath) != 0) {
            eprintln("sit: warning: failed to remove owl tempfile");
        }
        return 0;
    }

    var args = vec_new();
    vec_push(args, owl);
    vec_push(args, tmppath);
    var rc = exec_vec(args);
    if (sys_unlink(tmppath) != 0) {
        eprintln("sit: warning: failed to remove owl tempfile after exec");
    }
    return rc;
}

# Type codes stored in the objects.type INT column.
fn type_code_of(type_str, type_len) {
    if (type_len == 4) {
        if (memeq(type_str, "blob", 4) == 1) { return 0; }
        if (memeq(type_str, "tree", 4) == 1) { return 1; }
    }
    if (type_len == 6) {
        if (memeq(type_str, "commit", 6) == 1) { return 2; }
    }
    return 0 - 1;
}

# Open (or create) the patra-backed object store. Returns db handle, or 0.
# Used by the wire protocol when it needs an explicit handle (push/fetch
# open both ends with named locals); hot read paths should go through
# get_object_db() instead.
fn object_db_open() {
    patra_init();
    var db = sf_patra_open(".sit/objects.patra");
    if (db == 0) { return 0; }
    patra_exec(db, "CREATE TABLE objects (hash STR, ty INT, content BYTES)");
    return db;
}

# v0.6.4: process-wide cached handle for .sit/objects.patra. Collapses
# P-01/02/05/08/12/25 — every read_object / write_typed_object /
# resolve_hash previously did patra_init + patra_open + CREATE TABLE +
# loose-migration check + patra_close on every call. With the cache:
# first call opens + migrates once; subsequent calls reuse the handle;
# fd dies with the process (patra_close just frees in-process buffers
# and closes the fd — no WAL flush — so skipping it at exit is safe).
var _object_db_cached = 0;

fn get_object_db() {
    if (_object_db_cached != 0) { return _object_db_cached; }
    _object_db_cached = object_db_open();
    if (_object_db_cached == 0) { return 0; }
    # v0.6.10 — investigated patra 1.8's BATCH sync mode here and reverted:
    # the cache never closes the handle (fd dies with the process, no
    # patra_close call), so BATCH-pending writes between the every-64-writes
    # auto-flush would be lost on power loss within the kernel writeback
    # window. `copy_objects` already wraps its hot loop in patra_begin /
    # patra_commit (v0.6.5 P-03), which gets the same fsync amortization on
    # the only batch-shaped write path. Stay on FULL (default) for now;
    # revisit if/when sit grows explicit patra_flush() calls at command exit.
    object_db_migrate_from_loose(_object_db_cached);
    return _object_db_cached;
}

# Migrate legacy loose-file objects (under .sit/objects/<xx>/<yy...>) into
# the patra table. No-op if no legacy files present. Deletes loose files
# + empty 2-char directories as they're migrated.
fn object_db_migrate_from_loose(db) {
    if (sf_exists(".sit/objects") != 1) { return 0; }

    var dirs = sf_dir_list(str_from(".sit/objects"));
    var dn = vec_len(dirs);
    var di = 0;
    while (di < dn) {
        var s = vec_get(dirs, di);
        var sdata = str_data(s);
        var slen = str_len(s);

        if (slen == 2) {
            var sub_path = alloc_or_die(16);
            memcpy(sub_path, ".sit/objects/", 13);
            memcpy(sub_path + 13, sdata, 2);
            store8(sub_path + 15, 0);

            var files = sf_dir_list(str_from(sub_path));
            var fn_ct = vec_len(files);
            var fi = 0;
            while (fi < fn_ct) {
                var f = vec_get(files, fi);
                var fdata = str_data(f);
                var flen = str_len(f);

                if (flen == 62) {
                    var hex = alloc_or_die(65);
                    memcpy(hex, sdata, 2);
                    memcpy(hex + 2, fdata, 62);
                    store8(hex + 64, 0);

                    var loose_path = alloc_or_die(96);
                    object_path(loose_path, hex);
                    var pair[16];
                    if (read_file_heap(loose_path, &pair) == 0) {
                        var compressed = load64(&pair);
                        var clen = load64(&pair + 8);

                        # Sniff type from decompressed header for the INT column.
                        # S-08 + P-06 (v0.6.9): 4× initial; retry at 16 MiB ceiling
                        # only on confirmed -ERR_BUFFER_TOO_SMALL. Matches read_object.
                        var dec_cap = clen * 4;
                        if (dec_cap < 4096) { dec_cap = 4096; }
                        if (dec_cap > 16 * 1024 * 1024) { dec_cap = 16 * 1024 * 1024; }
                        var decompressed = alloc_or_die(dec_cap);
                        var dlen = zlib_decompress(compressed, clen, decompressed, dec_cap);
                        if (dlen == 0 - ERR_BUFFER_TOO_SMALL) {
                            if (dec_cap < 16 * 1024 * 1024) {
                                dec_cap = 16 * 1024 * 1024;
                                decompressed = alloc_or_die(dec_cap);
                                dlen = zlib_decompress(compressed, clen, decompressed, dec_cap);
                            }
                        }
                        var type_code = 0;
                        if (dlen > 5) {
                            if (memeq(decompressed, "blob ", 5) == 1) { type_code = 0; }
                            else {
                                if (memeq(decompressed, "tree ", 5) == 1) { type_code = 1; }
                                else {
                                    if (dlen > 7) {
                                        if (memeq(decompressed, "commit ", 7) == 1) { type_code = 2; }
                                    }
                                }
                            }
                        }

                        var types[24];
                        store64(&types + 0, 1);
                        store64(&types + 8, 0);
                        store64(&types + 16, 2);
                        var ivals[24];
                        store64(&ivals + 8, type_code);
                        var sptrs[24];
                        store64(&sptrs + 0, hex);
                        var slens[24];
                        store64(&slens + 0, 64);
                        var bptrs[24];
                        store64(&bptrs + 16, compressed);
                        var blens[24];
                        store64(&blens + 16, clen);
                        patra_insert_row(db, "objects", 7, 3,
                            &types, &ivals, &sptrs, &slens, &bptrs, &blens);

                        sf_unlink(loose_path);
                    }
                }
                fi = fi + 1;
            }
            sf_rmdir(sub_path);
        }
        di = di + 1;
    }
    return 0;
}

# Read a ref tip file (heads/tags/remotes leaf) — trim trailing CR/LF,
# validate 64-hex, return a heap-allocated 65-byte cstring or 0 on
# malformed content. Caller does not free (bump-allocated for the life
# of the fsck pass).
fn fsck_read_ref_tip(path) {
    var pair[16];
    if (read_file_heap(path, &pair) != 0) { return 0; }
    var data = load64(&pair);
    var len = load64(&pair + 8);
    # Trim trailing CR/LF (cyrius `break` in while-with-var is unreliable,
    # so use a flag).
    var trimming = 1;
    while (trimming == 1) {
        if (len == 0) { trimming = 0; }
        else {
            var lc = load8(data + len - 1) & 0xFF;
            if (lc == 10) { len = len - 1; }
            else {
                if (lc == 13) { len = len - 1; }
                else { trimming = 0; }
            }
        }
    }
    if (len != 64) { return 0; }
    if (hex_prefix_valid(data, 64) == 0) { return 0; }
    var out = alloc(65);
    memcpy(out, data, 64);
    store8(out + 64, 0);
    return out;
}

# Walk one refs subtree (`.sit/refs/heads` etc.) and push every valid
# tip hex into `roots`. Missing dir is a no-op. Malformed ref files are
# silently skipped — the integrity pass surfaces unreachable objects,
# and a broken ref shows up there as a dangling chain.
fn fsck_walk_refs_dir(dir, roots) {
    if (sf_exists(dir) != 1) { return 0; }
    var files = vec_new();
    dir_walk(str_from(sit_abs(dir)), files);   # abs: cwd-independent (fsck off-cwd / agnos)
    var i = 0;
    while (i < vec_len(files)) {
        var fp_str = vec_get(files, i);
        var fp_len = str_len(fp_str);
        var fp_data = str_data(fp_str);
        var fs_cstr = alloc(fp_len + 1);
        memcpy(fs_cstr, fp_data, fp_len);
        store8(fs_cstr + fp_len, 0);
        var hex = fsck_read_ref_tip(fs_cstr);
        if (hex != 0) { vec_push(roots, hex); }
        i = i + 1;
    }
    return 0;
}

# Collect every reachability root from the on-disk refs:
#   .sit/refs/heads/<*>, .sit/refs/tags/<*>, .sit/refs/remotes/<*>/<*>
# plus .sit/HEAD when it's a raw hex (detached) rather than symbolic.
# Symbolic HEAD targets are already covered by the matching ref file.
# Add every reflog entry's old+new oid (across all .sit/logs/** files) to
# `roots`. This is the reflog-reachability half of the v1.1.0 prune grace:
# an object referenced by any reflog entry is reachable, so `fsck --prune`
# won't drop the very commits the reflog exists to recover (e.g. the tip a
# `reset --hard` discarded). Mirrors git fsck's default reflog-as-roots.
fn fsck_collect_reflog_roots(roots) {
    if (sf_exists(".sit/logs") != 1) { return 0; }
    var files = vec_new();
    dir_walk(str_from(sit_abs(".sit/logs")), files);   # abs: cwd-independent
    var i = 0;
    while (i < vec_len(files)) {
        var fp = vec_get(files, i);
        var fl = str_len(fp);
        var fc = alloc(fl + 1);
        memcpy(fc, str_data(fp), fl);
        store8(fc + fl, 0);
        var pair[16];
        if (read_file_heap(fc, &pair) == 0) {
            _reflog_collect_oids(load64(&pair), load64(&pair + 8), roots);
        }
        i = i + 1;
    }
    return 0;
}

# Collect ONLY the refs/HEAD roots (heads, tags, remotes, detached HEAD).
# Reflog roots are collected separately by cmd_fsck via
# fsck_collect_reflog_roots so the "every object unreachable" prune tripwire
# can judge corruption from the refs set alone — a stale reflog must not mask
# a wiped HEAD/refs and let --prune delete a ref-only-reachable branch.
fn fsck_collect_roots() {
    var roots = vec_new();
    fsck_walk_refs_dir(".sit/refs/heads",   roots);
    fsck_walk_refs_dir(".sit/refs/tags",    roots);
    fsck_walk_refs_dir(".sit/refs/remotes", roots);

    if (sf_exists(".sit/HEAD") == 1) {
        var pair[16];
        if (read_file_heap(".sit/HEAD", &pair) == 0) {
            var data = load64(&pair);
            var len = load64(&pair + 8);
            var trimming = 1;
            while (trimming == 1) {
                if (len == 0) { trimming = 0; }
                else {
                    var lc = load8(data + len - 1) & 0xFF;
                    if (lc == 10) { len = len - 1; }
                    else {
                        if (lc == 13) { len = len - 1; }
                        else { trimming = 0; }
                    }
                }
            }
            if (len == 64) {
                if (hex_prefix_valid(data, 64) == 1) {
                    var hex = alloc(65);
                    memcpy(hex, data, 64);
                    store8(hex + 64, 0);
                    vec_push(roots, hex);
                }
            }
        }
    }
    return roots;
}

# Extract every `parent <hex>\n` from a commit body and push each as a
# fresh 65-byte cstring into `parents`. Distinct from parse_commit_body,
# which captures only the LAST parent line (merge commits have two);
# reachability MUST follow both legs or merged-only objects appear
# dangling. Stops at the first blank line (end of headers).
fn fsck_collect_commit_parents(body, body_len, parents) {
    var pos = 0;
    var done = 0;
    while (done == 0) {
        if (pos >= body_len) { done = 1; }
        else {
            # Find end of current line (cyrius `break` in while-with-var
            # is unreliable, so use a flag).
            var le = pos;
            var scanning = 1;
            while (scanning == 1) {
                if (le >= body_len) { scanning = 0; }
                else {
                    if (load8(body + le) == 10) { scanning = 0; }
                    else { le = le + 1; }
                }
            }
            var line_len = le - pos;
            if (line_len == 0) { done = 1; }
            else {
                if (line_len >= 71) {
                    if (memeq(body + pos, "parent ", 7) == 1) {
                        if (hex_prefix_valid(body + pos + 7, 64) == 1) {
                            var p = alloc(65);
                            memcpy(p, body + pos + 7, 64);
                            store8(p + 64, 0);
                            vec_push(parents, p);
                        }
                    }
                }
                pos = le + 1;
            }
        }
    }
    return 0;
}

# Extract `tree <hex>\n` from a commit body. Returns a heap-allocated
# 65-byte hex cstring, or 0 if absent / malformed. Looks at the first
# line only — git always emits `tree` as the very first header.
fn fsck_extract_commit_tree(body, body_len) {
    if (body_len < 70) { return 0; }
    if (memeq(body, "tree ", 5) == 0) { return 0; }
    if (hex_prefix_valid(body + 5, 64) == 0) { return 0; }
    var t = alloc(65);
    memcpy(t, body + 5, 64);
    store8(t + 64, 0);
    return t;
}

# Reachability walker for fsck. BFS from `root` over the object graph,
# marking each visited hex in `seen` (map_new, cstr-keyed). Commits
# enqueue their tree + every parent hex; trees enqueue every entry
# (sub-trees and blobs); blobs are leaves. Missing / unreadable objects
# get marked in `seen` so we don't loop, but no children are enqueued.
# Type detection is by framing prefix ("blob "/"tree "/"commit ").
#
# Distinct from `walk_reachable_phased` in src/wire.cyr: that walker
# only follows the first parse_commit_body-captured parent (which is
# actually the LAST parent line in the body — a pre-existing limitation
# that doesn't show up in CI because the fixtures are linear).
# Reachability must traverse every parent edge or merge-only objects
# look dangling.
fn fsck_walk_reachable(root, seen) {
    var queue = vec_new();
    vec_push(queue, root);
    while (vec_len(queue) > 0) {
        var hex = vec_get(queue, vec_len(queue) - 1);
        vec_pop(queue);
        if (map_has(seen, hex) == 0) {
            map_set(seen, hex, 1);
            var obj[24];
            if (read_object(hex, &obj) == 0) {
                var buf = load64(&obj);
                var blen = load64(&obj + 8);
                var coff = load64(&obj + 16);
                var body = buf + coff;
                var body_len = blen - coff;
                # Classify by framing prefix.
                if (blen >= 7) {
                    if (memeq(buf, "commit ", 7) == 1) {
                        var t = fsck_extract_commit_tree(body, body_len);
                        if (t != 0) {
                            if (map_has(seen, t) == 0) { vec_push(queue, t); }
                        }
                        var parents = vec_new();
                        fsck_collect_commit_parents(body, body_len, parents);
                        var pi = 0;
                        while (pi < vec_len(parents)) {
                            var p = vec_get(parents, pi);
                            if (map_has(seen, p) == 0) { vec_push(queue, p); }
                            pi = pi + 1;
                        }
                    }
                }
                if (blen >= 5) {
                    if (memeq(buf, "tree ", 5) == 1) {
                        var entries = parse_tree(body, body_len);
                        var en = vec_len(entries);
                        var ei = 0;
                        while (ei < en) {
                            var e = vec_get(entries, ei);
                            var ehash = tree_entry_hash(e);
                            if (map_has(seen, ehash) == 0) {
                                var ec = alloc(65);
                                memcpy(ec, ehash, 64);
                                store8(ec + 64, 0);
                                vec_push(queue, ec);
                            }
                            ei = ei + 1;
                        }
                    }
                }
                # blob: leaf — no further enqueue.
            }
        }
    }
    return 0;
}

# Map the patra `ty` INT back to the canonical word for dangling
# output. Returns 0 if unknown — caller falls back to "object".
fn fsck_ty_word(ty) {
    if (ty == 0) { return "blob"; }
    if (ty == 1) { return "tree"; }
    if (ty == 2) { return "commit"; }
    return 0;
}

# fsck — integrity + reachability.
#
# Integrity pass: SELECT every (hash, ty) from .sit/objects.patra; for
# each, read+decompress and sigil-rehash the framed body against the
# stored hex. Mismatch / unreadable rows are emitted on stderr and
# count toward `bad`.
#
# Reachability pass (v0.8.5): collect roots from refs/heads/tags/remotes
# + detached HEAD + every staged index entry; BFS the object graph
# from each root marking `seen`; any object in the integrity inventory
# that isn't in `seen` is dangling. Dangling objects are reported on
# stdout one per line in `dangling <type> <hex>` format (git-shaped);
# they don't fail the command — only integrity errors set non-zero
# exit, mirroring git's policy that dangling objects are expected
# after resets / rewinds.
# Delete a single object row by hex (v0.8.14, fsck --prune). The hex is
# validated 64-char hex before interpolation — even though it comes from the
# inventory SELECT, never build SQL from unchecked bytes. Returns patra_exec's
# code (0 = ok), or -1 if the hex fails validation.
fn db_object_delete(db, hex) {
    if (hex_prefix_valid(hex, 64) == 0) { return 0 - 1; }
    var sql = alloc(128);
    memcpy(sql, "DELETE FROM objects WHERE hash = '", 34);
    memcpy(sql + 34, hex, 64);
    memcpy(sql + 34 + 64, "'", 1);
    store8(sql + 34 + 64 + 1, 0);
    return patra_exec(db, sql);
}

# Extract a commit's author timestamp (unix seconds) from its raw body, for
# the prune age-window check. The ident line is "author NAME <EMAIL> TS TZ";
# TS is the second-to-last space-delimited token. Returns 0 if no parseable
# author line (caller then treats the object as undatable). Self-contained
# (parse_commit_body lives in the later commit.cyr module, out of bundle reach).
fn _fsck_commit_author_ts(body, len) {
    var i = 0;
    var astart = 0 - 1;
    var scanning = 1;
    while (scanning == 1) {
        if (i + 7 > len) { scanning = 0; }
        else {
            var at_ls = 0;
            if (i == 0) { at_ls = 1; }
            else { if (load8(body + i - 1) == 10) { at_ls = 1; } }
            if (at_ls == 1) {
                if (memeq(body + i, "author ", 7) == 1) { astart = i + 7; scanning = 0; }
            }
            if (scanning == 1) { i = i + 1; }
        }
    }
    if (astart < 0) { return 0; }

    var aend = astart;
    var f2 = 1;
    while (f2 == 1) {
        if (aend >= len) { f2 = 0; }
        else { if (load8(body + aend) == 10) { f2 = 0; } else { aend = aend + 1; } }
    }

    # Walk back over the TZ token to the space before it → that's ts_end.
    var p = aend - 1;
    var s1 = 1;
    while (s1 == 1) {
        if (p < astart) { s1 = 0; }
        else { if (load8(body + p) == 32) { s1 = 0; } else { p = p - 1; } }
    }
    var ts_end = p;
    # ts_start = one past the previous space.
    var ts_start = ts_end;
    var s2 = 1;
    while (s2 == 1) {
        if (ts_start - 1 < astart) { s2 = 0; }
        else {
            if (load8(body + ts_start - 1) == 32) { s2 = 0; }
            else { ts_start = ts_start - 1; }
        }
    }
    if (ts_start >= ts_end) { return 0; }

    var val = 0;
    var k = ts_start;
    var okp = 1;
    while (k < ts_end) {
        var d = load8(body + k);
        if (d < 48) { okp = 0; k = ts_end; }
        else {
            if (d > 57) { okp = 0; k = ts_end; }
            else { val = val * 10 + (d - 48); k = k + 1; }
        }
    }
    if (okp == 0) { return 0; }
    return val;
}

fn cmd_fsck() {
    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    # `--prune` removes dangling (unreachable) objects this walk identifies.
    # v1.1.0 added two grace mechanisms vs the old unconditional --prune=now:
    #   (1) reflog reachability — every .sit/logs/** entry's oids are roots
    #       (fsck_collect_reflog_roots), so a reset-discarded tip is protected
    #       as long as its reflog entry exists; and
    #   (2) an age window — a still-dangling object is kept unless it's older
    #       than the grace window. Datable objects are commits (author ts);
    #       trees/blobs can't be dated, so a positive window keeps them.
    # `--prune` uses a 90-day window (git's gc.reflogExpire default); the
    # legacy immediate behaviour is `--prune-now` (grace 0, like
    # `git gc --prune=now`). Both are refused mid-merge (.sit/MERGE_HEAD).
    var prune = 0;
    var grace_days = 90;
    var ai = 2;
    while (ai < argc()) {
        if (streq(argv(ai), "--prune") == 1) { prune = 1; }
        if (streq(argv(ai), "--prune-now") == 1) { prune = 1; grace_days = 0; }
        ai = ai + 1;
    }
    if (prune == 1) {
        if (sf_exists(".sit/MERGE_HEAD") == 1) {
            eprintln("sit: refusing --prune during an in-progress merge (.sit/MERGE_HEAD present)");
            return 1;
        }
    }

    var db = get_object_db();
    if (db == 0) {
        stdout_write("checked 0 objects, 0 bad, 0 dangling\n", 37);
        return 0;
    }

    # Integrity pass. v0.8.5: pull `ty` alongside `hash` so the
    # reachability report can emit `dangling <type> <hex>` without a
    # second read per dangling object.
    var rs = patra_query(db, "SELECT hash, ty FROM objects");
    var total = 0;
    var bad = 0;
    var hashes = vec_new();
    var ty_map = map_new();
    if (rs != 0) {
        var count = patra_result_count(rs);
        var i = 0;
        while (i < count) {
            var s = patra_result_get_str(rs, i, 0);
            var ty = patra_result_get_int(rs, i, 1);
            var copy = alloc_or_die(65);
            memcpy(copy, s, 64);
            store8(copy + 64, 0);
            vec_push(hashes, copy);
            map_set(ty_map, copy, ty + 1);
            i = i + 1;
        }
        patra_result_free(rs);
    }

    var hn = vec_len(hashes);
    var hi = 0;
    while (hi < hn) {
        var hex = vec_get(hashes, hi);
        var obj[24];
        if (read_object(hex, &obj) == 0) {
            var buf = load64(&obj);
            var blen = load64(&obj + 8);
            var actual = hash_data(buf, blen);
            if (streq(hex, actual) == 0) {
                syscall(SYS_WRITE, STDERR, "bad object ", 11);
                syscall(SYS_WRITE, STDERR, hex, 64);
                syscall(SYS_WRITE, STDERR, "\n", 1);
                bad = bad + 1;
            }
            total = total + 1;
        }
        else {
            syscall(SYS_WRITE, STDERR, "unreadable ", 11);
            syscall(SYS_WRITE, STDERR, hex, 64);
            syscall(SYS_WRITE, STDERR, "\n", 1);
            bad = bad + 1;
        }
        hi = hi + 1;
    }

    # Reachability pass (v0.8.5). Refs/HEAD roots first (count retained for
    # the prune corrupt-roots tripwire), then reflog roots appended (v1.1.0).
    var seen = map_new();
    var roots = fsck_collect_roots();
    var ref_root_count = vec_len(roots);
    fsck_collect_reflog_roots(roots);
    var ri = 0;
    while (ri < vec_len(roots)) {
        fsck_walk_reachable(vec_get(roots, ri), seen);
        ri = ri + 1;
    }

    # Staged blobs count as roots — without this, every `sit add` that
    # hasn't been committed yet would look dangling. (Mirrors git's
    # implicit-keep of `git ls-files` blobs during fsck.)
    var idx_entries = parse_index();
    if (idx_entries != 0) {
        var ii = 0;
        while (ii < vec_len(idx_entries)) {
            var e = vec_get(idx_entries, ii);
            var bin = entry_hash(e);
            var ihex = hex_encode(bin, 32);
            if (map_has(seen, ihex) == 0) { map_set(seen, ihex, 1); }
            ii = ii + 1;
        }
    }

    # Diff: objects in the inventory but not reachable.
    var dangling = 0;
    var dangling_hexes = vec_new();
    var di = 0;
    while (di < hn) {
        var hex2 = vec_get(hashes, di);
        if (map_has(seen, hex2) == 0) {
            var stored = map_get(ty_map, hex2);
            var ty_word = 0;
            if (stored > 0) { ty_word = fsck_ty_word(stored - 1); }
            if (ty_word == 0) { ty_word = "object"; }
            stdout_write("dangling ", 9);
            stdout_write(ty_word, strlen(ty_word));
            stdout_write(" ", 1);
            stdout_write(hex2, 64);
            stdout_write("\n", 1);
            dangling = dangling + 1;
            vec_push(dangling_hexes, hex2);
        }
        di = di + 1;
    }

    stdout_write("checked ", 8);
    write_unsigned(total);
    stdout_write(" objects, ", 10);
    write_unsigned(bad);
    stdout_write(" bad, ", 6);
    write_unsigned(dangling);
    stdout_write(" dangling\n", 10);

    # v0.8.14: prune the dangling set. Deletes each unreachable object, then
    # flushes (the main trailer only flushes stdout, not patra) so the removal
    # is durable across the process exit. Reachable history is untouched —
    # only objects absent from the reachability walk are removed.
    if (prune == 1) {
        # Data-loss guard: the reachability walk SKIPS unreadable objects
        # (read_object failure → its children are never enqueued), so a single
        # corrupt interior commit/tree would orphan its whole subgraph into the
        # dangling set. Pruning then deletes genuinely-reachable objects with no
        # reflog to recover them. Refuse while any object is bad/unreadable.
        if (bad > 0) {
            eprintln("sit: refusing --prune with bad/unreadable objects — resolve integrity first");
            return 1;
        }
        # If EVERY object is unreachable, the roots are almost certainly broken
        # (corrupt / missing HEAD or refs), not the objects. Pruning would wipe
        # the whole store. Refuse.
        if (total > 0) {
            if (dangling == total) {
                eprintln("sit: refusing --prune — every object is unreachable (corrupt or missing HEAD/refs?)");
                return 1;
            }
        }
        # Corrupt-roots tripwire: a stale .sit/logs must not stand in for a
        # wiped HEAD/refs. If there are NO refs/HEAD roots (only reflog roots),
        # the ref store is broken — pruning would delete any branch that was
        # never reflogged. Refuse unless there are objects but genuinely no
        # refs at all is impossible after init (HEAD always resolves once a
        # commit exists), so an empty ref-root set with objects present is the
        # corruption signal.
        if (total > 0) {
            if (ref_root_count == 0) {
                eprintln("sit: refusing --prune — no valid refs/HEAD roots (corrupt or missing HEAD/refs?)");
                return 1;
            }
        }
        # Age window: keep a still-dangling object unless it's older than the
        # grace window. Only commits carry a timestamp (author ts); trees/blobs
        # are undatable, so any positive window keeps them (grace 0 deletes
        # everything dangling — the old --prune=now behaviour).
        var now = clock_epoch_secs();
        var grace_secs = grace_days * 86400;
        var pruned = 0;
        var kept = 0;
        var pi = 0;
        while (pi < vec_len(dangling_hexes)) {
            var dhex = vec_get(dangling_hexes, pi);
            var keep = 0;
            if (grace_secs > 0) {
                # Conservative default under a positive window: KEEP unless we
                # can positively date the object past the window. Commits are
                # datable (author ts); an undatable commit (unreadable body or
                # unparseable ts) is kept just like trees/blobs — never delete
                # something we can't prove is old.
                keep = 1;
                var dstored = map_get(ty_map, dhex);
                if (dstored == 3) {                 # ty 2 (commit) + 1
                    var co[24];
                    if (read_object(dhex, &co) == 0) {
                        var cts = _fsck_commit_author_ts(load64(&co), load64(&co + 8));
                        if (cts > 0) {
                            if (now - cts >= grace_secs) { keep = 0; }
                        }
                    }
                }
            }
            if (keep == 1) { kept = kept + 1; }
            else {
                if (db_object_delete(db, dhex) == 0) { pruned = pruned + 1; }
            }
            pi = pi + 1;
        }
        patra_flush(db);
        stdout_write("pruned ", 7);
        write_unsigned(pruned);
        stdout_write(" objects", 8);
        if (kept > 0) {
            stdout_write(", kept ", 7);
            write_unsigned(kept);
            stdout_write(" within grace", 13);
        }
        stdout_write("\n", 1);
    }

    if (bad > 0) { return 1; }
    return 0;
}

fn hash_blob_of_content(content, content_len) {
    var full_cap = 32 + content_len;
    var full = alloc_or_die(full_cap);
    memcpy(full, "blob ", 5);
    var digits = write_decimal(full + 5, content_len);
    store8(full + 5 + digits, 0);
    var hdr_len = 5 + digits + 1;
    memcpy(full + hdr_len, content, content_len);
    return hash_data(full, hdr_len + content_len);
}

# Read a regular file into a heap buffer. Stores (buf_ptr, len) to out_pair.
# Returns 0 on success, negative on error.
fn hash_file_as_blob(path) {
    var pair[16];
    if (read_file_heap(path, &pair) != 0) { return 0; }
    return hash_blob_of_content(load64(&pair), load64(&pair + 8));
}

# Tree entry layout (24 bytes):
#   0..8:   mode ptr (heap cstring, e.g. "100644")
#   8..16:  name ptr (heap cstring)
#   16..24: hash_hex ptr (heap cstring, 64 chars + null)

# --- index.cyr ---

# index.cyr — staging index + .sitignore + cmd_add / cmd_rm / cmd_reset.
#
# Patra-backed index at .sit/index.patra. Git-parity `.sitignore` (v0.8.10):
# `*` / `?` / `[...]` char classes, `**` multi-segment wildcard, `!` negation
# (last match wins), and leading/middle `/` anchoring. See _wildmatch /
# is_ignored / load_sitignore below.

fn cmd_add() {
    if (argc() < 3) {
        eprintln("usage: sit add [-f] <path>");
        return 1;
    }

    var forced = 0;
    var arg_idx = 2;
    if (streq(argv(2), "-f") == 1) {
        forced = 1;
        arg_idx = 3;
        if (argc() < 4) {
            eprintln("usage: sit add -f <path>");
            return 1;
        }
    }
    var path = argv_heap(arg_idx);
    var path_len = strlen(path);

    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    if (forced == 0) {
        var patterns = load_sitignore();
        if (is_ignored(path, patterns) == 1) {
            syscall(SYS_WRITE, STDERR, "sit: '", 6);
            syscall(SYS_WRITE, STDERR, path, path_len);
            syscall(SYS_WRITE, STDERR, "' matches a .sitignore pattern (use -f to override)\n", 52);
            return 1;
        }
    }

    var fd = sf_open(path, 0, 0);
    if (fd < 0) {
        syscall(SYS_WRITE, STDERR, "sit: cannot open '", 18);
        syscall(SYS_WRITE, STDERR, path, path_len);
        syscall(SYS_WRITE, STDERR, "'\n", 2);
        return 1;
    }
    var size = syscall(SYS_LSEEK, fd, 0, SEEK_END);
    syscall(SYS_LSEEK, fd, 0, SEEK_SET);
    if (size < 0) {
        file_close(fd);
        eprintln("sit: cannot stat file");
        return 1;
    }
    # S-06: cap single-blob add at 1 GiB to prevent OOM from `sit add /dev/zero`
    # or symlinked-to-huge-file. Real-world source files don't approach this.
    if (size > 1073741824) {
        file_close(fd);
        eprintln("sit: file too large (> 1 GiB)");
        return 1;
    }

    var content = alloc(size);
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var r = file_read(fd, content + total, size - total);
        if (r <= 0) { rgo = 0; }
        else { total = total + r; if (total >= size) { rgo = 0; } }
    }
    file_close(fd);

    var hex = write_blob_object(content, total);
    if (hex == 0) {
        eprintln("sit: failed to write object");
        return 1;
    }

    if (index_upsert(hex, path) != 0) {
        eprintln("sit: failed to update index");
        return 1;
    }

    stdout_write("added ", 6);
    stdout_write(hex, 12);
    stdout_write(" ", 1);
    stdout_write(path, path_len);
    stdout_write("\n", 1);
    return 0;
}

# Common setup for read-side commands: parse prefix, resolve to full hash,
# read+decompress. On success: writes 24-byte struct to obj_out, returns 0.
# On error: emits message to stderr and returns non-zero for main to return.
fn index_db_open() {
    patra_init();
    var db = sf_patra_open(".sit/index.patra");
    if (db == 0) { return 0; }
    # Idempotent — second call returns "already exists", which we ignore.
    patra_exec(db, "CREATE TABLE entries (path STR, hash_hex STR)");
    return db;
}

# v0.6.4: process-wide cache for .sit/index.patra. Same pattern as
# get_object_db (object_db.cyr). Lazy-open + lazy-migrate-from-plaintext.
var _index_db_cached = 0;

fn get_index_db() {
    if (_index_db_cached != 0) { return _index_db_cached; }
    _index_db_cached = index_db_open();
    if (_index_db_cached == 0) { return 0; }
    # v0.6.10 — see get_object_db (object_db.cyr) for the BATCH-mode revert
    # rationale. Same shape: cache never closes, so BATCH-pending writes
    # would be lost on power loss before the every-64-writes auto-flush.
    index_migrate_from_plaintext(_index_db_cached);
    return _index_db_cached;
}

# Migrate legacy plaintext .sit/index (v0.1 format) into the patra table.
# No-op if the plaintext file is absent. Deletes it on successful migration.
fn index_migrate_from_plaintext(db) {
    if (sf_exists(".sit/index") != 1) { return 0; }
    var pair[16];
    if (read_file_heap(".sit/index", &pair) != 0) { return 0; }
    var data = load64(&pair);
    var len = load64(&pair + 8);

    var pos = 0;
    while (pos < len) {
        if (pos + 65 > len) { pos = len; }
        else {
            if (load8(data + pos + 64) != 9) { pos = len; }
            else {
                var nl = pos + 65;
                while (nl < len) {
                    if (load8(data + nl) == 10) { break; }
                    nl = nl + 1;
                }
                var plen = nl - pos - 65;
                # S-22: refuse multi-megabyte path lines (a malformed legacy
                # index could otherwise force a single huge alloc on migrate).
                # Real paths fit in a few hundred bytes; 4096 leaves headroom
                # for deep nested cases without paying for a malicious blob.
                if (plen > 4096) { pos = len; }
                else {

                var hash_copy = alloc(65);
                memcpy(hash_copy, data + pos, 64);
                store8(hash_copy + 64, 0);
                var path_copy = alloc(plen + 1);
                memcpy(path_copy, data + pos + 65, plen);
                store8(path_copy + plen, 0);

                var types[16];
                store64(&types + 0, 1);
                store64(&types + 8, 1);
                var ivals[16];
                var sptrs[16];
                store64(&sptrs + 0, path_copy);
                store64(&sptrs + 8, hash_copy);
                var slens[16];
                store64(&slens + 0, plen);
                store64(&slens + 8, 64);
                var bptrs[16];
                var blens[16];
                patra_insert_row(db, "entries", 7, 2,
                    &types, &ivals, &sptrs, &slens, &bptrs, &blens);

                pos = nl + 1;
                }
            }
        }
    }
    sf_unlink(".sit/index");
    return 0;
}

# Rewrite the staging index to exactly the given entries. DELETE + insert all.
fn rewrite_index(entries) {
    var db = get_index_db();
    if (db == 0) { return 0 - 1; }
    patra_exec(db, "DELETE FROM entries");

    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        var path = entry_path(e);
        var hash_hex = hex_encode(entry_hash(e), 32);

        var types[16];
        store64(&types + 0, 1);
        store64(&types + 8, 1);
        var ivals[16];
        var sptrs[16];
        store64(&sptrs + 0, path);
        store64(&sptrs + 8, hash_hex);
        var slens[16];
        store64(&slens + 0, strlen(path));
        store64(&slens + 8, 64);
        var bptrs[16];
        var blens[16];
        patra_insert_row(db, "entries", 7, 2,
            &types, &ivals, &sptrs, &slens, &bptrs, &blens);
        i = i + 1;
    }
    return 0;
}

# Upsert a single (hash, path) entry — replaces any existing row for that path.
# Used by `sit add` to stage a file.
fn index_upsert(hash_hex, path) {
    var existing = parse_index();
    var filtered = vec_new();
    if (existing != 0) {
        var n = vec_len(existing);
        var i = 0;
        while (i < n) {
            var e = vec_get(existing, i);
            if (streq(entry_path(e), path) == 0) { vec_push(filtered, e); }
            i = i + 1;
        }
    }

    var bytes = hex_decode(hash_hex, 64);
    if (bytes == 0) { return 0 - 1; }
    var new_e = alloc(40);
    memcpy(new_e, bytes, 32);
    var plen = strlen(path);
    var path_copy = alloc(plen + 1);
    memcpy(path_copy, path, plen);
    store8(path_copy + plen, 0);
    store64(new_e + 32, path_copy);
    vec_push(filtered, new_e);

    return rewrite_index(filtered);
}

# Staging entry layout (40 bytes):
#   0..32:  raw hash bytes (SHA-256, decoded from the hex in .sit/index)
#   32..40: path ptr (heap, null-terminated)
fn entry_hash(e) { return e; }
fn entry_path(e) { return load64(e + 32); }

# Load staging index from .sit/index.patra. Returns vec of entries or 0.
# Auto-migrates plaintext .sit/index from v0.1 layout if present.
fn parse_index() {
    # Nothing to load if neither file exists
    if (sf_exists(".sit/index.patra") != 1) {
        if (sf_exists(".sit/index") != 1) { return 0; }
    }

    var db = get_index_db();
    if (db == 0) { return 0; }

    # P-20 (v0.6.11): pre-sort at the patra layer so sort_entries can fall
    # through O(N) on the already-ordered vec. Patra supports ORDER BY since
    # at least 1.6.0; passing it here lets every parse_index consumer skip
    # the O(N²) insertion sort below.
    var rs = patra_query(db, "SELECT path, hash_hex FROM entries ORDER BY path");
    if (rs == 0) { return 0; }

    var count = patra_result_count(rs);
    if (count == 0) {
        patra_result_free(rs);
        return 0;
    }

    var entries = vec_new();
    var i = 0;
    while (i < count) {
        var path_str = patra_result_get_str(rs, i, 0);
        var hash_str = patra_result_get_str(rs, i, 1);

        var bytes = hex_decode(hash_str, 64);
        if (bytes != 0) {
            var entry = alloc(40);
            memcpy(entry, bytes, 32);
            # S-31 RESOLVED in v0.6.10: patra 1.6.1 shipped a sized accessor
            # `patra_result_get_str_len` that bound-walks within the
            # COL_STR_SZ slot. Replaces the v0.6.3 strnlen(path_str, 256)
            # workaround — same safety property at the read site, but now
            # asked of patra's API directly instead of guarded in sit.
            var plen = patra_result_get_str_len(rs, i, 0);
            var p = alloc(plen + 1);
            memcpy(p, path_str, plen);
            store8(p + plen, 0);
            store64(entry + 32, p);
            vec_push(entries, entry);
        }
        i = i + 1;
    }

    patra_result_free(rs);
    if (vec_len(entries) == 0) { return 0; }
    return entries;
}

# Byte-wise compare two null-terminated C strings. Returns -1/0/+1.
# Insertion-sort entries vec by path name (ascending). In place.
fn sort_entries(entries) {
    var n = vec_len(entries);
    var i = 1;
    while (i < n) {
        var cur = vec_get(entries, i);
        var cur_path = entry_path(cur);
        var j = i - 1;
        var placed = 0;
        while (placed == 0) {
            if (j < 0) { placed = 1; }
            else {
                var prev = vec_get(entries, j);
                if (strcmp_cstr(cur_path, entry_path(prev)) >= 0) { placed = 1; }
                else {
                    vec_set(entries, j + 1, prev);
                    j = j - 1;
                }
            }
        }
        vec_set(entries, j + 1, cur);
        i = i + 1;
    }
    return entries;
}

# After sorting, keep only the last entry for each path (staged-twice wins).
fn dedupe_entries(entries) {
    var n = vec_len(entries);
    var out = vec_new();
    var i = 0;
    while (i < n) {
        var cur = vec_get(entries, i);
        var is_last = 1;
        if (i + 1 < n) {
            var nxt = vec_get(entries, i + 1);
            if (strcmp_cstr(entry_path(cur), entry_path(nxt)) == 0) { is_last = 0; }
        }
        if (is_last == 1) { vec_push(out, cur); }
        i = i + 1;
    }
    return out;
}

# Internal tree-level entry (24 bytes):
#   0..8:   mode ptr ("100644" for files, "40000" for dirs)
#   8..16:  name ptr (heap, null-term; leaf name only)
#   16..24: hash bytes ptr (heap, 32 raw bytes)
fn cmd_reset() {
    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }
    if (argc() < 3) {
        eprintln("usage: sit reset <path> | sit reset --hard <ref>");
        return 1;
    }

    # --hard <ref>: move current branch ref to <ref>, overwrite working + index.
    if (streq(argv(2), "--hard") == 1) {
        if (argc() < 4) {
            eprintln("usage: sit reset --hard <ref>");
            return 1;
        }
        var target = argv_heap(3);
        var hex[72];
        var rr = resolve_hash(target, &hex);
        if (rr != 1) {
            syscall(SYS_WRITE, STDERR, "sit: cannot resolve '", 21);
            syscall(SYS_WRITE, STDERR, target, strlen(target));
            syscall(SYS_WRITE, STDERR, "'\n", 2);
            return 1;
        }
        var rl_old = read_head_ref();
        if (write_head_ref(&hex) != 0) {
            eprintln("sit: failed to update branch ref");
            return 1;
        }
        materialize_target(&hex);
        reflog_head_move(rl_old, &hex, reflog_msg_subject("reset: moving to ", target));
        stdout_write("HEAD reset --hard to ", 21);
        stdout_write(&hex, 12);
        stdout_write("\n", 1);
        return 0;
    }

    # sit reset <path>: unstage the path — set its index entry to HEAD's hash,
    # or remove it from the index if HEAD doesn't have it.
    var path = argv_heap(2);
    var path_len = strlen(path);

    var head_entries = read_head_tree_entries();
    var head_ent = tree_find(head_entries, path);

    var index_entries = parse_index();
    if (index_entries != 0) {
        sort_entries(index_entries);
        index_entries = dedupe_entries(index_entries);
    }

    var filtered = vec_new();
    if (index_entries != 0) {
        var n = vec_len(index_entries);
        var i = 0;
        while (i < n) {
            var e = vec_get(index_entries, i);
            if (streq(entry_path(e), path) == 0) { vec_push(filtered, e); }
            i = i + 1;
        }
    }

    if (head_ent != 0) {
        var head_hash_hex = tree_entry_hash(head_ent);
        var bytes = hex_decode(head_hash_hex, 64);
        if (bytes != 0) {
            var new_e = alloc(40);
            memcpy(new_e, bytes, 32);
            var pcopy = alloc(path_len + 1);
            memcpy(pcopy, path, path_len);
            store8(pcopy + path_len, 0);
            store64(new_e + 32, pcopy);
            vec_push(filtered, new_e);
        }
    }

    if (rewrite_index(filtered) != 0) {
        eprintln("sit: failed to update index");
        return 1;
    }
    stdout_write("unstaged '", 10);
    stdout_write(path, path_len);
    stdout_write("'\n", 2);
    return 0;
}

fn cmd_rm() {
    if (argc() < 3) {
        eprintln("usage: sit rm [--cached] <path>");
        return 1;
    }
    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    var cached = 0;
    var arg_idx = 2;
    if (streq(argv(2), "--cached") == 1) {
        cached = 1;
        arg_idx = 3;
        if (argc() < 4) {
            eprintln("usage: sit rm --cached <path>");
            return 1;
        }
    }
    var path = argv_heap(arg_idx);
    var path_len = strlen(path);

    var index_entries = parse_index();
    if (index_entries != 0) {
        sort_entries(index_entries);
        index_entries = dedupe_entries(index_entries);
    }

    var head_entries = read_head_tree_entries();

    var in_index = 0;
    if (index_entries != 0) {
        if (index_find(index_entries, path) != 0) { in_index = 1; }
    }
    var in_head = 0;
    if (tree_find(head_entries, path) != 0) { in_head = 1; }

    if (in_index == 0) {
        if (in_head == 0) {
            syscall(SYS_WRITE, STDERR, "sit: '", 6);
            syscall(SYS_WRITE, STDERR, path, path_len);
            syscall(SYS_WRITE, STDERR, "' is not tracked\n", 17);
            return 1;
        }
    }

    if (index_entries != 0) {
        var filtered = vec_new();
        var n = vec_len(index_entries);
        var i = 0;
        while (i < n) {
            var e = vec_get(index_entries, i);
            if (streq(entry_path(e), path) == 0) { vec_push(filtered, e); }
            i = i + 1;
        }
        if (rewrite_index(filtered) != 0) {
            eprintln("sit: failed to rewrite index");
            return 1;
        }
    }

    if (cached == 0) {
        if (sf_exists(path) == 1) {
            if (sf_unlink(path) != 0) {
                syscall(SYS_WRITE, STDERR, "sit: failed to remove '", 23);
                syscall(SYS_WRITE, STDERR, path, path_len);
                syscall(SYS_WRITE, STDERR, "'\n", 2);
                return 1;
            }
        }
    }

    stdout_write("rm '", 4);
    stdout_write(path, path_len);
    stdout_write("'\n", 2);
    return 0;
}

fn index_find(entries, path) {
    if (entries == 0) { return 0; }
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        if (streq(entry_path(e), path) == 1) { return e; }
        i = i + 1;
    }
    return 0;
}

# gitignore-style wildmatch (v0.8.10 — WM_PATHNAME semantics):
#   '*'     a run of non-'/' chars
#   '?'     one non-'/' char
#   '[...]' a char class for one non-'/' char ('!' negates; 'a-z' ranges;
#           a leading ']' is a literal member)
#   '**'    (two+ stars) a run that MAY cross '/'; a following '/' allows zero
#           dirs, so '**/foo' matches 'foo' at any depth and '/**/' collapses
#   '/'     a literal separator
# Trailing match also succeeds at a '/' boundary in str — directory exclusion:
# 'foo/bar' matches 'foo/bar/baz'. Pattern length capped (S-15) against crafted
# '*'-heavy patterns forcing exponential backtracking.
#
# Simplification vs git: any '**' crosses '/', even when not a whole path
# segment (git only crosses for a segment-bounded '**'). 'a**b' is vanishingly
# rare in real ignore files; the segment cases ('**/x', 'x/**', 'a/**/b') are
# exact.
var _GLOB_PAT_MAX = 256;

fn _wildmatch(pat, plen, str, slen) {
    if (plen > _GLOB_PAT_MAX) { return 0; }
    if (plen == 0) {
        if (slen == 0) { return 1; }
        if ((load8(str) & 0xFF) == 47) { return 1; }   # dir-exclusion
        return 0;
    }
    var pc = load8(pat) & 0xFF;

    if (pc == 42) {   # '*'
        var nstar = 0;
        var counting = 1;
        while (counting == 1) {
            if (nstar < plen) {
                if ((load8(pat + nstar) & 0xFF) == 42) { nstar = nstar + 1; }
                else { counting = 0; }
            }
            else { counting = 0; }
        }
        var rest = pat + nstar;
        var restlen = plen - nstar;
        if (nstar >= 2) {                       # '**' — may cross '/'
            if (restlen == 0) { return 1; }
            if ((load8(rest) & 0xFF) == 47) {   # '**/...' may match zero dirs
                if (_wildmatch(rest + 1, restlen - 1, str, slen) == 1) { return 1; }
            }
            var m = 0;
            var res = 0;
            var done = 0;
            while (done == 0) {
                if (_wildmatch(rest, restlen, str + m, slen - m) == 1) { res = 1; done = 1; }
                else {
                    if (m >= slen) { done = 1; }
                    else { m = m + 1; }
                }
            }
            return res;
        }
        # single '*' — run of non-'/'
        if (_wildmatch(rest, restlen, str, slen) == 1) { return 1; }
        if (slen == 0) { return 0; }
        if ((load8(str) & 0xFF) == 47) { return 0; }
        return _wildmatch(pat, plen, str + 1, slen - 1);
    }

    if (pc == 47) {   # '/'
        if (slen == 0) { return 0; }
        if ((load8(str) & 0xFF) != 47) { return 0; }
        return _wildmatch(pat + 1, plen - 1, str + 1, slen - 1);
    }

    if (slen == 0) { return 0; }
    var sc = load8(str) & 0xFF;

    if (pc == 63) {   # '?'
        if (sc == 47) { return 0; }
        return _wildmatch(pat + 1, plen - 1, str + 1, slen - 1);
    }

    if (pc == 91) {   # '[' char class
        if (sc == 47) { return 0; }
        var ci = 1;
        var negate = 0;
        if (ci < plen) {
            if ((load8(pat + ci) & 0xFF) == 33) { negate = 1; ci = ci + 1; }
        }
        var matched = 0;
        var first = 1;
        var closed = 0;
        var bad = 0;
        while (closed == 0) {
            if (ci >= plen) { bad = 1; closed = 1; }   # unterminated class
            else {
                var cc = load8(pat + ci) & 0xFF;
                if (cc == 93) {                        # ']'
                    if (first == 1) {                  # literal ']' as first member
                        if (sc == 93) { matched = 1; }
                        ci = ci + 1;
                        first = 0;
                    }
                    else { closed = 1; ci = ci + 1; }
                }
                else {
                    first = 0;
                    var is_range = 0;
                    if (ci + 2 < plen) {
                        if ((load8(pat + ci + 1) & 0xFF) == 45) {
                            if ((load8(pat + ci + 2) & 0xFF) != 93) { is_range = 1; }
                        }
                    }
                    if (is_range == 1) {
                        var lo = cc;
                        var hi = load8(pat + ci + 2) & 0xFF;
                        if (sc >= lo) { if (sc <= hi) { matched = 1; } }
                        ci = ci + 3;
                    }
                    else {
                        if (sc == cc) { matched = 1; }
                        ci = ci + 1;
                    }
                }
            }
        }
        if (bad == 1) { return 0; }
        var ok = matched;
        if (negate == 1) {
            if (matched == 1) { ok = 0; }
            else { ok = 1; }
        }
        if (ok == 0) { return 0; }
        return _wildmatch(pat + ci, plen - ci, str + 1, slen - 1);
    }

    if (pc != sc) { return 0; }
    return _wildmatch(pat + 1, plen - 1, str + 1, slen - 1);
}

# True if `path` (repo-relative, e.g. "src/build/foo.o") is ignored. Patterns are
# evaluated IN ORDER and the LAST matching pattern wins — so a later `!pattern`
# re-includes a file an earlier pattern excluded (git semantics). Each pattern is
# a struct: [text, text_len, negated, anchored] (see load_sitignore).
#
#   anchored (pattern had a leading or middle '/'): matched against the full path
#     from the repo root via _wildmatch (its '**' handles any-depth cases).
#   non-anchored (no '/'): matches at ANY level — tried against the full path and
#     against every suffix beginning just after a '/'.
fn is_ignored(path, patterns) {
    if (patterns == 0) { return 0; }
    var path_len = strlen(path);
    var n = vec_len(patterns);
    var i = 0;
    var result = 0;   # 0 = not ignored; the last matching pattern overwrites this
    while (i < n) {
        var p = vec_get(patterns, i);
        var text = load64(p);
        var tlen = load64(p + 8);
        var negated = load64(p + 16);
        var anchored = load64(p + 24);

        var m = 0;
        if (anchored == 1) {
            m = _wildmatch(text, tlen, path, path_len);
        }
        else {
            if (_wildmatch(text, tlen, path, path_len) == 1) { m = 1; }
            else {
                var k = 0;
                while (k < path_len) {
                    if (load8(path + k) == 47) {
                        if (_wildmatch(text, tlen, path + k + 1, path_len - k - 1) == 1) {
                            m = 1;
                            k = path_len;
                        }
                    }
                    if (k < path_len) { k = k + 1; }
                }
            }
        }

        if (m == 1) {
            if (negated == 1) { result = 0; }
            else { result = 1; }
        }
        i = i + 1;
    }
    return result;
}

# Read `.sitignore` into a vec of pattern structs (32 bytes each):
#   [0]  text ptr (NUL-terminated, with leading `!` / leading `/` / trailing `/`
#        stripped), [8] text_len, [16] negated (leading `!`), [24] anchored
#        (leading or middle `/` → matched from the repo root).
# Blank lines and `#` comments are skipped; `\!` / `\#` escape a literal first
# char; a trailing `/` (directory hint) is stripped (dir-only is not enforced —
# the same simplification as before).
fn load_sitignore() {
    # Backend-aware ignore file: .sitignore (sit) or .gitignore (git read-mode).
    var fname = _ignore_filename();
    if (sf_exists(fname) != 1) { return 0; }
    var pair[16];
    if (read_file_heap(fname, &pair) != 0) { return 0; }
    var data = load64(&pair);
    var len = load64(&pair + 8);

    var patterns = vec_new();
    var pos = 0;
    while (pos < len) {
        var line_end = pos;
        while (line_end < len) {
            if (load8(data + line_end) == 10) { break; }
            line_end = line_end + 1;
        }

        var ls = pos;
        var le = line_end;
        if (le > ls) {
            if (load8(data + le - 1) == 13) { le = le - 1; }   # strip CR
        }

        var keep = 1;
        if (le == ls) { keep = 0; }                            # blank line
        else {
            if (load8(data + ls) == 35) { keep = 0; }          # '#' comment
        }

        if (keep == 1) {
            var s = ls;
            var negated = 0;
            var c0 = load8(data + s) & 0xFF;
            if (c0 == 33) { negated = 1; s = s + 1; }           # leading '!'
            else {
                if (c0 == 92) {                                 # '\' escape
                    if (s + 1 < le) {
                        var nx = load8(data + s + 1) & 0xFF;
                        if (nx == 33) { s = s + 1; }             # '\!' -> literal '!'
                        else {
                            if (nx == 35) { s = s + 1; }         # '\#' -> literal '#'
                        }
                    }
                }
            }

            var anchored = 0;
            if (s < le) {
                if (load8(data + s) == 47) { anchored = 1; s = s + 1; }   # leading '/'
            }
            var e = le;
            if (e > s) {
                if (load8(data + e - 1) == 47) { e = e - 1; }   # strip trailing '/'
            }
            if (anchored == 0) {
                var k = s;
                while (k < e) {
                    if (load8(data + k) == 47) { anchored = 1; k = e; }   # middle '/'
                    else { k = k + 1; }
                }
            }

            var tlen = e - s;
            if (tlen > 0) {
                var text = alloc(tlen + 1);
                memcpy(text, data + s, tlen);
                store8(text + tlen, 0);
                var p = alloc(32);
                store64(p, text);
                store64(p + 8, tlen);
                store64(p + 16, negated);
                store64(p + 24, anchored);
                vec_push(patterns, p);
            }
        }
        pos = line_end + 1;
    }
    return patterns;
}

# Recursive working-dir walker. Entries are pushed as full repo-relative
# paths ("src/main.cyr"). Hardcoded skip: `.sit/`. Everything else is
# included unless it matches a `.sitignore` pattern.

# --- refs.cyr ---

# refs.cyr — HEAD / branch / tag / resolution.
#
# Refs live at .sit/HEAD (symbolic), .sit/refs/heads/<name>, .sit/refs/tags/<name>,
# and .sit/refs/remotes/<remote>/<name>. ensure_parent_dirs (util.cyr) is called
# by every write path so nested names like feature/foo work.

# Resolve a "<base>@{N}" reflog selector to the new-oid recorded N moves
# ago. Writes 64-hex + nul into out_buf. Returns 1 on success, 0 if `name`
# isn't a reflog selector or the base has no log / N is out of range. The
# base's log is found by class: HEAD → logs/HEAD; otherwise logs/refs/heads/
# <base>, then logs/refs/remotes/<base> (tags aren't logged). Called from
# resolve_ref_name in REVISION context — distinct from refname_valid, which
# rejects '@{' in ref-NAME context (so x@{0} never becomes a ref file).
fn resolve_reflog_spec(name, out_buf) {
    var spec[24];
    if (_reflog_spec_parse(name, &spec) == 0) { return 0; }
    var blen = load64(&spec + 8);
    var num = load64(&spec + 16);
    var base = alloc(blen + 1);
    memcpy(base, name, blen);
    store8(base + blen, 0);

    if (streq(base, "HEAD") == 1) {
        return reflog_read_nth("HEAD", num, out_buf);
    }

    # S-02: the base becomes a .sit/logs/ path component below; reject
    # traversal ('..', leading '/') and control chars before it does. An
    # invalid base simply isn't a resolvable selector → fall through (0).
    if (refname_valid(base) == 0) { return 0; }

    var hp = alloc(11 + blen + 1);
    memcpy(hp, "refs/heads/", 11);
    memcpy(hp + 11, base, blen);
    store8(hp + 11 + blen, 0);
    if (sf_exists(reflog_log_path(hp)) == 1) {
        return reflog_read_nth(hp, num, out_buf);
    }

    var rp = alloc(13 + blen + 1);
    memcpy(rp, "refs/remotes/", 13);
    memcpy(rp + 13, base, blen);
    store8(rp + 13 + blen, 0);
    if (sf_exists(reflog_log_path(rp)) == 1) {
        return reflog_read_nth(rp, num, out_buf);
    }
    return 0;
}

fn resolve_ref_name(name, out_buf) {
    # Storage seam (roadmap 1.2.0): a .git/ repo resolves refs from .git/HEAD,
    # .git/refs/, and .git/packed-refs. @{N} reflog specs are .sit-only for now.
    if (_repo_backend == 1) { return _git_resolve_ref_name(name, out_buf); }

    # Reflog selector <ref>@{N} takes precedence over plain-name lookup.
    if (resolve_reflog_spec(name, out_buf) == 1) { return 1; }
    if (streq(name, "HEAD") == 1) {
        var h = read_head_ref();
        if (h == 0) { return 0; }
        memcpy(out_buf, h, 64);
        store8(out_buf + 64, 0);
        return 1;
    }

    var name_len = strlen(name);

    var tag_path = alloc(15 + name_len + 1);
    memcpy(tag_path, ".sit/refs/tags/", 15);
    memcpy(tag_path + 15, name, name_len);
    store8(tag_path + 15 + name_len, 0);
    # S-11: all three ref-file readers below validate that the first 64 bytes
    # are actual hex before accepting. A garbage or attacker-crafted ref is
    # treated as "no such ref" rather than flowed through as a "hash".
    if (sf_exists(tag_path) == 1) {
        var tfd = sf_open(tag_path, 0, 0);
        if (tfd >= 0) {
            var tbuf = alloc(80);
            var tn = file_read(tfd, tbuf, 80);
            file_close(tfd);
            if (tn >= 64) {
                if (hex_prefix_valid(tbuf, 64) == 1) {
                    memcpy(out_buf, tbuf, 64);
                    store8(out_buf + 64, 0);
                    return 1;
                }
            }
        }
    }

    var head_path = alloc(16 + name_len + 1);
    memcpy(head_path, ".sit/refs/heads/", 16);
    memcpy(head_path + 16, name, name_len);
    store8(head_path + 16 + name_len, 0);
    if (sf_exists(head_path) == 1) {
        var hfd = sf_open(head_path, 0, 0);
        if (hfd >= 0) {
            var hbuf = alloc(80);
            var hn = file_read(hfd, hbuf, 80);
            file_close(hfd);
            if (hn >= 64) {
                if (hex_prefix_valid(hbuf, 64) == 1) {
                    memcpy(out_buf, hbuf, 64);
                    store8(out_buf + 64, 0);
                    return 1;
                }
            }
        }
    }

    # Remote-tracking ref (e.g. "origin/main" → .sit/refs/remotes/origin/main)
    var rem_path = alloc(18 + name_len + 1);
    memcpy(rem_path, ".sit/refs/remotes/", 18);
    memcpy(rem_path + 18, name, name_len);
    store8(rem_path + 18 + name_len, 0);
    if (sf_exists(rem_path) == 1) {
        var rfd = sf_open(rem_path, 0, 0);
        if (rfd >= 0) {
            var rbuf = alloc(80);
            var rn = file_read(rfd, rbuf, 80);
            file_close(rfd);
            if (rn >= 64) {
                if (hex_prefix_valid(rbuf, 64) == 1) {
                    memcpy(out_buf, rbuf, 64);
                    store8(out_buf + 64, 0);
                    return 1;
                }
            }
        }
    }

    return 0;
}

# Resolve a reference: either a symbolic name (HEAD, tag, branch) or a hex hash
# (full 64 chars or a prefix of 4+). Writes null-terminated hash into out_buf
# (65 bytes) and returns:
#    1  exact match
#    0  no match
#   -1  ambiguous
#   -2  prefix too short
fn read_head_ref_path() {
    var pair[16];
    # Backend-aware HEAD path: ".sit/HEAD" or ".git/HEAD" (both 9 bytes; the
    # "ref: <path>" symref format is identical across backends).
    var hp[12];
    memcpy(&hp, _repo_dir(), 5);
    memcpy(&hp + 5, "HEAD", 4);
    store8(&hp + 9, 0);
    if (read_file_heap(&hp, &pair) != 0) { return 0; }
    var buf = load64(&pair);
    var len = load64(&pair + 8);

    if (len < 5) { return 0; }
    if (memeq(buf, "ref: ", 5) == 0) { return 0; }

    var stop = 5;
    var scanning = 1;
    while (scanning == 1) {
        if (stop >= len) { scanning = 0; }
        else {
            var c = load8(buf + stop);
            if (c == 10) { scanning = 0; }
            else {
                if (c == 13) { scanning = 0; }
                else { stop = stop + 1; }
            }
        }
    }

    var ref_len = stop - 5;
    if (ref_len == 0) { return 0; }

    var ref = alloc(ref_len + 1);
    memcpy(ref, buf + 5, ref_len);
    store8(ref + ref_len, 0);
    return ref;
}

# Read the ref file pointed at by HEAD. Returns 64-char hex or 0.
fn read_head_ref() {
    # Storage seam (roadmap 1.2.0): git refs may be loose or in packed-refs, and
    # the id width is _id_hexlen(). Dispatch to the git reader before the .sit path.
    if (_repo_backend == 1) { return _git_read_head_ref(); }

    var ref_path = read_head_ref_path();
    if (ref_path == 0) { return 0; }
    var ref_len = strlen(ref_path);
    var full = alloc(5 + ref_len + 1);
    memcpy(full, ".sit/", 5);
    memcpy(full + 5, ref_path, ref_len);
    store8(full + 5 + ref_len, 0);

    if (sf_exists(full) != 1) { return 0; }
    var fd = sf_open(full, 0, 0);
    if (fd < 0) { return 0; }
    var buf = alloc(80);
    var n = file_read(fd, buf, 80);
    file_close(fd);
    if (n < 64) { return 0; }
    # S-11: validate the first 64 bytes are actual hex before returning —
    # otherwise a corrupt or hostile ref file flows garbage through the
    # whole stack (and into resolve_hash's LIKE after S-01 rejects it).
    if (hex_prefix_valid(buf, 64) == 0) { return 0; }
    store8(buf + 64, 0);
    return buf;
}

# Write the given 64-char hex to the ref file HEAD points at.
fn write_head_ref(hex) {
    var ref_path = read_head_ref_path();
    if (ref_path == 0) { return 0 - 1; }
    var ref_len = strlen(ref_path);
    var full = alloc(5 + ref_len + 1);
    memcpy(full, ".sit/", 5);
    memcpy(full + 5, ref_path, ref_len);
    store8(full + 5 + ref_len, 0);
    ensure_parent_dirs(full);

    var out = alloc(66);
    memcpy(out, hex, 64);
    store8(out + 64, 10);
    store8(out + 65, 0);
    if (sf_write_all(full, out, 65) < 0) { return 0 - 1; }
    return 0;
}

# Record a HEAD movement in the reflog. A branch-tip move that HEAD points
# at is logged TWICE per git semantics — once to .sit/logs/HEAD and once to
# the branch log (.sit/logs/refs/heads/<b>); a detached HEAD logs only to
# .sit/logs/HEAD. Call this AFTER a successful write_head_ref, passing the
# tip read BEFORE the write as old_hex (0 → creation). Best-effort: a failed
# append never propagates, so logging can't undo a committed ref move.
# Lives here (not reflog.cyr) because it reads read_head_ref_path, which is
# defined later than reflog.cyr in the single-pass dist bundle order.
fn reflog_head_move(old_hex, new_hex, msg) {
    # Resolve identity + timestamp ONCE so the HEAD log and the branch log
    # record an identical (ts, name, email) for this one atomic move (git's
    # single-timestamp-per-transaction behaviour).
    var nm = _reflog_user_name();
    var em = _reflog_user_email();
    var ts = clock_epoch_secs();
    _reflog_append_full("HEAD", old_hex, new_hex, msg, nm, em, ts);
    var branch = read_head_ref_path();
    if (branch != 0) {
        if (memeq(branch, "refs/heads/", 11) == 1) {
            _reflog_append_full(branch, old_hex, new_hex, msg, nm, em, ts);
        }
    }
    return 0;
}

# Extract the branch name from HEAD (e.g. "main" from "refs/heads/main").
# Returns heap cstring or 0 if HEAD isn't a branch ref.
fn current_branch_name() {
    var ref_path = read_head_ref_path();
    if (ref_path == 0) { return 0; }
    var ref_len = strlen(ref_path);
    if (ref_len <= 11) { return ref_path; }
    if (memeq(ref_path, "refs/heads/", 11) == 0) { return ref_path; }
    var name_len = ref_len - 11;
    var name = alloc(name_len + 1);
    memcpy(name, ref_path + 11, name_len);
    store8(name + name_len, 0);
    return name;
}

# Build and write a commit object. Returns hex hash or 0.
fn set_head_ref(ref_path) {
    var rlen = strlen(ref_path);
    var total = 5 + rlen + 1;
    var buf = alloc(total + 1);
    memcpy(buf, "ref: ", 5);
    memcpy(buf + 5, ref_path, rlen);
    store8(buf + 5 + rlen, 10);
    store8(buf + total, 0);
    if (sf_write_all(".sit/HEAD", buf, total) < 0) { return 0 - 1; }
    return 0;
}

# Extract hunks from an LCS op-script. A hunk groups consecutive
# non-keep ops (deletes and/or inserts) and records the base line range
# it covers along with the replacement lines from the other side.
#
# Hunk layout (24 bytes):
#   [0..8)   base_start (inclusive base line index)
#   [8..16)  base_end   (exclusive base line index)
#   [16..24) replacement lines vec (each element is a line-tuple pointer)
fn cmd_tag() {
    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    if (argc() < 3) {
        if (sf_exists(".sit/refs/tags") != 1) { return 0; }
        var raw = sf_dir_list(str_from(".sit/refs/tags"));
        var names = vec_new();
        var n = vec_len(raw);
        var i = 0;
        while (i < n) {
            var s = vec_get(raw, i);
            var slen = str_len(s);
            var nm = alloc(slen + 1);
            memcpy(nm, str_data(s), slen);
            store8(nm + slen, 0);
            vec_push(names, nm);
            i = i + 1;
        }
        sort_cstrings(names);
        var m = vec_len(names);
        i = 0;
        while (i < m) {
            var nm = vec_get(names, i);
            stdout_write(nm, strlen(nm));
            stdout_write("\n", 1);
            i = i + 1;
        }
        return 0;
    }

    # Deletion: sit tag -d <name>
    if (streq(argv(2), "-d") == 1) {
        if (argc() < 4) {
            eprintln("usage: sit tag -d <name>");
            return 1;
        }
        var dname = argv_heap(3);
        var dnlen = strlen(dname);
        var dpath = alloc(15 + dnlen + 1);
        memcpy(dpath, ".sit/refs/tags/", 15);
        memcpy(dpath + 15, dname, dnlen);
        store8(dpath + 15 + dnlen, 0);
        if (sf_exists(dpath) != 1) {
            syscall(SYS_WRITE, STDERR, "sit: tag '", 10);
            syscall(SYS_WRITE, STDERR, dname, dnlen);
            syscall(SYS_WRITE, STDERR, "' not found\n", 12);
            return 1;
        }
        if (sf_unlink(dpath) != 0) {
            eprintln("sit: failed to remove tag ref");
            return 1;
        }
        stdout_write("deleted tag '", 13);
        stdout_write(dname, dnlen);
        stdout_write("'\n", 2);
        return 0;
    }

    var name = argv_heap(2);
    var nlen = strlen(name);
    # S-02: tag names follow the same ref-format grammar as branches.
    if (refname_valid(name) == 0) {
        eprintln("sit: invalid tag name (see git check-ref-format rules)");
        return 1;
    }
    var path = alloc(15 + nlen + 1);
    memcpy(path, ".sit/refs/tags/", 15);
    memcpy(path + 15, name, nlen);
    store8(path + 15 + nlen, 0);

    if (sf_exists(path) == 1) {
        syscall(SYS_WRITE, STDERR, "sit: tag '", 10);
        syscall(SYS_WRITE, STDERR, name, nlen);
        syscall(SYS_WRITE, STDERR, "' already exists\n", 17);
        return 1;
    }

    var target_hex = 0;
    if (argc() >= 4) {
        var prefix = argv_heap(3);
        var hex[72];
        var rr = resolve_hash(prefix, &hex);
        if (rr != 1) {
            eprintln("sit: cannot resolve target commit");
            return 1;
        }
        target_hex = alloc(65);
        memcpy(target_hex, &hex, 64);
        store8(target_hex + 64, 0);
    }
    else {
        target_hex = read_head_ref();
        if (target_hex == 0) {
            eprintln("sit: cannot tag with no commits");
            return 1;
        }
    }

    ensure_dir(".sit/refs/tags");
    ensure_parent_dirs(path);

    var buf = alloc(66);
    memcpy(buf, target_hex, 64);
    store8(buf + 64, 10);
    store8(buf + 65, 0);
    if (sf_write_all(path, buf, 65) < 0) {
        eprintln("sit: failed to write tag ref");
        return 1;
    }

    stdout_write("created tag '", 13);
    stdout_write(name, nlen);
    stdout_write("'\n", 2);
    return 0;
}

fn cmd_branch() {
    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    if (argc() < 3) {
        if (sf_exists(".sit/refs/heads") != 1) { return 0; }
        var raw = sf_dir_list(str_from(".sit/refs/heads"));
        var names = vec_new();
        var n = vec_len(raw);
        var i = 0;
        while (i < n) {
            var s = vec_get(raw, i);
            var slen = str_len(s);
            var nm = alloc(slen + 1);
            memcpy(nm, str_data(s), slen);
            store8(nm + slen, 0);
            vec_push(names, nm);
            i = i + 1;
        }
        sort_cstrings(names);
        var curr = current_branch_name();
        i = 0;
        var m = vec_len(names);
        while (i < m) {
            var nm = vec_get(names, i);
            var is_current = 0;
            if (curr != 0) {
                if (streq(nm, curr) == 1) { is_current = 1; }
            }
            if (is_current == 1) { stdout_write("* ", 2); }
            else                 { stdout_write("  ", 2); }
            stdout_write(nm, strlen(nm));
            stdout_write("\n", 1);
            i = i + 1;
        }
        return 0;
    }

    # Deletion: sit branch -d <name>
    if (streq(argv(2), "-d") == 1) {
        if (argc() < 4) {
            eprintln("usage: sit branch -d <name>");
            return 1;
        }
        var dname = argv_heap(3);
        var dnlen = strlen(dname);
        var dpath = alloc(16 + dnlen + 1);
        memcpy(dpath, ".sit/refs/heads/", 16);
        memcpy(dpath + 16, dname, dnlen);
        store8(dpath + 16 + dnlen, 0);
        if (sf_exists(dpath) != 1) {
            syscall(SYS_WRITE, STDERR, "sit: branch '", 13);
            syscall(SYS_WRITE, STDERR, dname, dnlen);
            syscall(SYS_WRITE, STDERR, "' not found\n", 12);
            return 1;
        }
        var curr_br = current_branch_name();
        if (curr_br != 0) {
            if (streq(curr_br, dname) == 1) {
                eprintln("sit: cannot delete the currently checked-out branch");
                return 1;
            }
        }
        if (sf_unlink(dpath) != 0) {
            eprintln("sit: failed to remove branch ref");
            return 1;
        }
        # Mirror git: deleting a branch deletes its reflog too. Leaving the
        # log orphaned would pin the branch's objects against fsck --prune
        # forever (it walks every .sit/logs/** file) and corrupt <name>@{N}
        # if the branch were later recreated (append to a stale log). Best-
        # effort unlink — a missing log (branch never logged) is fine.
        var dlref = alloc(11 + dnlen + 1);
        memcpy(dlref, "refs/heads/", 11);
        memcpy(dlref + 11, dname, dnlen);
        store8(dlref + 11 + dnlen, 0);
        sf_unlink(reflog_log_path(dlref));
        stdout_write("deleted branch '", 16);
        stdout_write(dname, dnlen);
        stdout_write("'\n", 2);
        return 0;
    }

    var name = argv_heap(2);
    var nlen = strlen(name);
    # S-02: reject names that don't satisfy git check-ref-format rules.
    if (refname_valid(name) == 0) {
        eprintln("sit: invalid branch name (see git check-ref-format rules)");
        return 1;
    }
    var path = alloc(16 + nlen + 1);
    memcpy(path, ".sit/refs/heads/", 16);
    memcpy(path + 16, name, nlen);
    store8(path + 16 + nlen, 0);

    if (sf_exists(path) == 1) {
        syscall(SYS_WRITE, STDERR, "sit: branch '", 13);
        syscall(SYS_WRITE, STDERR, name, nlen);
        syscall(SYS_WRITE, STDERR, "' already exists\n", 17);
        return 1;
    }

    var head_hex = read_head_ref();
    if (head_hex == 0) {
        eprintln("sit: cannot create a branch with no commits");
        return 1;
    }

    ensure_parent_dirs(path);
    var buf = alloc(66);
    memcpy(buf, head_hex, 64);
    store8(buf + 64, 10);
    store8(buf + 65, 0);
    if (sf_write_all(path, buf, 65) < 0) {
        eprintln("sit: failed to write branch ref");
        return 1;
    }

    # Reflog the new branch's creation (old=zeros). HEAD doesn't move, so
    # only the new branch's log gets an entry — not logs/HEAD.
    var br_ref = alloc(11 + nlen + 1);
    memcpy(br_ref, "refs/heads/", 11);
    memcpy(br_ref + 11, name, nlen);
    store8(br_ref + 11 + nlen, 0);
    reflog_append(br_ref, 0, head_hex, "branch: Created from HEAD");

    stdout_write("created branch '", 16);
    stdout_write(name, nlen);
    stdout_write("'\n", 2);
    return 0;
}

# True if there are any staged or unstaged changes vs HEAD. Untracked files
# are not considered dirty (they don't block checkout unless they collide).
fn cmd_checkout() {
    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }
    if (argc() < 3) {
        eprintln("usage: sit checkout [-b] <branch>");
        return 1;
    }

    var create = 0;
    var arg_idx = 2;
    if (streq(argv(2), "-b") == 1) {
        create = 1;
        arg_idx = 3;
        if (argc() < 4) {
            eprintln("usage: sit checkout -b <branch>");
            return 1;
        }
    }
    var target = argv_heap(arg_idx);
    var tlen = strlen(target);

    if (create == 1) {
        # S-02: validate branch name before touching the filesystem.
        if (refname_valid(target) == 0) {
            eprintln("sit: invalid branch name (see git check-ref-format rules)");
            return 1;
        }
        var new_branch = alloc(16 + tlen + 1);
        memcpy(new_branch, ".sit/refs/heads/", 16);
        memcpy(new_branch + 16, target, tlen);
        store8(new_branch + 16 + tlen, 0);
        if (sf_exists(new_branch) == 1) {
            syscall(SYS_WRITE, STDERR, "sit: branch '", 13);
            syscall(SYS_WRITE, STDERR, target, tlen);
            syscall(SYS_WRITE, STDERR, "' already exists\n", 17);
            return 1;
        }
        var head_hex = read_head_ref();
        if (head_hex == 0) {
            eprintln("sit: cannot create a branch with no commits");
            return 1;
        }
        ensure_parent_dirs(new_branch);
        var buf = alloc(66);
        memcpy(buf, head_hex, 64);
        store8(buf + 64, 10);
        store8(buf + 65, 0);
        if (sf_write_all(new_branch, buf, 65) < 0) {
            eprintln("sit: failed to write branch ref");
            return 1;
        }
        # Reflog the -b branch creation (old=zeros) to the new branch's log.
        var nb_ref = alloc(11 + tlen + 1);
        memcpy(nb_ref, "refs/heads/", 11);
        memcpy(nb_ref + 11, target, tlen);
        store8(nb_ref + 11 + tlen, 0);
        reflog_append(nb_ref, 0, head_hex, "branch: Created from HEAD");
    }

    var target_ref_len = 11 + tlen;
    var target_ref = alloc(target_ref_len + 1);
    memcpy(target_ref, "refs/heads/", 11);
    memcpy(target_ref + 11, target, tlen);
    store8(target_ref + target_ref_len, 0);

    var target_path = alloc(5 + target_ref_len + 1);
    memcpy(target_path, ".sit/", 5);
    memcpy(target_path + 5, target_ref, target_ref_len);
    store8(target_path + 5 + target_ref_len, 0);

    if (sf_exists(target_path) != 1) {
        syscall(SYS_WRITE, STDERR, "sit: branch '", 13);
        syscall(SYS_WRITE, STDERR, target, tlen);
        syscall(SYS_WRITE, STDERR, "' not found\n", 12);
        return 1;
    }

    var curr = current_branch_name();
    if (curr != 0) {
        if (streq(curr, target) == 1) {
            stdout_write("already on '", 12);
            stdout_write(target, tlen);
            stdout_write("'\n", 2);
            return 0;
        }
    }

    if (is_dirty() == 1) {
        eprintln("sit: working tree has uncommitted changes");
        eprintln("sit:   commit or revert before switching branches");
        return 1;
    }

    var target_fd = sf_open(target_path, 0, 0);
    if (target_fd < 0) {
        eprintln("sit: cannot read target branch ref");
        return 1;
    }
    var target_hex = alloc(80);
    var n = file_read(target_fd, target_hex, 80);
    file_close(target_fd);
    if (n < 64) {
        eprintln("sit: target ref is invalid");
        return 1;
    }
    store8(target_hex + 64, 0);

    var target_entries = commit_tree_entries(target_hex);
    if (target_entries == 0) { target_entries = vec_new(); }
    var curr_entries = read_head_tree_entries();
    if (curr_entries == 0) { curr_entries = vec_new(); }

    # Collision check: untracked files on disk that would be overwritten
    var working = list_working_files();
    var wn = vec_len(working);
    var wi = 0;
    while (wi < wn) {
        var wpath = vec_get(working, wi);
        if (tree_find(curr_entries, wpath) == 0) {
            if (tree_find(target_entries, wpath) != 0) {
                syscall(SYS_WRITE, STDERR, "sit: untracked file '", 21);
                syscall(SYS_WRITE, STDERR, wpath, strlen(wpath));
                syscall(SYS_WRITE, STDERR, "' would be overwritten\n", 23);
                return 1;
            }
        }
        wi = wi + 1;
    }

    materialize_target(target_hex);

    # Capture the old HEAD tip before the symref moves (materialize doesn't
    # touch refs, so this still resolves the branch we're leaving).
    var co_old = read_head_ref();
    if (set_head_ref(target_ref) != 0) {
        eprintln("sit: failed to update HEAD");
        return 1;
    }

    # Reflog the branch switch to logs/HEAD only (no branch-tip moved):
    # "checkout: moving from <old> to <new>".
    var co_oldname = curr;
    if (co_oldname == 0) { co_oldname = "HEAD"; }
    var co_onl = strlen(co_oldname);
    var co_msg = alloc(30 + co_onl + tlen);
    var co_mp = 0;
    memcpy(co_msg + co_mp, "checkout: moving from ", 22); co_mp = co_mp + 22;
    memcpy(co_msg + co_mp, co_oldname, co_onl); co_mp = co_mp + co_onl;
    memcpy(co_msg + co_mp, " to ", 4); co_mp = co_mp + 4;
    memcpy(co_msg + co_mp, target, tlen); co_mp = co_mp + tlen;
    store8(co_msg + co_mp, 0);
    reflog_append("HEAD", co_old, target_hex, co_msg);

    stdout_write("switched to branch '", 20);
    stdout_write(target, tlen);
    stdout_write("'\n", 2);
    return 0;
}

# --- tree.cyr ---

# tree.cyr — sit tree objects.
#
# Top-level tree layout for subdirectory grouping (`tlvl_*`), git-SHA-256-compatible
# tree entry parse / build / flatten, and tree_find lookups. Trees encode
# directories as `40000 <name>\0<32B hash>` entries and files as `100644 ...`.

fn tlvl_mode(e) { return load64(e); }
fn tlvl_name(e) { return load64(e + 8); }
fn tlvl_bytes(e) { return load64(e + 16); }

# Recursive tree writer.
# `entries` is a slice of the sorted+deduped staging index; all entries passed
# at a given call share the same prefix of length `prefix_len` (empty at root).
# Lexical sort of full paths produces correct per-tree git order when walked
# depth-first — no separate sort step needed at the level.
# Returns tree hex hash, or 0 on failure.
fn build_tree(entries, prefix_len) {
    var level = vec_new();
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        var full_path = entry_path(e);
        var rest = full_path + prefix_len;
        var rest_len = strlen(full_path) - prefix_len;

        var slash = 0;
        var found = 0;
        while (slash < rest_len) {
            if (load8(rest + slash) == 47) { found = 1; break; }
            slash = slash + 1;
        }

        if (found == 0) {
            var name = alloc_or_die(rest_len + 1);
            memcpy(name, rest, rest_len);
            store8(name + rest_len, 0);

            var le = alloc_or_die(24);
            store64(le, "100644");
            store64(le + 8, name);
            store64(le + 16, entry_hash(e));
            vec_push(level, le);
            i = i + 1;
        }
        else {
            var subdir_name = alloc_or_die(slash + 1);
            memcpy(subdir_name, rest, slash);
            store8(subdir_name + slash, 0);

            var sub_prefix_len = prefix_len + slash + 1;
            var sub_entries = vec_new();

            var collecting = 1;
            while (collecting == 1) {
                if (i >= n) { collecting = 0; }
                else {
                    var ee = vec_get(entries, i);
                    var ee_path = entry_path(ee);
                    var ee_len = strlen(ee_path);
                    var ok = 1;
                    if (ee_len <= prefix_len + slash) { ok = 0; }
                    else {
                        var m = 0;
                        while (m < slash) {
                            if (load8(ee_path + prefix_len + m) != load8(rest + m)) { ok = 0; }
                            m = m + 1;
                        }
                        if (ok == 1) {
                            if (load8(ee_path + prefix_len + slash) != 47) { ok = 0; }
                        }
                    }
                    if (ok == 0) { collecting = 0; }
                    else {
                        vec_push(sub_entries, ee);
                        i = i + 1;
                    }
                }
            }

            var sub_hex = build_tree(sub_entries, sub_prefix_len);
            if (sub_hex == 0) { return 0; }
            var sub_bytes = hex_decode(sub_hex, 64);
            if (sub_bytes == 0) { return 0; }

            var le = alloc_or_die(24);
            store64(le, "40000");
            store64(le + 8, subdir_name);
            store64(le + 16, sub_bytes);
            vec_push(level, le);
        }
    }

    var body_size = 0;
    var k = 0;
    var nl = vec_len(level);
    while (k < nl) {
        var le = vec_get(level, k);
        body_size = body_size + strlen(tlvl_mode(le)) + 1 + strlen(tlvl_name(le)) + 1 + 32;
        k = k + 1;
    }

    var body = alloc_or_die(body_size);
    var pos = 0;
    k = 0;
    while (k < nl) {
        var le = vec_get(level, k);
        var mode = tlvl_mode(le);
        var name = tlvl_name(le);
        var mlen = strlen(mode);
        var nlen = strlen(name);
        memcpy(body + pos, mode, mlen); pos = pos + mlen;
        store8(body + pos, 32); pos = pos + 1;
        memcpy(body + pos, name, nlen); pos = pos + nlen;
        store8(body + pos, 0); pos = pos + 1;
        memcpy(body + pos, tlvl_bytes(le), 32); pos = pos + 32;
        k = k + 1;
    }

    return write_typed_object("tree", 4, body, body_size);
}

# Parse .sit/HEAD. If symbolic (`ref: refs/heads/<branch>\n`), returns the
# ref path (heap cstring, e.g. "refs/heads/main"). Returns 0 on missing HEAD,
# detached (raw hex), or malformed content.
fn tree_entry_mode(e) { return load64(e); }
fn tree_entry_name(e) { return load64(e + 8); }
fn tree_entry_hash(e) { return load64(e + 16); }

# Parse tree object body. Returns vec of entries.
fn parse_tree(body, body_len) {
    var entries = vec_new();
    # Raw hash width per active backend: 32 (sit SHA-256) or 20 (git SHA-1).
    var rawlen = _id_rawlen();
    var pos = 0;
    while (pos < body_len) {
        var sp = pos;
        while (sp < body_len) {
            if (load8(body + sp) == 32) { break; }
            sp = sp + 1;
        }
        if (sp >= body_len) { pos = body_len; }
        else {
            var mode_len = sp - pos;
            var mode = alloc_or_die(mode_len + 1);
            memcpy(mode, body + pos, mode_len);
            store8(mode + mode_len, 0);

            var nu = sp + 1;
            while (nu < body_len) {
                if (load8(body + nu) == 0) { break; }
                nu = nu + 1;
            }
            if (nu >= body_len) { pos = body_len; }
            else {
                var name_len = nu - sp - 1;
                var name = alloc_or_die(name_len + 1);
                memcpy(name, body + sp + 1, name_len);
                store8(name + name_len, 0);

                if (nu + 1 + rawlen > body_len) { pos = body_len; }
                else {
                    # S-03: reject tree entries whose mode isn't allowlisted or
                    # whose name would let an attacker escape the working tree.
                    # Silent drop here means a malicious subtree is treated as
                    # empty — materialize_target won't act on it, and fsck will
                    # flag the mismatch on the outer tree's hash-of-bytes.
                    if (tree_entry_mode_valid(mode) == 1) {
                        if (tree_entry_name_valid(name) == 1) {
                            var hash_hex = hex_encode(body + nu + 1, rawlen);
                            var e = alloc_or_die(24);
                            store64(e, mode);
                            store64(e + 8, name);
                            store64(e + 16, hash_hex);
                            vec_push(entries, e);
                        }
                    }
                    pos = nu + 1 + rawlen;
                }
            }
        }
    }
    return entries;
}

# Recursively walk a tree, pushing one entry per file to `out` with the full
# path (e.g., "src/main.cyr") stored in the `name` slot. Subtree entries are
# traversed, not emitted. Returned entries can be searched by `tree_find`
# against full paths because it only uses the name/hash slots.
#
# S-14: bounds recursion depth via a module-level counter. 256 levels matches
# git's limit and covers every realistic project hierarchy.

var _TREE_MAX_DEPTH = 256;
var _tree_walk_depth = 0;

fn flatten_tree(tree_hex, prefix, out) {
    if (_tree_walk_depth >= _TREE_MAX_DEPTH) {
        eprintln("sit: tree depth exceeds 256 — refusing to walk further");
        return 0 - 2;
    }
    _tree_walk_depth = _tree_walk_depth + 1;
    var obj[24];
    if (read_object(tree_hex, &obj) != 0) {
        _tree_walk_depth = _tree_walk_depth - 1;
        return 0 - 1;
    }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);

    var entries = parse_tree(buf + coff, blen - coff);
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        var mode = tree_entry_mode(e);
        var name = tree_entry_name(e);
        var hash_hex = tree_entry_hash(e);

        var prefix_len = strlen(prefix);
        var name_len = strlen(name);

        if (streq(mode, "40000") == 1) {
            var sub_prefix = alloc_or_die(prefix_len + name_len + 2);
            memcpy(sub_prefix, prefix, prefix_len);
            memcpy(sub_prefix + prefix_len, name, name_len);
            store8(sub_prefix + prefix_len + name_len, 47);
            store8(sub_prefix + prefix_len + name_len + 1, 0);
            flatten_tree(hash_hex, sub_prefix, out);
        }
        else {
            var full_path = alloc_or_die(prefix_len + name_len + 1);
            memcpy(full_path, prefix, prefix_len);
            memcpy(full_path + prefix_len, name, name_len);
            store8(full_path + prefix_len + name_len, 0);

            var flat = alloc_or_die(24);
            store64(flat, mode);
            store64(flat + 8, full_path);
            store64(flat + 16, hash_hex);
            vec_push(out, flat);
        }
        i = i + 1;
    }
    _tree_walk_depth = _tree_walk_depth - 1;
    return 0;
}

# Read HEAD → commit → tree, recursively flatten into full-path entries.
# Returns vec or 0 if there's no HEAD commit yet.
fn read_head_tree_entries() {
    var head_commit = read_head_ref();
    if (head_commit == 0) { return 0; }

    var obj[24];
    if (read_object(head_commit, &obj) != 0) { return 0; }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var body = buf + coff;
    var body_len = blen - coff;

    var hexlen = _id_hexlen();
    if (body_len < 6 + hexlen) { return 0; }
    if (memeq(body, "tree ", 5) == 0) { return 0; }
    var tree_hex = alloc_or_die(hexlen + 1);
    memcpy(tree_hex, body + 5, hexlen);
    store8(tree_hex + hexlen, 0);

    var out = vec_new();
    flatten_tree(tree_hex, "", out);
    return out;
}

# P-10: tree_find cache. The previous O(N) linear scan was called in O(N)
# loops (cmd_status iterating index entries against head_entries; cmd_diff;
# materialize_target; the merge three-way loops). For any entries vec that's
# searched more than once, build a name → entry hashmap on first call and
# reuse it for every subsequent tree_find on the same vec. Cache keyed by
# vec pointer; lifetime = process (sit is short-lived per invocation).
#
# Worst case (one tree_find per vec): one map build + one lookup = O(N) + O(1).
# Same complexity as the old linear scan. Strictly an improvement when called
# more than once on the same vec, which every hot caller does.
var _tree_find_keys = 0;
var _tree_find_maps = 0;

fn _tree_find_map(entries) {
    if (_tree_find_keys == 0) {
        _tree_find_keys = vec_new();
        _tree_find_maps = vec_new();
    }
    var k = vec_len(_tree_find_keys);
    var ki = 0;
    while (ki < k) {
        if (vec_get(_tree_find_keys, ki) == entries) {
            return vec_get(_tree_find_maps, ki);
        }
        ki = ki + 1;
    }
    var m = map_new();
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        map_set(m, tree_entry_name(e), e);
        i = i + 1;
    }
    vec_push(_tree_find_keys, entries);
    vec_push(_tree_find_maps, m);
    return m;
}

fn tree_find(entries, name) {
    if (entries == 0) { return 0; }
    var m = _tree_find_map(entries);
    return map_get(m, name);
}

fn tree_find_hash(entries, path) {
    if (entries == 0) { return 0; }
    var e = tree_find(entries, path);
    if (e == 0) { return 0; }
    return tree_entry_hash(e);
}

# Union of paths across three flattened tree entry vecs. Returns a vec of
# heap-copied path cstrings, each unique.
#
# P-18: dedup via hashmap rather than the O(N²) nested-streq scan over the
# growing `paths` vec. For three trees of N entries each, the old loop did
# ~3N × (3N/2) = ~4.5N² streqs; with the map it's 3N inserts + 3N membership
# checks, all O(1) amortized.
fn three_way_path_set(base, ours, theirs) {
    var paths = vec_new();
    var seen = map_new();
    var sources_cnt = 3;
    var sources[24];
    store64(&sources + 0, base);
    store64(&sources + 8, ours);
    store64(&sources + 16, theirs);

    var si = 0;
    while (si < sources_cnt) {
        var entries = load64(&sources + si * 8);
        if (entries != 0) {
            var n = vec_len(entries);
            var i = 0;
            while (i < n) {
                var e = vec_get(entries, i);
                var p = tree_entry_name(e);
                if (map_has(seen, p) == 0) {
                    var plen = strlen(p);
                    var copy = alloc_or_die(plen + 1);
                    memcpy(copy, p, plen);
                    store8(copy + plen, 0);
                    map_set(seen, copy, 1);
                    vec_push(paths, copy);
                }
                i = i + 1;
            }
        }
        si = si + 1;
    }
    return paths;
}

# Walk descendant's parent chain; return 1 if ancestor_hex is descendant
# or any of its ancestors. Linear — sit has no merge commits yet.

# --- diff.cyr ---

# diff.cyr — unified diff, LCS, hunk grouping, status, show.
#
# Classical LCS on split_lines tables (capped at 16M cells), git-style hunk
# grouping with 3-line context, unified-diff emitter, diffstat variant, and
# cmd_diff / cmd_show / cmd_status which all consume the same primitives.
# Also home to is_dirty and the working-tree walker used by status + add.

fn is_dirty() {
    var index_entries = parse_index();
    if (index_entries != 0) {
        sort_entries(index_entries);
        index_entries = dedupe_entries(index_entries);
    }
    var head_entries = read_head_tree_entries();

    if (index_entries != 0) {
        var n = vec_len(index_entries);
        var i = 0;
        while (i < n) {
            var e = vec_get(index_entries, i);
            var path = entry_path(e);
            var idx_hex = hex_encode(entry_hash(e), 32);
            var head_ent = tree_find(head_entries, path);
            if (head_ent == 0) { return 1; }
            if (streq(tree_entry_hash(head_ent), idx_hex) == 0) { return 1; }
            if (sf_exists(path) == 1) {
                var wh = hash_file_as_blob(path);
                if (wh != 0) {
                    if (streq(wh, idx_hex) == 0) { return 1; }
                }
            }
            else { return 1; }
            i = i + 1;
        }
    }

    if (head_entries != 0) {
        var hn = vec_len(head_entries);
        var hi = 0;
        while (hi < hn) {
            var he = vec_get(head_entries, hi);
            if (index_find(index_entries, tree_entry_name(he)) == 0) { return 1; }
            hi = hi + 1;
        }
    }
    return 0;
}

# Ensure all parent directories of `path` exist. For "src/lib/foo.cyr",
# creates "src" and "src/lib".
# Write "ref: <ref_path>\n" to .sit/HEAD. Returns 0 on success.
fn list_working_walk(prefix, fs_path, out, patterns) {
    var raw = sf_dir_list(str_from(fs_path));
    var n = vec_len(raw);
    var fs_path_len = strlen(fs_path);
    var prefix_len = strlen(prefix);
    var i = 0;
    while (i < n) {
        var s = vec_get(raw, i);
        var sdata = str_data(s);
        var slen = str_len(s);

        var skip = 0;
        if (slen == 4) {
            if (memeq(sdata, ".sit", 4) == 1) { skip = 1; }
            # git read-mode: never descend into a .git/ metadata dir.
            if (memeq(sdata, ".git", 4) == 1) { skip = 1; }
        }

        if (skip == 0) {
            var rel_path_len = prefix_len + slen;
            var rel_path = alloc(rel_path_len + 1);
            memcpy(rel_path, prefix, prefix_len);
            memcpy(rel_path + prefix_len, sdata, slen);
            store8(rel_path + rel_path_len, 0);
            if (is_ignored(rel_path, patterns) == 1) { skip = 1; }
        }

        if (skip == 0) {
            var child_fs = alloc(fs_path_len + 1 + slen + 1);
            memcpy(child_fs, fs_path, fs_path_len);
            store8(child_fs + fs_path_len, 47);
            memcpy(child_fs + fs_path_len + 1, sdata, slen);
            store8(child_fs + fs_path_len + 1 + slen, 0);

            if (is_dir(str_from(child_fs)) == 1) {
                var new_prefix = alloc(prefix_len + slen + 2);
                memcpy(new_prefix, prefix, prefix_len);
                memcpy(new_prefix + prefix_len, sdata, slen);
                store8(new_prefix + prefix_len + slen, 47);
                store8(new_prefix + prefix_len + slen + 1, 0);
                list_working_walk(new_prefix, child_fs, out, patterns);
            }
            else {
                var full_len = prefix_len + slen;
                var full = alloc(full_len + 1);
                memcpy(full, prefix, prefix_len);
                memcpy(full + prefix_len, sdata, slen);
                store8(full + full_len, 0);
                vec_push(out, full);
            }
        }
        i = i + 1;
    }
    return 0;
}

fn list_working_files() {
    var files = vec_new();
    var patterns = load_sitignore();
    list_working_walk("", ".", files, patterns);
    return files;
}

# A "status item" is a 16-byte (label_ptr, path_ptr) pair.
fn push_status_item(vec, label, path) {
    var item = alloc(16);
    store64(item, label);
    store64(item + 8, path);
    vec_push(vec, item);
    return 0;
}

fn print_labeled_section(title, title_len, items) {
    if (vec_len(items) == 0) { return 0; }
    stdout_write("\n", 1);
    stdout_write(title, title_len);
    stdout_write("\n", 1);
    var si = 0;
    while (si < vec_len(items)) {
        var it = vec_get(items, si);
        var lab = load64(it);
        var pth = load64(it + 8);
        stdout_write("  ", 2);
        stdout_write(lab, strlen(lab));
        stdout_write(pth, strlen(pth));
        stdout_write("\n", 1);
        si = si + 1;
    }
    return 1;
}

fn print_name_section(title, title_len, names) {
    if (vec_len(names) == 0) { return 0; }
    stdout_write("\n", 1);
    stdout_write(title, title_len);
    stdout_write("\n", 1);
    var si = 0;
    while (si < vec_len(names)) {
        var nm = vec_get(names, si);
        stdout_write("  ", 2);
        stdout_write(nm, strlen(nm));
        stdout_write("\n", 1);
        si = si + 1;
    }
    return 1;
}

fn cmd_status() {
    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    var head_entries = read_head_tree_entries();
    var index_entries = parse_index();
    if (index_entries != 0) {
        sort_entries(index_entries);
        index_entries = dedupe_entries(index_entries);
    }
    var working = list_working_files();

    var staged = vec_new();
    var unstaged = vec_new();
    var untracked = vec_new();

    if (index_entries != 0) {
        var ni = vec_len(index_entries);
        var ii = 0;
        while (ii < ni) {
            var e = vec_get(index_entries, ii);
            var path = entry_path(e);
            var idx_hash_hex = hex_encode(entry_hash(e), 32);

            var head_ent = tree_find(head_entries, path);
            var label = 0;
            if (head_ent == 0) { label = "new file:  "; }
            else {
                if (streq(tree_entry_hash(head_ent), idx_hash_hex) == 0) {
                    label = "modified:  ";
                }
            }
            if (label != 0) { push_status_item(staged, label, path); }

            if (sf_exists(path) == 1) {
                var working_hex = hash_file_as_blob(path);
                if (working_hex != 0) {
                    if (streq(working_hex, idx_hash_hex) == 0) {
                        push_status_item(unstaged, "modified:  ", path);
                    }
                }
            }
            else {
                push_status_item(unstaged, "deleted:   ", path);
            }
            ii = ii + 1;
        }
    }

    var nw = vec_len(working);
    var wi = 0;
    while (wi < nw) {
        var name = vec_get(working, wi);
        if (index_find(index_entries, name) == 0) {
            if (tree_find(head_entries, name) == 0) {
                vec_push(untracked, name);
            }
        }
        wi = wi + 1;
    }

    if (head_entries != 0) {
        var hn = vec_len(head_entries);
        var hi = 0;
        while (hi < hn) {
            var he = vec_get(head_entries, hi);
            var hpath = tree_entry_name(he);
            if (index_find(index_entries, hpath) == 0) {
                push_status_item(staged, "deleted:   ", hpath);
            }
            hi = hi + 1;
        }
    }

    var branch = current_branch_name();
    stdout_write("On branch ", 10);
    if (branch != 0) { stdout_write(branch, strlen(branch)); }
    else             { stdout_write("(detached)", 10); }
    stdout_write("\n", 1);
    if (read_head_ref() == 0) {
        stdout_write("No commits yet\n", 15);
    }
    if (read_merge_head() != 0) {
        var msg = "Merge in progress. Resolve conflicts and commit, or run 'sit merge --abort'.\n";
        stdout_write(msg, strlen(msg));
    }

    var any = 0;
    if (print_labeled_section("Staged for commit:", 18, staged) == 1)   { any = 1; }
    if (print_labeled_section("Unstaged changes:", 17, unstaged) == 1)   { any = 1; }
    if (print_name_section("Untracked files:", 16, untracked) == 1)      { any = 1; }

    if (any == 0) {
        stdout_write("\nnothing to commit, working tree clean\n", 39);
    }
    return 0;
}

# ---- diff ------------------------------------------------------------------
# Line layout (16 bytes): { ptr_into_data, len } — \n excluded.
fn line_ptr(l) { return load64(l); }
fn line_len(l) { return load64(l + 8); }

fn split_lines(data, len) {
    var lines = vec_new();
    var pos = 0;
    while (pos < len) {
        var start = pos;
        while (pos < len) {
            if (load8(data + pos) == 10) { break; }
            pos = pos + 1;
        }
        var line = alloc(16);
        store64(line, data + start);
        store64(line + 8, pos - start);
        vec_push(lines, line);
        if (pos < len) { pos = pos + 1; }
    }
    return lines;
}

fn lines_equal(a, b) {
    var alen = line_len(a);
    var blen = line_len(b);
    if (alen != blen) { return 0; }
    return memeq(line_ptr(a), line_ptr(b), alen);
}

# Read trace slice for depth `d` at diagonal `kp` (P-14). The slice holds the
# parity-(d-1) V entries in [-(d-1), d-1] that depth d read/produced; `kp` must
# be that parity (the caller only ever asks for valid k±1 / prev_k diagonals).
fn _myers_sget(slice, d, kp) {
    return load64(slice + ((kp + d - 1) / 2) * 8);
}

# Myers O((N+M)D) diff fallback (P-14). Produces the SAME op-tuple format as
# `lcs_diff` (16-byte {kind, line_ptr}, forward order) so callers don't care
# which path ran. Used when the LCS DP table would be too large — Myers needs
# only O(N+M) working space plus an O(D²) backtrack trace, where D is the edit
# distance, so a large-but-similar file (small D) diffs cheaply where the DP
# would allocate 100+ MB. Bounded: if D exceeds `dcap` (a fully-rewritten huge
# file — the rare pathological case) it returns 0, preserving the old "too
# large" refusal. Greedy forward search + trace backtrack, per Myers 1986.
fn myers_diff(a, b) {
    var n = vec_len(a);
    var m = vec_len(b);

    # D is bounded by `dcap`, so k = x - y stays in [-dcap, dcap]: V is sized to
    # that, not to N+M. Trace = Σ(d) i64 ≈ dcap²/2; dcap=4096 → ~67 MB ceiling.
    var dcap = 4096;
    var voff = dcap;
    var vsize = 2 * dcap + 1;
    var V = fl_alloc(vsize * 8);
    if (V == 0) { return 0; }
    store64(V + (1 + voff) * 8, 0);
    var trace = vec_new();

    var searching = 1;
    var found_d = 0 - 1;
    var d = 0;
    while (searching == 1) {
        if (d > dcap) { searching = 0; }
        else {
            # Snapshot V (depth d's inputs) for the backtrack — only d >= 1 is
            # ever read back. Compact: parity-(d-1) entries in [-(d-1), d-1].
            if (d >= 1) {
                var slice = fl_alloc(d * 8);
                var kp = 0 - (d - 1);
                while (kp <= d - 1) {
                    store64(slice + ((kp + d - 1) / 2) * 8, load64(V + (kp + voff) * 8));
                    kp = kp + 2;
                }
                vec_push(trace, slice);
            }
            var k = 0 - d;
            while (k <= d) {
                if (searching == 1) {
                    # x = (k==-d || (k!=d && V[k-1]<V[k+1])) ? V[k+1] : V[k-1]+1
                    var down = 0;
                    if (k == 0 - d) { down = 1; }
                    else {
                        if (k != d) {
                            if (load64(V + (k - 1 + voff) * 8) < load64(V + (k + 1 + voff) * 8)) { down = 1; }
                        }
                    }
                    var x = 0;
                    if (down == 1) { x = load64(V + (k + 1 + voff) * 8); }
                    else { x = load64(V + (k - 1 + voff) * 8) + 1; }
                    var y = x - k;
                    var snaking = 1;
                    while (snaking == 1) {
                        if (x < n) {
                            if (y < m) {
                                if (lines_equal(vec_get(a, x), vec_get(b, y)) == 1) {
                                    x = x + 1;
                                    y = y + 1;
                                }
                                else { snaking = 0; }
                            }
                            else { snaking = 0; }
                        }
                        else { snaking = 0; }
                    }
                    store64(V + (k + voff) * 8, x);
                    if (x >= n) {
                        if (y >= m) { found_d = d; searching = 0; }
                    }
                }
                k = k + 2;
            }
            if (searching == 1) { d = d + 1; }
        }
    }

    if (found_d < 0) { fl_free(V); return 0; }

    # Backtrack: from (n,m) to the origin, emitting ops in reverse.
    var script = vec_new();
    var x = n;
    var y = m;
    var dd = found_d;
    while (dd >= 1) {
        var slice = vec_get(trace, dd - 1);
        var k = x - y;
        var down = 0;
        if (k == 0 - dd) { down = 1; }
        else {
            if (k != dd) {
                if (_myers_sget(slice, dd, k - 1) < _myers_sget(slice, dd, k + 1)) { down = 1; }
            }
        }
        var prev_k = 0;
        if (down == 1) { prev_k = k + 1; }
        else { prev_k = k - 1; }
        var prev_x = _myers_sget(slice, dd, prev_k);
        var prev_y = prev_x - prev_k;
        var diaging = 1;
        while (diaging == 1) {
            if (x > prev_x) {
                if (y > prev_y) {
                    var op = alloc(16);
                    store64(op, 0);
                    store64(op + 8, vec_get(a, x - 1));
                    vec_push(script, op);
                    x = x - 1;
                    y = y - 1;
                }
                else { diaging = 0; }
            }
            else { diaging = 0; }
        }
        if (down == 1) {
            var op = alloc(16);
            store64(op, 2);
            store64(op + 8, vec_get(b, y - 1));
            vec_push(script, op);
        }
        else {
            var op = alloc(16);
            store64(op, 1);
            store64(op + 8, vec_get(a, x - 1));
            vec_push(script, op);
        }
        x = prev_x;
        y = prev_y;
        dd = dd - 1;
    }
    while (x > 0) {
        var op = alloc(16);
        store64(op, 0);
        store64(op + 8, vec_get(a, x - 1));
        vec_push(script, op);
        x = x - 1;
        y = y - 1;
    }

    # script is reversed; flip into forward order (matches lcs_diff).
    var out = vec_new();
    var si = vec_len(script) - 1;
    while (si >= 0) {
        vec_push(out, vec_get(script, si));
        si = si - 1;
    }
    fl_free(V);
    var ti = 0;
    while (ti < vec_len(trace)) {
        fl_free(vec_get(trace, ti));
        ti = ti + 1;
    }
    return out;
}

# LCS-based diff. Returns a vec of op-tuples (16 bytes):
#   op kind: 0 = keep, 1 = delete, 2 = insert
#   line ptr: points at one of the input line tuples
# For small inputs this is the exact O(N·M) DP; when the DP table would be too
# large it hands off to `myers_diff` (P-14), which only refuses (returns 0) on
# a pathologically large edit distance.
fn lcs_diff(a, b) {
    var n1 = vec_len(a);
    var n2 = vec_len(b);
    # S-07: per-dimension cap BEFORE the multiply to prevent integer-overflow
    # that would let `cells` wrap into a small positive and bypass the cap.
    # sqrt(16M) ~ 4096; keep a little headroom. Past the cap → Myers fallback.
    if (n1 > 8192) { return myers_diff(a, b); }
    if (n2 > 8192) { return myers_diff(a, b); }
    var stride = n2 + 1;
    var cells = (n1 + 1) * stride;
    if (cells > 16 * 1024 * 1024) { return myers_diff(a, b); }
    # P-15 (v0.6.9): the DP table can be up to 128 MB. fl_alloc routes large
    # allocations through mmap directly and we fl_free below before the
    # function returns — diff-heavy commands no longer permanently reserve
    # the table on the bump heap for the life of the process.
    var T = fl_alloc(cells * 8);
    if (T == 0) { return myers_diff(a, b); }

    # Zero the LCS base case — row 0 (`T[0][0..n2]`) and column 0
    # (`T[0..n1][0]`). The DP reads `T[i-1][*]` / `T[*][j-1]`, so the base must
    # be 0. `fl_alloc` only zero-fills fresh mmap pages (large tables); a small
    # table served from the recycled freelist carries stale non-zero values, so
    # without this the DP computed a too-short LCS (non-minimal diff) on the
    # 2nd+ diff in a process. Surfaced by the P-14 Myers differential test.
    var z = 0;
    while (z <= n2) { store64(T + z * 8, 0); z = z + 1; }
    z = 0;
    while (z <= n1) { store64(T + z * stride * 8, 0); z = z + 1; }

    var i = 1;
    while (i <= n1) {
        var j = 1;
        while (j <= n2) {
            var aline = vec_get(a, i - 1);
            var bline = vec_get(b, j - 1);
            var cellval = 0;
            if (lines_equal(aline, bline) == 1) {
                cellval = load64(T + ((i - 1) * stride + (j - 1)) * 8) + 1;
            }
            else {
                var up = load64(T + ((i - 1) * stride + j) * 8);
                var left = load64(T + (i * stride + (j - 1)) * 8);
                if (up >= left) { cellval = up; }
                else { cellval = left; }
            }
            store64(T + (i * stride + j) * 8, cellval);
            j = j + 1;
        }
        i = i + 1;
    }

    var script = vec_new();
    i = n1;
    var j = n2;
    while (i > 0) {
        if (j > 0) {
            if (lines_equal(vec_get(a, i - 1), vec_get(b, j - 1)) == 1) {
                var op = alloc(16);
                store64(op, 0);
                store64(op + 8, vec_get(a, i - 1));
                vec_push(script, op);
                i = i - 1;
                j = j - 1;
            }
            else {
                var up = load64(T + ((i - 1) * stride + j) * 8);
                var left = load64(T + (i * stride + (j - 1)) * 8);
                if (left >= up) {
                    var op = alloc(16);
                    store64(op, 2);
                    store64(op + 8, vec_get(b, j - 1));
                    vec_push(script, op);
                    j = j - 1;
                }
                else {
                    var op = alloc(16);
                    store64(op, 1);
                    store64(op + 8, vec_get(a, i - 1));
                    vec_push(script, op);
                    i = i - 1;
                }
            }
        }
        else {
            var op = alloc(16);
            store64(op, 1);
            store64(op + 8, vec_get(a, i - 1));
            vec_push(script, op);
            i = i - 1;
        }
    }
    while (j > 0) {
        var op = alloc(16);
        store64(op, 2);
        store64(op + 8, vec_get(b, j - 1));
        vec_push(script, op);
        j = j - 1;
    }

    var reversed = vec_new();
    var k = vec_len(script) - 1;
    while (k >= 0) {
        vec_push(reversed, vec_get(script, k));
        k = k - 1;
    }
    fl_free(T);
    return reversed;
}

# Annotated op layout (32 bytes):
#   0..8:   kind (0=keep, 1=del, 2=ins)
#   8..16:  line ptr
#   16..24: old_line (1-indexed; 0 if op has no presence in old)
#   24..32: new_line (1-indexed; 0 if op has no presence in new)
fn ann_kind(a) { return load64(a); }
fn ann_line(a) { return load64(a + 8); }
fn ann_old(a)  { return load64(a + 16); }
fn ann_new(a)  { return load64(a + 24); }

fn annotate_ops(ops) {
    var out = vec_new();
    var old_line = 0;
    var new_line = 0;
    var n = vec_len(ops);
    var i = 0;
    while (i < n) {
        var op = vec_get(ops, i);
        var kind = load64(op);
        var line = load64(op + 8);
        var a = alloc(32);
        store64(a, kind);
        store64(a + 8, line);
        if (kind == 0) {
            old_line = old_line + 1;
            new_line = new_line + 1;
            store64(a + 16, old_line);
            store64(a + 24, new_line);
        }
        else {
            if (kind == 1) {
                old_line = old_line + 1;
                store64(a + 16, old_line);
                store64(a + 24, 0);
            }
            else {
                new_line = new_line + 1;
                store64(a + 16, 0);
                store64(a + 24, new_line);
            }
        }
        vec_push(out, a);
        i = i + 1;
    }
    return out;
}

# Group annotated ops into hunks. Each hunk is a vec of ops.
# Algorithm: keep up to N leading-context keeps before the first change of a
# hunk; extend the hunk as long as consecutive keep-runs stay within 2N; when
# we see a (2N+1)-th keep since the last change, trim the hunk's trailing
# keeps to N and close it. The overshoot keep becomes the first of the next
# hunk's leading-context buffer.
fn group_hunks(annotated, ctx) {
    var hunks = vec_new();
    var pending = vec_new();
    var hunk = 0;
    var since_change = 0;

    var n = vec_len(annotated);
    var i = 0;
    while (i < n) {
        var op = vec_get(annotated, i);
        var kind = ann_kind(op);

        if (kind == 0) {
            if (hunk == 0) {
                vec_push(pending, op);
                if (vec_len(pending) > ctx) { vec_remove(pending, 0); }
            }
            else {
                since_change = since_change + 1;
                if (since_change <= 2 * ctx) { vec_push(hunk, op); }
                else {
                    # Close hunk: trim trailing keeps to exactly ctx.
                    var k = 0;
                    while (k < ctx) { vec_pop(hunk); k = k + 1; }
                    vec_push(hunks, hunk);
                    hunk = 0;
                    pending = vec_new();
                    vec_push(pending, op);
                    since_change = 0;
                }
            }
        }
        else {
            if (hunk == 0) {
                hunk = vec_new();
                var pi = 0;
                var pn = vec_len(pending);
                while (pi < pn) {
                    vec_push(hunk, vec_get(pending, pi));
                    pi = pi + 1;
                }
                pending = vec_new();
            }
            vec_push(hunk, op);
            since_change = 0;
        }
        i = i + 1;
    }

    if (hunk != 0) {
        var trim = since_change - ctx;
        if (trim > 0) {
            var k = 0;
            while (k < trim) { vec_pop(hunk); k = k + 1; }
        }
        vec_push(hunks, hunk);
    }
    return hunks;
}

# Compute hunk header ranges. Writes to out (32 bytes):
#   0..8:   old_start, 8..16: old_len, 16..24: new_start, 24..32: new_len
fn hunk_ranges(hunk, out) {
    var old_start = 0;
    var new_start = 0;
    var old_len = 0;
    var new_len = 0;
    var n = vec_len(hunk);
    var i = 0;
    while (i < n) {
        var op = vec_get(hunk, i);
        var kind = ann_kind(op);
        if (kind != 2) {
            if (old_start == 0) { old_start = ann_old(op); }
            old_len = old_len + 1;
        }
        if (kind != 1) {
            if (new_start == 0) { new_start = ann_new(op); }
            new_len = new_len + 1;
        }
        i = i + 1;
    }
    store64(out, old_start);
    store64(out + 8, old_len);
    store64(out + 16, new_start);
    store64(out + 24, new_len);
    return 0;
}

fn write_unsigned(n) {
    var buf[24];
    var digits = write_decimal(&buf, n);
    stdout_write(&buf, digits);
    return 0;
}

fn print_hunk_header(hunk) {
    var r[32];
    hunk_ranges(hunk, &r);
    var old_len = load64(&r + 8);
    var new_len = load64(&r + 24);
    stdout_write("@@ -", 4);
    write_unsigned(load64(&r));
    # Git convention: omit ",1" when the count is 1.
    if (old_len != 1) {
        stdout_write(",", 1);
        write_unsigned(old_len);
    }
    stdout_write(" +", 2);
    write_unsigned(load64(&r + 16));
    if (new_len != 1) {
        stdout_write(",", 1);
        write_unsigned(new_len);
    }
    stdout_write(" @@\n", 4);
    return 0;
}

# Pure compute layer: returns the annotated-ops vec for the (old, new) buffers,
# or 0 if the LCS table exceeds the 16M-cell cap. No I/O; caller owns the
# returned vec. Public API surface — consumed by `sit_diff_path` (the library
# export wrapper) so owl and other downstream consumers can walk the per-line
# annotations without paying for stringification + stdout writes.
fn compute_file_diff(old_buf, old_len, new_buf, new_len) {
    var a = split_lines(old_buf, old_len);
    var b = split_lines(new_buf, new_len);
    var ops = lcs_diff(a, b);
    if (ops == 0) { return 0; }
    return annotate_ops(ops);
}

fn print_file_diff(path, old_buf, old_len, new_buf, new_len, ctx) {
    stdout_write("--- a/", 6);
    stdout_write(path, strlen(path));
    stdout_write("\n+++ b/", 7);
    stdout_write(path, strlen(path));
    stdout_write("\n", 1);

    var annotated = compute_file_diff(old_buf, old_len, new_buf, new_len);
    if (annotated == 0) {
        eprintln("sit: diff table exceeds cap; file too large");
        return 1;
    }

    var hunks = group_hunks(annotated, ctx);

    var h = 0;
    var hn = vec_len(hunks);
    while (h < hn) {
        var hunk = vec_get(hunks, h);
        print_hunk_header(hunk);

        var ni = 0;
        var nn = vec_len(hunk);
        while (ni < nn) {
            var op = vec_get(hunk, ni);
            var kind = ann_kind(op);
            var l = ann_line(op);
            if (kind == 0) { stdout_write(" ", 1); }
            if (kind == 1) { stdout_write("-", 1); }
            if (kind == 2) { stdout_write("+", 1); }
            stdout_write(line_ptr(l), line_len(l));
            stdout_write("\n", 1);
            ni = ni + 1;
        }
        h = h + 1;
    }
    return 0;
}

# Count insertion / deletion lines between two buffers and print a diffstat
# line ` path | +N -M\n`. Writes (ins, del) to out_pair for caller totals.
fn print_file_stat(path, old_buf, old_len, new_buf, new_len, out_pair) {
    var a = split_lines(old_buf, old_len);
    var b = split_lines(new_buf, new_len);
    var ops = lcs_diff(a, b);
    if (ops == 0) {
        store64(out_pair, 0);
        store64(out_pair + 8, 0);
        eprintln("sit: diff table exceeds cap; file too large");
        return 1;
    }
    var ins = 0;
    var del = 0;
    var n = vec_len(ops);
    var i = 0;
    while (i < n) {
        var op = vec_get(ops, i);
        var kind = load64(op);
        if (kind == 1) { del = del + 1; }
        if (kind == 2) { ins = ins + 1; }
        i = i + 1;
    }
    store64(out_pair, ins);
    store64(out_pair + 8, del);
    stdout_write(" ", 1);
    stdout_write(path, strlen(path));
    stdout_write(" | +", 4);
    var nbuf[24];
    var d = write_decimal(&nbuf, ins);
    stdout_write(&nbuf, d);
    stdout_write(" -", 2);
    d = write_decimal(&nbuf, del);
    stdout_write(&nbuf, d);
    stdout_write("\n", 1);
    return 0;
}

# Read a blob object by hex hash; write (content_ptr, content_len) to out_pair.
# Returns 0 on success, negative on error.
fn read_blob_content(hex, out_pair) {
    var obj[24];
    if (read_object(hex, &obj) != 0) { return 0 - 1; }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    store64(out_pair, buf + coff);
    store64(out_pair + 8, blen - coff);
    return 0;
}

fn cmd_diff() {
    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    # Scan args: --staged flag, -U<N> context width (default 3), optional 1-2 positional refs.
    var staged = 0;
    var ref_a = 0;
    var ref_b = 0;
    var ctx = 3;
    var ai = 2;
    while (ai < argc()) {
        var a = argv(ai);
        if (streq(a, "--staged") == 1) { staged = 1; ai = ai + 1; }
        else {
            # -U<N>: hunk context width (matches `git diff -U<N>` /
            # `diff -U<N>` posix shape). N is a non-negative decimal.
            if (strlen(a) >= 2) {
                if (load8(a) == 45) {
                    if (load8(a + 1) == 85) {
                        var nstr = a + 2;
                        if (strlen(nstr) == 0) {
                            eprintln("usage: sit diff -U<N> [...] (N is a non-negative integer)");
                            return 1;
                        }
                        ctx = atoi(nstr);
                        if (ctx < 0) {
                            eprintln("usage: sit diff -U<N> [...] (N is a non-negative integer)");
                            return 1;
                        }
                        ai = ai + 1;
                        continue;
                    }
                }
            }
            if (ref_a == 0) { ref_a = argv_heap(ai); ai = ai + 1; }
            else {
                if (ref_b == 0) { ref_b = argv_heap(ai); ai = ai + 1; }
                else {
                    eprintln("usage: sit diff [--staged] [-U<N>] [<commit> [<commit>]]");
                    return 1;
                }
            }
        }
    }

    # Resolve any refs to commit trees.
    var tree_a_entries = 0;
    var tree_b_entries = 0;
    if (ref_a != 0) {
        var r[72];
        if (resolve_hash(ref_a, &r) != 1) {
            syscall(SYS_WRITE, STDERR, "sit: cannot resolve '", 21);
            syscall(SYS_WRITE, STDERR, ref_a, strlen(ref_a));
            syscall(SYS_WRITE, STDERR, "'\n", 2);
            return 1;
        }
        var ref_a_hex = alloc(65);
        memcpy(ref_a_hex, &r, 64);
        store8(ref_a_hex + 64, 0);
        tree_a_entries = commit_tree_entries(ref_a_hex);
        if (tree_a_entries == 0) { tree_a_entries = vec_new(); }
    }
    if (ref_b != 0) {
        var r[72];
        if (resolve_hash(ref_b, &r) != 1) {
            syscall(SYS_WRITE, STDERR, "sit: cannot resolve '", 21);
            syscall(SYS_WRITE, STDERR, ref_b, strlen(ref_b));
            syscall(SYS_WRITE, STDERR, "'\n", 2);
            return 1;
        }
        var ref_b_hex = alloc(65);
        memcpy(ref_b_hex, &r, 64);
        store8(ref_b_hex + 64, 0);
        tree_b_entries = commit_tree_entries(ref_b_hex);
        if (tree_b_entries == 0) { tree_b_entries = vec_new(); }
    }

    # Mode: tree-vs-tree (two refs given).
    if (tree_b_entries != 0) {
        var an = vec_len(tree_a_entries);
        var bn = vec_len(tree_b_entries);
        # For each path in A: if B has it with different hash, diff; if B lacks it, full delete.
        var i = 0;
        while (i < an) {
            var ae = vec_get(tree_a_entries, i);
            var apath = tree_entry_name(ae);
            var ahex = tree_entry_hash(ae);
            var be = tree_find(tree_b_entries, apath);
            if (be == 0) {
                var ap[16];
                if (read_blob_content(ahex, &ap) == 0) {
                    print_file_diff(apath, load64(&ap), load64(&ap + 8), 0, 0, ctx);
                }
            }
            else {
                if (streq(tree_entry_hash(be), ahex) == 0) {
                    var ap[16];
                    var bp[16];
                    if (read_blob_content(ahex, &ap) == 0) {
                        if (read_blob_content(tree_entry_hash(be), &bp) == 0) {
                            print_file_diff(apath,
                                load64(&ap), load64(&ap + 8),
                                load64(&bp), load64(&bp + 8), ctx);
                        }
                    }
                }
            }
            i = i + 1;
        }
        # Then: any path in B not in A → full addition.
        i = 0;
        while (i < bn) {
            var be = vec_get(tree_b_entries, i);
            var bpath = tree_entry_name(be);
            if (tree_find(tree_a_entries, bpath) == 0) {
                var bp[16];
                if (read_blob_content(tree_entry_hash(be), &bp) == 0) {
                    print_file_diff(bpath, 0, 0, load64(&bp), load64(&bp + 8), ctx);
                }
            }
            i = i + 1;
        }
        return 0;
    }

    # Mode: working-vs-ref (one ref given).
    if (tree_a_entries != 0) {
        var head_entries = tree_a_entries;
        var working_files = list_working_files();

        if (head_entries != 0) {
            var hn = vec_len(head_entries);
            var hi = 0;
            while (hi < hn) {
                var he = vec_get(head_entries, hi);
                var path = tree_entry_name(he);
                var head_hex = tree_entry_hash(he);

                if (sf_exists(path) == 1) {
                    var working_hex = hash_file_as_blob(path);
                    if (working_hex != 0) {
                        if (streq(head_hex, working_hex) == 0) {
                            var hp[16];
                            var wp[16];
                            if (read_blob_content(head_hex, &hp) == 0) {
                                if (read_file_heap(path, &wp) == 0) {
                                    print_file_diff(path,
                                        load64(&hp), load64(&hp + 8),
                                        load64(&wp), load64(&wp + 8), ctx);
                                }
                            }
                        }
                    }
                }
                else {
                    var hp[16];
                    if (read_blob_content(head_hex, &hp) == 0) {
                        print_file_diff(path, load64(&hp), load64(&hp + 8), 0, 0, ctx);
                    }
                }
                hi = hi + 1;
            }
        }

        var wn = vec_len(working_files);
        var wi = 0;
        while (wi < wn) {
            var wpath = vec_get(working_files, wi);
            if (tree_find(head_entries, wpath) == 0) {
                var wp[16];
                if (read_file_heap(wpath, &wp) == 0) {
                    print_file_diff(wpath, 0, 0, load64(&wp), load64(&wp + 8), ctx);
                }
            }
            wi = wi + 1;
        }
        return 0;
    }

    var index_entries = parse_index();
    if (index_entries != 0) {
        sort_entries(index_entries);
        index_entries = dedupe_entries(index_entries);
    }

    var head_entries = 0;
    if (staged == 1) { head_entries = read_head_tree_entries(); }

    # Under --staged, emit full-file deletion diffs for HEAD paths absent from index.
    if (staged == 1) {
        if (head_entries != 0) {
            var hn = vec_len(head_entries);
            var hi = 0;
            while (hi < hn) {
                var he = vec_get(head_entries, hi);
                var hpath = tree_entry_name(he);
                if (index_find(index_entries, hpath) == 0) {
                    var op[16];
                    if (read_blob_content(tree_entry_hash(he), &op) == 0) {
                        print_file_diff(hpath, load64(&op), load64(&op + 8), 0, 0, ctx);
                    }
                }
                hi = hi + 1;
            }
        }
    }

    if (index_entries == 0) { return 0; }

    var n = vec_len(index_entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(index_entries, i);
        var path = entry_path(e);
        var idx_hash_hex = hex_encode(entry_hash(e), 32);

        if (staged == 1) {
            var head_ent = tree_find(head_entries, path);
            if (head_ent == 0) {
                var ip[16];
                if (read_blob_content(idx_hash_hex, &ip) == 0) {
                    print_file_diff(path, 0, 0, load64(&ip), load64(&ip + 8), ctx);
                }
            }
            else {
                if (streq(tree_entry_hash(head_ent), idx_hash_hex) == 0) {
                    var hp[16];
                    var ip[16];
                    if (read_blob_content(tree_entry_hash(head_ent), &hp) == 0) {
                        if (read_blob_content(idx_hash_hex, &ip) == 0) {
                            print_file_diff(path,
                                load64(&hp), load64(&hp + 8),
                                load64(&ip), load64(&ip + 8), ctx);
                        }
                    }
                }
            }
        }
        else {
            if (sf_exists(path) == 1) {
                var working_hex = hash_file_as_blob(path);
                if (working_hex != 0) {
                    if (streq(working_hex, idx_hash_hex) == 0) {
                        var ip[16];
                        var wp[16];
                        if (read_blob_content(idx_hash_hex, &ip) == 0) {
                            if (read_file_heap(path, &wp) == 0) {
                                print_file_diff(path,
                                    load64(&ip), load64(&ip + 8),
                                    load64(&wp), load64(&wp + 8), ctx);
                            }
                        }
                    }
                }
            }
            else {
                var ip[16];
                if (read_blob_content(idx_hash_hex, &ip) == 0) {
                    print_file_diff(path, load64(&ip), load64(&ip + 8), 0, 0, ctx);
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

# Load a commit's tree and return its flattened entries. Returns 0 on error.
fn cmd_show() {
    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    var stat_mode = 0;
    var hash_arg = 0;
    var ctx = 3;
    var ai = 2;
    while (ai < argc()) {
        var aa = argv(ai);
        if (streq(aa, "--stat") == 1) { stat_mode = 1; ai = ai + 1; continue; }
        # -U<N>: hunk context width (matches `git show -U<N>` shape).
        if (strlen(aa) >= 2) {
            if (load8(aa) == 45) {
                if (load8(aa + 1) == 85) {
                    var nstr = aa + 2;
                    if (strlen(nstr) == 0) {
                        eprintln("usage: sit show [--stat] [-U<N>] [<hash>]");
                        return 1;
                    }
                    ctx = atoi(nstr);
                    if (ctx < 0) {
                        eprintln("usage: sit show [--stat] [-U<N>] [<hash>]");
                        return 1;
                    }
                    ai = ai + 1;
                    continue;
                }
            }
        }
        hash_arg = argv_heap(ai);
        ai = ai + 1;
    }

    var hex[72];
    if (hash_arg == 0) {
        var head = read_head_ref();
        if (head == 0) {
            eprintln("sit: no commits yet");
            return 0;
        }
        memcpy(&hex, head, 64);
        store8(&hex + 64, 0);
    }
    else {
        var rr = resolve_hash(hash_arg, &hex);
        if (rr == 0 - 2) { eprintln("sit: hash prefix too short (min 4 chars)"); return 1; }
        if (rr == 0 - 1) { eprintln("sit: ambiguous hash prefix"); return 1; }
        if (rr == 0)     { eprintln("sit: no object matches"); return 1; }
    }

    var obj[24];
    if (read_object(&hex, &obj) != 0) {
        eprintln("sit: cannot read object");
        return 1;
    }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var body = buf + coff;
    var body_len = blen - coff;

    var info[56];
    if (parse_commit_body(body, body_len, &info) != 0) {
        eprintln("sit: object is not a commit");
        return 1;
    }

    print_commit_header(&hex, &info, body, body_len);
    stdout_write("\n", 1);

    var tree_hex = load64(&info);
    var new_entries = vec_new();
    if (tree_hex != 0) { flatten_tree(tree_hex, "", new_entries); }

    var parent_hex = load64(&info + 8);
    var old_entries = vec_new();
    if (parent_hex != 0) {
        var po = commit_tree_entries(parent_hex);
        if (po != 0) { old_entries = po; }
    }

    var tot_files = 0;
    var tot_ins = 0;
    var tot_del = 0;
    var stat_pair[16];

    var n = vec_len(new_entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(new_entries, i);
        var path = tree_entry_name(e);
        var new_hash = tree_entry_hash(e);
        var old_ent = tree_find(old_entries, path);
        if (old_ent == 0) {
            var np[16];
            if (read_blob_content(new_hash, &np) == 0) {
                if (stat_mode == 1) {
                    print_file_stat(path, 0, 0, load64(&np), load64(&np + 8), &stat_pair);
                    tot_files = tot_files + 1;
                    tot_ins = tot_ins + load64(&stat_pair);
                    tot_del = tot_del + load64(&stat_pair + 8);
                }
                else {
                    print_file_diff(path, 0, 0, load64(&np), load64(&np + 8), ctx);
                }
            }
        }
        else {
            if (streq(tree_entry_hash(old_ent), new_hash) == 0) {
                var op[16];
                var np[16];
                if (read_blob_content(tree_entry_hash(old_ent), &op) == 0) {
                    if (read_blob_content(new_hash, &np) == 0) {
                        if (stat_mode == 1) {
                            print_file_stat(path,
                                load64(&op), load64(&op + 8),
                                load64(&np), load64(&np + 8),
                                &stat_pair);
                            tot_files = tot_files + 1;
                            tot_ins = tot_ins + load64(&stat_pair);
                            tot_del = tot_del + load64(&stat_pair + 8);
                        }
                        else {
                            print_file_diff(path,
                                load64(&op), load64(&op + 8),
                                load64(&np), load64(&np + 8), ctx);
                        }
                    }
                }
            }
        }
        i = i + 1;
    }

    var on = vec_len(old_entries);
    i = 0;
    while (i < on) {
        var e = vec_get(old_entries, i);
        var path = tree_entry_name(e);
        if (tree_find(new_entries, path) == 0) {
            var op[16];
            if (read_blob_content(tree_entry_hash(e), &op) == 0) {
                if (stat_mode == 1) {
                    print_file_stat(path, load64(&op), load64(&op + 8), 0, 0, &stat_pair);
                    tot_files = tot_files + 1;
                    tot_ins = tot_ins + load64(&stat_pair);
                    tot_del = tot_del + load64(&stat_pair + 8);
                }
                else {
                    print_file_diff(path, load64(&op), load64(&op + 8), 0, 0, ctx);
                }
            }
        }
        i = i + 1;
    }

    if (stat_mode == 1) {
        if (tot_files > 0) {
            var sbuf[24];
            var sd = write_decimal(&sbuf, tot_files);
            stdout_write(" ", 1);
            stdout_write(&sbuf, sd);
            if (tot_files == 1) { stdout_write(" file changed, ", 15); }
            else                { stdout_write(" files changed, ", 16); }
            sd = write_decimal(&sbuf, tot_ins);
            stdout_write(&sbuf, sd);
            if (tot_ins == 1) { stdout_write(" insertion(+), ", 15); }
            else              { stdout_write(" insertions(+), ", 16); }
            sd = write_decimal(&sbuf, tot_del);
            stdout_write(&sbuf, sd);
            if (tot_del == 1) { stdout_write(" deletion(-)\n", 13); }
            else              { stdout_write(" deletions(-)\n", 14); }
        }
    }
    return 0;
}

# =====================================================================
# Wire protocol — local-path transport (v0.5.0)
#
# A remote is another sit working-tree directory (the one containing `.sit/`).
# We open its patra object DB directly and walk refs by filesystem path.
# No pack bundles, no network. HTTP and SSH transports are v0.5.x work.
# =====================================================================

# Look up `remote.<name>.url` in the local config. Returns heap cstring or 0.

# --- commit.cyr ---

# commit.cyr — commit objects + log.
#
# Builders for signed and unsigned commit bodies, author-line parser,
# git-style header and oneline renderers, reachability helpers
# (is_ancestor, materialize_target, commit_tree_entries), and cmd_commit /
# cmd_log.

fn build_commit(tree_hex, parent_hex, message) {
    return build_commit_signed(tree_hex, parent_hex, message, 0);
}

# Same as build_commit, but when `seed` is non-zero, signs the commit with
# an ed25519 key derived from the 32-byte seed and injects a sitsig header.
fn build_commit_signed(tree_hex, parent_hex, message, seed) {
    # Priority: env → .sit/config → ~/.sitconfig → fallback
    var name = getenv("SIT_AUTHOR_NAME");
    if (name == 0) { name = config_get("user.name"); }
    if (name == 0) { name = "sit user"; }
    var email = getenv("SIT_AUTHOR_EMAIL");
    if (email == 0) { email = config_get("user.email"); }
    if (email == 0) { email = "user@localhost"; }
    var ts = clock_epoch_secs();

    var name_len = strlen(name);
    var email_len = strlen(email);
    var msg_len = strlen(message);

    var cap = 512 + msg_len + name_len * 2 + email_len * 2;
    if (parent_hex != 0) { cap = cap + 80; }
    var body = alloc_or_die(cap);
    var pos = 0;

    memcpy(body + pos, "tree ", 5); pos = pos + 5;
    memcpy(body + pos, tree_hex, 64); pos = pos + 64;
    store8(body + pos, 10); pos = pos + 1;

    if (parent_hex != 0) {
        memcpy(body + pos, "parent ", 7); pos = pos + 7;
        memcpy(body + pos, parent_hex, 64); pos = pos + 64;
        store8(body + pos, 10); pos = pos + 1;
    }

    memcpy(body + pos, "author ", 7); pos = pos + 7;
    memcpy(body + pos, name, name_len); pos = pos + name_len;
    memcpy(body + pos, " <", 2); pos = pos + 2;
    memcpy(body + pos, email, email_len); pos = pos + email_len;
    memcpy(body + pos, "> ", 2); pos = pos + 2;
    var digits = write_decimal(body + pos, ts); pos = pos + digits;
    memcpy(body + pos, " +0000\n", 7); pos = pos + 7;

    memcpy(body + pos, "committer ", 10); pos = pos + 10;
    memcpy(body + pos, name, name_len); pos = pos + name_len;
    memcpy(body + pos, " <", 2); pos = pos + 2;
    memcpy(body + pos, email, email_len); pos = pos + email_len;
    memcpy(body + pos, "> ", 2); pos = pos + 2;
    digits = write_decimal(body + pos, ts); pos = pos + digits;
    memcpy(body + pos, " +0000\n", 7); pos = pos + 7;

    store8(body + pos, 10); pos = pos + 1;
    memcpy(body + pos, message, msg_len); pos = pos + msg_len;
    if (msg_len == 0) { store8(body + pos, 10); pos = pos + 1; }
    else {
        if (load8(message + msg_len - 1) != 10) {
            store8(body + pos, 10); pos = pos + 1;
        }
    }

    if (seed != 0) {
        var new_len_slot[8];
        store64(&new_len_slot, 0);
        var signed = sign_commit_body(body, pos, seed, &new_len_slot);
        if (signed == 0) {
            return write_typed_object("commit", 6, body, pos);
        }
        return write_typed_object("commit", 6, signed, load64(&new_len_slot));
    }
    return write_typed_object("commit", 6, body, pos);
}

# Read a commit's parent hexes — the out+48 vec from parse_commit_body, or 0
# if the object is unreadable / not a parseable commit. The returned vec holds
# heap-owned 64-char NUL-terminated hex copies (safe to retain across calls).
# Consolidates the read_object → parse_commit_body → load64(out+48) boilerplate
# shared by the pure parent-graph walks (is_ancestor, find_merge_base). [v0.9.0]
fn commit_parents_of(hex) {
    var obj[24];
    if (read_object(hex, &obj) != 0) { return 0; }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var info[56];
    if (parse_commit_body(buf + coff, blen - coff, &info) != 0) { return 0; }
    return load64(&info + 48);
}

# True iff `ancestor_hex` is reachable from `descendant_hex` via any parent
# chain. BFS over the full commit DAG (every parent line, not just the last)
# with a seen-set so merge commits don't hide first-parent-only ancestors and
# diamond histories don't re-walk. Mirrors is_ancestor_in_db (wire.cyr), which
# does the same over a remote patra handle.
fn is_ancestor(ancestor_hex, descendant_hex) {
    if (streq(ancestor_hex, descendant_hex) == 1) { return 1; }

    var queue = vec_new();
    var seen = map_new();
    var start = alloc(65);
    memcpy(start, descendant_hex, 64);
    store8(start + 64, 0);
    vec_push(queue, start);

    while (vec_len(queue) > 0) {
        var cur = vec_get(queue, vec_len(queue) - 1);
        vec_pop(queue);
        if (map_has(seen, cur) == 1) { }
        else {
            map_set(seen, cur, 1);
            if (streq(cur, ancestor_hex) == 1) { return 1; }
            var pv = commit_parents_of(cur);
            if (pv != 0) {
                var pi = 0;
                while (pi < vec_len(pv)) {
                    vec_push(queue, vec_get(pv, pi));
                    pi = pi + 1;
                }
            }
        }
    }
    return 0;
}

# Overwrite working tree + index with target commit's tree. Used by both
# checkout and fast-forward merge. Does NOT update HEAD — caller does that.
fn materialize_target(target_hex) {
    var target_entries = commit_tree_entries(target_hex);
    if (target_entries == 0) { target_entries = vec_new(); }
    var curr_entries = read_head_tree_entries();
    if (curr_entries == 0) { curr_entries = vec_new(); }

    # S-03 belt-and-suspenders: `flatten_tree` concatenates prefix + name, so
    # even if parse_tree screened each component, a pre-existing bogus tree
    # in the local store still needs gating before we act on its paths.
    var cn = vec_len(curr_entries);
    var ci = 0;
    while (ci < cn) {
        var ce = vec_get(curr_entries, ci);
        var cpath = tree_entry_name(ce);
        if (tree_flat_path_valid(cpath) == 1) {
            if (tree_find(target_entries, cpath) == 0) {
                if (sf_exists(cpath) == 1) {
                    # S-16: refuse to declare success when a stale file the
                    # target says shouldn't exist couldn't be removed —
                    # otherwise `sit status` after checkout would still see
                    # it as tracked.
                    if (sf_unlink(cpath) != 0) {
                        syscall(SYS_WRITE, STDERR, "sit: cannot remove stale path '", 31);
                        syscall(SYS_WRITE, STDERR, cpath, strlen(cpath));
                        syscall(SYS_WRITE, STDERR, "' — materialize aborted\n", 24);
                        return 0 - 1;
                    }
                }
            }
        }
        ci = ci + 1;
    }

    var tn = vec_len(target_entries);
    var ti = 0;
    while (ti < tn) {
        var te = vec_get(target_entries, ti);
        var tpath = tree_entry_name(te);
        var thex = tree_entry_hash(te);
        if (tree_flat_path_valid(tpath) == 0) {
            # Silently skip rather than abort — materialize runs over many
            # paths and we want the valid ones to land. Emit to stderr so
            # operator knows something was filtered.
            syscall(SYS_WRITE, STDERR, "sit: refusing unsafe tree path: ", 32);
            syscall(SYS_WRITE, STDERR, tpath, strlen(tpath));
            syscall(SYS_WRITE, STDERR, "\n", 1);
        }
        else {
            ensure_parent_dirs(tpath);
            var tp[16];
            # S-27: a blob the tree references but the object DB can't read
            # is structural corruption — leaving the file silently absent
            # would mask the failure and produce a half-materialized working
            # tree. Abort with a clear error; callers that want best-effort
            # can re-run after `sit fsck`.
            if (read_blob_content(thex, &tp) != 0) {
                syscall(SYS_WRITE, STDERR, "sit: cannot read blob ", 22);
                syscall(SYS_WRITE, STDERR, thex, strlen(thex));
                syscall(SYS_WRITE, STDERR, " for path '", 11);
                syscall(SYS_WRITE, STDERR, tpath, strlen(tpath));
                syscall(SYS_WRITE, STDERR, "' — materialize aborted (working tree may be partial)\n", 55);
                return 0 - 1;
            }
            # S-16: file_write_all returns < 0 on any write or open failure
            # (permissions, ENOSPC, EROFS). Same partial-tree problem as the
            # blob-read failure above; abort with a clear pointer to the path.
            if (sf_write_all(tpath, load64(&tp), load64(&tp + 8)) < 0) {
                syscall(SYS_WRITE, STDERR, "sit: cannot write '", 19);
                syscall(SYS_WRITE, STDERR, tpath, strlen(tpath));
                syscall(SYS_WRITE, STDERR, "' — materialize aborted (working tree may be partial)\n", 55);
                return 0 - 1;
            }
        }
        ti = ti + 1;
    }

    var new_index = vec_new();
    ti = 0;
    while (ti < tn) {
        var te = vec_get(target_entries, ti);
        var tpath = tree_entry_name(te);
        var thex = tree_entry_hash(te);
        if (tree_flat_path_valid(tpath) == 1) {
            var bytes = hex_decode(thex, 64);
            if (bytes != 0) {
                var entry = alloc_or_die(40);
                memcpy(entry, bytes, 32);
                var plen = strlen(tpath);
                var pcopy = alloc_or_die(plen + 1);
                memcpy(pcopy, tpath, plen);
                store8(pcopy + plen, 0);
                store64(entry + 32, pcopy);
                vec_push(new_index, entry);
            }
        }
        ti = ti + 1;
    }
    rewrite_index(new_index);
    return 0;
}

fn parse_author_line(line, line_len, prefix_len, out) {
    var p = prefix_len;
    var found_close = 0;
    while (p < line_len) {
        if (load8(line + p) == 62) { found_close = 1; break; }
        p = p + 1;
    }
    if (found_close == 0) { return 0 - 1; }

    var ident_len = p - prefix_len + 1;
    var ident = alloc_or_die(ident_len + 1);
    memcpy(ident, line + prefix_len, ident_len);
    store8(ident + ident_len, 0);
    store64(out, ident);

    p = p + 1;
    if (p >= line_len) { return 0 - 1; }
    if (load8(line + p) != 32) { return 0 - 1; }
    p = p + 1;

    var ts = 0;
    var digit_count = 0;
    while (p < line_len) {
        var c = load8(line + p);
        if (c < 48) { break; }
        if (c > 57) { break; }
        digit_count = digit_count + 1;
        # S-18: i64 has ~19 decimal digits of range. Refuse 20+ digit
        # timestamps outright, and detect wrap on the 19th via `new < old`
        # (the only path a single decimal digit can produce a smaller value).
        if (digit_count > 19) { return 0 - 1; }
        var new_ts = ts * 10 + (c - 48);
        if (new_ts < ts) { return 0 - 1; }
        ts = new_ts;
        p = p + 1;
    }
    store64(out + 8, ts);

    if (p >= line_len) { return 0 - 1; }
    if (load8(line + p) != 32) { return 0 - 1; }
    p = p + 1;

    var tz_start = p;
    while (p < line_len) { p = p + 1; }
    var tz_len = p - tz_start;
    var tz = alloc_or_die(tz_len + 1);
    memcpy(tz, line + tz_start, tz_len);
    store8(tz + tz_len, 0);
    store64(out + 16, tz);

    return 0;
}

# Write the message portion of a commit body to stdout, indenting each
# line with four spaces (git-style).
fn print_indented_message(body, msg_start, body_len) {
    var msg_len = body_len - msg_start;
    while (msg_len > 0) {
        if (load8(body + msg_start + msg_len - 1) != 10) { break; }
        msg_len = msg_len - 1;
    }
    var mp = 0;
    while (mp < msg_len) {
        var mnl = mp;
        while (mnl < msg_len) {
            if (load8(body + msg_start + mnl) == 10) { break; }
            mnl = mnl + 1;
        }
        stdout_write("    ", 4);
        stdout_write(body + msg_start + mp, mnl - mp);
        stdout_write("\n", 1);
        mp = mnl + 1;
    }
    return 0;
}

# Parse a commit object body. Writes to out (56 bytes):
#   [0..8)   tree_hex ptr (heap, null-term 64 chars)
#   [8..16)  parent_hex ptr (or 0 for root commit) — LAST parent line seen
#   [16..24) author identity ptr (or 0)
#   [24..32) author epoch timestamp
#   [32..40) author tz ptr (or 0)
#   [40..48) msg_start (byte offset into body; 0 if no message)
#   [48..56) parents vec — EVERY parent hex, in body order; 0 for root commit
# Returns 0 on success, -1 if body has no tree line.
#
# out+8 keeps the last-parent pointer for back-compat with single-parent-chain
# readers (cmd_log, merge_base). out+48's vec is the multi-parent surface that
# reachability + ancestor walks consume so merge commits don't drop edges.
fn parse_commit_body(body, body_len, out) {
    store64(out, 0);
    store64(out + 8, 0);
    store64(out + 16, 0);
    store64(out + 24, 0);
    store64(out + 32, 0);
    store64(out + 40, 0);
    store64(out + 48, 0);

    # Object-id hex width per active backend: 64 (sit SHA-256) or 40 (git SHA-1).
    var hexlen = _id_hexlen();
    var pos = 0;
    var in_headers = 1;
    while (pos < body_len) {
        if (in_headers == 0) { pos = body_len; }
        else {
            var nl = pos;
            while (nl < body_len) {
                if (load8(body + nl) == 10) { break; }
                nl = nl + 1;
            }
            var line_len = nl - pos;

            if (line_len == 0) {
                in_headers = 0;
                store64(out + 40, nl + 1);
            }
            else {
                if (line_len > 5) {
                    if (memeq(body + pos, "tree ", 5) == 1) {
                        if (line_len >= 5 + hexlen) {
                            var t = alloc_or_die(hexlen + 1);
                            memcpy(t, body + pos + 5, hexlen);
                            store8(t + hexlen, 0);
                            store64(out, t);
                        }
                    }
                }
                if (line_len > 7) {
                    if (memeq(body + pos, "parent ", 7) == 1) {
                        if (line_len >= 7 + hexlen) {
                            var p = alloc_or_die(hexlen + 1);
                            memcpy(p, body + pos + 7, hexlen);
                            store8(p + hexlen, 0);
                            store64(out + 8, p);
                            # Collect every parent (merge commits have 2+) into a
                            # vec at out+48 so reachability + ancestor walks follow
                            # all edges, not just the last one captured at out+8.
                            var pv = load64(out + 48);
                            if (pv == 0) { pv = vec_new(); store64(out + 48, pv); }
                            vec_push(pv, p);
                        }
                    }
                    if (memeq(body + pos, "author ", 7) == 1) {
                        var ao[24];
                        if (parse_author_line(body + pos, line_len, 7, &ao) == 0) {
                            store64(out + 16, load64(&ao));
                            store64(out + 24, load64(&ao + 8));
                            store64(out + 32, load64(&ao + 16));
                        }
                    }
                }
            }
            pos = nl + 1;
        }
    }
    if (load64(out) == 0) { return 0 - 1; }
    return 0;
}

# Print the "commit <hex> / Author: / Date: / [Signature: ...] / blank / message" block.
fn print_commit_header(commit_hex, info, body, body_len) {
    stdout_write("commit ", 7);
    stdout_write(commit_hex, 64);
    stdout_write("\n", 1);

    var pk[32];
    var vr = verify_commit_body(body, body_len, &pk);
    if (vr == 1) {
        var pk_hex = hex_encode(&pk, 32);
        stdout_write("Signature: good (key ", 21);
        stdout_write(pk_hex, 12);
        stdout_write(")\n", 2);
    }
    if (vr == 0) {
        var pk_hex = hex_encode(&pk, 32);
        stdout_write("Signature: BAD (key ", 20);
        stdout_write(pk_hex, 12);
        stdout_write(")\n", 2);
    }

    var ident = load64(info + 16);
    if (ident != 0) {
        var ts = load64(info + 24);
        stdout_write("Author: ", 8);
        # S-21: author identity is attacker-controlled in a cloned commit.
        # Scrub control chars so a crafted commit can't forge log lines
        # via \r\n or drive terminal-escape attacks via \x1b[.
        write_sanitized(STDOUT, ident, strlen(ident));
        stdout_write("\n", 1);
        var iso = iso8601(ts);
        stdout_write("Date:   ", 8);
        stdout_write(iso, strlen(iso));
        stdout_write("\n", 1);
    }

    stdout_write("\n", 1);
    var msg_start = load64(info + 40);
    if (msg_start > 0) {
        print_indented_message(body, msg_start, body_len);
    }
    return 0;
}

# Print a one-line summary of a commit: "<hex12> <first line of message>".
fn print_commit_oneline(commit_hex, body, body_len, msg_start) {
    stdout_write(commit_hex, 12);
    stdout_write(" ", 1);
    if (msg_start > 0) {
        var p = msg_start;
        while (p < body_len) {
            if (load8(body + p) == 10) { p = body_len; }
            else { p = p + 1; }
        }
        # Walk back to find the first \n after msg_start
        var first_nl = msg_start;
        while (first_nl < body_len) {
            if (load8(body + first_nl) == 10) { break; }
            first_nl = first_nl + 1;
        }
        var subj_len = first_nl - msg_start;
        if (subj_len > 0) {
            stdout_write(body + msg_start, subj_len);
        }
    }
    stdout_write("\n", 1);
    return 0;
}

# ── sit log --graph (v0.8.12) ──────────────────────────────────────
#
# An ASCII commit-DAG renderer. Unlike the default `cmd_log` (which walks
# only the first-parent chain via out+8), `--graph` walks the FULL DAG via
# `parse_commit_body`'s out+48 parents vec so merge topology is visible.
#
# Layout uses a position grid: lane k draws at column 2*k; the odd column
# 2*k-1 is the "seam" to its left where merges (`\`) and joins (`/`) connect.
# A commit row shows `*` at the emitting lane and `|` at every other active
# lane; a merge commit (≥2 parents that open a new lane) is followed by a
# `|\` connector; a commit whose parent rejoins an existing lane is followed
# by a `|/` connector. For a linear history this degrades to a column of
# `*`. Emission order is reverse-topological (a commit before its parents),
# newest-first by author timestamp — same primitive a `merge_base` walk wants.
#
# Node layout (48 bytes), keyed by commit hex in `nodes`:
#   [0..8)  parents vec (heap-owned 64-char hex copies, body order)
#   [8..16) pending_children (unemitted children; ready when 0)
#   [16..24) decompressed body ptr (retained for subject rendering)
#   [24..32) body_len
#   [32..40) msg_start (offset into body; 0 if none)
#   [40..48) author epoch timestamp (emission-order key)
#
# Documented simplifications (consistent with the v0.8.10 `.sitignore`
# approach): spacing is sit-native, not byte-identical to git (git pads a
# merge commit row with extra spaces for its lanes; sit uses a single space
# before the commit info). A commit that simultaneously opens a new lane AND
# rejoins an existing one in the same step renders best-effort. Absent
# parents (shallow-clone boundaries) are filtered, so the graph stops cleanly
# at the boundary just like the default log.

fn _graph_build_node(hex) {
    var obj[24];
    if (read_object(hex, &obj) != 0) { return 0; }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var body = buf + coff;
    var body_len = blen - coff;
    var info[56];
    if (parse_commit_body(body, body_len, &info) != 0) { return 0; }
    var node = alloc_or_die(48);
    var pv = load64(&info + 48);
    var mine = vec_new();
    if (pv != 0) {
        var i = 0;
        while (i < vec_len(pv)) {
            var c = alloc_or_die(65);
            memcpy(c, vec_get(pv, i), 64);
            store8(c + 64, 0);
            vec_push(mine, c);
            i = i + 1;
        }
    }
    store64(node, mine);
    store64(node + 8, 0);
    store64(node + 16, body);
    store64(node + 24, body_len);
    store64(node + 32, load64(&info + 40));
    store64(node + 40, load64(&info + 24));
    return node;
}

# Find hex among lanes by string value (vec_find is pointer-equality).
# Returns the lane index, or -1.
fn _graph_lane_find(lanes, hex, excl) {
    var n = vec_len(lanes);
    var i = 0;
    var found = 0 - 1;
    while (i < n) {
        if (found < 0) {
            if (i != excl) {
                if (streq(vec_get(lanes, i), hex) == 1) { found = i; }
            }
        }
        i = i + 1;
    }
    return found;
}

# Write the subject (first message line) of a graph node, sanitized
# (S-21: commit messages are attacker-controlled in a cloned repo).
fn _graph_write_subject(node) {
    var body = load64(node + 16);
    var body_len = load64(node + 24);
    var msg_start = load64(node + 32);
    if (msg_start > 0) {
        var p = msg_start;
        var go = 1;
        while (go == 1) {
            if (p >= body_len) { go = 0; }
            else {
                if (load8(body + p) == 10) { go = 0; }
                else { p = p + 1; }
            }
        }
        var slen = p - msg_start;
        if (slen > 0) { write_sanitized(STDOUT, body + msg_start, slen); }
    }
    return 0;
}

# Emit a buffer trimmed of trailing spaces, plus newline (connector rows).
fn _graph_write_trimmed(buf, width) {
    var end = width;
    var go = 1;
    while (go == 1) {
        if (end <= 0) { go = 0; }
        else {
            if (load8(buf + end - 1) == 32) { end = end - 1; }
            else { go = 0; }
        }
    }
    if (end > 0) { stdout_write(buf, end); }
    stdout_write("\n", 1);
    return 0;
}

# Commit row: `*` at `col`, `|` at every other active lane, then info.
fn _graph_commit_row(lanes, col, hex, node) {
    var nl = vec_len(lanes);
    var width = 2 * nl - 1;
    var buf = alloc_or_die(width);
    var i = 0;
    while (i < width) { store8(buf + i, 32); i = i + 1; }
    var j = 0;
    while (j < nl) {
        var g = 124;
        if (j == col) { g = 42; }
        store8(buf + 2 * j, g);
        j = j + 1;
    }
    stdout_write(buf, width);
    stdout_write(" ", 1);
    stdout_write(hex, 12);
    stdout_write(" ", 1);
    _graph_write_subject(node);
    stdout_write("\n", 1);
    return 0;
}

# Merge connector: `|` at each lane < base, `\` at the seam of each lane
# >= base (the newly opened branches).
fn _graph_merge_connector(lanes, base) {
    var nl = vec_len(lanes);
    var width = 2 * nl - 1;
    var buf = alloc_or_die(width);
    var i = 0;
    while (i < width) { store8(buf + i, 32); i = i + 1; }
    var j = 0;
    while (j < base) { store8(buf + 2 * j, 124); j = j + 1; }
    var k = base;
    # Seam sits at the odd column 2*k-1, left of the new lane. Guard k>0:
    # a branch opened at column 0 has no column to its left (defensive — the
    # join branch needs >=2 lanes so base is normally >=1, but never let the
    # index underflow to buf-1).
    while (k < nl) {
        if (k > 0) { store8(buf + 2 * k - 1, 92); }
        k = k + 1;
    }
    _graph_write_trimmed(buf, width);
    return 0;
}

# Join connector: `|` at each surviving lane, `/` at the seam of the
# collapsing lane `rcol`. Rendered against the pre-removal lane count.
fn _graph_join_connector(old_nl, rcol) {
    var width = 2 * old_nl - 1;
    var buf = alloc_or_die(width);
    var i = 0;
    while (i < width) { store8(buf + i, 32); i = i + 1; }
    var j = 0;
    while (j < old_nl) {
        if (j != rcol) { store8(buf + 2 * j, 124); }
        j = j + 1;
    }
    # Seam at 2*rcol-1 — guard rcol>0 so a lane-0 collapse (the right-lane
    # branch commit being strictly newer than the left) doesn't write buf-1.
    # With rcol==0 there is no column to the left, so no `/` is drawn.
    if (rcol > 0) { store8(buf + 2 * rcol - 1, 47); }
    _graph_write_trimmed(buf, width);
    return 0;
}

fn print_graph(start_hex, limit) {
    var nodes = map_new();
    var order = vec_new();

    # Pass 1: BFS the full DAG, building one node per reachable commit.
    var queue = vec_new();
    var sc = alloc_or_die(65);
    memcpy(sc, start_hex, 64);
    store8(sc + 64, 0);
    vec_push(queue, sc);
    while (vec_len(queue) > 0) {
        var h = vec_get(queue, vec_len(queue) - 1);
        vec_pop(queue);
        if (map_get(nodes, h) != 0) { }
        else {
            var node = _graph_build_node(h);
            if (node == 0) { }
            else {
                map_set(nodes, h, node);
                vec_push(order, h);
                var pv = load64(node);
                if (pv != 0) {
                    var pi = 0;
                    while (pi < vec_len(pv)) {
                        vec_push(queue, vec_get(pv, pi));
                        pi = pi + 1;
                    }
                }
            }
        }
    }

    # Pass 2: pending_children = number of reachable children per commit.
    var oi = 0;
    while (oi < vec_len(order)) {
        var nn = map_get(nodes, vec_get(order, oi));
        var pv2 = load64(nn);
        if (pv2 != 0) {
            var pj = 0;
            while (pj < vec_len(pv2)) {
                var pn = map_get(nodes, vec_get(pv2, pj));
                if (pn != 0) { store64(pn + 8, load64(pn + 8) + 1); }
                pj = pj + 1;
            }
        }
        oi = oi + 1;
    }

    # Emission: lanes carry the commit each column awaits. Pick the
    # ready lane (pending==0) with the newest timestamp each step.
    var lanes = vec_new();
    var lc = alloc_or_die(65);
    memcpy(lc, start_hex, 64);
    store8(lc + 64, 0);
    vec_push(lanes, lc);
    var shown = 0;
    var cont = 1;
    while (cont == 1) {
        if (vec_len(lanes) == 0) { cont = 0; }
        else { if (limit >= 0) { if (shown >= limit) { cont = 0; } } }
        if (cont == 1) {
            var nl = vec_len(lanes);
            var col = 0 - 1;
            var best = 0 - 1;
            var i = 0;
            while (i < nl) {
                var ln = map_get(nodes, vec_get(lanes, i));
                if (ln != 0) {
                    if (load64(ln + 8) == 0) {
                        var ts = load64(ln + 40);
                        if (col < 0) { col = i; best = ts; }
                        else { if (ts > best) { col = i; best = ts; } }
                    }
                }
                i = i + 1;
            }
            if (col < 0) { col = 0; }
            var cur = vec_get(lanes, col);
            var node = map_get(nodes, cur);
            if (node == 0) { vec_remove(lanes, col); }
            else {
                _graph_commit_row(lanes, col, cur, node);
                shown = shown + 1;

                # Present parents = parents that exist locally (absent =
                # shallow boundary). Decrement each so it can become ready.
                var pv = load64(node);
                var present = vec_new();
                if (pv != 0) {
                    var k = 0;
                    while (k < vec_len(pv)) {
                        var p = vec_get(pv, k);
                        var pn = map_get(nodes, p);
                        if (pn != 0) {
                            store64(pn + 8, load64(pn + 8) - 1);
                            vec_push(present, p);
                        }
                        k = k + 1;
                    }
                }
                var npp = vec_len(present);
                if (npp == 0) { vec_remove(lanes, col); }
                else {
                    var p0 = vec_get(present, 0);
                    var ex0 = _graph_lane_find(lanes, p0, col);
                    if (ex0 >= 0) {
                        _graph_join_connector(vec_len(lanes), col);
                        vec_remove(lanes, col);
                    }
                    else { vec_set(lanes, col, p0); }
                    var base = vec_len(lanes);
                    var did_merge = 0;
                    var m = 1;
                    while (m < npp) {
                        var pk = vec_get(present, m);
                        if (_graph_lane_find(lanes, pk, 0 - 1) >= 0) { }
                        else { vec_push(lanes, pk); did_merge = 1; }
                        m = m + 1;
                    }
                    if (did_merge == 1) { _graph_merge_connector(lanes, base); }
                }
            }
        }
    }
    return 0;
}

fn cmd_log() {
    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    # argv scan: --oneline, --graph, -n <count>, and an optional positional <ref>.
    var oneline = 0;
    var graph = 0;
    var limit = 0 - 1;
    var start_ref = 0;
    var ai = 2;
    while (ai < argc()) {
        var a = argv(ai);
        if (streq(a, "--oneline") == 1) { oneline = 1; ai = ai + 1; }
        else {
          if (streq(a, "--graph") == 1) { graph = 1; ai = ai + 1; }
          else {
            if (streq(a, "-n") == 1) {
                if (ai + 1 >= argc()) {
                    eprintln("sit: -n requires a number");
                    return 1;
                }
                limit = atoi(argv(ai + 1));
                ai = ai + 2;
            }
            else {
                if (start_ref != 0) {
                    eprintln("usage: sit log [--oneline] [--graph] [-n <count>] [<ref>]");
                    return 1;
                }
                start_ref = argv_heap(ai);
                ai = ai + 1;
            }
          }
        }
    }

    var current_hex = 0;
    if (start_ref != 0) {
        var resolved[72];
        var rr = resolve_hash(start_ref, &resolved);
        if (rr != 1) {
            syscall(SYS_WRITE, STDERR, "sit: cannot resolve '", 21);
            syscall(SYS_WRITE, STDERR, start_ref, strlen(start_ref));
            syscall(SYS_WRITE, STDERR, "'\n", 2);
            return 1;
        }
        current_hex = alloc_or_die(65);
        memcpy(current_hex, &resolved, 64);
        store8(current_hex + 64, 0);
    }
    else {
        current_hex = read_head_ref();
    }
    if (current_hex == 0) {
        eprintln("sit: no commits yet");
        return 0;
    }

    # --graph walks the full DAG (out+48 parents); absent boundary parents
    # are filtered inside print_graph, so it's shallow-safe on its own.
    if (graph == 1) { return print_graph(current_hex, limit); }

    # Shallow-clone awareness (v0.8.12): `.sit/shallow` lists boundary
    # commits whose parents were not fetched. When the walk reaches one,
    # stop cleanly instead of erroring on the absent parent object.
    var shallow = map_new();
    if (sf_exists(".sit/shallow") == 1) {
        var spair[16];
        if (read_file_heap(".sit/shallow", &spair) == 0) {
            var sbuf = load64(&spair);
            var slen = load64(&spair + 8);
            var sp = 0;
            while (sp + 64 <= slen) {
                var hh = alloc_or_die(65);
                memcpy(hh, sbuf + sp, 64);
                store8(hh + 64, 0);
                map_set(shallow, hh, 1);
                sp = sp + 65;
            }
        }
    }

    var first = 1;
    var shown = 0;
    while (current_hex != 0) {
        if (limit >= 0) {
            if (shown >= limit) { current_hex = 0; }
        }
        if (current_hex == 0) { return 0; }

        var obj[24];
        if (read_object(current_hex, &obj) != 0) {
            eprintln("sit: cannot read commit object");
            return 1;
        }
        var buf = load64(&obj);
        var blen = load64(&obj + 8);
        var coff = load64(&obj + 16);
        var body = buf + coff;
        var body_len = blen - coff;

        var info[56];
        if (parse_commit_body(body, body_len, &info) != 0) {
            eprintln("sit: malformed commit");
            return 1;
        }

        if (oneline == 1) {
            print_commit_oneline(current_hex, body, body_len, load64(&info + 40));
        }
        else {
            if (first == 0) { stdout_write("\n", 1); }
            first = 0;
            print_commit_header(current_hex, &info, body, body_len);
        }

        shown = shown + 1;
        if (map_has(shallow, current_hex) == 1) {
            current_hex = 0;
        }
        else {
            current_hex = load64(&info + 8);
        }
    }
    return 0;
}

# Hash arbitrary content with "blob <len>\0" framing without writing.
# Returns 64-char null-terminated hex C-string (matches `sit add`'s hash).
fn commit_tree_entries(commit_hex) {
    var obj[24];
    if (read_object(commit_hex, &obj) != 0) { return 0; }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var body = buf + coff;
    var body_len = blen - coff;

    var info[56];
    if (parse_commit_body(body, body_len, &info) != 0) { return 0; }
    var tree_hex = load64(&info);
    if (tree_hex == 0) { return 0; }

    var out = vec_new();
    flatten_tree(tree_hex, "", out);
    return out;
}

fn cmd_commit() {
    var ac = argc();
    if (ac < 3) {
        eprintln("usage: sit commit [-S] [-m] <message>");
        return 1;
    }

    # Parse flags + message — support `sit commit <msg>`, `sit commit -m <msg>`,
    # and either of those with `-S` prepended or interleaved.
    var message = 0;
    var sign = 0;
    var k = 2;
    while (k < ac) {
        var a = argv(k);
        if (streq(a, "-S") == 1) { sign = 1; k = k + 1; }
        else {
            if (streq(a, "-m") == 1) {
                if (k + 1 >= ac) {
                    eprintln("sit: -m requires a message argument");
                    return 1;
                }
                message = argv_heap(k + 1);
                k = k + 2;
            }
            else {
                if (message == 0) { message = argv_heap(k); }
                k = k + 1;
            }
        }
    }
    if (message == 0) {
        eprintln("sit: commit message required");
        return 1;
    }

    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }

    var seed = 0;
    if (sign == 1) {
        seed = load_signing_seed();
        if (seed == 0) {
            eprintln("sit: no signing key (run 'sit key generate')");
            return 1;
        }
    }

    var entries = parse_index();
    if (entries == 0) {
        eprintln("sit: nothing to commit (empty or missing index)");
        return 1;
    }

    sort_entries(entries);
    entries = dedupe_entries(entries);

    var tree_hex = build_tree(entries, 0);
    if (tree_hex == 0) {
        eprintln("sit: failed to write tree object");
        return 1;
    }

    var parent_hex = read_head_ref();
    var merge_parent = read_merge_head();

    var commit_hex = 0;
    if (merge_parent != 0) {
        # Resolving an in-progress merge — 2-parent commit, then clear MERGE_HEAD.
        commit_hex = build_merge_commit_signed(tree_hex, parent_hex, merge_parent, message, seed);
        if (commit_hex != 0) {
            # S-16: a stale MERGE_HEAD silently turns the NEXT `sit commit` into
            # an unintended 2-parent merge. Refuse to declare success on the
            # commit if we couldn't clear it.
            if (sf_unlink(".sit/MERGE_HEAD") != 0) {
                eprintln("sit: commit object written but failed to clear .sit/MERGE_HEAD — next commit may incorrectly become a merge; remove the file manually");
                return 1;
            }
        }
    }
    else {
        commit_hex = build_commit_signed(tree_hex, parent_hex, message, seed);
    }
    if (commit_hex == 0) {
        eprintln("sit: failed to write commit object");
        return 1;
    }

    if (write_head_ref(commit_hex) != 0) {
        eprintln("sit: failed to update HEAD's ref");
        return 1;
    }

    # Reflog: parent_hex (read before the write) is the old tip; 0 → initial.
    var rl_prefix = "commit: ";
    if (merge_parent != 0) { rl_prefix = "commit (merge): "; }
    else { if (parent_hex == 0) { rl_prefix = "commit (initial): "; } }
    reflog_head_move(parent_hex, commit_hex, reflog_msg_subject(rl_prefix, message));

    var branch = current_branch_name();
    stdout_write("[", 1);
    if (branch != 0) { stdout_write(branch, strlen(branch)); }
    else             { stdout_write("detached", 8); }
    stdout_write(" ", 1);
    if (merge_parent != 0) {
        stdout_write("(merge) ", 8);
    }
    else {
        if (parent_hex == 0) {
            stdout_write("(root-commit) ", 14);
        }
    }
    stdout_write(commit_hex, 12);
    stdout_write("] ", 2);
    var msg_len = strlen(message);
    stdout_write(message, msg_len);
    if (msg_len > 0) {
        if (load8(message + msg_len - 1) != 10) {
            stdout_write("\n", 1);
        }
    }
    else { stdout_write("\n", 1); }
    return 0;
}

# Parse an "author ..." or "committer ..." line. prefix_len is 7 or 10.
# Writes to out (24 bytes):
#   out[0..8):   identity ptr (heap-copy, null-terminated) — "NAME <EMAIL>"
#   out[8..16):  timestamp (epoch seconds)
#   out[16..24): tz ptr (heap-copy, null-terminated) — e.g. "+0000"
# Returns 0 on success, -1 on parse error.

# --- merge.cyr ---

# merge.cyr — 3-way line-level merge.
#
# LCS-hunk extractors, overlap detection, three_way_line_merge, conflict-file
# renderer, MERGE_HEAD marker, find_merge_base, signed/unsigned merge commit
# builders, cmd_merge (including --abort).

fn extract_hunks(ops) {
    var hunks = vec_new();
    var n = vec_len(ops);
    var i = 0;
    var base_pos = 0;
    var in_hunk = 0;
    var hunk_start = 0;
    var hunk_inserts = 0;

    while (i < n) {
        var op = vec_get(ops, i);
        var kind = load64(op);
        var line = load64(op + 8);

        if (kind == 0) {
            # Keep — close any open hunk
            if (in_hunk == 1) {
                var h = alloc_or_die(24);
                store64(h, hunk_start);
                store64(h + 8, base_pos);
                store64(h + 16, hunk_inserts);
                vec_push(hunks, h);
                in_hunk = 0;
            }
            base_pos = base_pos + 1;
        }
        else {
            if (in_hunk == 0) {
                in_hunk = 1;
                hunk_start = base_pos;
                hunk_inserts = vec_new();
            }
            if (kind == 1) { base_pos = base_pos + 1; }
            else { vec_push(hunk_inserts, line); }
        }
        i = i + 1;
    }

    if (in_hunk == 1) {
        var h = alloc_or_die(24);
        store64(h, hunk_start);
        store64(h + 8, base_pos);
        store64(h + 16, hunk_inserts);
        vec_push(hunks, h);
    }
    return hunks;
}

# Two hunks overlap iff their base ranges share at least one line OR both
# are insert-only hunks (0-length base ranges) at the same base position.
fn hunks_overlap(h1, h2) {
    var s1 = load64(h1);
    var e1 = load64(h1 + 8);
    var s2 = load64(h2);
    var e2 = load64(h2 + 8);
    # Adjacent ranges (e1 == s2 OR e2 == s1) do NOT overlap.
    if (e1 <= s2) {
        if (e1 == s2) {
            if (s1 == e1) { if (s2 == e2) { return 1; } }
            return 0;
        }
        return 0;
    }
    if (e2 <= s1) { return 0; }
    return 1;
}

# Scan two hunk lists; return 1 if any pair overlaps.
fn any_hunk_overlap(hunks_a, hunks_b) {
    var na = vec_len(hunks_a);
    var nb = vec_len(hunks_b);
    var i = 0;
    while (i < na) {
        var j = 0;
        while (j < nb) {
            if (hunks_overlap(vec_get(hunks_a, i), vec_get(hunks_b, j)) == 1) { return 1; }
            j = j + 1;
        }
        i = i + 1;
    }
    return 0;
}

# Append a line-tuple's bytes + "\n" into `buf` starting at `pos`. Returns
# the new position.
fn append_line_to_buf(buf, pos, line_tup) {
    var lp = load64(line_tup);
    var ll = load64(line_tup + 8);
    memcpy(buf + pos, lp, ll);
    store8(buf + pos + ll, 10);
    return pos + ll + 1;
}

# Find a hunk in `hunks` whose base_start == b. Returns the hunk or 0.
fn hunk_starting_at(hunks, b) {
    var n = vec_len(hunks);
    var i = 0;
    while (i < n) {
        var h = vec_get(hunks, i);
        if (load64(h) == b) { return h; }
        i = i + 1;
    }
    return 0;
}

# Three-way line-level merge. Returns a heap pointer to merged content on
# clean merge, or 0 on conflict. Writes the merged length into `out_len_ptr`.
fn three_way_line_merge(base_buf, base_len, ours_buf, ours_len, theirs_buf, theirs_len, out_len_ptr) {
    var base_lines = split_lines(base_buf, base_len);
    var ours_lines = split_lines(ours_buf, ours_len);
    var theirs_lines = split_lines(theirs_buf, theirs_len);

    var ops_bo = lcs_diff(base_lines, ours_lines);
    var ops_bt = lcs_diff(base_lines, theirs_lines);
    if (ops_bo == 0) { return 0; }
    if (ops_bt == 0) { return 0; }

    var ours_hunks = extract_hunks(ops_bo);
    var theirs_hunks = extract_hunks(ops_bt);

    if (any_hunk_overlap(ours_hunks, theirs_hunks) == 1) { return 0; }

    # Walk base; at each position, apply any starting hunk from either side.
    var bn = vec_len(base_lines);
    # Worst-case output size: base + ours_inserts + theirs_inserts + deletions
    var cap = base_len + ours_len + theirs_len + 64;
    var out = alloc_or_die(cap);
    var pos = 0;

    var b = 0;
    while (b <= bn) {
        var oh = hunk_starting_at(ours_hunks, b);
        var th = hunk_starting_at(theirs_hunks, b);

        if (oh != 0) {
            var inserts = load64(oh + 16);
            var ilen = vec_len(inserts);
            var k = 0;
            while (k < ilen) {
                pos = append_line_to_buf(out, pos, vec_get(inserts, k));
                k = k + 1;
            }
            b = load64(oh + 8);
        }
        else {
            if (th != 0) {
                var inserts = load64(th + 16);
                var ilen = vec_len(inserts);
                var k = 0;
                while (k < ilen) {
                    pos = append_line_to_buf(out, pos, vec_get(inserts, k));
                    k = k + 1;
                }
                b = load64(th + 8);
            }
            else {
                if (b < bn) {
                    pos = append_line_to_buf(out, pos, vec_get(base_lines, b));
                }
                b = b + 1;
            }
        }
    }

    store64(out_len_ptr, pos);
    return out;
}

# Write `.sit/MERGE_HEAD` pointing at the other-parent commit for an
# in-progress merge. Next `sit commit` will read this and emit a 2-parent
# commit, then unlink it.
fn write_merge_head(hex) {
    var buf = alloc_or_die(66);
    memcpy(buf, hex, 64);
    store8(buf + 64, 10);
    store8(buf + 65, 0);
    if (sf_write_all(".sit/MERGE_HEAD", buf, 65) < 0) { return 0 - 1; }
    return 0;
}

# Read `.sit/MERGE_HEAD` if it exists. Returns heap-allocated 64-char hex
# cstring, or 0 if no merge is in progress.
fn read_merge_head() {
    if (sf_exists(".sit/MERGE_HEAD") != 1) { return 0; }
    var fd = sf_open(".sit/MERGE_HEAD", 0, 0);
    if (fd < 0) { return 0; }
    var buf = alloc_or_die(80);
    var n = file_read(fd, buf, 80);
    file_close(fd);
    if (n < 64) { return 0; }
    store8(buf + 64, 0);
    return buf;
}

# Write a file with git-style conflict markers for ours/theirs. The markers
# wrap full-file content (we're file-level 3-way, not line-level yet).
#   <<<<<<< HEAD
#   <ours content>
#   =======
#   <theirs content>
#   >>>>>>> <branch_name>
fn write_conflict_file(path, ours_hex, theirs_hex, branch_name) {
    var op[16];
    var tp[16];
    var ours_content = 0;
    var ours_len = 0;
    var theirs_content = 0;
    var theirs_len = 0;
    if (ours_hex != 0) {
        if (read_blob_content(ours_hex, &op) == 0) {
            ours_content = load64(&op);
            ours_len = load64(&op + 8);
        }
    }
    if (theirs_hex != 0) {
        if (read_blob_content(theirs_hex, &tp) == 0) {
            theirs_content = load64(&tp);
            theirs_len = load64(&tp + 8);
        }
    }

    var bn_len = strlen(branch_name);
    var cap = 64 + ours_len + theirs_len + bn_len;
    var out = alloc_or_die(cap);
    var pos = 0;

    memcpy(out + pos, "<<<<<<< HEAD\n", 13); pos = pos + 13;
    if (ours_len > 0) {
        memcpy(out + pos, ours_content, ours_len);
        pos = pos + ours_len;
        if (load8(ours_content + ours_len - 1) != 10) {
            store8(out + pos, 10); pos = pos + 1;
        }
    }
    memcpy(out + pos, "=======\n", 8); pos = pos + 8;
    if (theirs_len > 0) {
        memcpy(out + pos, theirs_content, theirs_len);
        pos = pos + theirs_len;
        if (load8(theirs_content + theirs_len - 1) != 10) {
            store8(out + pos, 10); pos = pos + 1;
        }
    }
    memcpy(out + pos, ">>>>>>> ", 8); pos = pos + 8;
    memcpy(out + pos, branch_name, bn_len); pos = pos + bn_len;
    store8(out + pos, 10); pos = pos + 1;

    ensure_parent_dirs(path);
    if (sf_write_all(path, out, pos) < 0) { return 0 - 1; }
    return 0;
}

# Find the lowest common ancestor of two commits. Walks a's ancestry into a
# set, then walks b's and returns the first hit. Returns 0 if no common
# ancestor exists (disjoint histories).
# Author timestamp of a commit (out+24), or 0 if unreadable. Used only as
# a deterministic tiebreak when a criss-cross history has multiple bases.
fn _merge_commit_ts(hex) {
    var obj[24];
    if (read_object(hex, &obj) != 0) { return 0; }
    var buf = load64(&obj);
    var blen = load64(&obj + 8);
    var coff = load64(&obj + 16);
    var info[56];
    if (parse_commit_body(buf + coff, blen - coff, &info) != 0) { return 0; }
    return load64(&info + 24);
}

# Lowest common ancestor of two commits over the FULL commit DAG (v0.8.13).
#
# The pre-v0.8.13 implementation walked only the single first-parent chain
# (out+8) on both sides, so for any history with a merge it returned a
# too-high ancestor — e.g. in a diamond where one tip reaches the true base
# only through a merge's second parent, it fell back to the root. This walks
# every parent (out+48), so the base is correct across merges.
#
# Algorithm:
#   1. anc_a = full-DAG ancestor set of `a` (includes `a`).
#   2. BFS from `b`; the first time a path hits a commit in anc_a it's a
#      common ancestor — record it and PRUNE (don't expand its parents, they
#      can only be higher/redundant). This yields the frontier of common
#      ancestors cheaply (bounded by merge width, not history length).
#   3. Reduce: a candidate that is an ancestor of another candidate is
#      redundant (the other is lower). The maximal survivors are the merge
#      base(s); return the newest by author timestamp for determinism.
#
# Criss-cross histories can have several equally-valid bases; sit returns one
# (git would do a recursive merge). Returns a 64-char NUL-terminated hex, or
# 0 if the two commits share no ancestor.
fn find_merge_base(a_hex, b_hex) {
    # Phase 1: ancestors of a (full DAG).
    var anc_a = map_new();
    var q = vec_new();
    var sa = alloc_or_die(65);
    memcpy(sa, a_hex, 64);
    store8(sa + 64, 0);
    vec_push(q, sa);
    while (vec_len(q) > 0) {
        var cur = vec_get(q, vec_len(q) - 1);
        vec_pop(q);
        if (map_has(anc_a, cur) == 1) { }
        else {
            map_set(anc_a, cur, 1);
            var pv = commit_parents_of(cur);
            if (pv != 0) {
                var pi = 0;
                while (pi < vec_len(pv)) {
                    vec_push(q, vec_get(pv, pi));
                    pi = pi + 1;
                }
            }
        }
    }

    # Phase 2: prune-BFS from b → frontier of common ancestors.
    var candidates = vec_new();
    var seen_b = map_new();
    var q2 = vec_new();
    var sb = alloc_or_die(65);
    memcpy(sb, b_hex, 64);
    store8(sb + 64, 0);
    vec_push(q2, sb);
    while (vec_len(q2) > 0) {
        var cur = vec_get(q2, vec_len(q2) - 1);
        vec_pop(q2);
        if (map_has(seen_b, cur) == 1) { }
        else {
            map_set(seen_b, cur, 1);
            if (map_has(anc_a, cur) == 1) {
                vec_push(candidates, cur);
            }
            else {
                var pv = commit_parents_of(cur);
                if (pv != 0) {
                    var pi = 0;
                    while (pi < vec_len(pv)) {
                        vec_push(q2, vec_get(pv, pi));
                        pi = pi + 1;
                    }
                }
            }
        }
    }

    var nc = vec_len(candidates);
    if (nc == 0) { return 0; }
    if (nc == 1) { return vec_get(candidates, 0); }

    # Phase 3: drop redundant candidates (ancestor of another), keep the
    # newest maximal one.
    var best = 0;
    var best_ts = 0 - 1;
    var ci = 0;
    while (ci < nc) {
        var c = vec_get(candidates, ci);
        var redundant = 0;
        var cj = 0;
        while (cj < nc) {
            if (cj != ci) {
                var d = vec_get(candidates, cj);
                if (streq(c, d) == 0) {
                    if (is_ancestor(c, d) == 1) { redundant = 1; cj = nc; }
                }
            }
            if (cj < nc) { cj = cj + 1; }
        }
        if (redundant == 0) {
            var ts = _merge_commit_ts(c);
            if (ts > best_ts) { best = c; best_ts = ts; }
        }
        ci = ci + 1;
    }
    # In a well-formed DAG the partial order always has a maximal element, so
    # `best` is set. Guard the corrupt/cyclic case (mutual is_ancestor marks
    # every candidate redundant) — fall back to a real candidate rather than
    # reporting "no common ancestor" when common ancestors demonstrably exist.
    if (best == 0) { best = vec_get(candidates, 0); }
    return best;
}

# Plumbing: `sit merge-base <commit> <commit>` (v0.8.13). Prints the
# full-DAG lowest common ancestor — git's `git merge-base` shape. Both args
# are resolved through resolve_hash (branch / tag / hex-prefix). Exposes the
# LCA so the merge base is testable independent of a full `sit merge`.
fn cmd_merge_base() {
    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }
    if (argc() < 4) {
        eprintln("usage: sit merge-base <commit> <commit>");
        return 1;
    }

    var resa[72];
    if (resolve_hash(argv(2), &resa) != 1) {
        syscall(SYS_WRITE, STDERR, "sit: cannot resolve '", 21);
        syscall(SYS_WRITE, STDERR, argv(2), strlen(argv(2)));
        syscall(SYS_WRITE, STDERR, "'\n", 2);
        return 1;
    }
    var ha = alloc_or_die(65);
    memcpy(ha, &resa, 64);
    store8(ha + 64, 0);

    var resb[72];
    if (resolve_hash(argv(3), &resb) != 1) {
        syscall(SYS_WRITE, STDERR, "sit: cannot resolve '", 21);
        syscall(SYS_WRITE, STDERR, argv(3), strlen(argv(3)));
        syscall(SYS_WRITE, STDERR, "'\n", 2);
        return 1;
    }
    var hb = alloc_or_die(65);
    memcpy(hb, &resb, 64);
    store8(hb + 64, 0);

    var base = find_merge_base(ha, hb);
    if (base == 0) {
        eprintln("sit: no common ancestor");
        return 1;
    }
    stdout_write(base, 64);
    stdout_write("\n", 1);
    return 0;
}

# Build + write a 2-parent merge commit. Mirrors build_commit but emits two
# `parent <hex>\n` header lines. Returns the new commit's hex hash.
fn build_merge_commit(tree_hex, p1_hex, p2_hex, message) {
    return build_merge_commit_signed(tree_hex, p1_hex, p2_hex, message, 0);
}

fn build_merge_commit_signed(tree_hex, p1_hex, p2_hex, message, seed) {
    var name = getenv("SIT_AUTHOR_NAME");
    if (name == 0) { name = config_get("user.name"); }
    if (name == 0) { name = "sit user"; }
    var email = getenv("SIT_AUTHOR_EMAIL");
    if (email == 0) { email = config_get("user.email"); }
    if (email == 0) { email = "user@localhost"; }
    var ts = clock_epoch_secs();

    var name_len = strlen(name);
    var email_len = strlen(email);
    var msg_len = strlen(message);

    var cap = 512 + msg_len + name_len * 2 + email_len * 2 + 160;
    var body = alloc_or_die(cap);
    var pos = 0;

    memcpy(body + pos, "tree ", 5); pos = pos + 5;
    memcpy(body + pos, tree_hex, 64); pos = pos + 64;
    store8(body + pos, 10); pos = pos + 1;

    memcpy(body + pos, "parent ", 7); pos = pos + 7;
    memcpy(body + pos, p1_hex, 64); pos = pos + 64;
    store8(body + pos, 10); pos = pos + 1;

    memcpy(body + pos, "parent ", 7); pos = pos + 7;
    memcpy(body + pos, p2_hex, 64); pos = pos + 64;
    store8(body + pos, 10); pos = pos + 1;

    memcpy(body + pos, "author ", 7); pos = pos + 7;
    memcpy(body + pos, name, name_len); pos = pos + name_len;
    memcpy(body + pos, " <", 2); pos = pos + 2;
    memcpy(body + pos, email, email_len); pos = pos + email_len;
    memcpy(body + pos, "> ", 2); pos = pos + 2;
    var digits = write_decimal(body + pos, ts); pos = pos + digits;
    memcpy(body + pos, " +0000\n", 7); pos = pos + 7;

    memcpy(body + pos, "committer ", 10); pos = pos + 10;
    memcpy(body + pos, name, name_len); pos = pos + name_len;
    memcpy(body + pos, " <", 2); pos = pos + 2;
    memcpy(body + pos, email, email_len); pos = pos + email_len;
    memcpy(body + pos, "> ", 2); pos = pos + 2;
    digits = write_decimal(body + pos, ts); pos = pos + digits;
    memcpy(body + pos, " +0000\n", 7); pos = pos + 7;

    store8(body + pos, 10); pos = pos + 1;
    memcpy(body + pos, message, msg_len); pos = pos + msg_len;
    if (msg_len == 0) { store8(body + pos, 10); pos = pos + 1; }
    else {
        if (load8(message + msg_len - 1) != 10) {
            store8(body + pos, 10); pos = pos + 1;
        }
    }

    if (seed != 0) {
        var new_len_slot[8];
        store64(&new_len_slot, 0);
        var signed = sign_commit_body(body, pos, seed, &new_len_slot);
        if (signed == 0) {
            return write_typed_object("commit", 6, body, pos);
        }
        return write_typed_object("commit", 6, signed, load64(&new_len_slot));
    }
    return write_typed_object("commit", 6, body, pos);
}

# Find a tree entry's hash_hex for a given path, or 0 if absent.
fn cmd_merge() {
    if (sf_exists(".sit/HEAD") != 1) {
        eprintln("sit: not a sit repository (run 'sit init')");
        return 1;
    }
    if (argc() < 3) {
        eprintln("usage: sit merge [-S] <branch> | sit merge --abort");
        return 1;
    }

    # --abort: restore working tree to HEAD, clear MERGE_HEAD.
    if (streq(argv(2), "--abort") == 1) {
        if (sf_exists(".sit/MERGE_HEAD") != 1) {
            eprintln("sit: no merge in progress");
            return 1;
        }
        var head = read_head_ref();
        if (head != 0) {
            # S-16: propagate materialize failure so we don't claim "merge
            # aborted" when the working tree wasn't actually restored.
            if (materialize_target(head) != 0) {
                eprintln("sit: failed to restore working tree from HEAD; .sit/MERGE_HEAD left in place");
                return 1;
            }
        }
        # S-16: a stale MERGE_HEAD silently turns the next commit into a
        # 2-parent merge. Same cliff as cmd_commit's clear path.
        if (sf_unlink(".sit/MERGE_HEAD") != 0) {
            eprintln("sit: failed to clear .sit/MERGE_HEAD — next commit may incorrectly become a merge; remove manually");
            return 1;
        }
        stdout_write("merge aborted\n", 14);
        return 0;
    }

    var merge_sign = 0;
    var merge_target_idx = 2;
    if (streq(argv(2), "-S") == 1) {
        merge_sign = 1;
        merge_target_idx = 3;
        if (argc() < 4) {
            eprintln("usage: sit merge [-S] <branch>");
            return 1;
        }
    }
    var target_name = argv_heap(merge_target_idx);
    var tnlen = strlen(target_name);

    var target_hex[72];
    var rr = resolve_hash(target_name, &target_hex);
    if (rr == 0 - 2) { eprintln("sit: merge target too short"); return 1; }
    if (rr == 0 - 1) { eprintln("sit: ambiguous merge target"); return 1; }
    if (rr == 0)     {
        syscall(SYS_WRITE, STDERR, "sit: '", 6);
        syscall(SYS_WRITE, STDERR, target_name, tnlen);
        syscall(SYS_WRITE, STDERR, "' is not a known branch, tag, or commit\n", 40);
        return 1;
    }

    var head_hex = read_head_ref();
    if (head_hex == 0) {
        eprintln("sit: current branch has no commits");
        return 1;
    }

    if (streq(&target_hex, head_hex) == 1) {
        stdout_write("already up to date\n", 19);
        return 0;
    }
    if (is_ancestor(&target_hex, head_hex) == 1) {
        stdout_write("already up to date\n", 19);
        return 0;
    }

    if (is_ancestor(head_hex, &target_hex) == 1) {
        if (is_dirty() == 1) {
            eprintln("sit: working tree has uncommitted changes");
            eprintln("sit:   commit or revert before merging");
            return 1;
        }
        if (write_head_ref(&target_hex) != 0) {
            eprintln("sit: failed to update branch ref");
            return 1;
        }
        materialize_target(&target_hex);
        reflog_head_move(head_hex, &target_hex,
            reflog_msg_join("merge ", target_name, ": Fast-forward"));

        stdout_write("fast-forward to ", 16);
        stdout_write(&target_hex, 12);
        stdout_write("\n", 1);
        return 0;
    }

    # Divergent → 3-way merge (file-level)
    if (is_dirty() == 1) {
        eprintln("sit: working tree has uncommitted changes");
        eprintln("sit:   commit or revert before merging");
        return 1;
    }

    var base_hex = find_merge_base(head_hex, &target_hex);
    if (base_hex == 0) {
        eprintln("sit: no common ancestor between current branch and target");
        return 1;
    }

    var base_entries = commit_tree_entries(base_hex);
    var ours_entries = commit_tree_entries(head_hex);
    var theirs_entries = commit_tree_entries(&target_hex);
    if (ours_entries == 0) { ours_entries = vec_new(); }
    if (theirs_entries == 0) { theirs_entries = vec_new(); }
    if (base_entries == 0) { base_entries = vec_new(); }

    var paths = three_way_path_set(base_entries, ours_entries, theirs_entries);
    var merged = vec_new();
    var conflicts = vec_new();

    var pn = vec_len(paths);
    var pi = 0;
    while (pi < pn) {
        var p = vec_get(paths, pi);
        var base_h = tree_find_hash(base_entries, p);
        var ours_h = tree_find_hash(ours_entries, p);
        var theirs_h = tree_find_hash(theirs_entries, p);

        # Result hash: 0 means "not in merged tree"
        var result_h = 0;
        var needs_conflict = 0;

        if (ours_h != 0) {
            if (theirs_h != 0) {
                if (streq(ours_h, theirs_h) == 1) {
                    result_h = ours_h;
                }
                else {
                    if (base_h != 0) {
                        if (streq(base_h, ours_h) == 1)   { result_h = theirs_h; }
                        else {
                            if (streq(base_h, theirs_h) == 1) { result_h = ours_h; }
                            else { needs_conflict = 1; }
                        }
                    }
                    else { needs_conflict = 1; }
                }
            }
            else {
                # theirs absent
                if (base_h != 0) {
                    if (streq(base_h, ours_h) == 1) { result_h = 0; }  # deleted by theirs
                    else { needs_conflict = 1; }  # ours modified, theirs deleted
                }
                else {
                    # Added only by ours
                    result_h = ours_h;
                }
            }
        }
        else {
            # ours absent
            if (theirs_h != 0) {
                if (base_h != 0) {
                    if (streq(base_h, theirs_h) == 1) { result_h = 0; }  # deleted by ours
                    else { needs_conflict = 1; }  # theirs modified, ours deleted
                }
                else {
                    result_h = theirs_h;
                }
            }
        }

        # Try line-level diff3 before declaring a file-level conflict.
        # Applies when base/ours/theirs all exist AND hunks don't overlap.
        if (needs_conflict == 1) {
            if (base_h != 0) {
                if (ours_h != 0) {
                    if (theirs_h != 0) {
                        var bp[16]; var op[16]; var tp[16];
                        if (read_blob_content(base_h, &bp) == 0) {
                            if (read_blob_content(ours_h, &op) == 0) {
                                if (read_blob_content(theirs_h, &tp) == 0) {
                                    var merged_len[8];
                                    var merged_buf = three_way_line_merge(
                                        load64(&bp), load64(&bp + 8),
                                        load64(&op), load64(&op + 8),
                                        load64(&tp), load64(&tp + 8),
                                        &merged_len);
                                    if (merged_buf != 0) {
                                        # Line-level merge succeeded — write as a new blob
                                        var new_hex = write_blob_object(merged_buf, load64(&merged_len));
                                        if (new_hex != 0) {
                                            result_h = new_hex;
                                            needs_conflict = 0;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        if (needs_conflict == 1) {
            var pc = alloc_or_die(strlen(p) + 1);
            memcpy(pc, p, strlen(p));
            store8(pc + strlen(p), 0);
            vec_push(conflicts, pc);
        }
        else {
            if (result_h != 0) {
                var bytes = hex_decode(result_h, 64);
                if (bytes != 0) {
                    var entry = alloc_or_die(40);
                    memcpy(entry, bytes, 32);
                    var pc = alloc_or_die(strlen(p) + 1);
                    memcpy(pc, p, strlen(p));
                    store8(pc + strlen(p), 0);
                    store64(entry + 32, pc);
                    vec_push(merged, entry);
                }
            }
        }
        pi = pi + 1;
    }

    if (vec_len(conflicts) > 0) {
        # Write auto-merged files to working tree so clean paths don't appear
        # conflicted in subsequent sit status.
        var mi = 0;
        var mn = vec_len(merged);
        while (mi < mn) {
            var me = vec_get(merged, mi);
            var mpath = load64(me + 32);
            var bytes32 = me;
            var mhex = hex_encode(bytes32, 32);
            ensure_parent_dirs(mpath);
            var mp[16];
            if (read_blob_content(mhex, &mp) == 0) {
                sf_write_all(mpath, load64(&mp), load64(&mp + 8));
            }
            mi = mi + 1;
        }

        # Write conflict-marker files for each conflicting path.
        var ci = 0;
        while (ci < vec_len(conflicts)) {
            var cp = vec_get(conflicts, ci);
            var ours_h = tree_find_hash(ours_entries, cp);
            var theirs_h = tree_find_hash(theirs_entries, cp);
            write_conflict_file(cp, ours_h, theirs_h, target_name);
            ci = ci + 1;
        }

        # Track MERGE_HEAD so the next sit commit produces a 2-parent commit.
        write_merge_head(&target_hex);

        syscall(SYS_WRITE, STDERR, "sit: merge conflict in ", 23);
        var buf[24];
        var digits = write_decimal(&buf, vec_len(conflicts));
        syscall(SYS_WRITE, STDERR, &buf, digits);
        syscall(SYS_WRITE, STDERR, " file(s):\n", 10);
        ci = 0;
        while (ci < vec_len(conflicts)) {
            syscall(SYS_WRITE, STDERR, "  ", 2);
            var cp2 = vec_get(conflicts, ci);
            syscall(SYS_WRITE, STDERR, cp2, strlen(cp2));
            syscall(SYS_WRITE, STDERR, "\n", 1);
            ci = ci + 1;
        }
        eprintln("sit: edit the marked files, 'sit add' them, then 'sit commit'");
        eprintln("sit:   'sit merge --abort' to cancel and restore the working tree");
        return 1;
    }

    # Clean merge — sort entries, build tree, create 2-parent commit
    sort_entries(merged);
    var tree_hex = build_tree(merged, 0);
    if (tree_hex == 0) {
        eprintln("sit: failed to write merged tree");
        return 1;
    }

    var msg_cap = 64 + tnlen + 32;
    var msg = alloc_or_die(msg_cap);
    memcpy(msg, "Merge branch '", 14);
    memcpy(msg + 14, target_name, tnlen);
    memcpy(msg + 14 + tnlen, "'", 1);
    store8(msg + 14 + tnlen + 1, 0);

    var head_copy = alloc_or_die(65);
    memcpy(head_copy, head_hex, 64);
    store8(head_copy + 64, 0);

    var merge_seed = 0;
    if (merge_sign == 1) {
        merge_seed = load_signing_seed();
        if (merge_seed == 0) {
            eprintln("sit: no signing key (run 'sit key generate')");
            return 1;
        }
    }
    var merge_hex = build_merge_commit_signed(tree_hex, head_copy, &target_hex, msg, merge_seed);
    if (merge_hex == 0) {
        eprintln("sit: failed to write merge commit");
        return 1;
    }

    if (write_head_ref(merge_hex) != 0) {
        eprintln("sit: failed to update branch ref");
        return 1;
    }
    materialize_target(merge_hex);
    reflog_head_move(head_copy, merge_hex,
        reflog_msg_join("merge ", target_name, ": Merge made by the '3-way' strategy"));

    stdout_write("merge ", 6);
    stdout_write(merge_hex, 12);
    stdout_write(": Merge branch '", 16);
    stdout_write(target_name, tnlen);
    stdout_write("'\n", 2);
    return 0;
}

# --- api.cyr ---

# api.cyr — sit's stable public API surface for Cyrius consumers.
#
# Downstream Cyrius projects consume sit as a dep:
#
#     [deps.sit]
#     git = "https://github.com/MacCracken/sit.git"
#     tag = "0.8.1"
#     modules = ["dist/sit.cyr"]
#
# Stable surface (governed by ADR 0009):
#   - sit_repo_open(cwd)        — open a sit repository, returns 1 / 0
#   - sit_repo_close(repo)      — release the handle (no-op in v0.8.1)
#   - sit_diff_path(repo, path) — HEAD-blob vs working-tree, returns
#                                 an annotated-ops vec (or 0)
#   - ann_kind / ann_line / ann_old / ann_new — accessors on the
#                                 annotated-op records returned by
#                                 sit_diff_path (defined in diff.cyr)
#
# Identifier convention: any name `_`-prefixed is internal and may
# change without notice. Public names use the `sit_` / `ann_` prefix.
# Breaking changes to anything in this file require a major bump.

# Open the sit/git repository at the process's CURRENT WORKING DIRECTORY.
# Returns 1 on success, 0 if the cwd holds neither a `.sit/` nor a `.git/`
# store (or `cwd` is null). `cwd` is retained for API compatibility but is
# now ADVISORY — pass `"."`; the reads are cwd-relative and this call no
# longer chdirs.
#
# v1.3.1: dropped the `syscall(SYS_CHDIR, cwd)`. It was portability-hostile —
# AGNOS's frozen syscall floor has no chdir (nor openat/getcwd), so the raw
# reference hard-failed the `dist/sit-read.cyr` consumer build on `--agnos`
# (regressing a downstream's AGNOS lane). And it was never load-bearing: every
# consumer opens the repo it is already in via `sit_repo_open(".")` (owl's
# gutter markers `src/vcs.cyr`, thoth's status bar, this repo's git_probe
# integration test) — where `chdir(".")` was a no-op. Removing it is
# behavior-preserving for all callers AND makes the read API AGNOS-native. To
# operate on a repo elsewhere, chdir into it before calling (the CLI does).
# Multiple concurrent handles aren't supported — treat the return as an opaque
# token for sit_repo_close / sit_diff_path.
fn sit_repo_open(cwd) {
    if (cwd == 0) { return 0; }
    # Storage seam (roadmap 1.2.0): succeed on a native .sit/ OR an existing
    # .git/ repo at the cwd; _detect_repo_backend sets the process-global backend
    # that read_object / read_head_ref / resolve_ref_name dispatch on. Returns -1
    # when neither store is present.
    if (_detect_repo_backend() < 0) { return 0; }
    # Set the repo root so subsequent reads resolve on agnos (which has no
    # cwd). Linux stays BYTE-IDENTICAL: consumers pass "." and sit_abs
    # treats a "." root as no-prefix (and an absolute root only prefixes
    # repo-relative paths). A non-"." absolute cwd enables agnos resolution.
    sit_set_repo_root(cwd);
    return 1;
}

# Release the sit repository handle. v0.8.1: no-op (no per-repo state).
# Reserved for future use; callers should still call it for forward
# compatibility.
fn sit_repo_close(repo) {
    return 0;
}

# Compute the diff between `path`'s HEAD blob and its working-tree contents.
# Returns a vec of annotated-op records (use `ann_kind` / `ann_line` /
# `ann_old` / `ann_new` to inspect each), or 0 if the file is either
# unchanged, absent from both HEAD and the working tree, or the LCS table
# exceeds its cap (16M cells; see diff.cyr P-15).
#
# Shape: ops are line-level (one per old + new line, per LCS edit script).
# `kind` is 0 = keep / 1 = delete (was in HEAD, removed from working) /
# 2 = add (in working, not in HEAD). Caller owns the returned vec.
fn sit_diff_path(repo, path) {
    if (path == 0) { return 0; }

    # Resolve HEAD's blob hash for `path`. Treat "no HEAD" / "path absent
    # from HEAD" the same as "old buffer is empty" so an all-added file
    # still yields useful annotations.
    var head_entries = read_head_tree_entries();
    var old_buf = 0;
    var old_len = 0;
    var hp[16];
    if (head_entries != 0) {
        var he = tree_find(head_entries, path);
        if (he != 0) {
            var head_hex = tree_entry_hash(he);
            if (read_blob_content(head_hex, &hp) == 0) {
                old_buf = load64(&hp);
                old_len = load64(&hp + 8);
            }
        }
    }

    # Resolve working-tree contents. Path missing from disk → empty new
    # buffer (yields an all-delete diff against HEAD).
    var new_buf = 0;
    var new_len = 0;
    var wp[16];
    if (sf_exists(path) == 1) {
        if (read_file_heap(path, &wp) == 0) {
            new_buf = load64(&wp);
            new_len = load64(&wp + 8);
        }
    }

    # Nothing on either side: no diff to report.
    if (old_buf == 0) {
        if (new_buf == 0) { return 0; }
    }

    return compute_file_diff(old_buf, old_len, new_buf, new_len);
}

# Return the current branch name for the open repo as a heap cstring (e.g.
# "main"), or 0 if HEAD is detached or not a branch ref. Backend-aware: reads
# .sit/HEAD or .git/HEAD through the storage seam (roadmap 1.2.0), so it works
# on both sit-native and existing git repositories. Caller owns the cstring.
# New public surface (ADR 0009): additive, SemVer-minor.
fn sit_repo_branch(repo) {
    return current_branch_name();
}

# A status record is a 16-byte {path_ptr, kind} pair. Internal builder.
fn _status_push(vec, path, kind) {
    var rec = alloc(16);
    store64(rec, path);
    store64(rec + 8, kind);
    vec_push(vec, rec);
    return 0;
}

# Byte-compare a HEAD blob (named by id `hex`) against working file `path`.
# Returns 1 if they differ (or either can't be read), 0 if identical. Uses a
# content compare rather than a re-hash so it needs no hash primitive — which
# is what lets it work on a git SHA-1 repo without a first-party SHA-1.
fn _blob_differs_from_file(hex, path) {
    var hp[16];
    if (read_blob_content(hex, &hp) != 0) { return 1; }
    var ob = load64(&hp);
    var ol = load64(&hp + 8);
    var wp[16];
    if (read_file_heap(path, &wp) != 0) { return 1; }
    var nb = load64(&wp);
    var nl = load64(&wp + 8);
    if (ol != nl) { return 1; }
    if (memeq(ob, nb, ol) == 0) { return 1; }
    return 0;
}

# Per-file HEAD-vs-working-tree status for the open repo. Returns a vec of
# opaque status records — read each with sit_status_path / sit_status_kind.
# Kinds: 1 = modified, 2 = new (untracked), 3 = deleted. Unmodified files are
# omitted. Backend-aware (roadmap 1.2.0): works on sit-native and existing git
# repos. v1 scope is HEAD-vs-worktree only — no staging-index (git .git/index /
# sit patra index) staged/unstaged split, and untracked honours the top-level
# ignore file (.gitignore in git mode). New public surface (ADR 0009): additive,
# SemVer-minor. Caller owns the returned vec.
fn sit_repo_status(repo) {
    var out = vec_new();
    var head_entries = read_head_tree_entries();
    var work_files = list_working_files();

    # Tracked files: deleted (gone from disk) or modified (content differs).
    if (head_entries != 0) {
        var hn = vec_len(head_entries);
        var i = 0;
        while (i < hn) {
            var he = vec_get(head_entries, i);
            var path = tree_entry_name(he);
            if (sf_exists(path) != 1) {
                _status_push(out, path, 3);
            }
            else {
                if (_blob_differs_from_file(tree_entry_hash(he), path) == 1) {
                    _status_push(out, path, 1);
                }
            }
            i = i + 1;
        }
    }

    # Working files absent from HEAD are new (untracked).
    var wn = vec_len(work_files);
    var j = 0;
    while (j < wn) {
        var wf = vec_get(work_files, j);
        var tracked = 0;
        if (head_entries != 0) {
            if (tree_find(head_entries, wf) != 0) { tracked = 1; }
        }
        if (tracked == 0) { _status_push(out, wf, 2); }
        j = j + 1;
    }
    return out;
}

# Accessors on a status record (mirror the ann_* pattern; opaque layout).
fn sit_status_path(rec) { return load64(rec); }
fn sit_status_kind(rec) { return load64(rec + 8); }
